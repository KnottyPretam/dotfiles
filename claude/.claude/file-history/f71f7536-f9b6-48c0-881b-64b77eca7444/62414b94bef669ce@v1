plot(chirp_time_s, q_rps*180/pi, 'b'); grid on; hold on
ylabel('Q (deg/s)')

xlabel('Time (sec)')

%% Preprocessing
dt = mean(diff(chirp_time_s));

% resample data at consistent DT
t               = [chirp_time_s(1):dt:chirp_time_s(end)]';
dele_total      = interp1(chirp_time_s, dele_total, t);
q_rps           = interp1(chirp_time_s, q_rps, t);
chirp_time_s    = t;

% Detrend the data:
dele_total      = nonlinear_detrend(dele_total, chirp_time_s);
q_rps           = nonlinear_detrend(q_rps, chirp_time_s);

freq_sample     = 1/dt;             % sampling frequency
freq_nyquist    = freq_sample/2;    % nyquist frequency

freq_Hz         = linspace(0, 1, fix(length(chirp_time_s)/2)+1)*freq_nyquist;  % frequency vector of interest

%% Estimate Frequency Response from Time History

% Estimate gain and phase from the time history data:
[mag_dB, phase_deg, freq_meas_Hz, coherence, Gyu, Syu, Syy, Suu] = estimate_freq_response(q_rps, dele_total, chirp_time_s, freq_init_Hz, freq_end_Hz);

idx_keep = coherence > 0.6; % coherence cutoff limit

freq_meas_Hz    = freq_meas_Hz(idx_keep);
mag_dB          = mag_dB(idx_keep);
phase_deg       = phase_deg(idx_keep);
coherence       = coherence(idx_keep);

% Plot the frequency domain estimates ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
fig_Bode = figure('Name','Plant Bode Plot');

subplot(3,1,1)
semilogx(freq_meas_Hz, mag_dB,'o','LineWidth',1.5,'MarkerSize',6);
grid on; hold on

ylabel('Gain (dB)')
xlabel('Frequency (Hz)')

legend('Transfer Function Truth/Analytical', 'Sys-ID Bode Est', 'Location', 'Best')

subplot(3,1,2)
semilogx(freq_meas_Hz, wrapTo180_custom(phase_deg),'o','LineWidth',1.5,'MarkerSize',6)
grid on; hold on

ylabel('Phase (deg)')
xlabel('Frequency (Hz)')

subplot(3,1,3)
semilogx(freq_meas_Hz, coherence, 'LineWidth', 1.5, 'MarkerSize', 6)
grid on; hold on

ylabel('Coherence ')
xlabel('Frequency (Hz)')

linkaxes(findall(gcf,'type','axes'),'x')

%% Estimate a Transfer Function

% Estimate numerator, denominator, and time delay from gain and phase
[num, den, tau] = estimate_tf_from_freq_response(freq_meas_Hz, mag_dB, phase_deg, 1, 0); 

% Display the estimated transfer functions:
tf_est = tf(num, den, 'InputDelay', tau)

% Plot the tf estimates ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
sys_id_freqresp = freqresp(tf_est, freq_Hz, 'Hz'); 
sys_id_freqresp = reshape(sys_id_freqresp, size(freq_Hz));

figure(fig_Bode);
subplot(3,1,1)
semilogx(freq_Hz, 20*log10(abs(sys_id_freqresp))); grid on; hold on

ylabel('Gain (dB)')
xlabel('Frequency (Hz)')

legend('Sys-ID Bode Est', 'Transfer Function Estimate', 'Location', 'Best')

subplot(3,1,2)
semilogx(freq_Hz, angle(sys_id_freqresp)*180/pi); grid on; hold on

ylabel('Phase (deg)')
xlabel('Frequency (Hz)')

xlim([0.01, 1000])

%% Compute Attitude Control Gains

% Tuning parameters ~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
% Phase margin target:
PM_target_deg   = 60;               % Keep this between 45 deg and 90 deg. Lower PM gives faster response but reduces stability.
% Bandwidth targets:
wc_inner_Hz     = 3;                % Higher value gives faster response, but degrades nonlinear stability, saturates motors, etc
wc_outer_Hz     = wc_inner_Hz/3;    % Outer loop bandwidth should be 3-5 times slower than the inner loop

[Kp_rate, Ki_rate, Kp_attitude, GM_dB, PM_deg] = compute_attitude_control_gains(num, den, tau, PM_target_deg, wc_inner_Hz, wc_outer_Hz)

%% Plot Linear Time History
q_est_rps = lsim(tf_est, dele_total, chirp_time_s);
 
figure(fig_td)

