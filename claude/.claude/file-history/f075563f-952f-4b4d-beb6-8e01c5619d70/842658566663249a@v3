# ---------- 2d. vehicle_torque_setpoint (rate-controller demand) ----------
def fft_vehicle_torque_setpoint(ulog, outdir, t0, t1, show_lpf=True):
    """Direct flat-top FFT PSD of vehicle_torque_setpoint roll/pitch/yaw
    (xyz, normalized [-1, 1]) over [t0, t1]. Same layout/style as the other
    FFT plots. Auto-selects the instance carrying real signal (valid timing +
    nonzero variance), since some logs publish an empty second instance.
    Torque is the rate-controller output, so the gyro LPF cutoffs are drawn
    (chip HW DLPF lines omitted)."""
    instances = all_instances(ulog, "vehicle_torque_setpoint")
    if not instances:
        print("[fft_torque] no vehicle_torque_setpoint; skipping")
        return
    chosen = None
    best_var = -1.0
    for d in instances:
        if not all(f"xyz[{k}]" in d.data for k in range(3)):
            continue
        t = t_seconds(d, ulog)
        mask = (t >= t0) & (t <= t1)
        if mask.sum() < 256:
            continue
        if float(np.median(np.diff(t[mask]))) <= 0:
            continue
        v = sum(float(np.nanstd(d.data[f"xyz[{k}]"][mask])) for k in range(3))
        if v > best_var:
            best_var = v
            chosen = d
    if chosen is None or best_var <= 0:
        print("[fft_torque] no vehicle_torque_setpoint instance with usable "
              "signal; skipping")
        return

    i = chosen.multi_id
    t = t_seconds(chosen, ulog)
    mask = (t >= t0) & (t <= t1)
    dt_pub = float(np.median(np.diff(t[mask])))
    fs = 1.0 / dt_pub
    tw = t[mask]
    cols = [chosen.data[f"xyz[{k}]"][mask] for k in range(3)]  # normalized

    fig, axes = plt.subplots(3, 1, figsize=(11, 9), sharex=True)
    for ax, axis_data, axis_name in zip(axes, cols, ["Roll", "Pitch", "Yaw"]):
        freqs, _, psd = direct_fft(axis_data, fs, t=tw)
        ax.plot(freqs, psd, color="steelblue", linewidth=0.8)
        annotate_top_peaks(ax, freqs, psd, n_peaks=6)
        ax.set_ylabel(f"{axis_name} PSD (norm²/Hz)")
        ax.grid(True, which="both", alpha=0.3)
        ax.set_xlim(0, fs / 2)
        if show_lpf:
            add_lpf_lines(ax, "gyro", fs, include_hw=False)
        ax.legend(loc="upper right", fontsize=7)
    axes[-1].set_xlabel("Frequency (Hz)")
    fig.suptitle(f"FFT PSD (flat-top) of vehicle_torque_setpoint_{i} "
                 f"(roll/pitch/yaw), fs={fs:.0f} Hz")
    fig.tight_layout()
    outpath = outdir / "imu_fft_vehicle_torque_setpoint.png"
    save_fig(fig, outpath)
    print(f"[fft_torque] wrote {outpath}")

