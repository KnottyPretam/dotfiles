# ---------- 8. motor PSD vs IMU PSD ----------
def _plot_source_panel(t, channels, title, units, outpath, t0, t1,
                       fft_kind="direct"):
    """Time series (top) + PSD (bottom) for a set of related motor/actuator/
    ESC channels. fft_kind="welch" uses a Welch density PSD; fft_kind="direct"
    uses the flat-top direct_fft, matching the imu_fft plots. Channels with
    <16 in-window samples, any non-finite (NaN) in-window value, or near-zero
    variance are skipped; the FFT window matches fft_around_event so source
    spectra line up directly with the IMU FFT plots."""
    mask = (t >= t0) & (t <= t1)
    n_in = int(mask.sum())
    if n_in < 16:
        print(f"[sources] {outpath.name}: too few samples in [{t0:.1f},{t1:.1f}]s")
        return
    dt = float(np.median(np.diff(t[mask])))
    fs = 1.0 / dt if dt > 0 else 1.0
    nperseg = min(n_in, 4096)

    fig, axes = plt.subplots(2, 1, figsize=(12, 8))
    plotted = 0
    for label, sig in channels.items():
        sig = np.asarray(sig, dtype=float)
        seg = sig[mask]
        if not np.isfinite(seg).all():
            continue  # unpopulated / NaN channel
        if np.std(seg) < 1e-6:
            continue  # disarmed / static channel
        axes[0].plot(t, sig, label=label, linewidth=0.8, alpha=0.85)
        if fft_kind == "direct":
            freqs, _, psd = direct_fft(seg, fs, t=t[mask])
        else:
            freqs, psd = welch(seg, fs=fs, window="hann",
                               nperseg=nperseg, noverlap=nperseg // 2,
                               scaling="density", detrend="constant")
        axes[1].plot(freqs, psd, label=label, linewidth=0.9, alpha=0.85)
        plotted += 1

    if plotted == 0:
        plt.close(fig)
        print(f"[sources] {outpath.name}: no channels with variance; skipping")
        return

    axes[0].set_ylabel(units)
    axes[0].set_xlabel("time (s)")
    axes[0].grid(True, alpha=0.3)
    axes[0].legend(loc="upper right", fontsize=7, ncol=2)

    axes[1].set_xlim(0, fs / 2)
    axes[1].set_xlabel("Frequency (Hz)")
    axes[1].set_ylabel(f"PSD ({units}²/Hz)")
    axes[1].grid(True, alpha=0.3)
    axes[1].legend(loc="upper right", fontsize=7, ncol=2)

    if fft_kind == "direct":
        method, res = "flat-top FFT", (fs / n_in)
    else:
        method, res = "Welch", (fs / nperseg)
    fig.suptitle(f"{title}  —  {method}, window t={t0:.1f}–{t1:.1f}s, "
                 f"fs≈{fs:.0f} Hz, Δf≈{res:.2f} Hz")
    fig.tight_layout()
    save_fig(fig, outpath)
    print(f"[sources] wrote {outpath}")


def plot_vibration_sources(ulog, outdir, t0, t1):
    """Characterize the three signals that drive airframe vibration —
    per-motor RPM, per-motor current (both from esc_status), and the PWM
    output the autopilot is sending each ESC (actuator_outputs). Each
    PNG: time series on top, Welch density PSD on bottom over [t0, t1]."""

    esc = get_topic(ulog, "esc_status")
    if esc is None:
        print("[sources] no esc_status topic; skipping RPM and current")
    else:
        t_esc = t_seconds(esc, ulog)
        for field, units, fname, title in [
            ("esc_rpm",     "RPM", "motor_rpm_sources.png",
             "esc_status per-motor RPM"),
            ("esc_current", "A",   "motor_current_sources.png",
             "esc_status per-motor current"),
        ]:
            keys = sorted(k for k in esc.data.keys()
                          if k.startswith("esc[") and k.endswith(f".{field}"))
            if not keys:
                print(f"[sources] no esc[].{field}; skipping {fname}")
                continue
            channels = {k: esc.data[k] for k in keys}
            _plot_source_panel(t_esc, channels, title, units,
                               outdir / fname, t0, t1)

    # Pick the actuator_outputs instance whose channels actually move inside
    # the analysis window — same heuristic as the old plot_motor_vs_imu_psd,
    # because some airframes publish an idle "raw" instance with high full-
    # log variance but no signal in the hover slice.
    motors = None
    best_var = 0.0
    for cand in all_instances(ulog, "actuator_outputs"):
        tc = cand.data["timestamp"] / 1e6
        m = (tc >= t0) & (tc <= t1)
        if m.sum() < 64:
            continue
        ch_keys = [k for k in cand.data.keys() if k.startswith("output[")]
        v = sum(float(np.nanstd(cand.data[k][m])) for k in ch_keys)
        if v > best_var:
            best_var = v
            motors = cand
    if motors is None:
        print("[sources] no usable actuator_outputs; skipping motor_pwm_sources.png")
        return
    tm = t_seconds(motors, ulog)
    out_keys = sorted((k for k in motors.data.keys() if k.startswith("output[")),
                      key=lambda s: int(s[len("output["):-1]))
    channels = {k: motors.data[k] for k in out_keys}
    _plot_source_panel(
        tm, channels,
        f"actuator_outputs[{motors.multi_id}] PWM per channel",
        "PWM", outdir / "motor_pwm_sources.png", t0, t1,
    )


def plot_actuator_control_sources(ulog, outdir, t0, t1):
    """Per-channel actuator command sources, overlaid, with the same flat-top
    direct_fft used by the imu_fft plots (time series top, PSD bottom). Mirrors
    the motor_current_sources layout.
      actuator_motors.control[*]      -> actuator_motor_sources.png
      actuator_servos.control[*]      -> actuator_servo_sources.png
      actuator_outputs[i].output[*]   -> actuator_outputs_<i>_sources.png (per instance)
    """
    specs = [
        ("actuator_motors", "control[", "norm", "actuator_motor_sources.png",
         "actuator_motors control per channel", False),
        ("actuator_servos", "control[", "norm", "actuator_servo_sources.png",
         "actuator_servos control per channel", False),
        ("actuator_outputs", "output[", "PWM", None, None, True),
    ]
    for topic, prefix, units, fname, title, per_instance in specs:
        instances = all_instances(ulog, topic)
        if not instances:
            print(f"[act_sources] no {topic}; skipping")
            continue
        for d in instances:
            if "timestamp_sample" in d.data:
                t = d.data["timestamp_sample"].astype(np.int64) / 1e6 - T_OFFSET
            else:
                t = t_seconds(d, ulog)
            keys = sorted((k for k in d.data if k.startswith(prefix)),
                          key=lambda s: int(s[len(prefix):-1]))
            if not keys:
                continue
            channels = {k: d.data[k] for k in keys}
            if per_instance:
                out_fname = f"{topic}_{d.multi_id}_sources.png"
                out_title = f"{topic}[{d.multi_id}] output per channel"
            else:
                out_fname, out_title = fname, title
            _plot_source_panel(t, channels, out_title, units,
                               outdir / out_fname, t0, t1, fft_kind="direct")

# ---------- verdict ----------
def write_verdict(ulog, outpath):
    lines = ["=== IMU vibration / failure verdict ===", ""]
    # EVENT_* are in absolute FMU-boot seconds; t_seconds() returns shifted
    # time, so convert once and use shifted bounds throughout this function.
    event_start = EVENT_START_S - T_OFFSET
    event_end   = EVENT_END_S   - T_OFFSET

    instances = all_instances(ulog, "vehicle_imu_status")
    for d in instances:
        i = d.multi_id
        t = t_seconds(d, ulog)
        mask = (t >= event_start - 5) & (t <= event_end + 5)
        if mask.sum() == 0:
            lines.append(f"IMU{i}: no samples in event window "
                         f"[{event_start-5:.1f},{event_end+5:.1f}] s — "
                         f"data range [{t.min():.1f},{t.max():.1f}] s")
            lines.append("")
            continue
        if "accel_vibration_metric" in d.data:
            v = d.data["accel_vibration_metric"][mask]
            lines.append(f"IMU{i}: accel_vibration_metric  "
                         f"max={v.max():.2f} m/s²  mean={v.mean():.2f}  "
                         f"(>5 degraded, >10 dangerous)")
        if "gyro_vibration_metric" in d.data:
            v = d.data["gyro_vibration_metric"][mask] * RAD_TO_DEG
            lines.append(f"IMU{i}: gyro_vibration_metric   "
                         f"max={v.max():.2f} deg/s  mean={v.mean():.2f}  "
                         f"(>11.5 bad)")
        clip_keys = [f"accel_clipping[{k}]" for k in range(3)
                     if f"accel_clipping[{k}]" in d.data]
        if clip_keys:
            delta = [int(d.data[k][-1]) - int(d.data[k][0]) for k in clip_keys]
            lines.append(f"IMU{i}: accel_clipping total over flight  "
                         f"X={delta[0]} Y={delta[1]} Z={delta[2]}")
        lines.append("")

    sel = get_topic(ulog, "sensor_selection")
    if sel is not None:
        if "accel_device_id" in sel.data:
            ids = sel.data["accel_device_id"]
            t = t_seconds(sel, ulog)
            switches = int(np.sum(np.diff(ids) != 0))
            in_event = int(np.sum((t[:-1] >= event_start) &
                                   (t[:-1] <= event_end) &
                                   (np.diff(ids) != 0)))
            lines.append(f"sensor_selection accel switches: total={switches}, "
                         f"during dropout={in_event}")
        if "gyro_device_id" in sel.data:
            ids = sel.data["gyro_device_id"]
            t = t_seconds(sel, ulog)
            switches = int(np.sum(np.diff(ids) != 0))
            in_event = int(np.sum((t[:-1] >= event_start) &
                                   (t[:-1] <= event_end) &
                                   (np.diff(ids) != 0)))
            lines.append(f"sensor_selection gyro switches:  total={switches}, "
                         f"during dropout={in_event}")
        lines.append("")

    lines.append("")
    lines.append("=== dropout summary ===")
    for s in all_instances(ulog, "vehicle_imu_status"):
        i = s.multi_id
        if "accel_error_count" in s.data:
            a = s.data["accel_error_count"]
            lines.append(f"vehicle_imu_status_{i}: accel_error_count "
                         f"start={int(a[0])} end={int(a[-1])} "
                         f"delta={int(a[-1]) - int(a[0])}")
        if "gyro_error_count" in s.data:
            g = s.data["gyro_error_count"]
            lines.append(f"vehicle_imu_status_{i}: gyro_error_count  "
                         f"start={int(g[0])} end={int(g[-1])} "
                         f"delta={int(g[-1]) - int(g[0])}")
    for d in all_instances(ulog, "sensor_accel_fifo"):
        i = d.multi_id
        gap_t, missed = fifo_dropout_events(d)
        if len(gap_t) == 0:
            lines.append(f"sensor_accel_fifo_{i}: no dropouts inferred "
                         f"(gap > 1.5×dt)")
            continue
        order = np.argsort(missed)[::-1][:3]
        top = ", ".join(f"(t={gap_t[k]:.2f}s, missed={int(missed[k])})"
                        for k in order)
        lines.append(f"sensor_accel_fifo_{i}: events={len(gap_t)} "
                     f"total_missed={int(missed.sum())}  top3: {top}")

    txt = "\n".join(lines)
    print("\n" + txt)
    outpath.write_text(txt)
    print(f"\n[verdict] wrote {outpath}")

# ---------- main ----------
def parse_args():
    p = argparse.ArgumentParser(description=__doc__,
                                formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("ulog", nargs="?", default=ULOG_PATH,
                   help="Path to .ulg file (default: %(default)s)")
    p.add_argument("--config", default=None,
                   help="Optional YAML config; overrides built-in defaults.")
    p.add_argument("--start", type=float, default=None,
                   help="FFT window start (s). Overrides config and default.")
    p.add_argument("--end",   type=float, default=None,
                   help="FFT window end   (s). Overrides config and default.")
    p.add_argument("--outdir", default=None,
                   help="Directory to write plots and findings "
                        "(default: ./imuVibe_<logName>_plots; overrides config).")
    return p.parse_args()


def apply_yaml_config(path):
    """Mutate module-level config globals from a YAML file. Keys are optional."""
    if not _HAS_YAML:
        sys.exit("--config requires PyYAML: pip install pyyaml")
    with open(path) as f:
        cfg = yaml.safe_load(f) or {}
    global EVENT_START_S, EVENT_END_S, PRE_S, OUTDIR, LPF_CUTOFFS, HW_REFERENCES, SDLOG_MODE
    if "event_start_s" in cfg: EVENT_START_S = float(cfg["event_start_s"])
    if "event_end_s"   in cfg: EVENT_END_S   = float(cfg["event_end_s"])
    if "pre_s"         in cfg: PRE_S         = float(cfg["pre_s"])
    if "outdir"        in cfg: OUTDIR        = Path(cfg["outdir"])
    if "lpf_cutoffs"   in cfg: LPF_CUTOFFS   = cfg["lpf_cutoffs"]
    if "hw_references" in cfg: HW_REFERENCES = cfg["hw_references"]
    if "sdlog_mode"    in cfg: SDLOG_MODE    = int(cfg["sdlog_mode"])


def compute_time_offset(ulog):
    """For SDLOG_MODE=0, return the timestamp of the first actuator_outputs
    sample (seconds, FMU-boot). Walks instance ids 0, 1, 2, ... in order and
    uses the first one that exists. For modes 1 and 2, returns 0.0 (no shift)."""
    if SDLOG_MODE != 0:
        return 0.0
    instances = sorted(all_instances(ulog, "actuator_outputs"),
                       key=lambda d: d.multi_id)
    for d in instances:
        ts = d.data.get("timestamp")
        if ts is not None and len(ts) > 0:
            return float(ts[0]) / 1e6
    print("[time-shift] no actuator_outputs found; T_OFFSET=0")
    return 0.0


def fft_window(ulog, cli_start, cli_end, config_loaded=False):
    """Decide the (t0, t1) time window for all FFT plots.
    User-facing values (CLI flags, YAML/script EVENT_*) are interpreted as
    absolute FMU-boot seconds and converted to the script's shifted frame by
    subtracting T_OFFSET. Default falls back to the full sensor_accel_fifo
    span (already shifted)."""
    if cli_start is not None and cli_end is not None:
        return float(cli_start) - T_OFFSET, float(cli_end) - T_OFFSET
    if config_loaded:
        return float(EVENT_START_S) - T_OFFSET, float(EVENT_END_S) - T_OFFSET
    accel = get_topic(ulog, "sensor_accel_fifo")
    if accel is not None and "timestamp_sample" in accel.data:
        t = accel.data["timestamp_sample"] / 1e6 - T_OFFSET
    else:
        any_d = ulog.data_list[0]
        t = any_d.data["timestamp"] / 1e6 - T_OFFSET
    return float(t.min()), float(t.max())


def main():
    args = parse_args()
    if args.config:
        apply_yaml_config(args.config)
    global OUTDIR
    if args.outdir:
        OUTDIR = Path(args.outdir)
    elif OUTDIR is None:
        OUTDIR = Path.cwd() / f"imuVibe_{Path(args.ulog).stem}_plots"

    path = Path(args.ulog)
    if not path.exists():
        print(f"ERROR: {path} not found.")
        sys.exit(1)
    print(f"Loading {path}...")
    ulog = load(str(path))

    global T_OFFSET
    T_OFFSET = compute_time_offset(ulog)
    print(f"SDLOG_MODE={SDLOG_MODE}  T_OFFSET={T_OFFSET:.3f}s "
          f"({'shift active' if T_OFFSET else 'no shift'})")

    t0, t1 = fft_window(ulog, args.start, args.end, config_loaded=bool(args.config))
    print(f"FFT window: t0={t0:.2f}s  t1={t1:.2f}s  ({t1-t0:.2f}s)")

    OUTDIR.mkdir(parents=True, exist_ok=True)
    print(f"Writing outputs to {OUTDIR}/")
    plot_vibration_metrics(ulog, OUTDIR / "imu_vibration_metrics.png")
    plot_fifo_magnitude_timeseries(ulog, OUTDIR)
    plot_vehicle_imu_magnitude_timeseries(ulog, OUTDIR)
    fft_around_event(ulog, OUTDIR, t0, t1, show_lpf=True)
    fft_vehicle_imu(ulog, OUTDIR, t0, t1, show_lpf=True)
    plot_vehicle_angular_velocity_timeseries(ulog, OUTDIR)
    fft_vehicle_angular_velocity(ulog, OUTDIR, t0, t1, show_lpf=True)
    fft_vehicle_torque_setpoint(ulog, OUTDIR, t0, t1, show_lpf=True)
    plot_consistency(ulog, OUTDIR / "imu_consistency.png")
    plot_timing_vehicle_imu(ulog, OUTDIR / "imu_timing_vehicle_imu.png")
    plot_timing_sensor_accel_fifo(ulog, OUTDIR / "imu_timing_sensor_accel_fifo.png")
    plot_bias(ulog, OUTDIR / "imu_bias_drift.png")
    plot_selection(ulog, OUTDIR / "imu_selection.png")
    plot_innovations(ulog, OUTDIR / "imu_innovations.png")
    plot_vibration_sources(ulog, OUTDIR, t0, t1)
    plot_actuator_control_sources(ulog, OUTDIR, t0, t1)
    write_verdict(ulog, OUTDIR / "imu_findings.txt")
    print("\nDone.")

if __name__ == "__main__":
    main()
