# ---------- 4. per-topic timing + dropout views ----------
def gap_based_dropped_count(t, expected_dt_s=None):
    """Estimate dropped samples in a uniformly-sampled time series via gap
    inference: any Δt > 1.5×expected contributes round(Δt/expected) - 1."""
    if len(t) < 2:
        return 0
    dt = np.diff(t)
    expected = (expected_dt_s if expected_dt_s is not None
                else float(np.median(dt)))
    if expected <= 0:
        return 0
    over = dt > 1.5 * expected
    if not over.any():
        return 0
    return int(np.maximum(
        np.round(dt[over] / expected).astype(int) - 1, 0).sum())


def _plot_dt_with_outliers(ax, t, label, expected_dt_s=None,
                           n_recorded=None, n_dropped=None):
    """Plot Δt vs time on a log axis. Mark Δt > 1.5×expected as red dots and
    annotate max-Δt. expected_dt_s defaults to the median of np.diff(t).
    n_recorded / n_dropped are appended to the legend label when given."""
    if len(t) < 2:
        return
    dt_ms = np.diff(t) * 1000.0
    tt = t[1:]
    expected_ms = (expected_dt_s if expected_dt_s is not None
                   else float(np.median(np.diff(t)))) * 1000.0
    full_label = label
    if n_recorded is not None or n_dropped is not None:
        parts = []
        if n_recorded is not None:
            parts.append(f"recorded: {n_recorded}")
        if n_dropped is not None:
            parts.append(f"dropped: {n_dropped}")
        full_label = f"{label} ({', '.join(parts)})"
    ax.plot(tt, dt_ms, ".", markersize=1, color="steelblue", label=full_label)
    if expected_ms > 0:
        thresh = 1.5 * expected_ms
        out = dt_ms > thresh
        if out.any():
            ax.plot(tt[out], dt_ms[out], ".", markersize=4, color="red",
                    label=f"Δt > {thresh:.2f} ms")
        ax.axhline(expected_ms, color="green", linestyle="--", linewidth=0.8,
                   alpha=0.6, label=f"expected={expected_ms:.2f} ms")
    imax = int(np.argmax(dt_ms))
    ax.annotate(f"max Δt={dt_ms[imax]:.1f} ms @ t={tt[imax]:.1f}s",
                xy=(tt[imax], dt_ms[imax]),
                xytext=(0.7, 0.85), textcoords="axes fraction",
                fontsize=8,
                arrowprops=dict(arrowstyle="->", color="black"))
    ax.set_ylabel("Δt (ms)")
    ax.set_yscale("log")
    ax.grid(True, alpha=0.3)
    ax.legend(loc="upper left", fontsize=7)


