# ---------- 2a'. FFT per vehicle_imu instance (delta_velocity / delta_angle) ----------
def fft_vehicle_imu(ulog, outdir, t0, t1, show_lpf=True):
    """Direct flat-top FFT PSD of vehicle_imu acceleration (delta_velocity /
    delta_velocity_dt, g) and angular velocity (delta_angle / delta_angle_dt,
    deg/s) over [t0, t1], per instance. Matches the layout of fft_around_event
    for sensor_*_fifo. Note: vehicle_imu publish rate is typically far lower
    than the raw FIFO stream, so usable bandwidth is correspondingly limited."""
    instances = all_instances(ulog, "vehicle_imu")
    if not instances:
        print("[fft_vehicle_imu] no vehicle_imu; skipping")
        return
    for sensor_kind, delta_field, dt_field, ylabel, scale in [
        ("accel", "delta_velocity", "delta_velocity_dt", "PSD g²/Hz",       1.0 / G_MS2),
        ("gyro",  "delta_angle",    "delta_angle_dt",    "PSD (deg/s)²/Hz", RAD_TO_DEG),
    ]:
        for d in instances:
            i = d.multi_id
            if dt_field not in d.data:
                continue
            t = t_seconds(d, ulog)
            dt_int = d.data[dt_field].astype(np.float64) / 1e6
            valid = dt_int > 0
            axes_data = []
            for k in range(3):
                key = f"{delta_field}[{k}]"
                if key not in d.data:
                    break
                rate = np.zeros_like(dt_int)
                rate[valid] = d.data[key][valid] / dt_int[valid]
                axes_data.append(rate * scale)
            if len(axes_data) < 3:
                continue
            mask = (t >= t0) & (t <= t1) & valid
            if mask.sum() < 256:
                print(f"[fft_vehicle_imu]   {sensor_kind} vehicle_imu_{i}: "
                      f"too few samples ({int(mask.sum())})")
                continue
            tw = t[mask]
            x, y, z = [a[mask] for a in axes_data]
            dt_pub = float(np.median(np.diff(tw)))
            if dt_pub <= 0:
                continue
            fs = 1.0 / dt_pub

            fig, axes = plt.subplots(3, 1, figsize=(11, 9), sharex=True)
            for ax, axis_data, axis_name in zip(axes, [x, y, z], ["X", "Y", "Z"]):
                freqs, _, psd = direct_fft(axis_data, fs, t=tw)
                ax.plot(freqs, psd, color="steelblue", linewidth=0.8)
                annotate_top_peaks(ax, freqs, psd, n_peaks=6)
                ax.set_ylabel(f"{axis_name} {ylabel}")
                ax.grid(True, which="both", alpha=0.3)
                ax.set_xlim(0, fs / 2)
                if show_lpf:
                    add_lpf_lines(ax, sensor_kind, fs)
                ax.legend(loc="upper right", fontsize=7)
            axes[-1].set_xlabel("Frequency (Hz)")
            fig.suptitle(f"FFT PSD (flat-top) of vehicle_imu_{i} {sensor_kind}, "
                         f"fs={fs:.1f} Hz")
            fig.tight_layout()
            outpath = outdir / f"imu_fft_{sensor_kind}_vehicle_imu_{i}.png"
            save_fig(fig, outpath)
            print(f"[fft_vehicle_imu] wrote {outpath}")

# ---------- 2b'. magnitude time series from vehicle_imu ----------
def plot_vehicle_imu_magnitude_timeseries(ulog, outdir):
    """Per-axis (X, Y, Z) time series from vehicle_imu, all IMU instances
    overlaid. Acceleration in g (delta_velocity / delta_velocity_dt) and
    angular velocity in deg/s (delta_angle / delta_angle_dt)."""
    instances = all_instances(ulog, "vehicle_imu")
    if not instances:
        print("[vehicle_imu_mag] no vehicle_imu; skipping")
        return
    cycle = plt.rcParams["axes.prop_cycle"].by_key()["color"]
    for sensor_kind, delta_field, dt_field, units, scale in [
        ("accel", "delta_velocity", "delta_velocity_dt", "g",     1.0 / G_MS2),
        ("gyro",  "delta_angle",    "delta_angle_dt",    "deg/s", RAD_TO_DEG),
    ]:
        fig, axes = plt.subplots(3, 1, figsize=(12, 9), sharex=True)
        plotted_any = False
        for d in instances:
            i = d.multi_id
            color = cycle[i % len(cycle)]
            if dt_field not in d.data:
                continue
            t = t_seconds(d, ulog)
            dt_s = d.data[dt_field].astype(np.float64) / 1e6
            valid = dt_s > 0
            for ax, k in zip(axes, range(3)):
                key = f"{delta_field}[{k}]"
                if key not in d.data:
                    continue
                rate = np.full_like(dt_s, np.nan)
                rate[valid] = d.data[key][valid] / dt_s[valid]
                ax.plot(t, rate * scale, color=color,
                        label=f"vehicle_imu_{i}",
                        linewidth=1.0, alpha=0.85)
                plotted_any = True
        if not plotted_any:
            plt.close(fig)
            print(f"[vehicle_imu_mag] no {delta_field} fields; skipping {sensor_kind}")
            continue
        for ax, axis_name in zip(axes, ["X", "Y", "Z"]):
            ax.set_ylabel(f"{sensor_kind} {axis_name} ({units})")
            ax.legend(loc="upper right", fontsize=8)
            ax.grid(True, alpha=0.3)
        axes[-1].set_xlabel("time (s)")
        fig.suptitle(f"vehicle_imu per-axis {sensor_kind} time series")
        fig.tight_layout()
        outpath = outdir / f"imu_{sensor_kind}_vehicle_imu_mag.png"
        save_fig(fig, outpath)
        print(f"[vehicle_imu_mag] wrote {outpath}")

# ---------- 2c. vehicle_angular_velocity (filtered controller rate) ----------
def plot_vehicle_angular_velocity_timeseries(ulog, outdir):
    """Per-axis (X, Y, Z) time series of vehicle_angular_velocity — the
    filtered angular rate the rate controller runs on (post software LPF/
    notch), in deg/s. Same layout/style as the sensor_gyro_fifo time-series
    plot."""
    d = get_topic(ulog, "vehicle_angular_velocity")
    if d is None:
        print("[ang_vel_ts] no vehicle_angular_velocity; skipping")
        return
    t = t_seconds(d, ulog)
    scale = RAD_TO_DEG
    fig, axes = plt.subplots(3, 1, figsize=(12, 9), sharex=True)
    for ax, k in zip(axes, range(3)):
        key = f"xyz[{k}]"
        if key not in d.data:
            continue
        ax.plot(t, d.data[key] * scale, color="steelblue",
                label="vehicle_angular_velocity",
                linewidth=0.4, alpha=0.6)
    for ax, axis_name in zip(axes, ["X", "Y", "Z"]):
        ax.set_ylabel(f"gyro {axis_name} (deg/s)")
        ax.legend(loc="upper right", fontsize=8)
        ax.grid(True, alpha=0.3)
    axes[-1].set_xlabel("time (s)")
    fig.suptitle("vehicle_angular_velocity per-axis time series")
    fig.tight_layout()
    outpath = outdir / "imu_gyro_vehicle_angular_velocity_mag.png"
    save_fig(fig, outpath)
    print(f"[ang_vel_ts] wrote {outpath}")


def fft_vehicle_angular_velocity(ulog, outdir, t0, t1, show_lpf=True):
    """Direct flat-top FFT PSD of vehicle_angular_velocity (deg/s) over
    [t0, t1]. Same layout/style as the sensor_gyro_fifo FFT plot. fs is
    derived from sample spacing since vehicle_angular_velocity carries no
    intra-batch dt field."""
    d = get_topic(ulog, "vehicle_angular_velocity")
    if d is None:
