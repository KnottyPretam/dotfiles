def fifo_dropout_events(d):
    """Return (gap_times_s, missed_counts) for inferred dropouts in a
    sensor_*_fifo topic. A dropout is any inter-batch gap larger than
    1.5 × dt[i]; missed_count = round(gap / dt[i]) - 1."""
    ts_last = d.data["timestamp_sample"].astype(np.int64)   # µs, last sample
    dt_us   = d.data["dt"].astype(np.int64)                 # µs, intra-batch
    nsamp   = d.data["samples"].astype(np.int32)
    if len(ts_last) < 2:
        return np.array([]), np.array([], dtype=int)
    t_first = ts_last - (nsamp - 1) * dt_us                 # µs, first sample
    gap_us  = t_first[1:] - ts_last[:-1]                    # µs
    dt_next = dt_us[1:]
    valid   = dt_next > 0
    over    = np.zeros_like(gap_us, dtype=bool)
    over[valid] = gap_us[valid] > 1.5 * dt_next[valid]
    missed  = np.zeros_like(gap_us, dtype=int)
    missed[over] = np.maximum(
        np.round(gap_us[over] / dt_next[over]).astype(int) - 1, 0)
    gap_t_s = t_first[1:] / 1e6 - T_OFFSET
    keep = missed > 0
    return gap_t_s[keep], missed[keep]


