function [d,ax,fh,opts] = RunPlots(inputfilepath,opts)
addpath('UTILS');
warning off

if ~exist('opts'), opts = struct; end
if ~isfield(opts,'log_folder'); opts.log_folder = '../Logs/*.ulg'; end
if ~isfield(opts,'verbose'); opts.verbose = true; end
if ~isfield(opts,'skip_plotting'); opts.skip_plotting = false; end
if ~isfield(opts,'plot_airplane'); opts.plot_airplane = false; end
if ~isfield(opts,'plot_sensors'); opts.plot_sensors = false; end
if ~isfield(opts,'plot_controls'); opts.plot_controls = true; end
if ~isfield(opts,'plot_controls_ext'); opts.plot_controls_ext = false; end
if ~isfield(opts,'plot_propulsion'); opts.plot_propulsion = false; end
if ~isfield(opts,'plot_cpu'); opts.plot_cpu = false; end                                                                                                                                                                     
if ~isfield(opts,'time_base'); opts.time_base = 'avionics'; end
if ~isfield(opts,'save_mat'); opts.save_mat = true; end
if ~isfield(opts,'save_fig'); opts.save_fig = true; end
if ~isfield(opts,'close_all'); opts.close_all = true; end
if ~isfield(opts,'skip_bin_to_mat'); opts.skip_bin_to_mat = true; end
if ~isfield(opts,'air_density'); opts.air_density = 1.19; end
if ~isfield(opts,'use_derived_airspeeds'); opts.use_derived_airspeeds = true; end
if ~isfield(opts,'use_onboard_airspeeds'); opts.use_onboard_airspeeds = true; end
if ~isfield(opts,'rc_map_aetr'); opts.rc_map_aetr = [2 3 1 4]; end
if ~isfield(opts,'ao_servo_ind'); opts.ao_servo_ind = 1; end % actuator outputs that servos belong to
if ~isfield(opts,'ao_motor_ind'); opts.ao_motor_ind = 0; end % actuator outputs that motors belong to
if ~isfield(opts,'left_swash_ind'); opts.left_swash_ind = [0 1 2]; end % swash servo indices in actuator outputs [1 2 3], zero ref
if ~isfield(opts,'rght_swash_ind'); opts.rght_swash_ind = [4 5 6]; end % swash servo indices in actuator outputs [1 2 3], zero ref
if ~isfield(opts,'mot_ind'); opts.mot_ind = [0 1]; end % motor indices in actuator outputs [left right]
if ~isfield(opts,'esc_ind'); opts.esc_ind = [0 3]; end % esc indices in esc_status [left right]
if ~isfield(opts,'batt_ind'); opts.batt_ind = 0; end % batt index
if ~isfield(opts,'csurf_ind'); opts.csurf_ind = [3 7]; end % control surface servo indices in actuator outputs [el_left el_right]
if ~isfield(opts,'k_collective'); opts.k_collective = 0.7817; end % multipler for converting servo angle to a blade angle for collective
if ~isfield(opts,'k_cyclic'); opts.k_cyclic = 0.3555; end % multipler for converting servo angle to a blade angle for cyclic

%% Load PX4 Data
if (nargin == 0 || isempty(inputfilepath))
    [inputfile,inputpath] = uigetfile(opts.log_folder,'Choose data file');
    inputfilepath = [inputpath inputfile];
else
    [inputpath,inputname,ext] = fileparts(inputfilepath); inputpath = [inputpath filesep];
    inputfile = [inputname ext];
end
inputname = inputfile(1:end-4);
tag_txt = inputname;

if(opts.verbose), fprintf('Running input file: %s\n',inputfilepath); end

tic;
% convert binary
if (opts.skip_bin_to_mat && isfile([inputpath filesep tag_txt '.mat']))
    % read from existing mat file
    load([inputpath filesep tag_txt '.mat']);
    toc_read = toc; if(opts.verbose), fprintf('Skipped input file reading (it already existed)\n'); end
else
    % convert ulg to csv files with pyulog
    d = ReadData(inputpath,inputname);
    d = orderfields(d);
    toc_read = toc; if(opts.verbose), fprintf('Read input file in %1.1fs\n',toc_read); end
end

%% time function
switch opts.time_base
    case 'avionics'
        % avionics time
        to = d.actuator_outputs_2.timestamp(1);
        tf = d.actuator_outputs_2.timestamp(end);
        f_t = @(t_us) t_us*1E-6;
    case 'log_start'
        % time from log start
        to = d.actuator_outputs_2.timestamp(1);
        tf = d.actuator_outputs_2.timestamp(end);
        f_t = @(t_us) (t_us - to)*1E-6;
    case 'thunderball'
        % Thunderball-specific: time from log start (same offset as log_start)
        to = d.actuator_outputs_2.timestamp(1);
        tf = d.actuator_outputs_2.timestamp(end);
        f_t = @(t_us) (t_us - to)*1E-6;
end

%% derived data
% convenience functions
tic
r2d = 180/pi;
d2r = 1/r2d;
rho_sl = 1.225;
my_acts = num2str(opts.ao_servo_ind,'actuator_outputs_%1.0f');
my_mots = num2str(opts.ao_motor_ind,'actuator_outputs_%1.0f');
try d.sensor_mag_0.norm = sqrt(d.sensor_mag_0.x.^2 + d.sensor_mag_0.y.^2 + d.sensor_mag_0.z.^2); end
try d.differential_pressure_0.ias = sqrt(2*abs(d.differential_pressure_0.differential_pressure_pa)/rho_sl); end
try d.vehicle_attitude_0.q = [d.vehicle_attitude_0.q_1_ d.vehicle_attitude_0.q_2_ d.vehicle_attitude_0.q_3_ d.vehicle_attitude_0.q_0_ ]; end % reordering for MathUs
try d.vehicle_attitude_0.rpy = MathUs.QuatToEuler(d.vehicle_attitude_0.q); end % hover
try
    d.vehicle_attitude_0.rpy_h = d.vehicle_attitude_0.rpy;
    d.vehicle_attitude_0.rpy_c = MathUs.QuatToEuler(MathUs.QuatRotB(d.vehicle_attitude_0.q,MathUs.EulerToQuat([0 90 0]*pi/180))); % cruise
    vtol_state = MathUs.RebaseTimeScale(d.vehicle_attitude_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
    is_h = vtol_state == 3 | vtol_state == 1;
    d.vehicle_attitude_0.rpy = d.vehicle_attitude_0.rpy_h.*(is_h) + d.vehicle_attitude_0.rpy_c.*(~is_h); % combine
    d.vehicle_attitude_0.vtol_state = vtol_state; clear is_h vtol_state;
end
try
   rpy_h = [ d.vehicle_angular_velocity_0.xyz_0_ d.vehicle_angular_velocity_0.xyz_1_ d.vehicle_angular_velocity_0.xyz_2_];
   rpy_c = [-d.vehicle_angular_velocity_0.xyz_2_ d.vehicle_angular_velocity_0.xyz_1_ d.vehicle_angular_velocity_0.xyz_0_];
   vtol_state = MathUs.RebaseTimeScale(d.vehicle_angular_velocity_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
   is_h = vtol_state == 3 | vtol_state == 1;
   d.vehicle_angular_velocity_0.rpy = rpy_h.*(is_h) + rpy_c.*(~is_h); % combine
   d.vehicle_angular_velocity_0.vtol_state = vtol_state; clear is_h vtol_state rpy_h rpy_c;
end
try
   rpy_h = [ d.vehicle_rates_setpoint_0.roll d.vehicle_rates_setpoint_0.pitch d.vehicle_rates_setpoint_0.yaw];
   rpy_c = [-d.vehicle_rates_setpoint_0.yaw  d.vehicle_rates_setpoint_0.pitch d.vehicle_rates_setpoint_0.roll];
   vtol_state = MathUs.RebaseTimeScale(d.vehicle_rates_setpoint_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
   is_h = vtol_state == 3 | vtol_state == 1;
   d.vehicle_rates_setpoint_0.rpy = rpy_h.*(is_h) + rpy_c.*(~is_h); % combine
   d.vehicle_rates_setpoint_0.vtol_state = vtol_state; clear is_h vtol_state rpy_h rpy_c;
end
try
   rpy_h = [ d.vehicle_torque_setpoint_0.xyz_0_ d.vehicle_torque_setpoint_0.xyz_1_ d.vehicle_torque_setpoint_0.xyz_2_];
   rpy_c = [-d.vehicle_torque_setpoint_0.xyz_2_ d.vehicle_torque_setpoint_0.xyz_1_ d.vehicle_torque_setpoint_0.xyz_0_];
   vtol_state = MathUs.RebaseTimeScale(d.vehicle_torque_setpoint_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
   is_h = vtol_state == 3 | vtol_state == 1;
   d.vehicle_torque_setpoint_0.rpy = rpy_h.*(is_h) + rpy_c.*(~is_h); % combine
   d.vehicle_torque_setpoint_0.vtol_state = vtol_state; clear is_h vtol_state rpy_h rpy_c;
end
try d.vehicle_attitude_setpoint_0.q = [d.vehicle_attitude_setpoint_0.q_d_1_ d.vehicle_attitude_setpoint_0.q_d_2_ d.vehicle_attitude_setpoint_0.q_d_3_ d.vehicle_attitude_setpoint_0.q_d_0_]; end
try d.vehicle_attitude_setpoint_0.rpy = MathUs.QuatToEuler(d.vehicle_attitude_setpoint_0.q); end

try
    tau = 0.5;
    k = ceil(tau/median(diff(f_t(d.vehicle_local_position_0.timestamp))));
    d.vehicle_local_position_0.ax = MathUs.smooth_moving_average(MathUs.tdiff(d.vehicle_local_position_0.vx,f_t(d.vehicle_local_position_0.timestamp)),k);
    d.vehicle_local_position_0.ay = MathUs.smooth_moving_average(MathUs.tdiff(d.vehicle_local_position_0.vy,f_t(d.vehicle_local_position_0.timestamp)),k);
    d.vehicle_local_position_0.az = MathUs.smooth_moving_average(MathUs.tdiff(d.vehicle_local_position_0.vz,f_t(d.vehicle_local_position_0.timestamp)),k);
end
try d.vehicle_local_position_0.v = sqrt(d.vehicle_local_position_0.vx.^2 + d.vehicle_local_position_0.vy.^2); end
try d.estimator_optical_flow_vel_0.v = sqrt(d.estimator_optical_flow_vel_0.vel_body_0_.^2 + d.estimator_optical_flow_vel_0.vel_body_1_.^2); end
try
    xn = [d.vehicle_local_position_0.x  d.vehicle_local_position_0.y];
    vn = [d.vehicle_local_position_0.vx d.vehicle_local_position_0.vy];
    psi = MathUs.RebaseTimeScale(d.vehicle_local_position_0.timestamp,d.vehicle_attitude_0.rpy(:,3),d.vehicle_attitude_0.timestamp);
    xb = MathUs.RotateHeadingFrame(xn,psi);
    vb = MathUs.RotateHeadingFrame(vn,psi);
    d.vehicle_local_position_0.xb = xb(:,1);  d.vehicle_local_position_0.yb = xb(:,2);
    d.vehicle_local_position_0.vxb = vb(:,1); d.vehicle_local_position_0.vyb = vb(:,2);
end
try
    xn = [d.vehicle_local_position_setpoint_0.x  d.vehicle_local_position_setpoint_0.y];
    vn = [d.vehicle_local_position_setpoint_0.vx d.vehicle_local_position_setpoint_0.vy];
    psi = MathUs.RebaseTimeScale(d.vehicle_local_position_setpoint_0.timestamp,d.vehicle_local_position_0.heading,d.vehicle_local_position_0.timestamp);
    xb = MathUs.RotateHeadingFrame(xn,psi);
    vb = MathUs.RotateHeadingFrame(vn,psi);
    d.vehicle_local_position_setpoint_0.xb = xb(:,1);  d.vehicle_local_position_setpoint_0.yb = xb(:,2);
    d.vehicle_local_position_setpoint_0.vxb = vb(:,1); d.vehicle_local_position_setpoint_0.vyb = vb(:,2);
    vna = [MathUs.RebaseTimeScale(d.vehicle_local_position_setpoint_0.timestamp,d.vehicle_local_position_0.vx,d.vehicle_local_position_0.timestamp) MathUs.RebaseTimeScale(d.vehicle_local_position_setpoint_0.timestamp,d.vehicle_local_position_0.vy,d.vehicle_local_position_0.timestamp)];
    vnerr = vn - vna;
    d.vehicle_local_position_setpoint_0.vx_err = vnerr(:,1);
    d.vehicle_local_position_setpoint_0.vy_err = vnerr(:,2);
    vberr = MathUs.RotateHeadingFrame(vnerr,psi);
    d.vehicle_local_position_setpoint_0.vxb_err = vberr(:,1);
    d.vehicle_local_position_setpoint_0.vyb_err = vberr(:,2);
    vberr = MathUs.RotateHeadingFrame(vnerr,d.vehicle_local_position_setpoint_0.yaw);
    d.vehicle_local_position_setpoint_0.vxb_err_sp = vberr(:,1);
    d.vehicle_local_position_setpoint_0.vyb_err_sp = vberr(:,2);
end
try
    xn = [d.estimator_local_position_0.x  d.estimator_local_position_0.y];
    vn = [d.estimator_local_position_0.vx d.estimator_local_position_0.vy];
    psi = d.estimator_local_position_0.heading;
    xb = MathUs.RotateHeadingFrame(xn,psi);
    vb = MathUs.RotateHeadingFrame(vn,psi);
    d.estimator_local_position_0.xb = xb(:,1);  d.estimator_local_position_0.yb = xb(:,2);
    d.estimator_local_position_0.vxb = vb(:,1); d.estimator_local_position_0.vyb = vb(:,2);
end
try
    alt_home = d.home_position_0.alt(1);
    d.vehicle_global_position_0.alt_ahl = d.vehicle_global_position_0.alt - alt_home;
    d.vehicle_gps_position_0.alt_ahl = d.vehicle_gps_position_0.alt - alt_home*1E3;
end
try
    d.(['battery_status_' num2str(opts.batt_ind)]).power = d.(['battery_status_' num2str(opts.batt_ind)]).voltage_v.*d.(['battery_status_' num2str(opts.batt_ind)]).current_a;
    d.(['battery_status_' num2str(opts.batt_ind)]).power_f = d.(['battery_status_' num2str(opts.batt_ind)]).voltage_filtered_v.*d.(['battery_status_' num2str(opts.batt_ind)]).current_filtered_a;
end
try
    d.(my_mots).motors = [d.(my_mots).(num2str(opts.mot_ind(1),' output_%1.0f_')) d.(my_mots).(num2str(opts.mot_ind(2),' output_%1.0f_'))] / 8191 * 10000;
    d.(my_acts).swash_left = ([d.(my_acts).(num2str(opts.left_swash_ind(1),' output_%1.0f_'))  d.(my_acts).(num2str(opts.left_swash_ind(2),' output_%1.0f_')) d.(my_acts).(num2str(opts.left_swash_ind(3),' output_%1.0f_'))] - 500)/500*opts.servo_range;
    d.(my_acts).swash_rght = ([d.(my_acts).(num2str(opts.rght_swash_ind(1),' output_%1.0f_'))  d.(my_acts).(num2str(opts.rght_swash_ind(2),' output_%1.0f_')) d.(my_acts).(num2str(opts.rght_swash_ind(3),' output_%1.0f_'))] - 500)/500*opts.servo_range;
    d.(my_acts).col_left = 1/3*( d.(my_acts).swash_left(:,1) + d.(my_acts).swash_left(:,2) + d.(my_acts).swash_left(:,3)) * opts.k_collective;
    d.(my_acts).col_rght = 1/3*( d.(my_acts).swash_rght(:,1) + d.(my_acts).swash_rght(:,2) + d.(my_acts).swash_rght(:,3)) * opts.k_collective;
    sw_pos = [330 90 210]*pi/180; sw_cos = max(cos(sw_pos));
    sw_mult = [1 -1]; % to flip signs or scale the swashplate control output [collective cyclic]
    d.(my_acts).cyc_left = (d.(my_acts).col_left - d.(my_acts).swash_left(:,1))/sw_cos*sw_mult(2) * opts.k_cyclic;
    d.(my_acts).cyc_rght = (d.(my_acts).col_rght - d.(my_acts).swash_rght(:,1))/sw_cos*sw_mult(2) * opts.k_cyclic;
    d.(my_acts).rol = sw_mult(1)*(d.(my_acts).col_left - d.(my_acts).col_rght)/2;
    d.(my_acts).pit = (d.(my_acts).cyc_left + d.(my_acts).cyc_rght)/2;
    d.(my_acts).yaw = (-d.(my_acts).cyc_left + d.(my_acts).cyc_rght)/2;
    d.(my_acts).clm = (d.(my_acts).col_left + d.(my_acts).col_rght)/2;
    d.(my_acts).elevons = [d.(my_acts).(num2str(opts.csurf_ind(1),' output_%1.0f_')) d.(my_acts).(num2str(opts.csurf_ind(2),' output_%1.0f_'))];
    d.(my_acts).elevator = (- (d.(my_acts).elevons(:,1)-1500) + (d.(my_acts).elevons(:,2)-1500))/2;
    d.(my_acts).aileron = (+ (d.(my_acts).elevons(:,1)-1500) + (d.(my_acts).elevons(:,2)-1500))/2;
end
try
    d.esc_data = table;
    for i = 1:length(opts.esc_ind)
        d.esc_data.timestamp(:,i) = (d.esc_status_0.(['esc_' num2str(opts.esc_ind(i)) '__timestamp']));
        d.esc_data.rpm(:,i) = (d.esc_status_0.(['esc_' num2str(opts.esc_ind(i)) '__esc_rpm']));
        d.esc_data.voltage(:,i) = (d.esc_status_0.(['esc_' num2str(opts.esc_ind(i)) '__esc_voltage']));
        d.esc_data.current(:,i) = (d.esc_status_0.(['esc_' num2str(opts.esc_ind(i)) '__esc_current']));
        d.esc_data.temp(:,i) = (d.esc_status_0.(['esc_' num2str(opts.esc_ind(i)) '__esc_temperature']));
        d.esc_data.effort(:,i) = (d.esc_status_0.(['esc_' num2str(opts.esc_ind(i)) '__esc_power']))/100;
        d.esc_data.vpk(:,i) = d.esc_data.effort(:,i).*d.esc_data.voltage(:,i);
    end
end

if opts.save_mat, save([inputpath filesep tag_txt],'d'); end
toc_read = toc; if(opts.verbose), fprintf('\b, Calculated derived data %1.1fs\n',toc_read); end
%% start with plotting
if opts.skip_plotting, return; end
tic
if opts.close_all
    close all
end
clear fh ah
ih = 0;

% standard plots
f_genplot6 = @(d,t,group,field,scale,legend_txt,line_fmt) plot(t,scale.*eval(sprintf('d.%s.%s',group,field)),line_fmt,'DisplayName',legend_txt);
f_genplot  = @(d,t,group,field,scale,legend_txt) plot(t,scale.*eval(sprintf('d.%s.%s',group,field)),'DisplayName',legend_txt);
f_genplot7 = @(d,group,field,scale,line_fmt) f_genplot6(d,f_t(d.(group).timestamp),group,field,scale,[group '.' field],line_fmt);
f_genplot3 = @(d,group,field,scale,legend_txt) f_genplot(d,f_t(d.(group).timestamp),group,field,scale,legend_txt);
f_genplot4 = @(d,group,field,scale) f_genplot(d,f_t(d.(group).timestamp),group,field,scale,[group '.' field]);
f_genplot8 = @(d,group,field,legend_txt) f_genplot(d,f_t(d.(group).timestamp),group,field,1,legend_txt);
f_genplot2 = @(d,group,field) f_genplot(d,f_t(d.(group).timestamp),group,field,1,[group '.' field]);

set(0,'DefaultAxesFontSize',12);
set(0,'DefaultFigureColor',[1,1,1])
set(0,'DefaultFigureWindowStyle','docked')
set(0,'DefaultFigureCreateFcn',@(fig,~)addToolbarExplorationButtons(fig))

if opts.plot_airplane
    %% airspeed and climb
    ih = ih + 1; fh(ih) = figure('Name','airspeed and climb');
    iax = 1;

    ax(ih,iax) = subplot(3,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'tecs_status_0','true_airspeed_filtered'); end
    try f_genplot2(d,'tecs_status_0','true_airspeed_sp'); end

    grid on; legend('interpreter','none');
    ylabel('speed (m/s)');
    title({'Airspeed / Ground Speed / Climb Data',tag_txt},'interpreter','none');

    ax(ih,iax) = subplot(3,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'tecs_status_0','height_rate'); end
    try f_genplot2(d,'tecs_status_0','height_rate_setpoint'); end
    grid on; legend('interpreter','none');
    ylabel('climb (m/s)');

    ax(ih,iax) = subplot(3,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'tecs_status_0','throttle_sp'); end
    try f_genplot2(d,'tecs_status_0','pitch_sp_rad'); end
    try f_genplot2(d,'tecs_status_0','throttle_integ'); end
    try f_genplot2(d,'tecs_status_0','pitch_integ'); end
    grid on; legend('interpreter','none');
    ylabel('-');
    
    grid on;
    xlabel('time (s)');

    %% total energy
    ih = ih + 1; fh(ih) = figure('Name','tecs');
    iax = 1;

    ax(ih,iax) = subplot(3,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'tecs_status_0','total_energy_rate'); end
    try f_genplot2(d,'tecs_status_0','total_energy_rate_sp'); end
    grid on; legend('interpreter','none');
    ylabel('TE dot (W)');
    title({'TECS',tag_txt},'interpreter','none');

    ax(ih,iax) = subplot(3,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'tecs_status_0','total_energy_balance_rate'); end
    try f_genplot2(d,'tecs_status_0','total_energy_balance_rate_sp'); end
    grid on; legend('interpreter','none');
    ylabel('TE blance dot(W)');

    ax(ih,iax) = subplot(3,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'tecs_status_0','throttle_sp'); end
    try f_genplot2(d,'tecs_status_0','pitch_sp_rad'); end
    try f_genplot2(d,'tecs_status_0','throttle_integ'); end
    try f_genplot2(d,'tecs_status_0','pitch_integ'); end
    grid on; legend('interpreter','none');
    ylabel('-');

    grid on;
    xlabel('time (s)');

    %% pitot
    ih = ih + 1; fh(ih) = figure('Name','pitot');
    iax = 1; n = 3;

    ax(ih,iax) = subplot(n,1,iax); iax = iax + 1; hold on;
    %try f_genplot2(d,'differential_pressure_0','ias'); end
    try f_genplot2(d,'airspeed_validated_0','indicated_airspeed_m_s'); end
    try f_genplot2(d,'airspeed_validated_0','calibrated_airspeed_m_s'); end
    try f_genplot2(d,'airspeed_validated_0','true_airspeed_m_s'); end
    %try f_genplot2(d,'airspeed_0','indicated_airspeed_m_s'); end
    %try f_genplot2(d,'airspeed_0','true_airspeed_m_s'); end
    try f_genplot2(d,'vehicle_gps_position_0','vel_m_s'); end
    grid on; legend('interpreter','none');
    ylabel('speed (m/s)');
    title({'Pitot',tag_txt},'interpreter','none');
    
    ax(ih,iax) = subplot(n,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'differential_pressure_0','differential_pressure_pa'); end
    grid on; legend('interpreter','none');
    ylabel('(Pa)');
    
    ax(ih,iax) = subplot(n,1,iax); iax = iax + 1; hold on;
    try f_genplot2(d,'differential_pressure_0','temperature'); end
    try f_genplot2(d,'vehicle_air_data_0','baro_temp_celcius'); end
    grid on; legend('interpreter','none');
    ylabel('(degC)');
    
    grid on;
    xlabel('time (s)');

end

if opts.plot_sensors
    if isfield(d,'sensor_gps_0')
        %% gps
        ih = ih + 1; fh(ih) = figure('Name','gps');
        iax = 1; n = 3;

        ax(ih,iax) = subplot(n,1,iax); iax = iax + 1; hold on;
