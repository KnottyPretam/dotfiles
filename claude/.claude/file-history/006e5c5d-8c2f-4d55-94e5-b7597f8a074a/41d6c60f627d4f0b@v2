# Collective chirp: sweeps symmetric collective pitch.
# Rotors are held at CA_CHIRP_RPM for the whole sweep (rpm decoupled from collective).
# NOTE: CA_CHIRP_RPM is the normalized motor command for your ~6000 rpm hold point;
#       edit it to match your hardware/model. CA_CHIRP_AMP is in collective-pitch units.
param set CA_CHIRP_MODE 3
param set CA_CHIRP_AMP 0.20
param set CA_CHIRP_F0 0.5
param set CA_CHIRP_F1 15
param set CA_CHIRP_T 20
param set CA_CHIRP_ORD 1
param set CA_CHIRP_RPM 0.60
