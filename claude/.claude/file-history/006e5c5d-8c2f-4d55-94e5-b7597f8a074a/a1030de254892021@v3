// ------------------------------------------------------------------------
// updateSetpoint() invariants.
// ------------------------------------------------------------------------

TEST(ActuatorEffectivenessTwinRotorTailsitterTest, ChirpHoldsRpmAndBypassesControl)
{
	param_control_autosave(false);
	// Cyclic-pitch chirp: rotors must be held at CA_CHIRP_RPM regardless of the (bypassed) thrust setpoint.
	setChirpParams(Twin::CHIRP_CYCLIC_PITCH, 0.5f, 1.f, 5.f, 10.f, 1.f, 0.42f);

	// Arm the vehicle so the chirp activates.
	uORB::Publication<vehicle_status_s> status_pub{ORB_ID(vehicle_status)};
	vehicle_status_s status{};
	status.arming_state = vehicle_status_s::ARMING_STATE_ARMED;
	status.armed_time = hrt_absolute_time();
	status_pub.publish(status);

	Twin twin(nullptr);
	ActuatorEffectiveness::Configuration configuration{};
	twin.getEffectivenessMatrix(configuration, EffectivenessUpdateReason::MOTOR_ACTIVATION_UPDATE);

	Vector<float, 6> control_sp{};
	control_sp(Axis::THRUST_Z) = -1.f; // would command high throttle on the normal path

	ActuatorEffectiveness::ActuatorVector actuator_sp{};
	ActuatorEffectiveness::ActuatorVector actuator_min{};
	actuator_min.setAll(-1.f);
	ActuatorEffectiveness::ActuatorVector actuator_max{};
	actuator_max.setAll(2.f);

	twin.updateSetpoint(control_sp, 0, actuator_sp, actuator_min, actuator_max);

	// Sweep is at t ~= 0 (<< CA_CHIRP_T), so it is active and the motors are held at CA_CHIRP_RPM.
	EXPECT_FLOAT_EQ(actuator_sp(0), 0.42f);
	EXPECT_FLOAT_EQ(actuator_sp(1), 0.42f);
}

TEST(ActuatorEffectivenessTwinRotorTailsitterTest, ChirpOffFollowsThrottleCurve)
{
	param_control_autosave(false);

	// Predefined throttle curve (same shape as the helicopter test).
	float curve[5] = {0.f, .3f, .6f, .8f, 1.f};
	for (int i = 0; i < 5; i++) {
		char buffer[17];
		snprintf(buffer, sizeof(buffer), "CA_HELI_THR_C%u", i);
		param_set(param_find(buffer), &curve[i]);
	}
	float krpm = 1.f;
	param_set(param_find("CA_TWIN0_KRPM"), &krpm);
	setChirpParams(Twin::CHIRP_OFF, 0.f, 0.1f, 10.f, 10.f, 1.f, 0.f);

	Twin twin(nullptr);
	ActuatorEffectiveness::Configuration configuration{};
	twin.getEffectivenessMatrix(configuration, EffectivenessUpdateReason::MOTOR_ACTIVATION_UPDATE);

	Vector<float, 6> control_sp{};
	control_sp(Axis::THRUST_Z) = -.5f; // -> throttle curve maps to 0.6

	ActuatorEffectiveness::ActuatorVector actuator_sp{};
	ActuatorEffectiveness::ActuatorVector actuator_min{};
	actuator_min.setAll(0.f);
	ActuatorEffectiveness::ActuatorVector actuator_max{};
	actuator_max.setAll(1.f);

	// First call initialises the blended _krpm via updateConfig(); assert on the second.
	twin.updateSetpoint(control_sp, 0, actuator_sp, actuator_min, actuator_max);
	twin.updateSetpoint(control_sp, 0, actuator_sp, actuator_min, actuator_max);

	EXPECT_FLOAT_EQ(actuator_sp(0), 0.6f); // throttle curve value * spoolup(1, disarmed) * krpm(1)
	EXPECT_FLOAT_EQ(actuator_sp(1), 0.6f);
}
