// ------------------------------------------------------------------------
// Chirp equation (the core "logic"). Deterministic, no dependence on hrt.
// ------------------------------------------------------------------------

TEST(ChirpTest, StartsAtZero)
{
	Chirp chirp;
	chirp.init(0.1f, 10.f, 1.f, 10.f, 1.f);
	EXPECT_NEAR(chirp.update(0.f), 0.f, 1e-6f);
}

TEST(ChirpTest, ConstantFrequencyIsPureSine)
{
	// f0 == f1 -> beta = 0 -> out(t) = amp * sin(2*pi*f*t)
	Chirp chirp;
	chirp.init(2.f, 2.f, 1.f, 10.f, 1.f);
	EXPECT_NEAR(chirp.update(0.125f), 1.f, 1e-4f); // 2*pi*2*0.125 = pi/2 -> sin = 1
	EXPECT_NEAR(chirp.update(0.25f), 0.f, 1e-4f);  // 2*pi*2*0.25  = pi    -> sin = 0

	// amplitude scales the output
	chirp.init(2.f, 2.f, 1.f, 10.f, 3.f);
	EXPECT_NEAR(chirp.update(0.125f), 3.f, 1e-4f);
}

TEST(ChirpTest, LinearSweep)
{
	// f0=0, f1=2, k=1, T=4 -> beta=0.5, phase(t)=2*pi*(0.25*t^2)
	Chirp chirp;
	chirp.init(0.f, 2.f, 1.f, 4.f, 1.f);
	EXPECT_NEAR(chirp.update(0.f), 0.f, 1e-6f);
	EXPECT_NEAR(chirp.update(1.f), 1.f, 1e-4f); // phase = pi/2 -> sin = 1
	EXPECT_NEAR(chirp.update(2.f), 0.f, 1e-4f); // phase = 2*pi -> sin = 0
}

TEST(ChirpTest, SecondOrderSweep)
{
	// f0=0, f1=3, k=2, T=3 -> beta=1/3, phase(t)=2*pi*(t^3/9); at t=T phase=6*pi -> sin = 0
	Chirp chirp;
	chirp.init(0.f, 3.f, 2.f, 3.f, 1.f);
	EXPECT_NEAR(chirp.update(3.f), 0.f, 1e-3f);
}

TEST(ChirpTest, FinishedAfterDuration)
{
	Chirp chirp;
	chirp.init(0.f, 2.f, 1.f, 4.f, 1.f);
	EXPECT_FALSE(chirp.finished(3.5f));
	EXPECT_TRUE(chirp.finished(4.5f));
}

TEST(ChirpTest, ZeroDurationIsSafe)
{
	Chirp chirp;
	chirp.init(0.f, 2.f, 1.f, 0.f, 1.f);
	EXPECT_FLOAT_EQ(chirp.update(2.f), 0.f);
}

// ------------------------------------------------------------------------
// Routing: applyChirp() bypasses the control setpoint and drives the
// selected axis. Called with an explicit elapsed time, so deterministic.
// ------------------------------------------------------------------------

static void setChirpParams(int32_t mode, float amp, float f0, float f1, float total_time, float order, float rpm)
{
	int32_t m = mode;
	param_set(param_find("CA_CHIRP_MODE"), &m);
	param_set(param_find("CA_CHIRP_AMP"), &amp);
	param_set(param_find("CA_CHIRP_F0"), &f0);
	param_set(param_find("CA_CHIRP_F1"), &f1);
	param_set(param_find("CA_CHIRP_T"), &total_time);
	param_set(param_find("CA_CHIRP_ORD"), &order);
	param_set(param_find("CA_CHIRP_RPM"), &rpm);
}

// Builds a chirp value of 1.0 at t=0.125 by using a constant 2 Hz sweep (f0=f1=2).
static constexpr float kChirpEvalTime = 0.125f;
static constexpr float kChirpExpected = 1.f; // sin(2*pi*2*0.125) = 1

TEST(ActuatorEffectivenessTwinRotorTailsitterTest, ChirpRoutingCyclicPitch)
{
	param_control_autosave(false);
	setChirpParams(Twin::CHIRP_CYCLIC_PITCH, 1.f, 2.f, 2.f, 10.f, 1.f, 0.5f);
	Twin twin(nullptr);

	Vector<float, 6> sp;
	sp.setAll(7.f); // garbage that must be overwritten
	float motor = -1.f;
	float coll = -1.f;
	twin.applyChirp(kChirpEvalTime, sp, motor, coll);

	EXPECT_NEAR(sp(Axis::PITCH), kChirpExpected, 1e-4f);
	EXPECT_FLOAT_EQ(sp(Axis::ROLL), 0.f);
	EXPECT_FLOAT_EQ(sp(Axis::YAW), 0.f);
	EXPECT_FLOAT_EQ(sp(Axis::THRUST_Z), 0.f);
	EXPECT_FLOAT_EQ(motor, 0.5f); // rotor held at CA_CHIRP_RPM
	EXPECT_FLOAT_EQ(coll, 0.f);
}

