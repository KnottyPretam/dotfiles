# RPM chirp: sweeps the rotor motor command around the CA_CHIRP_RPM baseline.
# Cyclic and collective are held at baseline.
# NOTE: CA_CHIRP_RPM is the normalized motor command for your ~6000 rpm baseline;
#       edit it to match your hardware/model. CA_CHIRP_AMP is in motor-command units
#       (the sweep is added on top of CA_CHIRP_RPM, so keep amp + rpm within [0, 1]).
param set CA_CHIRP_MODE 5
param set CA_CHIRP_AMP 0.10
param set CA_CHIRP_F0 0.5
param set CA_CHIRP_F1 15
param set CA_CHIRP_T 20
param set CA_CHIRP_ORD 1
param set CA_CHIRP_RPM 0.60
