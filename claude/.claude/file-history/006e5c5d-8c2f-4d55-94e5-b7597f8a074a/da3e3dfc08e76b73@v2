#pragma once

#include <mathlib/mathlib.h>
#include <math.h>

/**
 * Polynomial frequency-sweep (chirp) signal generator.
 *
 * The instantaneous frequency sweeps from freq_init to freq_final over the
 * total_time duration following a polynomial of order chirp_order:
 *
 *     f(t)  = freq_init + beta * t^k,   with  beta = (freq_final - freq_init) / T^k
 *     out(t)= amp * sin( 2*pi * ( beta/(k+1) * t^(k+1) + freq_init * t ) )
 *
 * where t is the running elapsed time in [0, T], T = total_time and k = chirp_order.
 * k = 1 yields the textbook linear chirp. At t = 0 the output is 0 (smooth start).
 */
class Chirp
{
public:
	Chirp() = default;

	void configure(float freq_init, float freq_final, float chirp_order, float total_time, float amplitude)
	{
		_freq_init = freq_init;
		_freq_final = freq_final;
		_chirp_order = chirp_order;
		_total_time = total_time;
		_amplitude = amplitude;
	}

	// Chirp signal at elapsed time t [s]. t is clamped to [0, total_time].
	float update(float t) const
	{
		if (_total_time <= 0.f) {
			return 0.f;
		}

		const float tc = math::constrain(t, 0.f, _total_time);
		const float beta = (_freq_final - _freq_init) / powf(_total_time, _chirp_order);
		const float phase = 2.f * M_PI_F * (beta / (_chirp_order + 1.f) * powf(tc, _chirp_order + 1.f) + _freq_init * tc);
		return _amplitude * sinf(phase);
	}

	bool finished(float t) const { return t > _total_time; }

	float duration() const { return _total_time; }

private:
	float _freq_init{0.f};   ///< sweep start frequency [Hz]
	float _freq_final{0.f};  ///< sweep end frequency [Hz]
	float _chirp_order{1.f}; ///< polynomial order of the sweep (1 = linear)
	float _total_time{0.f};  ///< sweep duration [s]
	float _amplitude{0.f};   ///< output amplitude (units of the target axis)
};
