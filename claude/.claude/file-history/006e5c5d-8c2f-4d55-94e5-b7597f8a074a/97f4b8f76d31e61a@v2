#pragma once

#include "ActuatorEffectiveness.hpp"
#include "Chirp.hpp"

#include <px4_platform_common/module_params.h>

#include <uORB/Subscription.hpp>
#include <uORB/topics/vehicle_status.h>
#include <uORB/topics/manual_control_switches.h>
#include <uORB/topics/vehicle_thrust_setpoint.h> // <-- TODO : hacking this message for convenience; make a custom tailsitter_allocation message?
#include <uORB/topics/vehicle_land_detected.h>
#include <uORB/topics/parameter_update.h>
#include <uORB/Subscription.hpp>

class ActuatorEffectivenessTwinRotorTailsitter : public ModuleParams, public ActuatorEffectiveness
{
public:

	static constexpr int NUM_SWASH_PLATE_SERVOS_MAX = 6;
	static constexpr int NUM_SURFACE_SERVOS_MAX = 2;
	static constexpr int NUM_CURVE_POINTS = 5;
	static constexpr int N_FLIGHT_CONFIG = 2;

	struct SwashPlateGeometry {
		float angle;
		float arm_length;
		float trim;
	};

	struct Geometry {
		SwashPlateGeometry swash_plate_servos[NUM_SWASH_PLATE_SERVOS_MAX];
		int num_swash_plate_servos{0};
		int num_surface_servos{0};
		float throttle_curve[NUM_CURVE_POINTS];
		float pitch_curve[NUM_CURVE_POINTS];
		float phase;
		float rol_body_to_rotor[N_FLIGHT_CONFIG];
		float pit_body_to_rotor[N_FLIGHT_CONFIG];
		float yaw_body_to_rotor[N_FLIGHT_CONFIG];
		float thr_body_to_rotor[N_FLIGHT_CONFIG];
		float thr_body_to_rotor_trim[N_FLIGHT_CONFIG];
		float body_to_ail[N_FLIGHT_CONFIG];
		float body_to_ele[N_FLIGHT_CONFIG];
		float body_to_ele_trim[N_FLIGHT_CONFIG];
		float krpm[N_FLIGHT_CONFIG];
		float col_min[N_FLIGHT_CONFIG];
		float col_max[N_FLIGHT_CONFIG];
		float cyc_lim[N_FLIGHT_CONFIG];
		float dir;
		float yaw_sign;
		float spoolup_time;
		float surface_trim[NUM_SURFACE_SERVOS_MAX];
	};

	ActuatorEffectivenessTwinRotorTailsitter(ModuleParams *parent);
	virtual ~ActuatorEffectivenessTwinRotorTailsitter() = default;

	bool getEffectivenessMatrix(Configuration &configuration, EffectivenessUpdateReason external_update) override;

	const char *name() const override { return "Twin Rotor Tailsitter"; }


	const Geometry &geometry() const { return _geometry; }

	void updateSetpoint(const matrix::Vector<float, NUM_AXES> &control_sp, int matrix_index,
			    ActuatorVector &actuator_sp, const matrix::Vector<float, NUM_ACTUATORS> &actuator_min,
			    const matrix::Vector<float, NUM_ACTUATORS> &actuator_max) override;

	void getUnallocatedControl(int matrix_index, control_allocator_status_s &status) override;

	typedef enum  {
		HOVER = 0,
		CRUISE
	} FlightConfigs;

	void setFlightConfig(FlightConfigs fm) {_flight_config = fm;}

	// Chirp injection for actuator system identification (see Chirp.hpp).
	// One chirp is active at a time; the selected axis is swept while the others are held.
	enum ChirpMode {
		CHIRP_OFF = 0,
		CHIRP_CYCLIC_PITCH,    // sweep body PITCH  -> symmetric cyclic
		CHIRP_CYCLIC_YAW,      // sweep body YAW    -> differential cyclic
		CHIRP_COLLECTIVE,      // sweep collective pitch
		CHIRP_COLLECTIVE_ROLL, // sweep body ROLL   -> differential collective
		CHIRP_RPM              // sweep rotor RPM (motor command)
	};

	// Bypasses the incoming control setpoint: zeroes sp, injects the chirp onto the selected
	// axis, and returns the motor command (held rpm, or rpm+chirp in RPM mode) and the value
	// to add to collective pitch. Exposed for unit testing; updateSetpoint() calls it with the
	// hrt-derived elapsed time t.
	void applyChirp(float t, matrix::Vector<float, NUM_AXES> &sp, float &motor_cmd, float &collective_add);

private:
	float throttleSpoolupProgress();
	bool mainMotorEnaged();

	void updateParams() override;

	struct SaturationFlags {
		bool roll_pos;
		bool roll_neg;
		bool pitch_pos;
		bool pitch_neg;
		bool yaw_pos;
		bool yaw_neg;
		bool thrust_pos;
		bool thrust_neg;
	};
	static void setSaturationFlag(float coeff, bool &positive_flag, bool &negative_flag);

	struct ParamHandlesSwashPlate {
		param_t angle;
		param_t arm_length;
		param_t trim;
	};
	struct ParamHandles {
		ParamHandlesSwashPlate swash_plate_servos[NUM_SWASH_PLATE_SERVOS_MAX];
		param_t num_swash_plate_servos;
		param_t num_surface_servos;
		param_t throttle_curve[NUM_CURVE_POINTS];
		param_t pitch_curve[NUM_CURVE_POINTS];
		param_t phase;
		param_t rol_body_to_rotor[N_FLIGHT_CONFIG];
		param_t pit_body_to_rotor[N_FLIGHT_CONFIG];
		param_t yaw_body_to_rotor[N_FLIGHT_CONFIG];
		param_t thr_body_to_rotor[N_FLIGHT_CONFIG];
		param_t thr_body_to_rotor_trim[N_FLIGHT_CONFIG];
		param_t body_to_ail[N_FLIGHT_CONFIG];
		param_t body_to_ele[N_FLIGHT_CONFIG];
		param_t body_to_ele_trim[N_FLIGHT_CONFIG];
		param_t krpm[N_FLIGHT_CONFIG];
		param_t col_min[N_FLIGHT_CONFIG];
		param_t col_max[N_FLIGHT_CONFIG];
		param_t cyc_lim[N_FLIGHT_CONFIG];
		param_t dir;
		param_t spoolup_time;
		param_t surface_trim[NUM_SURFACE_SERVOS_MAX];
		param_t calmode;
		param_t chirp_mode;
		param_t chirp_amp;
		param_t chirp_total_time;
		param_t chirp_order;
		param_t chirp_freq_init;
		param_t chirp_freq_final;
		param_t chirp_rpm;
	};
	ParamHandles _param_handles{};

	Geometry _geometry{};

	int _first_swash_plate_servo_index{};
	int _first_surface_servo_index{};

	uORB::Subscription _vehicle_thrust_setpoint_sub{ORB_ID(vehicle_thrust_setpoint)}; // <-- TODO : hacking this message for convenience; make a custom tailsitter_allocation message?
	uORB::Subscription _vehicle_land_detected_sub{ORB_ID(vehicle_land_detected)};
	int _flight_config = FlightConfigs::HOVER;
	int _flight_config_last = FlightConfigs::HOVER;
	float _surf_blnd = 1.f; // 0 = use last config, 1 = use new config
	float _swsh_blnd = 1.f; // 0 = use last config, 1 = use new config
	float blendParam(float *x,float blnd) {return blnd*x[_flight_config] + (1.f-blnd)*x[_flight_config_last];}
	void updateConfig(void);
	float _rol_body_to_rotor;
	float _pit_body_to_rotor;
	float _yaw_body_to_rotor;
	float _thr_body_to_rotor;
	float _thr_body_to_rotor_trim;
	float _body_to_ail;
	float _body_to_ele;
	float _body_to_ele_trim;
	float _krpm;
	float _col_min;
	float _col_max;
	float _cyc_lim;
	int _calmode = 0;
	bool _islanded = false;

	SaturationFlags _saturation_flags;

	// Throttle spoolup state
	uORB::Subscription _vehicle_status_sub{ORB_ID(vehicle_status)};
	bool _armed{false};
	uint64_t _armed_time{0};

	uORB::Subscription _parameter_update_sub{ORB_ID(parameter_update)};
	uORB::Subscription _manual_control_switches_sub{ORB_ID(manual_control_switches)};
	bool _main_motor_engaged{true};

	// Chirp injection state
	Chirp _chirp{};
	int32_t _chirp_mode{CHIRP_OFF};
	float _chirp_rpm{0.f};
	uint64_t _chirp_start_time{0};
	bool _chirp_started{false};
};
