# Common bench/SITL params applied before every chirp run.
# Purpose: keep the vehicle ARMED for the whole sweep without RC / GPS / data link,
# so the one-shot chirp can run to completion on the ground.
# (CA_AIRFRAME 11, SDLOG_MODE 0, SDLOG_PROFILE 2065 and CBRK_SUPPLY_CHK are already
#  set by the 1069_gazebo-classic_twinrotor_tailsitter airframe, so they are not repeated here.)
param set NAV_RCL_ACT 0
param set NAV_DLL_ACT 0
param set COM_RCL_EXCEPT 7
param set COM_ARM_WO_GPS 1
# Disable the airspeed sensor preflight check (no airspeed sensor on the SITL bench).
param set CBRK_AIRSPD_CHK 162128
# Don't auto-disarm on the ground / while not taking off, so the full sweep runs.
param set COM_DISARM_LAND -1
param set COM_DISARM_PRFLT -1
