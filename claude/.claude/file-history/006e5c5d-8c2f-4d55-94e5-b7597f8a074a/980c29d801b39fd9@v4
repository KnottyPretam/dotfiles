ActuatorEffectivenessTwinRotorTailsitter::ActuatorEffectivenessTwinRotorTailsitter(ModuleParams *parent)
	: ModuleParams(parent)
{
	for (int i = 0; i < NUM_SWASH_PLATE_SERVOS_MAX; ++i) {
		char buffer[17];
		snprintf(buffer, sizeof(buffer), "CA_SP0_ANG%u", i);
		_param_handles.swash_plate_servos[i].angle = param_find(buffer);
		snprintf(buffer, sizeof(buffer), "CA_SP0_ARM_L%u", i);
		_param_handles.swash_plate_servos[i].arm_length = param_find(buffer);
		snprintf(buffer, sizeof(buffer), "CA_SV_CS%u_TRIM", i);
		_param_handles.swash_plate_servos[i].trim = param_find(buffer);
	}
	for (int i = 0; i < NUM_SURFACE_SERVOS_MAX; ++i){
		char buffer[17];
		snprintf(buffer, sizeof(buffer), "CA_SV_CS%u_TRIM", i + NUM_SWASH_PLATE_SERVOS_MAX);
		_param_handles.surface_trim[i] = param_find(buffer);
	}

	_param_handles.num_swash_plate_servos = param_find("CA_SP0_COUNT");
	_param_handles.num_surface_servos = param_find("CA_TWIN_SV_COUNT");

	for (int i = 0; i < NUM_CURVE_POINTS; ++i) {
		char buffer[17];
		snprintf(buffer, sizeof(buffer), "CA_HELI_THR_C%u", i);
		_param_handles.throttle_curve[i] = param_find(buffer);
		snprintf(buffer, sizeof(buffer), "CA_HELI_PITCH_C%u", i);
		_param_handles.pitch_curve[i] = param_find(buffer);
	}
	for (int i = 0; i < N_FLIGHT_CONFIG; ++i) {
		char buffer[24];

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2R_R", i);
		_param_handles.rol_body_to_rotor[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2R_P", i);

		_param_handles.pit_body_to_rotor[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2R_Y", i);
		_param_handles.yaw_body_to_rotor[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2R_Z", i);
		_param_handles.thr_body_to_rotor[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2R_Z_0", i);
		_param_handles.thr_body_to_rotor_trim[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2A", i);
		_param_handles.body_to_ail[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2E", i);
		_param_handles.body_to_ele[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_B2E_0", i);
		_param_handles.body_to_ele_trim[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_KRPM", i);
		_param_handles.krpm[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_COL_MIN", i);
		_param_handles.col_min[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_COL_MAX", i);
		_param_handles.col_max[i] = param_find(buffer);

		snprintf(buffer, sizeof(buffer), "CA_TWIN%u_CYC_LIM", i);
		_param_handles.cyc_lim[i] = param_find(buffer);
	}

	_param_handles.phase = param_find("CA_HELI_PHASE");
	_param_handles.dir = param_find("CA_TWIN_DIR");
	_param_handles.spoolup_time = param_find("COM_SPOOLUP_TIME");
	_param_handles.calmode = param_find("CA_CALMODE");

	_param_handles.chirp_mode = param_find("CA_CHIRP_MODE");
	_param_handles.chirp_amp = param_find("CA_CHIRP_AMP");
	_param_handles.chirp_total_time = param_find("CA_CHIRP_T");
	_param_handles.chirp_order = param_find("CA_CHIRP_ORD");
	_param_handles.chirp_freq_init = param_find("CA_CHIRP_F0");
	_param_handles.chirp_freq_final = param_find("CA_CHIRP_F1");
	_param_handles.chirp_rpm = param_find("CA_CHIRP_RPM");

	updateParams();
}

void ActuatorEffectivenessTwinRotorTailsitter::updateParams()
{
	ModuleParams::updateParams();

	int32_t count = 0;

	if (param_get(_param_handles.num_swash_plate_servos, &count) != 0) {
		PX4_ERR("param_get failed");
		return;
	}

	_geometry.num_swash_plate_servos = math::constrain((int)count, 3, NUM_SWASH_PLATE_SERVOS_MAX);
	param_get(_param_handles.num_surface_servos, &count);
	_geometry.num_surface_servos = math::constrain((int)count, 0, NUM_SURFACE_SERVOS_MAX);

	for (int i = 0; i < _geometry.num_swash_plate_servos; ++i) {
		float angle_deg{};
		param_get(_param_handles.swash_plate_servos[i].angle, &angle_deg);
		_geometry.swash_plate_servos[i].angle = math::radians(angle_deg);
		param_get(_param_handles.swash_plate_servos[i].arm_length, &_geometry.swash_plate_servos[i].arm_length);
		param_get(_param_handles.swash_plate_servos[i].trim, &_geometry.swash_plate_servos[i].trim);
	}

	for (int i = 0; i < NUM_CURVE_POINTS; ++i) {
		param_get(_param_handles.throttle_curve[i], &_geometry.throttle_curve[i]);
		param_get(_param_handles.pitch_curve[i], &_geometry.pitch_curve[i]);
	}

	for (int i = 0; i < _geometry.num_surface_servos; ++i) {
		param_get(_param_handles.surface_trim[i], &_geometry.surface_trim[i]);
	}

	for (int i = 0; i < N_FLIGHT_CONFIG; ++i) {
		param_get(_param_handles.rol_body_to_rotor[i], &_geometry.rol_body_to_rotor[i]);
		param_get(_param_handles.pit_body_to_rotor[i], &_geometry.pit_body_to_rotor[i]);
		param_get(_param_handles.yaw_body_to_rotor[i], &_geometry.yaw_body_to_rotor[i]);
		param_get(_param_handles.thr_body_to_rotor[i], &_geometry.thr_body_to_rotor[i]);
		param_get(_param_handles.thr_body_to_rotor_trim[i], &_geometry.thr_body_to_rotor_trim[i]);
		param_get(_param_handles.body_to_ail[i], &_geometry.body_to_ail[i]);
		param_get(_param_handles.body_to_ele[i], &_geometry.body_to_ele[i]);
		param_get(_param_handles.body_to_ele_trim[i], &_geometry.body_to_ele_trim[i]);
		param_get(_param_handles.krpm[i], &_geometry.krpm[i]);
		param_get(_param_handles.col_min[i], &_geometry.col_min[i]);
		param_get(_param_handles.col_max[i], &_geometry.col_max[i]);
		param_get(_param_handles.cyc_lim[i], &_geometry.cyc_lim[i]);
	}

	param_get(_param_handles.phase, &_geometry.phase);
	_geometry.phase = math::radians(_geometry.phase);
	param_get(_param_handles.spoolup_time, &_geometry.spoolup_time);
	int32_t r_dir = 0;
	param_get(_param_handles.dir, &r_dir);
	_geometry.yaw_sign = (r_dir == 1) ? -1.f : 1.f;
	param_get(_param_handles.calmode, (int32_t*) &_calmode);

	// Chirp (system identification) configuration
	const int32_t prev_chirp_mode = _chirp_mode;
	float chirp_amp = 0.f;
	float chirp_total_time = 0.f;
	float chirp_order = 1.f;
	float chirp_freq_init = 0.f;
	float chirp_freq_final = 0.f;
	param_get(_param_handles.chirp_mode, &_chirp_mode);
	param_get(_param_handles.chirp_amp, &chirp_amp);
	param_get(_param_handles.chirp_total_time, &chirp_total_time);
	param_get(_param_handles.chirp_order, &chirp_order);
	param_get(_param_handles.chirp_freq_init, &chirp_freq_init);
	param_get(_param_handles.chirp_freq_final, &chirp_freq_final);
	param_get(_param_handles.chirp_rpm, &_chirp_rpm);
	_chirp.init(chirp_freq_init, chirp_freq_final, chirp_order, chirp_total_time, chirp_amp);

	// restart the one-shot sweep whenever the chirp is enabled/switched
	if (_chirp_mode != prev_chirp_mode) {
		_chirp_started = false;
	}
}

bool
ActuatorEffectivenessTwinRotorTailsitter::getEffectivenessMatrix(Configuration &configuration,
		EffectivenessUpdateReason external_update)
{
	if (external_update == EffectivenessUpdateReason::NO_EXTERNAL_UPDATE) {
		return false;
	}

	// Motors. As the allocation is non-linear, we use updateSetpoint() instead of the matrix
	configuration.addActuator(ActuatorType::MOTORS, Vector3f{}, Vector3f{});
	configuration.addActuator(ActuatorType::MOTORS, Vector3f{}, Vector3f{});

	// N swash plate servos
	_first_swash_plate_servo_index = configuration.num_actuators_matrix[0];
	for (int i = 0; i < _geometry.num_swash_plate_servos; ++i) {
		configuration.addActuator(ActuatorType::SERVOS, Vector3f{}, Vector3f{});
		configuration.trim[configuration.selected_matrix](i) = _geometry.swash_plate_servos[i].trim;
	}

	// elevon servos
	_first_surface_servo_index = configuration.num_actuators_matrix[0];
	for (int i = 0; i < _geometry.num_surface_servos; ++i) {
		configuration.addActuator(ActuatorType::SERVOS, Vector3f{}, Vector3f{});
		configuration.trim[configuration.selected_matrix](i + _geometry.num_swash_plate_servos) = _geometry.surface_trim[i];
	}

	return true;
}

void ActuatorEffectivenessTwinRotorTailsitter::updateSetpoint(const matrix::Vector<float, NUM_AXES> &control_sp,
		int matrix_index, ActuatorVector &actuator_sp, const matrix::Vector<float, NUM_ACTUATORS> &actuator_min,
		const matrix::Vector<float, NUM_ACTUATORS> &actuator_max)
{
	parameter_update_s parameter_update;
	if (_parameter_update_sub.update(&parameter_update)) {
		updateParams();
	}
	vehicle_land_detected_s vld;
	if (_vehicle_land_detected_sub.update(&vld)){
		_islanded = vld.landed;
	}

	vehicle_status_s vehicle_status;
	if (_vehicle_status_sub.update(&vehicle_status)) {
		_armed = vehicle_status.arming_state == vehicle_status_s::ARMING_STATE_ARMED;
		_armed_time = vehicle_status.armed_time;
	}

	_saturation_flags = {};

	// Chirp injection (system identification): replace the incoming control setpoint with a
	// swept-frequency signal on the selected axis, bypassing the MC controllers.
	matrix::Vector<float, NUM_AXES> actBench_sp = control_sp;
	float collective_add = 0.f;
	float motor_cmd = 0.f;
	bool motor_override = false;

	if (_chirp_mode != CHIRP_OFF) {
		if (_armed) {
			if (!_chirp_started) {
				_chirp_start_time = hrt_absolute_time();
				_chirp_started = true;
			}

			const float t = (hrt_absolute_time() - _chirp_start_time) / 1e6f;
			applyChirp(t, actBench_sp, motor_cmd, collective_add);
			motor_override = true;

		} else {
			// re-arm replays the one-shot sweep from the start
			_chirp_started = false;
		}
	}

	// throttle curve
	const float throttle = motor_override
			       ? motor_cmd
			       : math::interpolateN(-actBench_sp(ControlAxis::THRUST_Z), _geometry.throttle_curve) * throttleSpoolupProgress() * _krpm;
	const float collective_pitch = math::interpolateN(-actBench_sp(ControlAxis::THRUST_Z), _geometry.pitch_curve) + collective_add;

	// actuator mapping
	actuator_sp(0) = mainMotorEnaged() ? throttle : NAN;
	actuator_sp(1) = mainMotorEnaged() ? throttle : NAN;

	// Saturation check for yaw
	if (actuator_sp(1) < actuator_min(1)) {
		setSaturationFlag(_geometry.yaw_sign, _saturation_flags.yaw_neg, _saturation_flags.yaw_pos);

	} else if (actuator_sp(1) > actuator_max(1)) {
		setSaturationFlag(_geometry.yaw_sign, _saturation_flags.yaw_pos, _saturation_flags.yaw_neg);
	}

	updateConfig(); // updates mixing parameters based on flight configuration
	for (int i = 0; i < _geometry.num_swash_plate_servos; i++) {
		// convert vehicle control to rotor control - assumes two identical rotors, symmetric about x-z plane, pointing up
		// swash 0 = left = servos 0-2, swash 1 = right = servos 3-5
		float r_sign = (i < 3) ? 1 : -1; // left = positive, right = negative
		float r_roll = 0.f;
		float r_pitch = -_pit_body_to_rotor*actBench_sp(ControlAxis::PITCH) + r_sign*_yaw_body_to_rotor*actBench_sp(ControlAxis::YAW);
		float r_coll = _thr_body_to_rotor_trim + _thr_body_to_rotor*collective_pitch + r_sign*_rol_body_to_rotor*actBench_sp(ControlAxis::ROLL);

		// apply swashplate limits
		r_roll = math::constrain(r_roll, -_cyc_lim, +_cyc_lim);
		r_pitch = math::constrain(r_pitch, -_cyc_lim, +_cyc_lim);
		r_coll = math::constrain(r_coll, _col_min, _col_max);

		// calculate actuator setpoint
		float roll_coeff = r_sign * sinf(_geometry.swash_plate_servos[i].angle - _geometry.phase) * _geometry.swash_plate_servos[i].arm_length;
		float pitch_coeff = cosf(_geometry.swash_plate_servos[i].angle - _geometry.phase) * _geometry.swash_plate_servos[i].arm_length;
		actuator_sp(_first_swash_plate_servo_index + i) = r_coll
				+ r_pitch * pitch_coeff
				- r_roll * roll_coeff
				+ _geometry.swash_plate_servos[i].trim;

		// Saturation check for roll & pitch
		if (actuator_sp(_first_swash_plate_servo_index + i) < actuator_min(_first_swash_plate_servo_index + i)) {
			setSaturationFlag(roll_coeff, _saturation_flags.roll_pos, _saturation_flags.roll_neg);
			setSaturationFlag(pitch_coeff, _saturation_flags.pitch_neg, _saturation_flags.pitch_pos);

		} else if (actuator_sp(_first_swash_plate_servo_index + i) > actuator_max(_first_swash_plate_servo_index + i)) {
			setSaturationFlag(roll_coeff, _saturation_flags.roll_neg, _saturation_flags.roll_pos);
			setSaturationFlag(pitch_coeff, _saturation_flags.pitch_pos, _saturation_flags.pitch_neg);
		}
	}

	for (int i = 0; i < _geometry.num_surface_servos; i++) {
		// convert vehicle control to elevon control
		// 0 = left, 1 = right
		float r_sign = (i < 1) ? 1 : -1; // left = positive, right = negative
		actuator_sp(_first_surface_servo_index + i) = _body_to_ele_trim + r_sign*_body_to_ail*actBench_sp(ControlAxis::YAW) + _body_to_ele*actBench_sp(ControlAxis::PITCH) + _geometry.surface_trim[i];
	}
}

void ActuatorEffectivenessTwinRotorTailsitter::applyChirp(float t, matrix::Vector<float, NUM_AXES> &sp,
		float &motor_cmd, float &collective_add)
{
	const float c = _chirp.finished(t) ? 0.f : _chirp.update(t);

	sp.setAll(0.f);         // bypass the MC controllers
	collective_add = 0.f;
	motor_cmd = _chirp_rpm; // hold the rotor at the configured speed

	switch (_chirp_mode) {
	case CHIRP_CYCLIC_PITCH:    sp(ControlAxis::PITCH) = c; break;
	case CHIRP_CYCLIC_YAW:      sp(ControlAxis::YAW)   = c; break;
	case CHIRP_COLLECTIVE_ROLL: sp(ControlAxis::ROLL)  = c; break;
	case CHIRP_COLLECTIVE:      collective_add = c;         break;
	case CHIRP_RPM:             motor_cmd = _chirp_rpm + c; break;
	default: break;
	}
}

// set mixing parameters based on configuration
void ActuatorEffectivenessTwinRotorTailsitter::updateConfig()
{
	// get tailsitter allocation configuration
	vehicle_thrust_setpoint_s tailsitter_allocation;
	if (_vehicle_thrust_setpoint_sub.update(&tailsitter_allocation)) {
		_flight_config = tailsitter_allocation.flight_config;
		_flight_config_last = tailsitter_allocation.flight_config_last;
		_surf_blnd = ((float)tailsitter_allocation.surf_blend_100)/100; // 0 - 1
		_swsh_blnd = ((float)tailsitter_allocation.swsh_blend_100)/100; // 0 - 1
	}
	// on ground calibration overrride
	if(_islanded && _calmode > 0){
		// squash all except trims
		_geometry.rol_body_to_rotor[_flight_config] = 0.f;
		_geometry.pit_body_to_rotor[_flight_config] = 0.f;
		_geometry.yaw_body_to_rotor[_flight_config] = 0.f;
		_geometry.thr_body_to_rotor[_flight_config] = 0.f;
		_geometry.body_to_ail[_flight_config] = 0.f;
		_geometry.body_to_ele[_flight_config] = 0.f;
	}
	// blend parameters based on configuration
	if (_swsh_blnd >= 1.f && _surf_blnd >= 1.f) {
		_rol_body_to_rotor = _geometry.rol_body_to_rotor[_flight_config];
		_pit_body_to_rotor = _geometry.pit_body_to_rotor[_flight_config];
		_yaw_body_to_rotor = _geometry.yaw_body_to_rotor[_flight_config];
		_thr_body_to_rotor = _geometry.thr_body_to_rotor[_flight_config];
		_thr_body_to_rotor_trim = _geometry.thr_body_to_rotor_trim[_flight_config];
		_body_to_ail = _geometry.body_to_ail[_flight_config];
		_body_to_ele = _geometry.body_to_ele[_flight_config];
		_body_to_ele_trim = _geometry.body_to_ele_trim[_flight_config];
		_krpm = _geometry.krpm[_flight_config];
		_col_min = _geometry.col_min[_flight_config];
		_col_max = _geometry.col_max[_flight_config];
		_cyc_lim = _geometry.cyc_lim[_flight_config];
	} else {
		_rol_body_to_rotor = blendParam(_geometry.rol_body_to_rotor,_swsh_blnd);
		_pit_body_to_rotor = blendParam(_geometry.pit_body_to_rotor,_swsh_blnd);
		_yaw_body_to_rotor = blendParam(_geometry.yaw_body_to_rotor,_swsh_blnd);
		_thr_body_to_rotor = blendParam(_geometry.thr_body_to_rotor,_swsh_blnd);
		_thr_body_to_rotor_trim = blendParam(_geometry.thr_body_to_rotor_trim,_swsh_blnd);
		_body_to_ail = blendParam(_geometry.body_to_ail,_surf_blnd);
		_body_to_ele = blendParam(_geometry.body_to_ele,_surf_blnd);
		_body_to_ele_trim = blendParam(_geometry.body_to_ele_trim,_surf_blnd);
		_krpm = blendParam(_geometry.krpm,_swsh_blnd);
		_col_min = blendParam(_geometry.col_min,_swsh_blnd);
		_col_max = blendParam(_geometry.col_max,_swsh_blnd);
		_cyc_lim = blendParam(_geometry.cyc_lim,_swsh_blnd);
	}
}

bool ActuatorEffectivenessTwinRotorTailsitter::mainMotorEnaged()
{
	manual_control_switches_s manual_control_switches;

	if (_manual_control_switches_sub.update(&manual_control_switches)) {
		_main_motor_engaged = manual_control_switches.engage_main_motor_switch == manual_control_switches_s::SWITCH_POS_NONE
				      || manual_control_switches.engage_main_motor_switch == manual_control_switches_s::SWITCH_POS_ON;
	}

	return _main_motor_engaged;
}

float ActuatorEffectivenessTwinRotorTailsitter::throttleSpoolupProgress()
{
	// _armed / _armed_time are refreshed at the top of updateSetpoint()
	const float time_since_arming = (hrt_absolute_time() - _armed_time) / 1e6f;
	const float spoolup_progress = time_since_arming / _geometry.spoolup_time;

	if (_armed && spoolup_progress < 1.f) {
		return spoolup_progress;
	}

	return 1.f;
}


void ActuatorEffectivenessTwinRotorTailsitter::setSaturationFlag(float coeff, bool &positive_flag, bool &negative_flag)
{
	if (coeff > 0.f) {
		// A positive change in given axis will increase saturation
		positive_flag = true;

	} else if (coeff < 0.f) {
		// A negative change in given axis will increase saturation
		negative_flag = true;
	}
}

void ActuatorEffectivenessTwinRotorTailsitter::getUnallocatedControl(int matrix_index, control_allocator_status_s &status)
{

	// Note: the values '-1', '1' and '0' are just to indicate a negative,
	// positive or no saturation to the rate controller. The actual magnitude is not used.
	if (_saturation_flags.roll_pos) {
		status.unallocated_torque[0] = 1.f;

	} else if (_saturation_flags.roll_neg) {
		status.unallocated_torque[0] = -1.f;
	}

	if (_saturation_flags.pitch_pos) {
		status.unallocated_torque[1] = 1.f;

	} else if (_saturation_flags.pitch_neg) {
		status.unallocated_torque[1] = -1.f;
	}

	if (_saturation_flags.yaw_pos) {
		status.unallocated_torque[2] = 1.f;

	} else if (_saturation_flags.yaw_neg) {
		status.unallocated_torque[2] = -1.f;
	}

	if (_saturation_flags.thrust_pos) {
		status.unallocated_thrust[2] = 1.f;

	} else if (_saturation_flags.thrust_neg) {
		status.unallocated_thrust[2] = -1.f;
	}
}
