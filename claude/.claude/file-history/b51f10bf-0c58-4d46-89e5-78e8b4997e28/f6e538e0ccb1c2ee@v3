#!/usr/bin/env bash
set -e

# Repo to mount: first arg, else current dir. The path is identical inside and
# outside the container so compile_commands.json works with the host LSP (clangd).
PX4_HOST_REPO="$(cd "${1:-$PWD}" && pwd)"
export PX4_HOST_REPO

# Container/project name = the repo directory name (lowercased).
export PX4_CONTAINER_SUFFIX="$(basename "$PX4_HOST_REPO" | tr 'A-Z' 'a-z')"

DIR="${HOME}/tools/dev/docker_runner"
COMPOSE_FILE="${DIR}/docker-compose.dev.yaml"
REQS="${DIR}/px4_sitl_runner_requirements.txt"
DEVICE_OVERRIDE="${DIR}/.devices.override.yaml"
PROJECT_NAME="px4_${PX4_CONTAINER_SUFFIX}"

# Ensure the pip requirements path is a FILE: Docker silently creates a directory
# for a missing bind-mount source, which breaks `pip install -r`.
[ -f "$REQS" ] || touch "$REQS"

# Pass through only host devices that actually exist, so `docker compose up`
# doesn't fail on absent hardware (camera/serial).
DEVICE_LINES=""
for d in /dev/dri /dev/video0 /dev/ttyACM0; do
  [ -e "$d" ] && DEVICE_LINES+="      - \"$d:$d\""$'\n'
done

COMPOSE_ARGS=(-f "$COMPOSE_FILE")
if [ -n "$DEVICE_LINES" ]; then
  {
    echo "services:"
    echo "  px4_dev:"
    echo "    devices:"
    printf '%s' "$DEVICE_LINES"
  } > "$DEVICE_OVERRIDE"
  COMPOSE_ARGS+=(-f "$DEVICE_OVERRIDE")
fi

# Hard guard: the host 145xx range is reserved for real flight test / HIL with
# MAVLink. Refuse to launch if the merged config would expose those ports on the
# host (either via host networking or a 145xx port publish).
CONFIG="$(docker compose -p "$PROJECT_NAME" "${COMPOSE_ARGS[@]}" config 2>/dev/null)"

if grep -qE '^[[:space:]]*network_mode:[[:space:]]*"?host"?[[:space:]]*$' <<<"$CONFIG"; then
  echo "ERROR: this docker instance is trying to use host networking, which would put" >&2
  echo "       the container's MAVLink ports (145xx) directly on the host and collide" >&2
  echo "       with flight test / HIL. Aborting." >&2
  echo "       Keep 'network_mode: bridge', then retry the docker instance." >&2
  exit 1
fi

BAD_PORTS=""
for p in $(grep -E 'published:' <<<"$CONFIG" | sed -E 's/.*published:[[:space:]]*"?([0-9]+)"?.*/\1/'); do
  [ "$p" -ge 14500 ] 2>/dev/null && [ "$p" -le 14599 ] && BAD_PORTS+="$p "
done
if [ -n "$BAD_PORTS" ]; then
  echo "ERROR: this docker instance is trying to publish host port(s): ${BAD_PORTS}" >&2
  echo "       The 145xx range is reserved for flight test / HIL with MAVLink." >&2
  echo "       Remap to a shifted host range (e.g. 245xx -> container 145xx) and" >&2
  echo "       retry the docker instance." >&2
  exit 1
fi

docker compose -p "$PROJECT_NAME" "${COMPOSE_ARGS[@]}" up -d px4_dev
exec docker compose -p "$PROJECT_NAME" "${COMPOSE_ARGS[@]}" exec px4_dev bash
