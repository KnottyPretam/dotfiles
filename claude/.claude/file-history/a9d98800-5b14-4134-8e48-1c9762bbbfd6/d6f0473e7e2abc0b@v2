// Receive and queue a message for processing
void ms_vehicleData::processUpdate(const std::string& name, void* data)
{
    if(name == mINPUT_GCS)
    {
        stBuffer buffer = *static_cast<stBuffer*>(data);  
        stanag_primary_interface.input_message(buffer.buffer);

        mavlinkGCSInterface.input_message(buffer.buffer, buffer.size);
    }
    else if(name == mINPUT_AUTOPILOT)
    {
        stBuffer buffer = *static_cast<stBuffer*>(data);   
        autopilotInterface.input_message(buffer.buffer, buffer.size);
    }
    else if(name == mINPUT_GIMBAL)
    {
        stBuffer buffer = *static_cast<stBuffer*>(data);
        nighthawk_interface.input_message(buffer.buffer, buffer.size);
    }
    else if(name == mINPUT_MUNITION)
    {
        // munitionInterface.inputMessage(data);
    }   
    else if(name == mSTANAG_MESSAGE_ENCODED)
    {
        stBuffer buf = *static_cast<stBuffer*>(data);
        std::string cpp_string(mOUTPUT_GCS);
        notify(cpp_string, &buf);
    }   
    else if(name == mMAVLINK_MESSAGE_ENCODED)
    {
        stBuffer buf = *static_cast<stBuffer*>(data);
        std::string cpp_string(mOUTPUT_AUTOPILOT);
        notify(cpp_string, &buf);
    }     
    else if(name == mMAVLINK_GCS_MESSAGE_ENCODED)
    {
        stBuffer buf = *static_cast<stBuffer*>(data);
        std::string cpp_string(mOUTPUT_GCS);
        notify(cpp_string, &buf);
    }
    else if(name == mCOLIBRI_MESSAGE_ENCODED)
    {
        stBuffer buf = *static_cast<stBuffer*>(data);
        std::string cpp_string(mOUTPUT_GIMBAL);
        notify(cpp_string, &buf);
    }
}

