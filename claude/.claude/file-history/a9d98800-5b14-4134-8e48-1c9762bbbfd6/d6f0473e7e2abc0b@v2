{

}

void ms_vehicleData::createComponent(kw_observer* _manager)
{
    kw_component::createComponent(_manager);

    // Register Callbacks
    manager->addObserver(mINPUT_GCS, this);
    manager->addObserver(mINPUT_AUTOPILOT, this);
    manager->addObserver(mINPUT_GIMBAL, this);
    manager->addObserver(mINPUT_MUNITION, this);

    addMavlinkOutputObserver(this);
    addMavlinkGCSOutputObserver(this);
    stanag_primary_interface.addOutputObserver(this);
    nighthawk_interface.addOutputObserver(this);

    mavlinkGCSInterface.set_component_id(MAV_COMP_ID_AUTOPILOT1);

    autopilotInterface.set_component_id(MAV_COMP_ID_MISSIONPLANNER);
}

void ms_vehicleData::mainThread() // Runs a thread for this component
{
    while (running) 
    {
        // Check queue for data to process
        // Find Message name to call correct callback
        std::this_thread::sleep_for(std::chrono::seconds(1));
    }
}

void ms_vehicleData::addSTANAGObserver(const std::string& messageName, kw_observer* observer)
{
