double k =  0.01313028257522543792196524143472;

#pragma pack(push, 1)

struct __colibri_message_full_ack
{
    // =================================================
    // 0–2 : HEADER / RESERVED
    // =================================================
    uint8_t header1;
    uint8_t header2;
    uint8_t header3;

    // =================================================
    // 3 : HEADER / RESERVED
    // =================================================

    uint8_t camera_status;

    // =================================================
    // 4–17 : POINTING / TRACKING (16-bit values)
    // =================================================
    uint8_t fov_msb;            // 4
    uint8_t fov_lsb;            // 5

    uint8_t mech_roll_msb;      // 6
    uint8_t mech_roll_lsb;      // 7

    uint8_t mech_pitch_msb;     // 8
    uint8_t mech_pitch_lsb;     // 9

    uint8_t elec_x_msb;         // 10
    uint8_t elec_x_lsb;         // 11

    uint8_t elec_y_msb;         // 12
    uint8_t elec_y_lsb;         // 13

    uint8_t los_rate_x_msb;     // 14
    uint8_t los_rate_x_lsb;     // 15

    uint8_t los_rate_y_msb;     // 16
    uint8_t los_rate_y_lsb;     // 17

    // =================================================
    // 19–30 : IMU (ACCEL + GYRO + COMPASS)
    // =================================================

    // Accelerometer
    uint8_t accel_x_msb;        // 19
    uint8_t accel_x_lsb;        // 20

    uint8_t accel_y_msb;        // 21
    uint8_t accel_y_lsb;        // 22

    uint8_t accel_z_msb;        // 23
    uint8_t accel_z_lsb;        // 24

    // Gyro
    uint8_t gyro_x_msb;         // 25
    uint8_t gyro_x_lsb;         // 26

    uint8_t gyro_y_msb;         // 27
    uint8_t gyro_y_lsb;         // 28

    uint8_t gyro_z_msb;         // 29
    uint8_t gyro_z_lsb;         // 30 

    // Gyro Angular rate full scale (FF) speed +/-682.66(6) deg/sec range

    // =================================================
    // 31–36 : COMPASS
    // =================================================

    uint8_t compass_x_msb;      // 31
    uint8_t compass_x_lsb;      // 32

    uint8_t compass_y_msb;      // 33
    uint8_t compass_y_lsb;      // 34

    uint8_t compass_z_msb;      // 35
    uint8_t compass_z_lsb;      // 36

    // =================================================
    // 37–38 : TIME FROM PPS (10kHz counter)
    // =================================================
    uint8_t time_from_pps_msb; // 37
    uint8_t time_from_pps_lsb; // 38 Free running counter 10KHz (100us) tick.
                               //    The counter stuck at 0xFFFF if there is no 1PPS signal

    // =================================================
    // 39–40 : SYSTEM STATUS
    // =================================================
    uint8_t sys_status_msb;     // 39 bit flags
    uint8_t sys_status_lsb;     // 40 error code

    // =================================================
    // 41–42 : GIMBAL TEMPERATURE
    // =================================================
    uint8_t gimbal_temp_msb;    // 41
    uint8_t gimbal_temp_lsb;    // 42 Degrees*100

    // =================================================
    // 43–45 : CAMERA / FIRMWARE
    // =================================================
    uint8_t camera_type;
    uint8_t firmware_msb;
    uint8_t firmware_lsb;

    // =================================================
    // 46–51 : MECHANICAL / LRF / TIMING
    // =================================================
    uint8_t mech_yaw_msb;
    uint8_t mech_yaw_lsb;

    uint8_t lrf_msb;
    uint8_t lrf_lsb;

    uint8_t time_tag_msb;
    uint8_t time_tag_lsb;

    // =================================================
    // 52 : RESERVED / BOUNDARY
    // =================================================
    uint8_t b52;

    // =================================================
    // 53–58 : MECHANICAL OFFSETS
    // =================================================
    uint8_t pitch_offset_msb;
    uint8_t pitch_offset_lsb;

    uint8_t roll_offset_msb;
    uint8_t roll_offset_lsb;

    uint8_t yaw_offset_msb;
    uint8_t yaw_offset_lsb;

    // =================================================
    // 59–62 : CORRELATOR / IR SATURATION (RAW ARRAY)
    // =================================================
    uint8_t correlator_ir_sat_0;
    uint8_t correlator_ir_sat_1;
    uint8_t correlator_ir_sat_2;
    uint8_t correlator_ir_sat_3;

    // =================================================
    // 63 : CHECK SUM
    // =================================================
    uint8_t checksum;
};

#pragma pack(pop)

//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//Checksum Functions
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

static inline bool calculate_checksum( uint8_t* buffer, unsigned int checksum)
{
    unsigned int calculated_checksum;

    if(calculated_checksum == checksum)
        return true;
    else
        return false;
}

static inline bool validate_checksum( uint8_t* buffer, unsigned int checksum)
{
    unsigned int calculated_checksum;

    if(calculated_checksum == checksum)
        return true;
    else
        return false;
}

//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//Colibri Encode/Decode
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

static inline bool colibri_control_encode(__colibri_message_command _message, uint8_t* buffer )
{
    int index = 0;

    pack(&buffer[index], _message.header1); index += 8;                    // 0
    pack(&buffer[index], _message.header2); index += 8;                    // 1
    pack(&buffer[index], _message.header3); index += 8;                    // 2
    pack(&buffer[index], _message.correlator_byte_0); index += 8;          // 3
    pack(&buffer[index], _message.correlator_byte_1); index += 8;          // 4
    pack(&buffer[index], _message.correlator_byte_2); index += 8;          // 5
    pack(&buffer[index], _message.correlator_byte_3); index += 8;          // 6

    pack(&buffer[index], _message.camera_status); index += 8;              // 3
   
    pack(&buffer[index], _message.stabilization); index += 8;              // 4
    pack(&buffer[index], _message.thermal_channel_color); index += 8;      // 5
    pack(&buffer[index], _message.safety_switch); index += 8;              // 6
    pack(&buffer[index], _message.illuminator_settings); index += 8;       // 7

    pack(&buffer[index], _message.focus_settings); index += 8;             // 8

    pack(&buffer[index], _message.correlator_reserved); index += 8;        // 9
    pack(&buffer[index], _message.correlator_byte_0); index += 8;          // 10
    pack(&buffer[index], _message.correlator_byte_1); index += 8;          // 11
    pack(&buffer[index], _message.correlator_byte_2); index += 8;          // 12
    pack(&buffer[index], _message.correlator_byte_3); index += 8;          // 13

    pack(&buffer[index], _message.position_lsb); index += 8;               // 14
    pack(&buffer[index], _message.pitch_msb); index += 8;                  // 15
    pack(&buffer[index], _message.roll_msb); index += 8;                   // 16
    pack(&buffer[index], _message.yaw_msb); index += 8;                    // 17

    pack(&buffer[index], _message.pos_lsb); index += 8;                    // 18
    

    pack(&buffer[index], _message.checksum); index += 8;                   // 19

    return calculate_checksum( buffer, _message.checksum);

}

static inline bool colibri_full_ack_decode(__colibri_message_full_ack &_message, uint8_t* buffer )
{
    int index = 0;

     // =================================================
    // HEADER
    // =================================================
    unpack(&buffer[index], _message.header1); index += 1;
    unpack(&buffer[index], _message.header2); index += 1;
    unpack(&buffer[index], _message.header3); index += 1;
    unpack(&buffer[index], _message.camera_status); index += 1;

    // =================================================
    // POINTING / TRACKING (MSB/LSB pairs)
    // =================================================
    unpack(&buffer[index], _message.fov_msb); index += 1;
    unpack(&buffer[index], _message.fov_lsb); index += 1;

    unpack(&buffer[index], _message.mech_roll_msb); index += 1;
    unpack(&buffer[index], _message.mech_roll_lsb); index += 1;

    unpack(&buffer[index], _message.mech_pitch_msb); index += 1;
    unpack(&buffer[index], _message.mech_pitch_lsb); index += 1;

    unpack(&buffer[index], _message.elec_x_msb); index += 1;
    unpack(&buffer[index], _message.elec_x_lsb); index += 1;

    unpack(&buffer[index], _message.elec_y_msb); index += 1;
    unpack(&buffer[index], _message.elec_y_lsb); index += 1;

    unpack(&buffer[index], _message.los_rate_x_msb); index += 1;
    unpack(&buffer[index], _message.los_rate_x_lsb); index += 1;

    unpack(&buffer[index], _message.los_rate_y_msb); index += 1;
    unpack(&buffer[index], _message.los_rate_y_lsb); index += 1;

    // =================================================
    // IMU
    // =================================================
    unpack(&buffer[index], _message.accel_x_msb); index += 1;
    unpack(&buffer[index], _message.accel_x_lsb); index += 1;

    unpack(&buffer[index], _message.accel_y_msb); index += 1;
    unpack(&buffer[index], _message.accel_y_lsb); index += 1;

    unpack(&buffer[index], _message.accel_z_msb); index += 1;
    unpack(&buffer[index], _message.accel_z_lsb); index += 1;

    unpack(&buffer[index], _message.gyro_x_msb); index += 1;
    unpack(&buffer[index], _message.gyro_x_lsb); index += 1;

    unpack(&buffer[index], _message.gyro_y_msb); index += 1;
    unpack(&buffer[index], _message.gyro_y_lsb); index += 1;

    unpack(&buffer[index], _message.gyro_z_msb); index += 1;
    unpack(&buffer[index], _message.gyro_z_lsb); index += 1;

    // =================================================
    // COMPASS
    // =================================================
    unpack(&buffer[index], _message.compass_x_msb); index += 1;
    unpack(&buffer[index], _message.compass_x_lsb); index += 1;

    unpack(&buffer[index], _message.compass_y_msb); index += 1;
    unpack(&buffer[index], _message.compass_y_lsb); index += 1;

    unpack(&buffer[index], _message.compass_z_msb); index += 1;
    unpack(&buffer[index], _message.compass_z_lsb); index += 1;

    // =================================================
    // TIME
    // =================================================
    unpack(&buffer[index], _message.time_from_pps_msb); index += 1;
    unpack(&buffer[index], _message.time_from_pps_lsb); index += 1;

    // =================================================
    // SYSTEM STATUS
    // =================================================
    unpack(&buffer[index], _message.sys_status_msb); index += 1;
    unpack(&buffer[index], _message.sys_status_lsb); index += 1;

    // =================================================
    // TEMP
    // =================================================
    unpack(&buffer[index], _message.gimbal_temp_msb); index += 1;
    unpack(&buffer[index], _message.gimbal_temp_lsb); index += 1;

    // =================================================
    // CAMERA / FW
    // =================================================
    unpack(&buffer[index], _message.camera_type); index += 1;
    unpack(&buffer[index], _message.firmware_msb); index += 1;
    unpack(&buffer[index], _message.firmware_lsb); index += 1;

    // =================================================
    // MECH / LRF / TIME TAG
    // =================================================
    unpack(&buffer[index], _message.mech_yaw_msb); index += 1;
    unpack(&buffer[index], _message.mech_yaw_lsb); index += 1;

    unpack(&buffer[index], _message.lrf_msb); index += 1;
    unpack(&buffer[index], _message.lrf_lsb); index += 1;

    unpack(&buffer[index], _message.time_tag_msb); index += 1;
    unpack(&buffer[index], _message.time_tag_lsb); index += 1;

    // =================================================
    // RESERVED
    // =================================================
    unpack(&buffer[index], _message.b52); index += 1;

    // =================================================
    // OFFSETS
    // =================================================
    unpack(&buffer[index], _message.pitch_offset_msb); index += 1;
    unpack(&buffer[index], _message.pitch_offset_lsb); index += 1;

    unpack(&buffer[index], _message.roll_offset_msb); index += 1;
    unpack(&buffer[index], _message.roll_offset_lsb); index += 1;

    unpack(&buffer[index], _message.yaw_offset_msb); index += 1;
    unpack(&buffer[index], _message.yaw_offset_lsb); index += 1;

    // =================================================
    // CORRELATOR
    // =================================================
    unpack(&buffer[index], _message.correlator_ir_sat_0); index += 1;
    unpack(&buffer[index], _message.correlator_ir_sat_1); index += 1;
    unpack(&buffer[index], _message.correlator_ir_sat_2); index += 1;
    unpack(&buffer[index], _message.correlator_ir_sat_3); index += 1;

    // =================================================
    // CHECKSUM
    // =================================================
    unpack(&buffer[index], _message.checksum); index += 1;


    return validate_checksum( buffer, _message.checksum);
}

static inline bool colibri_ack_decode(__colibri_message_ack &_message, uint8_t* buffer )
{
    int index = 0;

     // =================================================
    // HEADER
    // =================================================
    unpack(&buffer[index], _message.header1); index += 1;                  // 0
    unpack(&buffer[index], _message.header2); index += 1;                  // 1
    unpack(&buffer[index], _message.header3); index += 1;                  // 2
    unpack(&buffer[index], _message.camera_status); index += 1;            // 3

    // =================================================
    // POINTING / TRACKING (MSB/LSB pairs)
    // =================================================

    unpack(&buffer[index], _message.rollpitch_lsb_supp); index += 1;       // 4

    unpack(&buffer[index], _message.zoom); index += 1;                     // 5

    unpack(&buffer[index], _message.vsync); index += 1;                    // 6

    unpack(&buffer[index], _message.pitch_msb); index += 1;                // 7
    unpack(&buffer[index], _message.roll_msb); index += 1;                 // 8

    unpack(&buffer[index], _message.rollpitch_lsb_main); index += 1;       // 9

    unpack(&buffer[index], _message.x_report_msb); index += 1;             // 10
    unpack(&buffer[index], _message.y_report_msb); index += 1;             // 11

    unpack(&buffer[index], _message.xy_lsb); index += 1;                   // 12

    unpack(&buffer[index], _message.over_temp); index += 1;                // 13

    unpack(&buffer[index], _message.correlator_byte_0); index += 1;        // 14
    unpack(&buffer[index], _message.correlator_byte_1); index += 1;        // 15
    unpack(&buffer[index], _message.correlator_byte_2); index += 1;        // 16
    unpack(&buffer[index], _message.correlator_byte_3); index += 1;        // 17
    unpack(&buffer[index], _message.correlator_byte_4); index += 1;        // 18

    // =================================================
    // CHECKSUM
    // =================================================
    unpack(&buffer[index], _message.checksum); index += 1;                 // 19

    std::cout<<(_message.zoom);

    return validate_checksum( buffer, _message.checksum);
}

