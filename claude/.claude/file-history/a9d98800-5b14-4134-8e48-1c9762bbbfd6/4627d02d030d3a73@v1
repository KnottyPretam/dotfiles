//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//Camera Control Message Structure Variables [HOST2CAM]
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%


#pragma pack(push, 1)

struct __colibri_message_command
{
    // =================================================
    // 0–2 : HEADER 
    // =================================================
    uint8_t header1;
    uint8_t header2;
    uint8_t header3;   //Camera Control Mode 
                       //Note : 0xF7 or 0xF8 or 0xF9 or 0xFA – switches camera to 115,200bps automatic to 100Hz in a full ack mode.

    // =================================================
    // 3 : HEADER 
    // =================================================

    uint8_t camera_status;

    // =================================================
    // 4–17 : POINTING / TRACKING (16-bit values)
    // =================================================
    uint8_t stabilization;          // 4

    uint8_t thermal_channel_color;  // 5

    uint8_t safety_switch;          // 6 

    uint8_t illuminator_settings;   // 7

    uint8_t focus_settings;         // 8

    uint8_t correlator_reserved;    // 9

    uint8_t correlator_byte_0;     // 10
    uint8_t correlator_byte_1;     // 11
    uint8_t correlator_byte_2;     // 12
    uint8_t correlator_byte_3;     // 13

    uint8_t position_lsb;          // 14
    uint8_t pitch_msb;             // 15
    uint8_t roll_msb;              // 16
    uint8_t yaw_msb;               // 17 UNUSED

    uint8_t pos_lsb;               // 18

    // =================================================
    // 19 : CHECK SUM
    // =================================================
    uint8_t checksum;              // 19

};

#pragma pack(pop)

//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
//Camera Acknowledgement Message Structure Variables [CAM2HOST]
//%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%


#pragma pack(push, 1)

struct __colibri_message_ack
{
    // =================================================
    // 0–2 : HEADER / RESERVED
    // =================================================
    uint8_t header1;
    uint8_t header2;
    uint8_t header3;

    // =================================================
    // 3 : HEADER / RESERVED
    // =================================================

    uint8_t camera_status;

    // =================================================
    // 4–17 : POINTING / TRACKING (16-bit values)
    // =================================================
    uint8_t rollpitch_lsb_supp;          // 4 Roll/Pitch
    uint8_t zoom;            // 5 Zoom

    uint8_t vsync;      // 6 Num of Vertical syncs (since last CMD).
                        //This info is used for precise calculations of camera location.
                        //(legal values: 0-255).

    uint8_t pitch_msb;              // 7
    uint8_t roll_msb;               // 8
    uint8_t rollpitch_lsb_main;     // 9

    uint8_t x_report_msb;         // 10
    uint8_t y_report_msb;         // 11

    uint8_t xy_lsb;               // 12
    uint8_t over_temp;            // 13

    uint8_t correlator_byte_0;     // 14
    uint8_t correlator_byte_1;     // 15

    uint8_t correlator_byte_2;     // 16
    uint8_t correlator_byte_3;     // 17
    uint8_t correlator_byte_4;     // 18

    // =================================================
    // 19 : CHECK SUM
    // =================================================
    uint8_t checksum;

};

#pragma pack(pop)

