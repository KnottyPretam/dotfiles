cmake_minimum_required(VERSION 3.20)

project(ms_app)
set(MS_APP_NAME ${PROJECT_NAME})

set(CMAKE_MODULE_PATH ${CMAKE_MODULE_PATH} ${PROJECT_SOURCE_DIR}/cmake/) # Append directory

set(CMAKE_CXX_STANDARD 11)              # Set C++ version for compilation
set(CMAKE_CXX_STANDARD_REQUIRED ON)     # Require this version explicitly
set(CMAKE_CXX_EXTENSIONS OFF)           # Don't allow extensions to std C++ library
set(CMAKE_EXPORT_COMPILE_COMMANDS ON)   # Needed by clang-tidy

# Create an option to enable debug code
option(ENABLE_CLANG_TIDY "Enable Clang Tidy static code analysis" ON)

# Include the Tools.cmake module (clang-tidy commands)
include(BuildTools)

# build easyloggingpp library
if(NOT TARGET easyloggingpp)
    set(build_static_lib ON CACHE BOOL "Build easyloggingpp as a static library" FORCE)
endif()

# Define library sources
add_executable(${MS_APP_NAME}
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_app.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_communications.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_authorization.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_gimbalControl.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_munitionControl.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_vehicleControl.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_vehicleData.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_flight.cc
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_flightMavlink.cc            
            ${CMAKE_CURRENT_LIST_DIR}/src/ms_globals.cc
            )

# Add include directories to library target
target_include_directories( ${MS_APP_NAME} PUBLIC
                            ${CMAKE_CURRENT_LIST_DIR}/include
                            ${CMAKE_CURRENT_LIST_DIR}/../lib/kw_core/include
                            ${CMAKE_CURRENT_LIST_DIR}/../lib/stanag_4586/include
                            ${CMAKE_CURRENT_LIST_DIR}/../lib/mavlink/include
                            ${CMAKE_CURRENT_LIST_DIR}/../../Mavlink/c_library_v2
                            ${CMAKE_CURRENT_LIST_DIR}/../../Mavlink/c_library_v2/common                            
                            )

target_link_libraries( ${MS_APP_NAME}
                        PRIVATE ${CMAKE_CURRENT_LIST_DIR}/../lib/kw_core/build/libkw_core.a
                        PRIVATE ${CMAKE_CURRENT_LIST_DIR}/../lib/mavlink/build/libmavlink.a
                        PRIVATE ${CMAKE_CURRENT_LIST_DIR}/../lib/stanag_4586/build/libstanag_4586.a
                        )

# add clang-format to target; this will cause clang-tidy (static analysis) to run 
# before building the executable target
if(ENABLE_CLANG_TIDY)
    add_clangtidy_to_target(${MS_APP_NAME})
    #add_clangtidy_header_check(${MS_APP_NAME})
endif()

# Add test directory
add_subdirectory(test)