ms_gimbalControl::ms_gimbalControl(const std::string& componentName) : kw_component(componentName)
{
    std::memset(&cmd_template, 0, sizeof(cmd_template));
    cmd_template.header1 = COLIBRI_HDR1;
    cmd_template.header2 = COLIBRI_HDR2;
    cmd_template.header3 = COLIBRI_HDR3_FA_AUTOROLL;  // fast protocol, 3-axis auto-roll/yaw-stab

    // Rev 43 §5.5: pitch/roll MSB rate = 0x80 with LSB = 0 means zero rate command.
    cmd_template.pitch_msb = 0x80;
    cmd_template.roll_msb  = 0x80;
    cmd_template.yaw_msb   = 0x80;
}

ms_gimbalControl::~ms_gimbalControl() = default;

void ms_gimbalControl::createComponent(kw_observer* _manager)
{
    kw_component::createComponent(_manager);

    vehicleData->addNighthawkObserver(mCOLIBRI_ACK_FIXED, this);
    vehicleData->addNighthawkObserver(mCOLIBRI_ACK_FULL,  this);
}

void ms_gimbalControl::mainThread()
{
    while (running)
    {
        std::this_thread::sleep_for(std::chrono::seconds(1));
    }
}

