#ifndef MS_GIMBALCONTROL_H
#define MS_GIMBALCONTROL_H

#include "kw_component.h"
#include "ms_colibri_command_interface.h"
#include "ms_globals.h"

class ms_gimbalControl : public kw_component
{
public:
    ms_gimbalControl(const std::string& componentName);
    ~ms_gimbalControl();

    void createComponent(kw_observer* _outputObserver);

    void mainThread();

    void processUpdate(const std::string& name, void* data);

    // High-level Colibri commands. Each mutates cmd_template and immediately
    // emits a new 20-byte Host->Cam message via the colibri interface.
    void setMode(enColibriMode mode);
    void setChannel(enColibriChannel channel);
    void setRate(int16_t pitch_rate, int16_t roll_rate, int16_t yaw_rate);
    void setFOV(uint16_t deg_x10);
    void fireLRF(bool fire);

protected:
    void send_current_command();

    __colibri_message_command cmd_template{};
};

#endif
