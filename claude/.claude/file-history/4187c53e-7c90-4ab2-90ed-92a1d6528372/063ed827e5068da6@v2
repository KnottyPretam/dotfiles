# Makefile
# Makefile

.DEFAULT_GOAL := all

BIN_DIR := bin
PYTHON  := python3
SH      := bash

# Add Python scripts here, one per line.
PY_SCRIPTS := \
	dev/ulg_postProcess/codex/run_flight_dict.py \
	dev/mavLink/mavlink_shell.py \
	dev/imu_vibe/analyze_imu_vibration.py \
	dev/ulg_postProcess/claude/process_flight.py

# Add shell scripts here, one per line.
SH_SCRIPTS := \
	dev/docker_runner/devcon.sh

# Convert:
#   src/tools/foo.py -> bin/foo
#   scripts/admin/bar.py -> bin/bar
PY_BINS := $(foreach s,$(PY_SCRIPTS),$(BIN_DIR)/$(notdir $(basename $(s))))
SH_BINS := $(foreach s,$(SH_SCRIPTS),$(BIN_DIR)/$(notdir $(basename $(s))))
ALL_BINS := $(PY_BINS) $(SH_BINS)

.PHONY: all clean
all: $(ALL_BINS)

# Fail if two scripts would generate the same output name.
ifneq ($(words $(ALL_BINS)),$(words $(sort $(ALL_BINS))))
$(error Duplicate executable names detected in PY_SCRIPTS/SH_SCRIPTS)
endif

$(BIN_DIR):
	mkdir -p $@

define MAKE_PY_WRAPPER
$(BIN_DIR)/$(notdir $(basename $(1))): $(1) Makefile | $(BIN_DIR)
	@printf '%s\n' \
		'#!/bin/sh' \
		'exec "$(PYTHON)" "$(abspath $(1))" "$$$$@"' \
		> $$@
	@chmod 0755 $$@
endef

$(foreach script,$(PY_SCRIPTS),$(eval $(call MAKE_PY_WRAPPER,$(script))))

define MAKE_SH_WRAPPER
$(BIN_DIR)/$(notdir $(basename $(1))): $(1) Makefile | $(BIN_DIR)
	@printf '%s\n' \
		'#!/bin/sh' \
		'exec "$(SH)" "$(abspath $(1))" "$$$$@"' \
		> $$@
	@chmod 0755 $$@
endef

$(foreach script,$(SH_SCRIPTS),$(eval $(call MAKE_SH_WRAPPER,$(script))))

clean:
	rm -f -- $(ALL_BINS)
