cfg.np                  = 2;           % plant denom order
cfg.nz                  = 0;           % plant numer order
cfg.min_segment_s       = 10;          % skip mode if no contiguous segment ≥ this
cfg.PM_target_deg       = 60;
cfg.wc_inner_Hz         = 3;
cfg.wc_outer_Hz         = 1;
