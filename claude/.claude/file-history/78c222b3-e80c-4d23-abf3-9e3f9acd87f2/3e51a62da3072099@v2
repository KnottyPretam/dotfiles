function [D, prm_path, csv_dir] = ulg_to_csv(ulg_path, out_dir)
% Convert a .ulg to CSV per-topic dumps + a params file, then load CSVs into a struct of tables.
% D fields are named like Thunderball: vehicle_angular_velocity_0, vehicle_torque_setpoint_0, etc.

[~, base, ~] = fileparts(ulg_path);

csv_dir = fullfile(out_dir, 'csv');
if ~isfolder(csv_dir); mkdir(csv_dir); end
prm_path = fullfile(out_dir, 'params.prm');

fprintf('[ulg_to_csv] running ulog_params...\n');
cmd = sprintf('ulog_params "%s" > "%s"', ulg_path, prm_path);
[st, msg] = system(cmd);
if st ~= 0
    warning('ulog_params returned %d: %s', st, msg);
end

fprintf('[ulg_to_csv] running ulog2csv...\n');
cmd = sprintf('ulog2csv -o "%s" "%s"', csv_dir, ulg_path);
[st, msg] = system(cmd);
if st ~= 0
    error('ulog2csv failed (%d): %s', st, msg);
end

files = dir(fullfile(csv_dir, [base '_*.csv']));
if isempty(files)
    error('no CSV files found in %s after ulog2csv', csv_dir);
end

D = struct();
prefix_len = length(base) + 2; % includes trailing underscore
for k = 1:numel(files)
    fname = files(k).name;
    if length(fname) <= prefix_len + 4; continue; end
    topic = fname(prefix_len:end-4);
    field = matlab.lang.makeValidName(topic);
    try
        D.(field) = readtable(fullfile(csv_dir, fname));
    catch err
        warning('failed to read %s: %s', fname, err.message);
    end
end

fprintf('[ulg_to_csv] loaded %d topics\n', numel(fieldnames(D)));
end
