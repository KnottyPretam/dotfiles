function params = parse_px4_params(prm_path)
% Parse a .prm file produced by `ulog_params`.
% Output is a containers.Map from parameter name (char) to numeric value (double).

params = containers.Map('KeyType','char','ValueType','double');
if ~isfile(prm_path)
    warning('params file not found: %s', prm_path);
    return;
end

fid = fopen(prm_path, 'r');
cleanup = onCleanup(@() fclose(fid));

line_re = '^\s*([A-Z][A-Z0-9_]*)[\s,]+(-?\d+(?:\.\d*)?(?:[eE][+-]?\d+)?)';
while true
    line = fgetl(fid);
    if ~ischar(line); break; end
    tok = regexp(line, line_re, 'tokens', 'once');
    if isempty(tok); continue; end
    name = tok{1};
    val = str2double(tok{2});
    if isnan(val); continue; end
    params(name) = val;
end
end
