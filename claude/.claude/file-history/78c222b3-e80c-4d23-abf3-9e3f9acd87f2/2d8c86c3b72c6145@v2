function segs = segment_by_vtol_state(t, vtol_state, target_state, min_seconds)
% Return Nx2 array of [i_start, i_end] index pairs where vtol_state == target_state
% contiguously for at least min_seconds.
% t is a column vector of seconds (already monotonic). vtol_state is the same length.

t = t(:); vtol_state = vtol_state(:);
in_state = (vtol_state == target_state);

if ~any(in_state)
    segs = zeros(0,2);
    return;
end

d = diff([0; in_state; 0]);
starts = find(d == 1);
ends   = find(d == -1) - 1;

keep = false(numel(starts),1);
for i = 1:numel(starts)
    s = starts(i); e = ends(i);
    if e > numel(t); e = numel(t); end
    if t(e) - t(s) >= min_seconds
        keep(i) = true;
    end
end

segs = [starts(keep), ends(keep)];
end
