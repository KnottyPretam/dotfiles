#!/usr/bin/env bash
# Launch the MATLAB sysID pipeline on a ULG file, in the background, headless.
# Usage: ./run_sysid.sh /path/to/log.ulg
#
# Edit the cfg block at the top of run_sysid.m to change regime (mc/fw/both) and other knobs.

set -euo pipefail

ulg="${1:?usage: run_sysid.sh <path.ulg>}"
if [[ ! -r "$ulg" || "$ulg" != *.ulg ]]; then
    echo "not a readable .ulg: $ulg" >&2
    exit 1
fi

ulg_abs="$(readlink -f "$ulg")"
ts="$(date +%Y%m%d_%H%M%S)"
base="$(basename "$ulg_abs" .ulg)"
here="$(cd "$(dirname "$0")" && pwd)"
cwd="$(pwd)"                                          # user's invocation directory
outdir="${cwd}/output/${base}_${ts}"                  # outputs land in the caller's cwd
mkdir -p "$outdir"
log="${outdir}/run.log"

cd "$here"                                            # so matlab -batch finds the .m files
nohup matlab -batch "run_sysid('${ulg_abs}','${outdir}')" > "$log" 2>&1 &
pid=$!
echo "PID=$pid"
echo "log=$log"
echo "outdir=$outdir"
