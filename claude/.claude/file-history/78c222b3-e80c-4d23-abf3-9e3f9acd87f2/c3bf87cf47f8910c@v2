function write_margin_report(report_path, results, meta)
% Write a human-readable margins.txt with header + per-regime sections.
% results : struct array with fields .mode .axis .loop .source .row (struct with margins or [])
% meta    : struct with fields .ulg .timestamp .regime .fmin .fmax .coh_cutoff .min_seg_s
%                              .deflection_source .vtol_summary .segments  .gain_info

fid = fopen(report_path, 'w');
cleanup = onCleanup(@() fclose(fid));

fprintf(fid, 'ULG: %s\n', meta.ulg);
fprintf(fid, 'Run: %s\n', meta.timestamp);
fprintf(fid, 'Regime: %s\n', meta.regime);
fprintf(fid, 'Frequency band: %.3f–%.3f Hz   Coherence cutoff: %.2f   Min segment: %.1f s\n', ...
        meta.fmin, meta.fmax, meta.coh_cutoff, meta.min_seg_s);
fprintf(fid, 'Deflection input: %s (rpy frame, VTOL-state aware)\n', meta.deflection_source);
fprintf(fid, '%s\n', meta.vtol_summary);
fprintf(fid, '\n');

modes = {};
for k = 1:numel(results); modes{end+1} = results(k).mode; end %#ok<AGROW>
modes = unique(modes, 'stable');

header_fmt = '%-9s %-7s %-9s %-9s %-9s %-9s %-9s %-9s %-9s\n';
row_fmt    = '%-9s %-7s %-9s %9.2f %9.1f %9.3f %9.3f %9.2f %9.1f\n';
skip_fmt   = '%-9s %-7s %-9s %-9s\n';

for m = 1:numel(modes)
    mode = modes{m};
    fprintf(fid, '===== %s =====\n', upper(mode));
    if isfield(meta.segments, mode)
        s = meta.segments.(mode);
        if isempty(s.list)
            fprintf(fid, 'Segments: none ≥ %.1f s\n', meta.min_seg_s);
        else
            fprintf(fid, 'Segments: ');
            for j = 1:size(s.list,1)
                fprintf(fid, '[%.1f–%.1f]s (%.1fs)%s', ...
                    s.list(j,1), s.list(j,2), s.list(j,2)-s.list(j,1), ...
                    iif(j<size(s.list,1), ', ', ''));
            end
            fprintf(fid, '   total %.1f s   selected: [%.1f–%.1f] s\n', ...
                s.total_s, s.selected(1), s.selected(2));
        end
    end
    fprintf(fid, '\n');

    fprintf(fid, header_fmt, 'Loop', 'Axis', 'Source', 'GM_dB', 'PM_deg', 'wc_Hz', 'VM', 'DGM_dB', 'DPM_deg');
    fprintf(fid, '%s\n', repmat('-', 1, 85));

    for k = 1:numel(results)
        r = results(k);
        if ~strcmp(r.mode, mode); continue; end
        if isempty(r.row)
            fprintf(fid, skip_fmt, r.loop, r.axis, r.source, ['SKIPPED: ' r.reason]);
        else
            fprintf(fid, row_fmt, r.loop, r.axis, r.source, ...
                r.row.GM_dB, r.row.PM_deg, r.row.wc_Hz, r.row.VM, r.row.DGM_dB, r.row.DPM_deg);
        end
    end
    fprintf(fid, '\n');

    if isfield(meta.gain_info, mode)
        gi = meta.gain_info.(mode);
        fprintf(fid, 'Logged gains used:\n');
        for kk = 1:numel(gi)
            g = gi(kk);
            fns = fieldnames(g.gains);
            parts = cell(1, numel(fns));
            for ii = 1:numel(fns)
                parts{ii} = sprintf('%s=%g', fns{ii}, g.gains.(fns{ii}));
            end
            if ~isempty(g.missing)
                miss = sprintf(' MISSING:[%s]', strjoin(g.missing, ','));
            else
                miss = '';
            end
            fprintf(fid, '  %s  %s%s\n', g.axis, strjoin(parts, '  '), miss);
        end
        fprintf(fid, '\n');
    end
end
end

function y = iif(cond, a, b)
if cond; y = a; else; y = b; end
end
