function R = analyze_loop(plant_tf, C_tf, fmin_Hz, fmax_Hz)
% Build open- and closed-loop transfer functions from controller C and plant,
% compute classical and vector (disk) margins.
% Returns struct R with fields:
%   L            -- open-loop tf
%   T            -- closed-loop tf
%   GM_dB        -- gain margin (dB)
%   PM_deg       -- phase margin (deg)
%   wc_Hz        -- phase-crossover-based crossover (Wcp/2pi)
%   wcg_Hz       -- gain-crossover-based (Wcg/2pi)
%   VM           -- vector / disk margin = min |1 + L(jw)|
%   DGM_dB       -- equivalent disk gain margin
%   DPM_deg      -- equivalent disk phase margin
%   w_grid       -- omega grid used for VM
%   L_response   -- L(jw) on w_grid
%   ok           -- true if margin computation succeeded
%   reason       -- skip cause if ok==false

R = struct('L',[],'T',[],'GM_dB',NaN,'PM_deg',NaN,'wc_Hz',NaN,'wcg_Hz',NaN, ...
           'VM',NaN,'DGM_dB',NaN,'DPM_deg',NaN,'w_grid',[],'L_response',[], ...
           'ok',false,'reason','');

if isempty(plant_tf) || isempty(C_tf)
    R.reason = 'controller or plant tf is empty';
    return;
end

try
    L = series(C_tf, plant_tf);
    T = feedback(L, 1);

    [GM, PM, Wcg, Wcp] = margin(L);

    w = logspace(log10(2*pi*max(fmin_Hz,1e-3)), log10(2*pi*fmax_Hz), 4096).';
    h = squeeze(freqresp(L, w));
    VM = min(abs(1 + h));
    if VM >= 1
        DGM_dB = Inf;
        DPM_deg = 180;
    else
        DGM_dB  = 20*log10(1 / (1 - VM));
        DPM_deg = 2 * asind(VM / 2);
    end

    R.L          = L;
    R.T          = T;
    R.GM_dB      = 20*log10(GM);
    R.PM_deg     = PM;
    R.wc_Hz      = Wcp / (2*pi);
    R.wcg_Hz     = Wcg / (2*pi);
    R.VM         = VM;
    R.DGM_dB     = DGM_dB;
    R.DPM_deg    = DPM_deg;
    R.w_grid     = w;
    R.L_response = h;
    R.ok         = true;
catch err
    R.reason = sprintf('margin analysis failed: %s', err.message);
end
end
