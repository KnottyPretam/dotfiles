function rpy = quat_to_euler(q)
% Convert quaternion to roll/pitch/yaw (Tait-Bryan, ZYX) in radians.
% Input convention: q = [q1 q2 q3 q0] (scalar last), matches Thunderball/MathUs.
% Input q is Nx4. Output rpy is Nx3 = [roll, pitch, yaw].

q1 = q(:,1); q2 = q(:,2); q3 = q(:,3); q0 = q(:,4);

rpy = zeros(size(q,1), 3);
rpy(:,1) = atan2(2.*q2.*q3 + 2.*q0.*q1, q0.^2 - q1.^2 - q2.^2 + q3.^2);
sin_pitch = 2.*q1.*q3 - 2.*q0.*q2;
sin_pitch = max(min(sin_pitch, 1), -1);
rpy(:,2) = -asin(sin_pitch);
rpy(:,3) = atan2(2.*q1.*q2 + 2.*q0.*q3, q0.^2 + q1.^2 - q2.^2 - q3.^2);
end
