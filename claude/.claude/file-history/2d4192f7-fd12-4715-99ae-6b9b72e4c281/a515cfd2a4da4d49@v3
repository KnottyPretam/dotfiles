#!/usr/bin/env python3
"""
Echo a heartbeat to a specific Android phone over adb at a real-time 100 Hz.

Why this design:
  * adb is scoped to the phone's serial (-s RFCTC0KZEAV) so it can ONLY ever
    talk to that one device. adb finds Android phones by USB descriptor, not by
    /dev/ttyACM*, so it will never touch /dev/ttyACM0 (the 3DR ControlZero board).
  * We never call `adb kill-server` / `adb reconnect` -- those reset the whole
    USB transport layer and could disturb other devices. Everything stays
    scoped to this one phone.
  * One PERSISTENT `adb shell` is opened and fed commands over stdin. Spawning a
    fresh `adb shell` per tick has ~30-50 ms latency -- impossible at 100 Hz.
  * Pacing is drift-corrected against a monotonic clock so the average rate stays
    locked to 100 Hz over time instead of slowly falling behind.
"""

import subprocess
import sys
import time

SERIAL = "RFCTC0KZEAV"   # Galaxy S23 (adb device:dm1q) -- NOT the ControlZero board
HZ = 100
PERIOD = 1.0 / HZ        # 10 ms


def device_present() -> bool:
    out = subprocess.run(
        ["adb", "devices"], capture_output=True, text=True
    ).stdout
    return any(line.startswith(SERIAL) and "device" in line
               for line in out.splitlines())


def main() -> int:
    if not device_present():
        print(f"error: adb device {SERIAL} not found / not authorized.",
              file=sys.stderr)
        print("       run `adb devices` and check the phone screen.",
              file=sys.stderr)
        return 1

    # Persistent shell, scoped to the phone only.
    proc = subprocess.Popen(
        ["adb", "-s", SERIAL, "shell"],
        stdin=subprocess.PIPE,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        text=True,
        bufsize=1,  # line-buffered
    )

    print(f"sending heartbeat to {SERIAL} at {HZ} Hz (Ctrl-C to stop)...")

    seq = 0
    start = time.perf_counter()
    next_t = start
    last_report = start
    sent_since_report = 0

    try:
        while True:
            # The command that runs on the phone each tick. Swap this line for
            # whatever "notification"/ping you actually want on-device.
            proc.stdin.write(f"echo HB {seq} {time.time():.4f}\n")
            proc.stdin.flush()

            seq += 1
            sent_since_report += 1
            next_t += PERIOD

            # Once per second, report the real achieved rate.
            now = time.perf_counter()
            if now - last_report >= 1.0:
                rate = sent_since_report / (now - last_report)
                print(f"  seq={seq}  actual={rate:6.1f} Hz")
                last_report = now
                sent_since_report = 0

            # Drift-corrected sleep to the next 10 ms boundary.
            slack = next_t - time.perf_counter()
            if slack > 0:
                time.sleep(slack)
            else:
                # Fell behind (USB/device stall) -- resync, don't burst-catch-up.
                next_t = time.perf_counter()

            if proc.poll() is not None:
                print("error: adb shell exited unexpectedly.", file=sys.stderr)
                return 1
    except KeyboardInterrupt:
        print(f"\nstopped after {seq} beats.")
    finally:
        try:
            proc.stdin.close()
        except Exception:
            pass
        proc.terminate()
        try:
            proc.wait(timeout=2)
        except subprocess.TimeoutExpired:
            proc.kill()

    return 0


if __name__ == "__main__":
    sys.exit(main())
