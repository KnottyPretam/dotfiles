#!/usr/bin/env python3
"""
IMU vibration & failure-mode analysis for log_1_2026-4-29-13-48-36.

Companion to analyze_killswitch.py. Focuses on IMU health during the
window where manual_control_signal_lost was true (72.76s -> 102.91s).

Outputs:
  - imu_vibration_metrics.png   : per-IMU vibration metrics + clipping counters
  - imu_fft_<sensor>_<N>.png        : direct flat-top FFT PSD (g²/Hz, (deg/s)²/Hz)
  - imu_fft_mag_<sensor>_<N>.png    : Welch density PSD (g²/Hz, (deg/s)²/Hz)
  - imu_fft_spec_<sensor>_<N>.png   : Welch power spectrum (g² RMS, (deg/s)² RMS)
  - imu_consistency.png         : per-axis disagreement across the IMUs
  - imu_timing.png              : sample dt distribution, dropout detection
  - imu_bias_drift.png          : estimator_sensor_bias trends
  - imu_selection.png           : which sensor was selected over time
  - imu_innovations.png         : EKF innovations & test ratios
  - motor_rpm_sources.png       : esc_status per-motor RPM (time-series + PSD)
  - motor_current_sources.png   : esc_status per-motor current (time-series + PSD)
  - motor_pwm_sources.png       : actuator_outputs PWM per channel (time-series + PSD)
  - imu_findings.txt            : printed verdict
"""

import sys
from pathlib import Path
import numpy as np
import matplotlib.pyplot as plt
from pyulog import ULog
from scipy.signal import find_peaks, welch
from scipy.signal.windows import flattop

# ---------- config ----------
ULOG_PATH = "log_1_2026-4-29-13-48-36.ulg"
EVENT_START_S = 72.76
EVENT_END_S   = 102.91
PRE_S         = 10.0
OUTDIR        = Path(".")
G_MS2         = 9.80665   # 1 g in m/s²
RAD_TO_DEG    = 180.0 / np.pi

# Software low-pass filter cutoffs (Hz). These are PX4 IMU_*_CUTOFF defaults;
# override with what you have set on this airframe (param show IMU_*).
LPF_CUTOFFS = {
    "accel": {
        "IMU_ACCEL_CUTOFF": 30.0,   # default 30 Hz software LPF on accel
    },
    "gyro": {
        "IMU_GYRO_CUTOFF":  25.0,   # default 25 Hz software LPF on gyro for control
        "IMU_DGYRO_CUTOFF": 30.0,   # derivative-of-gyro LPF for D term
    },
}

# Hardware DLPF / Nyquist references per chip on the Control Zero.
# These help identify aliasing risk in the FFT plots.
HW_REFERENCES = {
    "accel": [
        ("ICM-20602 DLPF (~218 Hz)",  218.0),
        ("BMI088 accel BW (~145 Hz)", 145.0),
        ("ICM-20948 DLPF (~246 Hz)",  246.0),
    ],
    "gyro": [
        ("ICM-20602 DLPF (~250 Hz)",  250.0),
        ("BMI088 gyro BW (~230 Hz)",  230.0),
        ("ICM-20948 DLPF (~197 Hz)",  197.0),
    ],
}

# ---------- helpers ----------
def load(ulog_path):
    return ULog(ulog_path)

def get_topic(ulog, name, instance=None):
    for d in ulog.data_list:
        if d.name == name and (instance is None or d.multi_id == instance):
            return d
    return None

def all_instances(ulog, name):
    return [d for d in ulog.data_list if d.name == name]

def t_seconds(d, ulog):
    # Absolute FMU-boot seconds. EVENT_START_S/EVENT_END_S above are taken
    # from messages.txt, whose timestamps are boot-relative — not log-relative.
    return d.data["timestamp"] / 1e6

def slice_window(t, x, t0, t1):
    m = (t >= t0) & (t <= t1)
    return t[m], x[m]

def fifo_to_series(d):
    """Expand a sensor_*_fifo topic (batched) into per-sample (t, x, y, z)
    arrays in physical units. Each ULog row carries up to 32 raw int16
    samples; we keep only the first `samples` of each row, scale them, and
    rebuild per-sample timestamps from `timestamp_sample` (last sample) and
    `dt` (intra-batch period)."""
    ts_last = d.data["timestamp_sample"].astype(np.int64)  # µs, last sample
    dt_us   = d.data["dt"].astype(np.int64)                # µs, intra-batch
    nsamp   = d.data["samples"].astype(np.int32)
    scale   = d.data["scale"].astype(np.float64)

    X = np.stack([d.data[f"x[{k}]"] for k in range(32)], axis=1).astype(np.float64)
    Y = np.stack([d.data[f"y[{k}]"] for k in range(32)], axis=1).astype(np.float64)
    Z = np.stack([d.data[f"z[{k}]"] for k in range(32)], axis=1).astype(np.float64)

    out_t, out_x, out_y, out_z = [], [], [], []
    for i in range(len(ts_last)):
        n = int(nsamp[i])
        if n <= 0:
            continue
        # sample k (0..n-1) was taken at ts_last - (n-1-k)*dt
        t_us = ts_last[i] - (n - 1 - np.arange(n)) * dt_us[i]
        out_t.append(t_us)
        out_x.append(X[i, :n] * scale[i])
        out_y.append(Y[i, :n] * scale[i])
        out_z.append(Z[i, :n] * scale[i])

    t = np.concatenate(out_t) / 1e6  # → seconds, FMU-boot
    return t, np.concatenate(out_x), np.concatenate(out_y), np.concatenate(out_z)

def direct_fft(x, fs):
    """Single flat-top-windowed rfft over the whole segment.
    Returns (freq, amp, psd):
      amp — coherent-gain-corrected one-sided peak amplitude in signal units.
      psd — one-sided power spectral density in units²/Hz.
    Matches fft_accel_fifo.amplitude_spectrum (flat-top picks accurate peak
    heights regardless of bin alignment); the PSD view is the same FFT
    re-normalized by the window's noise gain."""
    x = np.asarray(x, dtype=np.float64)
    x = x - x.mean()
    N = x.size
    w = flattop(N)
    X = np.fft.rfft(x * w)
    freq = np.fft.rfftfreq(N, d=1.0 / fs)

    amp = (2.0 / (N * w.mean())) * np.abs(X)
    amp[0] /= 2.0
    if N % 2 == 0:
        amp[-1] /= 2.0

    psd = (np.abs(X) ** 2) / (fs * np.sum(w * w))
    if N % 2 == 0:
        psd[1:-1] *= 2.0
    else:
        psd[1:] *= 2.0
    return freq, amp, psd

def annotate_top_peaks(ax, freqs, psd, n_peaks=6, color="darkorange"):
    """Mark the top-N peaks by prominence on a log-PSD plot."""
    if len(psd) < 16:
        return
    log_psd = np.log10(np.maximum(psd, 1e-30))
    # distance=5 bins keeps us from picking shoulders of the same peak
    peaks, props = find_peaks(log_psd, distance=5, prominence=0.3)
    if len(peaks) == 0:
        return
    order = np.argsort(props["prominences"])[::-1][:n_peaks]
    for idx in order:
        f = freqs[peaks[idx]]
        p = psd[peaks[idx]]
        ax.plot(f, p, "v", color=color, markersize=5)
        ax.annotate(f"{f:.0f} Hz", xy=(f, p), xytext=(0, 8),
                    textcoords="offset points", fontsize=7,
                    color=color, ha="center")

def add_lpf_lines(ax, sensor_kind, fs):
    """Draw vertical lines for software LPF cutoffs and chip hardware DLPFs.
    Skip lines past Nyquist."""
    nyq = fs / 2.0
    sw = LPF_CUTOFFS.get(sensor_kind, {})
    for name, f in sw.items():
        if f < nyq:
            ax.axvline(f, color="green", linestyle="--", linewidth=1.2,
                       alpha=0.8, label=f"{name}={f:g} Hz")
    for name, f in HW_REFERENCES.get(sensor_kind, []):
        if f < nyq:
            ax.axvline(f, color="purple", linestyle=":", linewidth=1,
                       alpha=0.6, label=name)
    ax.axvline(nyq, color="red", linestyle="-", linewidth=0.8, alpha=0.4,
               label=f"Nyquist={nyq:.0f} Hz")

# ---------- 1. vibration metrics & clipping ----------
def plot_vibration_metrics(ulog, outpath):
    fig, axes = plt.subplots(3, 1, figsize=(12, 9), sharex=True)
    instances = all_instances(ulog, "vehicle_imu_status")
    print(f"[vibration] found {len(instances)} vehicle_imu_status instances")

    for d in instances:
        i = d.multi_id
        t = t_seconds(d, ulog)
        if "accel_vibration_metric" in d.data:
            axes[0].plot(t, d.data["accel_vibration_metric"], label=f"IMU{i}")
        if "gyro_vibration_metric" in d.data:
            axes[1].plot(t, d.data["gyro_vibration_metric"] * RAD_TO_DEG,
                         label=f"IMU{i}")
        # pyulog flattens vector fields into per-index keys.
        clip_keys = [f"accel_clipping[{k}]" for k in range(3)
                     if f"accel_clipping[{k}]" in d.data]
        if clip_keys:
            total = sum(d.data[k] for k in clip_keys)
            axes[2].plot(t, total, label=f"IMU{i} (XYZ sum)")

    for ax in axes:
        if ax.get_legend_handles_labels()[0]:
            ax.legend(loc="upper left", fontsize=8)
        ax.grid(True, alpha=0.3)
    axes[0].set_ylabel("accel_vibration_metric\n(m/s² RMS HP)")
    axes[1].set_ylabel("gyro_vibration_metric\n(deg/s RMS HP)")
    axes[2].set_ylabel("cumulative\naccel clipping count")
    axes[2].set_xlabel("time (s)")
    fig.suptitle("IMU vibration metrics & clipping")
    fig.tight_layout()
    fig.savefig(outpath, dpi=120)
    plt.close(fig)
    print(f"[vibration] wrote {outpath}")

# ---------- 2. FFT per IMU around the event ----------
def fft_around_event(ulog, outdir, show_lpf=True):
    """Compute FFT for sensor_accel_fifo and sensor_gyro_fifo per instance,
    in a window covering the build-up phase. The FIFO topics carry the raw
    high-rate stream (kHz), unlike sensor_accel/sensor_gyro which are
    decimated."""
    t0 = max(0.0, 56.0 - PRE_S)
    t1 = min(EVENT_START_S + 5, 80.0)

    accel_inst = all_instances(ulog, "sensor_accel_fifo")
    gyro_inst  = all_instances(ulog, "sensor_gyro_fifo")
    print(f"[fft] {len(accel_inst)} sensor_accel_fifo, {len(gyro_inst)} sensor_gyro_fifo")

    for sensor_kind, instances, ylabel, scale in [
        ("accel", accel_inst, "PSD g²/Hz",       1.0 / G_MS2),
        ("gyro",  gyro_inst,  "PSD (deg/s)²/Hz", RAD_TO_DEG),
    ]:
        for d in instances:
            i = d.multi_id
            t, x, y, z = fifo_to_series(d)
            mask = (t >= t0) & (t <= t1)
            if mask.sum() < 256:
                print(f"[fft]   {sensor_kind}{i}: too few samples")
                continue
            x, y, z = x[mask] * scale, y[mask] * scale, z[mask] * scale
            dt = float(np.median(d.data["dt"])) / 1e6
            fs = 1.0 / dt

            fig, axes = plt.subplots(3, 1, figsize=(11, 9), sharex=True)
            for ax, axis_data, axis_name in zip(axes, [x, y, z], ["X", "Y", "Z"]):
                freqs, _, psd = direct_fft(axis_data, fs)
                ax.plot(freqs, psd, color="steelblue", linewidth=0.8)
                annotate_top_peaks(ax, freqs, psd, n_peaks=6)
                ax.set_ylabel(f"{axis_name} {ylabel}")
                ax.grid(True, which="both", alpha=0.3)
                ax.set_xlim(0, fs / 2)
                if show_lpf:
                    add_lpf_lines(ax, sensor_kind, fs)
                ax.legend(loc="upper right", fontsize=7)
            axes[-1].set_xlabel("Frequency (Hz)")
            res_hz = fs / len(x)
            fig.suptitle(f"FFT PSD (flat-top) of sensor_{sensor_kind}_fifo_{i}, "
                         f"fs={fs:.0f} Hz, ")
            fig.tight_layout()
            outpath = outdir / f"imu_fft_{sensor_kind}_{i}.png"
            fig.savefig(outpath, dpi=120)
            plt.close(fig)
            print(f"[fft] wrote {outpath}")

# ---------- 2b. magnitude time series from FIFO topics ----------
def plot_fifo_magnitude_timeseries(ulog, outdir):
    """Per-axis (X, Y, Z) time series from the high-rate FIFO topics, all
    IMU instances overlaid, with the matching sensor_<kind> (decimated +
    software-LPF'd) trace overlaid on top in the same color so you can see
    what the filter is actually shaving off."""
    cycle = plt.rcParams["axes.prop_cycle"].by_key()["color"]
    for sensor_kind, units, scale in [
        ("accel", "g",     1.0 / G_MS2),
        ("gyro",  "deg/s", RAD_TO_DEG),
    ]:
        instances = all_instances(ulog, f"sensor_{sensor_kind}_fifo")
        if not instances:
            print(f"[mag_ts] no sensor_{sensor_kind}_fifo; skipping")
            continue
        filtered_by_id = {d.multi_id: d
                          for d in all_instances(ulog, f"sensor_{sensor_kind}")}
        fig, axes = plt.subplots(3, 1, figsize=(12, 9), sharex=True)
        for d in instances:
            i = d.multi_id
            color = cycle[i % len(cycle)]
            t, x, y, z = fifo_to_series(d)
            for ax, axis_data in zip(axes, [x, y, z]):
                ax.plot(t, axis_data * scale, color=color,
                        label=f"sensor_{sensor_kind}_fifo_{i}",
                        linewidth=0.4, alpha=0.6)
            df = filtered_by_id.get(i)
            if df is None:
                continue
            tf = t_seconds(df, ulog)
            for ax, axis_name in zip(axes, ["x", "y", "z"]):
                if axis_name not in df.data:
                    continue
                ax.plot(tf, df.data[axis_name] * scale, color=color,
                        label=f"sensor_{sensor_kind}_{i}",
                        linewidth=1.0, alpha=0.95)
        for ax, axis_name in zip(axes, ["X", "Y", "Z"]):
            ax.set_ylabel(f"{sensor_kind} {axis_name} ({units})")
            ax.legend(loc="upper right", fontsize=8)
            ax.grid(True, alpha=0.3)
        axes[-1].set_xlabel("time (s)")
        fig.suptitle(f"sensor_{sensor_kind}_fifo per-axis time series "
                     f"(thin = raw FIFO, thick = sensor_{sensor_kind} filtered)")
        fig.tight_layout()
        outpath = outdir / f"imu_{sensor_kind}_fifo_mag.png"
        fig.savefig(outpath, dpi=120)
        plt.close(fig)
        print(f"[mag_ts] wrote {outpath}")

# ---------- 2c. Welch PSD (averaged) — companion to the direct-FFT view ----------
def fft_magnitude_around_event(ulog, outdir, show_lpf=True):
    """Welch density PSD (Hann, 50% overlap) on the same axes/window as
    fft_around_event. The Welch averaging gives a smoother noise floor
    and broader peaks than the single-shot direct FFT in fft_around_event;
    the two PNGs together let you tell sharp rotor harmonics from
    distributed structural noise."""
    t0 = max(0.0, 56.0 - PRE_S)
    t1 = min(EVENT_START_S + 5, 80.0)

    for sensor_kind, ylabel, scale in [
        ("accel", "PSD g²/Hz",       1.0 / G_MS2),
        ("gyro",  "PSD (deg/s)²/Hz", RAD_TO_DEG),
    ]:
        for d in all_instances(ulog, f"sensor_{sensor_kind}_fifo"):
            i = d.multi_id
            t, x, y, z = fifo_to_series(d)
            mask = (t >= t0) & (t <= t1)
            if mask.sum() < 256:
                print(f"[fft_mag]   {sensor_kind}{i}: too few samples")
                continue
            x, y, z = x[mask] * scale, y[mask] * scale, z[mask] * scale
            dt = float(np.median(d.data["dt"])) / 1e6
            fs = 1.0 / dt
            nperseg = min(len(x), 4096)

            fig, axes = plt.subplots(3, 1, figsize=(11, 9), sharex=True)
            for ax, axis_data, axis_name in zip(axes, [x, y, z], ["X", "Y", "Z"]):
                freqs, psd = welch(axis_data, fs=fs, window="hann",
                                   nperseg=nperseg, noverlap=nperseg // 2,
                                   scaling="density", detrend="constant")
                ax.plot(freqs, psd, color="steelblue", linewidth=0.8)
                annotate_top_peaks(ax, freqs, psd, n_peaks=6)
                ax.set_ylabel(f"{axis_name} {ylabel}")
                ax.grid(True, alpha=0.3)
                ax.set_xlim(0, fs / 2)
                if show_lpf:
                    add_lpf_lines(ax, sensor_kind, fs)
                ax.legend(loc="upper right", fontsize=7)
            axes[-1].set_xlabel("Frequency (Hz)")
            res_hz = fs / nperseg
            fig.suptitle(f"Welch PSD (density, Hann) of sensor_{sensor_kind}_fifo_{i}, "
                         f"t={t0:.1f}–{t1:.1f}s, fs={fs:.0f} Hz, "
                         f"Δf≈{res_hz:.2f} Hz")
            fig.tight_layout()
            outpath = outdir / f"imu_fft_mag_{sensor_kind}_{i}.png"
            fig.savefig(outpath, dpi=120)
            plt.close(fig)
            print(f"[fft_mag] wrote {outpath}")

# ---------- 2d. Welch power spectrum (RMS² per bin) ----------
def fft_spectrum_around_event(ulog, outdir, show_lpf=True):
    """Same layout as fft_magnitude_around_event but with Welch
    scaling='spectrum' (RMS² per bin, not per-Hz density). Peak heights
    read directly as the squared RMS amplitude of the underlying tone in
    that bin — useful when comparing the energy at a specific harmonic
    against a vibration-amplitude budget rather than a noise-density spec."""
    t0 = max(0.0, 56.0 - PRE_S)
    t1 = min(EVENT_START_S + 5, 80.0)

    for sensor_kind, ylabel, scale in [
        ("accel", "spectrum g² RMS",       1.0 / G_MS2),
        ("gyro",  "spectrum (deg/s)² RMS", RAD_TO_DEG),
    ]:
        for d in all_instances(ulog, f"sensor_{sensor_kind}_fifo"):
            i = d.multi_id
            t, x, y, z = fifo_to_series(d)
            mask = (t >= t0) & (t <= t1)
            if mask.sum() < 256:
                print(f"[fft_spec]   {sensor_kind}{i}: too few samples")
                continue
            x, y, z = x[mask] * scale, y[mask] * scale, z[mask] * scale
            dt = float(np.median(d.data["dt"])) / 1e6
            fs = 1.0 / dt
            nperseg = min(len(x), 4096)

            fig, axes = plt.subplots(3, 1, figsize=(11, 9), sharex=True)
            for ax, axis_data, axis_name in zip(axes, [x, y, z], ["X", "Y", "Z"]):
                freqs, spec = welch(axis_data, fs=fs, window="hann",
                                    nperseg=nperseg, noverlap=nperseg // 2,
                                    scaling="spectrum", detrend="constant")
                ax.plot(freqs, spec, color="steelblue", linewidth=0.8)
                annotate_top_peaks(ax, freqs, spec, n_peaks=6)
                ax.set_ylabel(f"{axis_name} {ylabel}")
                ax.grid(True, alpha=0.3)
                ax.set_xlim(0, fs / 2)
                if show_lpf:
                    add_lpf_lines(ax, sensor_kind, fs)
                ax.legend(loc="upper right", fontsize=7)
            axes[-1].set_xlabel("Frequency (Hz)")
            res_hz = fs / nperseg
            fig.suptitle(f"Welch power spectrum (scaling=spectrum, Hann) of "
                         f"sensor_{sensor_kind}_fifo_{i}, "
                         f"t={t0:.1f}–{t1:.1f}s, fs={fs:.0f} Hz, "
                         f"Δf≈{res_hz:.2f} Hz")
            fig.tight_layout()
            outpath = outdir / f"imu_fft_spec_{sensor_kind}_{i}.png"
            fig.savefig(outpath, dpi=120)
            plt.close(fig)
            print(f"[fft_spec] wrote {outpath}")

# ---------- 3. consistency between IMUs ----------
def plot_consistency(ulog, outpath):
    instances = all_instances(ulog, "vehicle_imu_status")
    fig, axes = plt.subplots(2, 1, figsize=(12, 7), sharex=True)
    for d in instances:
        i = d.multi_id
        t = t_seconds(d, ulog)
        if "accel_inconsistency_m_s_s" in d.data:
            v = d.data["accel_inconsistency_m_s_s"]
            mag = np.linalg.norm(v, axis=1) if v.ndim == 2 else v
            axes[0].plot(t, mag, label=f"IMU{i}")
        if "gyro_inconsistency_rad_s" in d.data:
            v = d.data["gyro_inconsistency_rad_s"]
            mag = np.linalg.norm(v, axis=1) if v.ndim == 2 else v
            axes[1].plot(t, mag * RAD_TO_DEG, label=f"IMU{i}")
    for ax in axes:
        if ax.get_legend_handles_labels()[0]:
            ax.legend(loc="upper left", fontsize=8)
        ax.grid(True, alpha=0.3)
    axes[0].set_ylabel("|accel inconsistency|\n(m/s²)")
    axes[1].set_ylabel("|gyro inconsistency|\n(deg/s)")
    axes[1].set_xlabel("time (s)")
    fig.suptitle("Per-axis disagreement between IMU instances")
    fig.tight_layout()
    fig.savefig(outpath, dpi=120)
    plt.close(fig)
    print(f"[consistency] wrote {outpath}")

# ---------- 4. sample timing & dropouts ----------
def plot_timing(ulog, outpath):
    accel_inst = all_instances(ulog, "sensor_accel")
    fig, axes = plt.subplots(len(accel_inst), 1,
                              figsize=(12, 2.5 * len(accel_inst)),
                              sharex=True, squeeze=False)
    axes = axes.ravel()
    for ax, d in zip(axes, accel_inst):
        i = d.multi_id
        t = t_seconds(d, ulog)
        dt_ms = np.diff(t) * 1000.0
        ax.plot(t[1:], dt_ms, ".", markersize=1)
        ax.set_ylabel(f"IMU{i}\nΔt (ms)")
        ax.grid(True, alpha=0.3)
        ax.set_yscale("log")
        if len(dt_ms):
            imax = np.argmax(dt_ms)
            ax.annotate(f"max Δt={dt_ms[imax]:.1f} ms @ t={t[imax+1]:.1f}s",
                        xy=(t[imax+1], dt_ms[imax]),
                        xytext=(0.7, 0.85), textcoords="axes fraction",
                        fontsize=8,
                        arrowprops=dict(arrowstyle="->", color="black"))
    axes[-1].set_xlabel("time (s)")
    fig.suptitle("sensor_accel inter-sample timing (look for spikes / dropouts)")
    fig.tight_layout()
    fig.savefig(outpath, dpi=120)
    plt.close(fig)
    print(f"[timing] wrote {outpath}")

# ---------- 5. EKF bias trends ----------
def plot_bias(ulog, outpath):
    bias = all_instances(ulog, "estimator_sensor_bias")
    if not bias:
        print("[bias] no estimator_sensor_bias topic; skipping")
        return
    fig, axes = plt.subplots(2, 1, figsize=(12, 6), sharex=True)
    for d in bias:
        i = d.multi_id
        t = t_seconds(d, ulog)
        for axis_idx, axis_name in enumerate("xyz"):
            key_a = f"accel_bias[{axis_idx}]"
            key_g = f"gyro_bias[{axis_idx}]"
            if key_a in d.data:
                axes[0].plot(t, d.data[key_a], label=f"EKF{i} a{axis_name}", alpha=0.7)
            if key_g in d.data:
                axes[1].plot(t, d.data[key_g] * RAD_TO_DEG,
                             label=f"EKF{i} g{axis_name}", alpha=0.7)
    for ax in axes:
        ax.legend(loc="upper left", fontsize=7, ncol=3)
        ax.grid(True, alpha=0.3)
    axes[0].set_ylabel("accel bias (m/s²)")
    axes[1].set_ylabel("gyro bias (deg/s)")
    axes[1].set_xlabel("time (s)")
    fig.tight_layout()
    fig.savefig(outpath, dpi=120)
    plt.close(fig)
    print(f"[bias] wrote {outpath}")

# ---------- 6. sensor selection ----------
def plot_selection(ulog, outpath):
    """sensor_selection tells you which accel/gyro device the
    consolidator picked. Frequent changes = sensor voter struggling."""
    sel = get_topic(ulog, "sensor_selection")
    if sel is None:
        print("[selection] no sensor_selection topic; skipping")
        return
    t = t_seconds(sel, ulog)
    fig, axes = plt.subplots(2, 1, figsize=(12, 5), sharex=True)
    if "accel_device_id" in sel.data:
        ids = sel.data["accel_device_id"]
        uniq = {v: i for i, v in enumerate(sorted(set(ids)))}
        idx = np.array([uniq[v] for v in ids])
        axes[0].step(t, idx, where="post")
        axes[0].set_yticks(list(uniq.values()))
        axes[0].set_yticklabels([f"0x{v:08x}" for v in uniq.keys()],
                                fontsize=7)
        axes[0].set_ylabel("selected accel\ndevice_id")
    if "gyro_device_id" in sel.data:
        ids = sel.data["gyro_device_id"]
        uniq = {v: i for i, v in enumerate(sorted(set(ids)))}
        idx = np.array([uniq[v] for v in ids])
        axes[1].step(t, idx, where="post")
        axes[1].set_yticks(list(uniq.values()))
        axes[1].set_yticklabels([f"0x{v:08x}" for v in uniq.keys()],
                                fontsize=7)
        axes[1].set_ylabel("selected gyro\ndevice_id")
    for ax in axes:
        ax.grid(True, alpha=0.3)
    axes[1].set_xlabel("time (s)")
    fig.suptitle("Sensor voter selection (steps = primary IMU switch)")
    fig.tight_layout()
    fig.savefig(outpath, dpi=120)
    plt.close(fig)
    print(f"[selection] wrote {outpath}")

# ---------- 7. EKF innovations ----------
def plot_innovations(ulog, outpath):
    """estimator_innovations and estimator_innovation_test_ratios show
    how badly the EKF was fighting its sensors. Test ratio > 1 = sensor
    measurement was rejected."""
    innov = all_instances(ulog, "estimator_innovations")
    ratios = all_instances(ulog, "estimator_innovation_test_ratios")

    if not innov and not ratios:
        print("[innovations] no estimator_innovation* topics; skipping")
        return

    panel_specs = []
    for field in ["gps_hvel", "gps_vvel", "gps_hpos", "gps_vpos",
                  "mag_field", "heading", "baro"]:
        for d in innov:
            if field in d.data or f"{field}[0]" in d.data:
                panel_specs.append(("innov", field))
                break
    if ratios:
        panel_specs.append(("ratio", "all"))

    n_panels = len(panel_specs)
    if n_panels == 0:
        print("[innovations] nothing to plot; skipping")
        return

    fig, axes = plt.subplots(n_panels, 1, figsize=(12, 2.2 * n_panels),
                              sharex=True, squeeze=False)
    axes = axes.ravel()
    p = 0
    for kind, field in panel_specs:
        ax = axes[p]
        if kind == "innov":
            for d in innov:
                i = d.multi_id
                t = t_seconds(d, ulog)
                if field in d.data:
                    ax.plot(t, d.data[field], label=f"EKF{i}", alpha=0.8)
                else:
                    for k in range(3):
                        key = f"{field}[{k}]"
                        if key in d.data:
                            ax.plot(t, d.data[key], label=f"EKF{i}[{k}]", alpha=0.6)
            ax.set_ylabel(f"{field}\ninnovation")
        else:
            for d in ratios:
                i = d.multi_id
                t = t_seconds(d, ulog)
                for k in d.data.keys():
                    if k == "timestamp":
                        continue
                    try:
                        ax.plot(t, d.data[k], label=f"EKF{i}.{k}",
                                alpha=0.6, linewidth=0.8)
                    except Exception:
                        pass
            ax.axhline(1.0, color="red", linestyle="--", linewidth=1,
                       label="reject threshold (=1.0)")
            ax.set_ylabel("innovation\ntest ratio")
            ax.set_yscale("log")
        ax.legend(loc="upper left", fontsize=6, ncol=4)
        ax.grid(True, alpha=0.3)
        p += 1
    axes[-1].set_xlabel("time (s)")
    fig.suptitle("EKF innovations & test ratios (>1 = measurement rejected)")
    fig.tight_layout()
    fig.savefig(outpath, dpi=120)
    plt.close(fig)
    print(f"[innovations] wrote {outpath}")

# ---------- 8. motor PSD vs IMU PSD ----------
def _plot_source_panel(t, channels, title, units, outpath, t0, t1):
    """Time series (top) + Welch density PSD (bottom) for a set of related
    motor/actuator/ESC channels. Channels with <16 in-window samples or
    near-zero variance are skipped; the FFT window matches fft_around_event
    so source spectra line up directly with the IMU FFT plots."""
    mask = (t >= t0) & (t <= t1)
    n_in = int(mask.sum())
    if n_in < 16:
        print(f"[sources] {outpath.name}: too few samples in [{t0:.1f},{t1:.1f}]s")
        return
    dt = float(np.median(np.diff(t[mask])))
    fs = 1.0 / dt if dt > 0 else 1.0
    nperseg = min(n_in, 4096)

    fig, axes = plt.subplots(2, 1, figsize=(12, 8))
    plotted = 0
    for label, sig in channels.items():
        sig = np.asarray(sig, dtype=float)
        seg = sig[mask]
        if np.std(seg) < 1e-6:
            continue  # disarmed / static channel
        axes[0].plot(t, sig, label=label, linewidth=0.8, alpha=0.85)
        freqs, psd = welch(seg, fs=fs, window="hann",
                           nperseg=nperseg, noverlap=nperseg // 2,
                           scaling="density", detrend="constant")
        axes[1].plot(freqs, psd, label=label, linewidth=0.9, alpha=0.85)
        plotted += 1

    if plotted == 0:
        plt.close(fig)
        print(f"[sources] {outpath.name}: no channels with variance; skipping")
        return

    axes[0].set_ylabel(units)
    axes[0].set_xlabel("time (s)")
    axes[0].grid(True, alpha=0.3)
    axes[0].legend(loc="upper right", fontsize=7, ncol=2)

    axes[1].set_xlim(0, fs / 2)
    axes[1].set_xlabel("Frequency (Hz)")
    axes[1].set_ylabel(f"PSD ({units}²/Hz)")
    axes[1].grid(True, alpha=0.3)
    axes[1].legend(loc="upper right", fontsize=7, ncol=2)

    fig.suptitle(f"{title}  —  FFT window t={t0:.1f}–{t1:.1f}s, "
                 f"fs≈{fs:.0f} Hz, Δf≈{fs/nperseg:.2f} Hz")
    fig.tight_layout()
    fig.savefig(outpath, dpi=120)
    plt.close(fig)
    print(f"[sources] wrote {outpath}")


def plot_vibration_sources(ulog, outdir):
    """Characterize the three signals that drive airframe vibration —
    per-motor RPM, per-motor current (both from esc_status), and the PWM
    output the autopilot is sending each ESC (actuator_outputs). Each
    PNG: time series on top, Welch density PSD on bottom over the same
    window as fft_around_event."""
    t0 = max(0.0, 56.0 - PRE_S)
    t1 = min(EVENT_START_S + 5, 80.0)

    esc = get_topic(ulog, "esc_status")
    if esc is None:
        print("[sources] no esc_status topic; skipping RPM and current")
    else:
        t_esc = t_seconds(esc, ulog)
        for field, units, fname, title in [
            ("esc_rpm",     "RPM", "motor_rpm_sources.png",
             "esc_status per-motor RPM"),
            ("esc_current", "A",   "motor_current_sources.png",
             "esc_status per-motor current"),
        ]:
            keys = sorted(k for k in esc.data.keys()
                          if k.startswith("esc[") and k.endswith(f".{field}"))
            if not keys:
                print(f"[sources] no esc[].{field}; skipping {fname}")
                continue
            channels = {k: esc.data[k] for k in keys}
            _plot_source_panel(t_esc, channels, title, units,
                               outdir / fname, t0, t1)

    # Pick the actuator_outputs instance whose channels actually move inside
    # the analysis window — same heuristic as the old plot_motor_vs_imu_psd,
    # because some airframes publish an idle "raw" instance with high full-
    # log variance but no signal in the hover slice.
    motors = None
    best_var = 0.0
    for cand in all_instances(ulog, "actuator_outputs"):
        tc = cand.data["timestamp"] / 1e6
        m = (tc >= t0) & (tc <= t1)
        if m.sum() < 64:
            continue
        ch_keys = [k for k in cand.data.keys() if k.startswith("output[")]
        v = sum(float(np.nanstd(cand.data[k][m])) for k in ch_keys)
        if v > best_var:
            best_var = v
            motors = cand
    if motors is None:
        print("[sources] no usable actuator_outputs; skipping motor_pwm_sources.png")
        return
    tm = t_seconds(motors, ulog)
    out_keys = sorted((k for k in motors.data.keys() if k.startswith("output[")),
                      key=lambda s: int(s[len("output["):-1]))
    channels = {k: motors.data[k] for k in out_keys}
    _plot_source_panel(
        tm, channels,
        f"actuator_outputs[{motors.multi_id}] PWM per channel",
        "PWM", outdir / "motor_pwm_sources.png", t0, t1,
    )

# ---------- verdict ----------
def write_verdict(ulog, outpath):
    lines = ["=== IMU vibration / failure verdict ===", ""]

    instances = all_instances(ulog, "vehicle_imu_status")
    for d in instances:
        i = d.multi_id
        t = t_seconds(d, ulog)
        mask = (t >= EVENT_START_S - 5) & (t <= EVENT_END_S + 5)
        if mask.sum() == 0:
            lines.append(f"IMU{i}: no samples in event window "
                         f"[{EVENT_START_S-5:.1f},{EVENT_END_S+5:.1f}] s — "
                         f"data range [{t.min():.1f},{t.max():.1f}] s")
            lines.append("")
            continue
        if "accel_vibration_metric" in d.data:
            v = d.data["accel_vibration_metric"][mask]
            lines.append(f"IMU{i}: accel_vibration_metric  "
                         f"max={v.max():.2f} m/s²  mean={v.mean():.2f}  "
                         f"(>5 degraded, >10 dangerous)")
        if "gyro_vibration_metric" in d.data:
            v = d.data["gyro_vibration_metric"][mask] * RAD_TO_DEG
            lines.append(f"IMU{i}: gyro_vibration_metric   "
                         f"max={v.max():.2f} deg/s  mean={v.mean():.2f}  "
                         f"(>11.5 bad)")
        clip_keys = [f"accel_clipping[{k}]" for k in range(3)
                     if f"accel_clipping[{k}]" in d.data]
        if clip_keys:
            delta = [int(d.data[k][-1]) - int(d.data[k][0]) for k in clip_keys]
            lines.append(f"IMU{i}: accel_clipping total over flight  "
                         f"X={delta[0]} Y={delta[1]} Z={delta[2]}")
        lines.append("")

    sel = get_topic(ulog, "sensor_selection")
    if sel is not None:
        if "accel_device_id" in sel.data:
            ids = sel.data["accel_device_id"]
            t = t_seconds(sel, ulog)
            switches = int(np.sum(np.diff(ids) != 0))
            in_event = int(np.sum((t[:-1] >= EVENT_START_S) &
                                   (t[:-1] <= EVENT_END_S) &
                                   (np.diff(ids) != 0)))
            lines.append(f"sensor_selection accel switches: total={switches}, "
                         f"during dropout={in_event}")
        if "gyro_device_id" in sel.data:
            ids = sel.data["gyro_device_id"]
            t = t_seconds(sel, ulog)
            switches = int(np.sum(np.diff(ids) != 0))
            in_event = int(np.sum((t[:-1] >= EVENT_START_S) &
                                   (t[:-1] <= EVENT_END_S) &
                                   (np.diff(ids) != 0)))
            lines.append(f"sensor_selection gyro switches:  total={switches}, "
                         f"during dropout={in_event}")
        lines.append("")

    for d in all_instances(ulog, "sensor_accel"):
        i = d.multi_id
        t = t_seconds(d, ulog)
        mask = (t >= EVENT_START_S) & (t <= EVENT_END_S)
        tw = t[mask]
        if len(tw) > 2:
            dt_ms = np.diff(tw) * 1000.0
            lines.append(f"sensor_accel_{i} during dropout: "
                         f"n={len(tw)}, median Δt={np.median(dt_ms):.2f} ms, "
                         f"max Δt={dt_ms.max():.2f} ms")

    txt = "\n".join(lines)
    print("\n" + txt)
    outpath.write_text(txt)
    print(f"\n[verdict] wrote {outpath}")

# ---------- main ----------
def main():
    path = Path(sys.argv[1]) if len(sys.argv) > 1 else Path(ULOG_PATH)
    if not path.exists():
        print(f"ERROR: {path} not found. Pass ulog path as arg.")
        sys.exit(1)
    print(f"Loading {path}...")
    ulog = load(str(path))

    OUTDIR.mkdir(exist_ok=True)
    plot_vibration_metrics(ulog, OUTDIR / "imu_vibration_metrics.png")
    plot_fifo_magnitude_timeseries(ulog, OUTDIR)
    fft_around_event(ulog, OUTDIR, show_lpf=True)
    fft_magnitude_around_event(ulog, OUTDIR, show_lpf=True)
    fft_spectrum_around_event(ulog, OUTDIR, show_lpf=True)
    plot_consistency(ulog, OUTDIR / "imu_consistency.png")
    plot_timing(ulog, OUTDIR / "imu_timing.png")
    plot_bias(ulog, OUTDIR / "imu_bias_drift.png")
    plot_selection(ulog, OUTDIR / "imu_selection.png")
    plot_innovations(ulog, OUTDIR / "imu_innovations.png")
    plot_vibration_sources(ulog, OUTDIR)
    write_verdict(ulog, OUTDIR / "imu_findings.txt")
    print("\nDone.")

if __name__ == "__main__":
    main()
