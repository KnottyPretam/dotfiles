function mat_path = ulog_to_mat(ulg_path, run_dir)
% ULOG_TO_MAT  Convert a PX4 ULog into the .mat consumed by the sys-ID tool.
%
%   mat_path = ulog_to_mat(ulg_path, run_dir)
%
% Replicates Thunderball's mat-generation logic (ReadData.m + the
% rpy-derivation blocks of RunPlots.m) so the output struct 'd' is
% compatible with run_system_id_and_gain_design. Each ULog topic becomes a
% table; the relevant attitude/rate/torque topics get an added Nx3 '.rpy'
% (roll/pitch/yaw, hover/cruise blended by VTOL state). The result is saved
% to <run_dir>/<name>.mat.
%
% This is a faithful but minimal subset of Thunderball: the time-base and
% the position/esc/swashplate derivations are intentionally omitted (the
% sys-ID step does not use them, and dropping the time base also removes
% Thunderball's hard dependency on actuator_outputs_2).
%
% Requires pyulog (ulog2csv / ulog_params) on PATH and the vendored
% MathUs.m alongside this file.

% Make the vendored MathUs.m reachable even when called standalone.
addpath(fileparts(mfilename('fullpath')));

% PX4 CSV headers like xyz[0] become xyz_0_; silence the rename warning,
% matching Thunderball's `warning off`.
ws = warning('off', 'all');
restore_warn = onCleanup(@() warning(ws)); %#ok<NASGU>

[~, name] = fileparts(ulg_path);
csvdir = fullfile(run_dir, 'csv');
if ~exist(csvdir, 'dir'); mkdir(csvdir); end

%% Convert ULog -> CSV (pyulog); dump params (best effort)
cmd = sprintf('ulog2csv -o "%s" "%s"', csvdir, ulg_path);
fprintf('[ulog_to_mat] %s\n', cmd);
status = system(cmd);
if status ~= 0
    error('ulog_to_mat:ulog2csv', ...
        'ulog2csv failed (exit %d). Install pyulog and ensure ulog2csv is on PATH.', status);
end
system(sprintf('ulog_params "%s" > "%s"', ulg_path, fullfile(run_dir, 'params.prm')));

%% Read every CSV into a struct of tables (ReadData.m logic)
csv_files = dir(fullfile(csvdir, [name '*.csv']));
if isempty(csv_files)
    error('ulog_to_mat:noCsv', ...
        'No CSV files produced in %s. The log may be empty or pyulog failed.', csvdir);
end
d = struct();
for i = 1:numel(csv_files)
    csv_name = csv_files(i).name;
    msg_name = csv_name((numel(name)+2):end-4);   % strip "<name>_" prefix and ".csv"
    d.(msg_name) = readtable(fullfile(csvdir, csv_name), 'VariableNamingRule', 'modify');
end
d = orderfields(d);

%% Derived roll/pitch/yaw frames (verbatim from Thunderball RunPlots.m, lines 90-125)
try d.vehicle_attitude_0.q = [d.vehicle_attitude_0.q_1_ d.vehicle_attitude_0.q_2_ d.vehicle_attitude_0.q_3_ d.vehicle_attitude_0.q_0_ ]; end % reordering for MathUs
try d.vehicle_attitude_0.rpy = MathUs.QuatToEuler(d.vehicle_attitude_0.q); end % hover
try
    d.vehicle_attitude_0.rpy_h = d.vehicle_attitude_0.rpy;
    d.vehicle_attitude_0.rpy_c = MathUs.QuatToEuler(MathUs.QuatRotB(d.vehicle_attitude_0.q,MathUs.EulerToQuat([0 90 0]*pi/180))); % cruise
    vtol_state = MathUs.RebaseTimeScale(d.vehicle_attitude_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
    is_h = vtol_state == 3 | vtol_state == 1;
    d.vehicle_attitude_0.rpy = d.vehicle_attitude_0.rpy_h.*(is_h) + d.vehicle_attitude_0.rpy_c.*(~is_h); % combine
    d.vehicle_attitude_0.vtol_state = vtol_state; clear is_h vtol_state;
end
try
   rpy_h = [ d.vehicle_angular_velocity_0.xyz_0_ d.vehicle_angular_velocity_0.xyz_1_ d.vehicle_angular_velocity_0.xyz_2_];
   rpy_c = [-d.vehicle_angular_velocity_0.xyz_2_ d.vehicle_angular_velocity_0.xyz_1_ d.vehicle_angular_velocity_0.xyz_0_];
   vtol_state = MathUs.RebaseTimeScale(d.vehicle_angular_velocity_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
   is_h = vtol_state == 3 | vtol_state == 1;
   d.vehicle_angular_velocity_0.rpy = rpy_h.*(is_h) + rpy_c.*(~is_h); % combine
   d.vehicle_angular_velocity_0.vtol_state = vtol_state; clear is_h vtol_state rpy_h rpy_c;
end
try
   rpy_h = [ d.vehicle_rates_setpoint_0.roll d.vehicle_rates_setpoint_0.pitch d.vehicle_rates_setpoint_0.yaw];
   rpy_c = [-d.vehicle_rates_setpoint_0.yaw  d.vehicle_rates_setpoint_0.pitch d.vehicle_rates_setpoint_0.roll];
   vtol_state = MathUs.RebaseTimeScale(d.vehicle_rates_setpoint_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
   is_h = vtol_state == 3 | vtol_state == 1;
   d.vehicle_rates_setpoint_0.rpy = rpy_h.*(is_h) + rpy_c.*(~is_h); % combine
   d.vehicle_rates_setpoint_0.vtol_state = vtol_state; clear is_h vtol_state rpy_h rpy_c;
end
try
   rpy_h = [ d.vehicle_torque_setpoint_0.xyz_0_ d.vehicle_torque_setpoint_0.xyz_1_ d.vehicle_torque_setpoint_0.xyz_2_];
   rpy_c = [-d.vehicle_torque_setpoint_0.xyz_2_ d.vehicle_torque_setpoint_0.xyz_1_ d.vehicle_torque_setpoint_0.xyz_0_];
   vtol_state = MathUs.RebaseTimeScale(d.vehicle_torque_setpoint_0.timestamp, d.vtol_vehicle_status_0.vehicle_vtol_state,d.vtol_vehicle_status_0.timestamp);
   is_h = vtol_state == 3 | vtol_state == 1;
   d.vehicle_torque_setpoint_0.rpy = rpy_h.*(is_h) + rpy_c.*(~is_h); % combine
   d.vehicle_torque_setpoint_0.vtol_state = vtol_state; clear is_h vtol_state rpy_h rpy_c;
end
try d.vehicle_attitude_setpoint_0.q = [d.vehicle_attitude_setpoint_0.q_d_1_ d.vehicle_attitude_setpoint_0.q_d_2_ d.vehicle_attitude_setpoint_0.q_d_3_ d.vehicle_attitude_setpoint_0.q_d_0_]; end
try d.vehicle_attitude_setpoint_0.rpy = MathUs.QuatToEuler(d.vehicle_attitude_setpoint_0.q); end

%% Guard: the sys-ID step needs these rpy fields
for t = {'vehicle_angular_velocity_0', 'vehicle_torque_setpoint_0'}
    tn = t{1};
    if ~isfield(d, tn) || ~ismember('rpy', d.(tn).Properties.VariableNames)
        error('ulog_to_mat:missingRPY', ['Failed to build %s.rpy (needed by the sys-ID step). ' ...
            'vtol_vehicle_status_0 present: %d. The hover/cruise frame blend mirrors Thunderball, ' ...
            'which targets VTOL logs containing that topic plus the source signals.'], ...
            tn, isfield(d, 'vtol_vehicle_status_0'));
    end
end

%% Save (variable name 'd', as Thunderball does)
mat_path = fullfile(run_dir, [name '.mat']);
save(mat_path, 'd');
fprintf('[ulog_to_mat] saved %s\n', mat_path);
end
