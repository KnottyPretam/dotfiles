function results = run_system_id_and_gain_design(mat_path, out_dir, opts)
% RUN_SYSTEM_ID_AND_GAIN_DESIGN  Chirp system-ID for roll/pitch/yaw, with
% current-system stability margins and a pidtune retune, saving every figure.
%
%   results = run_system_id_and_gain_design(mat_path, out_dir)
%   results = run_system_id_and_gain_design(mat_path, out_dir, opts)
%
% For each axis it produces up to THREE figure groups, each prefixed in the
% figure title and filename so they never collide:
%
%   * CURRENT    - identify the plant from the FULL time series (original
%                  method) and evaluate the as-flown controller against it
%                  (gains from the .prm: rate Kp=K*P, Ki=K*I, Kd=K*D from
%                  MC_<AXIS>RATE_*, attitude P = MC_<AXIS>_P).
%   * TIME SLICE - the SAME identification + as-flown evaluation, but on the
%                  per-axis chirp window only (produced when time_slice is on
%                  and a window is given). Identical figure set to CURRENT.
%   * RETUNE     - pidtune gains, always designed from the CURRENT (full-
%                  series) plant.
%
% Figures are saved to OUT_DIR/figures/<axis>/ (PNG + .fig); margins.txt and
% results.mat carry all three groups.
%
% opts fields (all optional):
%   axes           cellstr subset of {'roll','pitch','yaw'} (default all)
%   prm_path       path to the .prm params for current gains (set by run_sysid)
%   wc_inner_Hz    retune rate-loop target crossover (default 3)
%   wc_outer_Hz    retune attitude-loop target crossover (default 1)
%   PM_target_deg  retune phase-margin target for pidtune (default 60)
%   coh_cutoff     coherence threshold for FRF points (default 0.8)
%   freq_init_Hz   chirp start frequency (default 0.01)
%   freq_end_Hz    chirp end frequency (default 5.5)
%   deriv_filter_N current-loop derivative filter coefficient (default 10)
%   visible        show figures while running (default false)
%   formats        cellstr of saved formats (default {'png','fig'})

if nargin < 3 || isempty(opts); opts = struct(); end
if ~isfield(opts, 'axes');          opts.axes = {'roll', 'pitch', 'yaw'}; end
if ischar(opts.axes) || isstring(opts.axes); opts.axes = cellstr(opts.axes); end
if ~isfield(opts, 'prm_path');      opts.prm_path = '';       end
if ~isfield(opts, 'wc_inner_Hz');   opts.wc_inner_Hz = 3;     end
if ~isfield(opts, 'wc_outer_Hz');   opts.wc_outer_Hz = 1;     end
if ~isfield(opts, 'PM_target_deg'); opts.PM_target_deg = 60;  end
if ~isfield(opts, 'coh_cutoff');    opts.coh_cutoff = 0.8;    end
if ~isfield(opts, 'freq_init_Hz');  opts.freq_init_Hz = 0.01; end
if ~isfield(opts, 'freq_end_Hz');   opts.freq_end_Hz = 5.5;   end
if ~isfield(opts, 'deriv_filter_N'); opts.deriv_filter_N = 10; end
if ~isfield(opts, 'time_slice');    opts.time_slice = true;   end
if ~isfield(opts, 'slices');        opts.slices = struct();   end
if ~isfield(opts, 'visible');       opts.visible = false;     end
if ~isfield(opts, 'formats');       opts.formats = {'png', 'fig'}; end

% sysID_tool dependencies (frequency-response estimation, TF fit, gain design)
addpath('/home/choudhury/repos/sysID_tool');
addpath('/home/choudhury/repos/sysID_tool/Utilities');

% Figure styling. Unlike the original script we do NOT dock or attach the
% toolbar-exploration create-fcn, so this runs under `matlab -batch`.
set(0, 'DefaultLineLineWidth', 2)
set(0, 'DefaultAxesFontSize', 12);
set(0, 'DefaultFigureColor', [1, 1, 1])
prev_vis = get(0, 'DefaultFigureVisible');
if ~opts.visible
    set(0, 'DefaultFigureVisible', 'off');
end
restore_vis = onCleanup(@() set(0, 'DefaultFigureVisible', prev_vis)); %#ok<NASGU>

% Axis -> rpy column index + display labels
axis_defs.roll  = struct('col', 1, 'name', 'Roll',  'rate_sym', 'P', 'cmd', 'Roll Torque Cmd');
axis_defs.pitch = struct('col', 2, 'name', 'Pitch', 'rate_sym', 'Q', 'cmd', 'Pitch Torque Cmd');
axis_defs.yaw   = struct('col', 3, 'name', 'Yaw',   'rate_sym', 'R', 'cmd', 'Yaw Torque Cmd');

% Load flight data
fprintf('[run_system_id] loading %s\n', mat_path);
S = load(mat_path);
if ~isfield(S, 'd')
    error('run_system_id:noD', '%s has no variable ''d''.', mat_path);
end
d = S.d;

% As-flown controller gains (current system), if the params are available
gains = [];
if ~isempty(opts.prm_path) && exist(opts.prm_path, 'file')
    try
        gains = read_px4_gains(opts.prm_path);
        fprintf('[run_system_id] as-flown gains read from %s\n', opts.prm_path);
    catch ME
        warning('run_system_id:prm', 'Could not parse %s: %s', opts.prm_path, ME.message);
    end
else
    warning('run_system_id:noPrm', ['No .prm params provided; current-system margins ' ...
        'will be skipped. For a .mat input, place <name>.prm beside it.']);
end

if ~exist(out_dir, 'dir'); mkdir(out_dir); end

results = struct();
close all

% Overview figure: full body-rate series with the per-axis slice windows shaded.
if opts.time_slice && ~isempty(fieldnames(opts.slices))
    try
        plot_slice_overview(d, opts.slices, out_dir, opts.formats);
    catch ME
        warning('run_system_id:overview', 'time-slice overview failed: %s', ME.message);
    end
end

for ia = 1:numel(opts.axes)
    ax_key = lower(opts.axes{ia});
    if ~isfield(axis_defs, ax_key)
        warning('run_system_id:badAxis', 'Skipping unknown axis ''%s''.', ax_key);
        continue
    end
    A = axis_defs.(ax_key);
    fprintf('\n========== %s axis (rpy column %d) ==========\n', A.name, A.col);

    fig_dir = fullfile(out_dir, 'figures', ax_key);
    if ~exist(fig_dir, 'dir'); mkdir(fig_dir); end

    gax = [];
    if ~isempty(gains) && isfield(gains, ax_key); gax = gains.(ax_key); end

    win = [];
    if opts.time_slice && isfield(opts.slices, ax_key); win = opts.slices.(ax_key); end

    try
        results.(ax_key) = analyze_axis(d, A, opts, gax, win);
    catch ME
        fprintf(2, '[%s] analysis failed: %s\n', A.name, ME.message);
        results.(ax_key) = struct('axis', A.name, 'col', A.col, 'error', ME.message);
    end

    save_all_figures(fig_dir, opts.formats);   % saves partial output on failure too
    close all
end

write_margins(fullfile(out_dir, 'margins.txt'), results);
save(fullfile(out_dir, 'results.mat'), 'results');
fprintf('\n[run_system_id] done. Outputs in %s\n', out_dir);
end


% ======================================================================
function res = analyze_axis(d, A, opts, gax, win)
% Per-axis sys-ID. Produces up to three figure groups:
%   Current    - as-flown analysis on the FULL series (the original method)
%   Time slice - same analysis on the per-axis chirp window (if WIN given)
%   Retune     - pidtune gains, designed from the CURRENT (full-series) plant
% WIN (optional) = [t0 t1] chirp window in absolute avionics seconds.
if nargin < 5; win = []; end
k = A.col;

% Input = attitude setpoint (rad); output = body rate (rad/s).
% (Alternative input: d.vehicle_torque_setpoint_0.)
command_time  = d.vehicle_attitude_setpoint_0.timestamp * 1e-6;
command_defl  = d.vehicle_attitude_setpoint_0.rpy(:, k);
measured_time = d.vehicle_angular_velocity_0.timestamp * 1e-6;
measured_rate = d.vehicle_angular_velocity_0.rpy(:, k);

t    = command_time;
cmd  = command_defl;
rate = interp1(measured_time, measured_rate, t);
valid = ~isnan(rate);          % interp1 -> NaN outside the measurement range
t = t(valid); cmd = cmd(valid); rate = rate(valid);

% CURRENT: full time series (original method) - always produced.
C = eval_dataset('Current', A, opts, gax, t, cmd, rate, '');

% TIME SLICE: per-axis chirp window (only when a window is given).
TS = [];
if ~isempty(win)
    m = t >= win(1) & t <= win(2);
    if nnz(m) < 10
        error('analyze_axis:slice', '%s time slice [%g %g] s has only %d samples.', ...
            A.name, win(1), win(2), nnz(m));
    end
    fprintf('[%s] time slice %g-%g s -> %d samples\n', A.name, win(1), win(2), nnz(m));
    TS = eval_dataset('Time slice', A, opts, gax, t(m), cmd(m), rate(m), ...
        sprintf(' [%g-%g s]', win(1), win(2)));
end

% RETUNE: pidtune designed from the CURRENT (full-series) plant.
[Kp_rate, Ki_rate, Kp_attitude, ~, ~] = ...
    compute_attitude_control_gains(C.num, C.den, C.tau, ...
    opts.PM_target_deg, opts.wc_inner_Hz, opts.wc_outer_Hz) %#ok<NOPRT>
rename_fig('Loop-Gain Bode Plot',       sprintf('%s Retune - Loop-Gain Bode', A.name));
rename_fig('Closed-Loop Bode Plot',     sprintf('%s Retune - Closed-Loop Bode', A.name));
rename_fig('Closed-Loop Step Response', sprintf('%s Retune - Step Response', A.name));

[np, dp] = pade(C.tau, 2);
sys_q = tf(C.num, C.den) * tf(np, dp);
Li_r  = tf([Kp_rate Ki_rate], [1 0]) * sys_q;    % rate (inner) open loop
Ti_r  = feedback(Li_r, 1);
Lo_r  = Kp_attitude * (tf(1, [1 0]) * Ti_r);     % attitude (outer) open loop
To_r  = feedback(Lo_r, 1);
nichols_annotated(Li_r, sprintf('%s Retune - Nichols Rate (Inner) Open Loop', A.name));
nichols_annotated(Lo_r, sprintf('%s Retune - Nichols Attitude (Outer) Open Loop', A.name));
[gm, PM_in_r]  = margin(Li_r); GM_in_r  = mag2db(gm);
[gm, PM_out_r] = margin(Lo_r); GM_out_r = mag2db(gm);
retune = struct('Kp_rate', Kp_rate, 'Ki_rate', Ki_rate, 'Kp_attitude', Kp_attitude, ...
    'GM_in_dB', GM_in_r, 'PM_in_deg', PM_in_r, 'GM_out_dB', GM_out_r, 'PM_out_deg', PM_out_r, ...
    'bw_in_Hz', closed_loop_bw(Ti_r), 'bw_out_Hz', closed_loop_bw(To_r));

res = struct('axis', A.name, 'col', k, 'slice', win, ...
    'current', C, 'timeslice', TS, 'retune', retune);
end


% ======================================================================
function out = eval_dataset(label, A, opts, gax, t, cmd, rate, sl_txt)
% Identify the plant and evaluate the as-flown controller for ONE dataset
% (the full series or a time-sliced window). LABEL ('Current' or 'Time slice')
% prefixes every figure so the groups never collide. Returns the identified
% plant plus the as-flown open-loop margins / closed-loop crossovers.
pfx = sprintf('%s %s', A.name, label);

% Time history (re-zeroed to the start of this dataset)
t = t - t(1);
fig_td = figure('Name', sprintf('%s - Time Domain Data', pfx));
subplot(2, 1, 1)
plot(t, cmd, 'b'); grid on; hold on
ylabel(A.cmd); title(sprintf('%s (%s)%s', A.name, lower(label), sl_txt))
subplot(2, 1, 2)
plot(t, rate * 180 / pi, 'b'); grid on; hold on
ylabel(sprintf('%s (deg/s)', A.rate_sym)); xlabel('Time (sec)')

% Resample to a consistent dt, then detrend
dt   = mean(diff(t));
tu   = (t(1):dt:t(end))';
cmd  = interp1(t, cmd, tu);
rate = interp1(t, rate, tu);
t    = tu;
cmd  = nonlinear_detrend(cmd, t);
rate = nonlinear_detrend(rate, t);
freq_Hz = linspace(0, 1, fix(length(t) / 2) + 1) * ((1 / dt) / 2);

% Frequency response
[mag_dB, phase_deg, freq_meas_Hz, coherence] = ...
    estimate_freq_response(rate, cmd, t, opts.freq_init_Hz, opts.freq_end_Hz);
rename_fig('PSD Calc -- Time Domain', sprintf('%s - PSD Time Domain', pfx));
rename_fig('PSD Calc -- Freq Domain', sprintf('%s - PSD Freq Domain', pfx));

keep = coherence > opts.coh_cutoff;
freq_meas_Hz = freq_meas_Hz(keep);
mag_dB = mag_dB(keep); phase_deg = phase_deg(keep); coherence = coherence(keep);

fig_Bode = figure('Name', sprintf('%s - Plant Bode Plot', pfx));
subplot(3, 1, 1)
semilogx(freq_meas_Hz, mag_dB, 'o', 'LineWidth', 1.5, 'MarkerSize', 6); grid on; hold on
ylabel('Gain (dB)'); xlabel('Frequency (Hz)')
title(sprintf('%s %s (identified)', A.name, lower(label)))
subplot(3, 1, 2)
semilogx(freq_meas_Hz, wrapTo180_custom(phase_deg), 'o', 'LineWidth', 1.5, 'MarkerSize', 6); grid on; hold on
ylabel('Phase (deg)'); xlabel('Frequency (Hz)')
subplot(3, 1, 3)
semilogx(freq_meas_Hz, coherence, 'LineWidth', 1.5, 'MarkerSize', 6); grid on; hold on
ylabel('Coherence '); xlabel('Frequency (Hz)')
linkaxes(findall(gcf, 'type', 'axes'), 'x')

% Fit the plant transfer function
[num, den, tau] = estimate_tf_from_freq_response(freq_meas_Hz, mag_dB, phase_deg, 1, 0);
tf_est = tf(num, den, 'InputDelay', tau);
fr = reshape(freqresp(tf_est, freq_Hz, 'Hz'), size(freq_Hz));
figure(fig_Bode);
subplot(3, 1, 1); semilogx(freq_Hz, 20 * log10(abs(fr)));
legend('Sys-ID Bode Est', 'Transfer Function Estimate', 'Location', 'Best')
subplot(3, 1, 2); semilogx(freq_Hz, angle(fr) * 180 / pi); xlim([0.01, 1000])

% Model-fit overlay on the time-domain figure
q_est = lsim(tf_est, cmd, t);
figure(fig_td);
subplot(2, 1, 1); plot(t, cmd); legend('Raw Input', 'Detrended Input')
subplot(2, 1, 2); plot(t, q_est * 180 / pi); legend('Non-Linear Measurements', 'Linear Sys-ID Model')

out = struct('label', label, 'num', num, 'den', den, 'tau', tau, 'tf_est', tf_est, ...
    'has_current', false, 'Kp', NaN, 'Ki', NaN, 'Kd', NaN, 'Katt', NaN, ...
    'GM_in_dB', NaN, 'PM_in_deg', NaN, 'GM_out_dB', NaN, 'PM_out_deg', NaN, ...
    'bw_in_Hz', NaN, 'bw_out_Hz', NaN);

% As-flown controller against THIS dataset's plant
if ~isempty(gax) && all(~isnan([gax.Kp gax.Ki gax.Katt]))
    [np, dp] = pade(tau, 2);
    sys_q = tf(num, den) * tf(np, dp);
    s = tf('s');
    if gax.Kd > 0 && gax.Kp > 0
        Tf = gax.Kd / (gax.Kp * opts.deriv_filter_N);   % filtered derivative
        C_rate = gax.Kp + gax.Ki / s + gax.Kd * s / (Tf * s + 1);
    else
        C_rate = gax.Kp + gax.Ki / s;                   % PI
    end
    Li = C_rate * sys_q;                Ti = feedback(Li, 1);
    Lo = gax.Katt * (tf(1, [1 0]) * Ti); To = feedback(Lo, 1);
    [gm, pm_in]  = margin(Li); gm_in  = mag2db(gm);
    [gm, pm_out] = margin(Lo); gm_out = mag2db(gm);
    plot_current_loops(pfx, Li, Lo, Ti, To);
    out.has_current = true;
    out.Kp = gax.Kp; out.Ki = gax.Ki; out.Kd = gax.Kd; out.Katt = gax.Katt;
    out.GM_in_dB  = gm_in;  out.PM_in_deg  = pm_in;
    out.GM_out_dB = gm_out; out.PM_out_deg = pm_out;
    out.bw_in_Hz  = closed_loop_bw(Ti); out.bw_out_Hz = closed_loop_bw(To);
    fprintf('[%s %s] inner GM=%.3g dB PM=%.3g deg  outer GM=%.3g dB PM=%.3g deg\n', ...
        A.name, label, gm_in, pm_in, gm_out, pm_out);
end
end


% ======================================================================
function plot_current_loops(prefix, Li, Lo, Ti, To)
% Current-system loop figures (as-flown gains): loop-gain Bode, Nichols
% (inner + outer), and closed-loop step.
figure('Name', sprintf('%s - Loop-Gain Bode', prefix)); margin(Li); grid on
nichols_annotated(Li, sprintf('%s - Nichols Rate (Inner) Open Loop', prefix));
nichols_annotated(Lo, sprintf('%s - Nichols Attitude (Outer) Open Loop', prefix));
figure('Name', sprintf('%s - Step Response', prefix));
subplot(2, 1, 1); step(To); grid on; ylabel('Attitude'); title(sprintf('%s closed-loop step', prefix))
subplot(2, 1, 2); step(Ti); grid on; ylabel('Rate'); xlabel('Time (sec)')
end


% ======================================================================
function g = read_px4_gains(prm_path)
% Parse as-flown PX4 hover (MC) controller gains from a .prm dump.
% Effective rate gains fold in the K multiplier: Kp=K*P, Ki=K*I, Kd=K*D.
txt = fileread(prm_path);
axn = {'ROLL', 'PITCH', 'YAW'};
key = {'roll', 'pitch', 'yaw'};
for i = 1:3
    K = pget(txt, ['MC_' axn{i} 'RATE_K']); if isnan(K); K = 1; end
    P = pget(txt, ['MC_' axn{i} 'RATE_P']);
    I = pget(txt, ['MC_' axn{i} 'RATE_I']);
    D = pget(txt, ['MC_' axn{i} 'RATE_D']); if isnan(D); D = 0; end
    Katt = pget(txt, ['MC_' axn{i} '_P']);
    g.(key{i}) = struct('Kp', K * P, 'Ki', K * I, 'Kd', K * D, 'Katt', Katt);
end
end


% ======================================================================
function v = pget(txt, name)
% Read a single "NAME,value" (or whitespace-separated) parameter; NaN if absent.
tok = regexp(txt, ['(?m)^\s*' name '[,\s]+([-+0-9.eE]+)'], 'tokens', 'once');
if isempty(tok); v = NaN; else; v = str2double(tok{1}); end
end


% ======================================================================
function f_hz = closed_loop_bw(T)
% Closed-loop "crossover" frequency (Hz): the LOWER of
%   (a) the -3 dB gain crossing (3 dB below the DC gain), and
%   (b) the -90 deg phase crossing,
% of the closed-loop transfer function T. NaN if T is unstable or neither
% crossing falls within the search grid.
if ~isstable(T); f_hz = NaN; return; end
w      = logspace(-2, 4, 6000);              % rad/s (~0.0016 .. 1591 Hz)
resp   = squeeze(freqresp(T, w));
mag_dB = 20 * log10(abs(resp));
ph_deg = unwrap(angle(resp)) * 180 / pi;
mag0   = 20 * log10(abs(dcgain(T)));
if ~isfinite(mag0); mag0 = mag_dB(1); end
i_g = find(mag_dB <= mag0 - 3, 1, 'first');  % -3 dB gain crossing
i_p = find(ph_deg <= -90,      1, 'first');  % -90 deg phase crossing
w_c = [];
if ~isempty(i_g); w_c(end + 1) = w(i_g); end %#ok<AGROW>
if ~isempty(i_p); w_c(end + 1) = w(i_p); end %#ok<AGROW>
if isempty(w_c); f_hz = NaN; else; f_hz = min(w_c) / (2 * pi); end
end


% ======================================================================
function s = hzstr(x)
if isnan(x); s = 'n/a'; else; s = sprintf('%.3g Hz', x); end
end


% ======================================================================
function s = dbstr(x)
if isnan(x); s = 'n/a'; elseif isinf(x); s = 'Inf dB'; else; s = sprintf('%.3g dB', x); end
end


% ======================================================================
function s = degstr(x)
if isnan(x); s = 'n/a'; elseif isinf(x); s = 'Inf deg'; else; s = sprintf('%.3g deg', x); end
end


% ======================================================================
function rename_fig(oldName, newName)
% Rename the (just-created) figure(s) carrying oldName.
h = findall(0, 'Type', 'figure', 'Name', oldName);
for i = 1:numel(h); h(i).Name = newName; end
end


% ======================================================================
function save_all_figures(dest_dir, formats)
% Save every open figure into dest_dir, named from each figure's 'Name'.
figs = findall(0, 'Type', 'figure');
if isempty(figs); return; end
[~, order] = sort([figs.Number]);
figs = figs(order);
for i = 1:numel(figs)
    f  = figs(i);
    nm = f.Name;
    if isempty(nm); nm = sprintf('figure_%d', f.Number); end
    base = fullfile(dest_dir, sanitize_name(nm));
    for j = 1:numel(formats)
        switch lower(formats{j})
            case 'png'
                try
                    exportgraphics(f, [base '.png'], 'Resolution', 150);
                catch
                    print(f, [base '.png'], '-dpng', '-r150');
                end
            case {'fig', 'matlab'}
                savefig(f, [base '.fig']);
            otherwise
                try exportgraphics(f, [base '.' lower(formats{j})]); end
        end
    end
end
fprintf('[run_system_id] saved %d figures to %s\n', numel(figs), dest_dir);
end


% ======================================================================
function s = sanitize_name(s)
s = regexprep(s, '[^\w]+', '_');   % non-word chars -> underscore
s = regexprep(s, '_+', '_');       % collapse repeats
s = regexprep(s, '^_|_$', '');     % trim leading/trailing
if isempty(s); s = 'figure'; end
end


% ======================================================================
function write_margins(path, results)
% margins.txt: three groups per axis -- current (full series), time slice
% (chirp window), and retune (pidtune from the full-series plant).
fid = fopen(path, 'w');
if fid < 0; warning('run_system_id:margins', 'cannot write %s', path); return; end
closer = onCleanup(@() fclose(fid)); %#ok<NASGU>
fprintf(fid, 'Stability from flight sys-ID. Three groups per axis:\n');
fprintf(fid, '  current    = as-flown gains on the full-series plant (original method)\n');
fprintf(fid, '  time slice = as-flown gains on the per-axis chirp window\n');
fprintf(fid, '  retune     = pidtune gains, designed from the full-series plant\n');
fprintf(fid, 'GM/PM are open-loop margins; CL crossover = min(-3 dB gain, -90 deg phase) of the closed loop.\n\n');
axs = fieldnames(results);
for i = 1:numel(axs)
    r = results.(axs{i});
    fprintf(fid, '== %s ==\n', axs{i});
    if isfield(r, 'error')
        fprintf(fid, '  FAILED: %s\n\n', r.error);
        continue
    end
    % As-flown gains (shared by current + time slice); from whichever has them.
    g = [];
    if isfield(r, 'current') && ~isempty(r.current) && r.current.has_current
        g = r.current;
    elseif isfield(r, 'timeslice') && ~isempty(r.timeslice) && r.timeslice.has_current
        g = r.timeslice;
    end
    if ~isempty(g)
        fprintf(fid, '  as-flown gains: rate Kp=%.5g  Ki=%.5g  Kd=%.5g   attitude P=%.5g\n', ...
            g.Kp, g.Ki, g.Kd, g.Katt);
    else
        fprintf(fid, '  as-flown gains: (unavailable - no .prm gains found)\n');
    end

    margins_block(fid, 'current (full series)', r.current);
    if isfield(r, 'timeslice') && ~isempty(r.timeslice)
        lbl = 'time slice';
        if isfield(r, 'slice') && ~isempty(r.slice)
            lbl = sprintf('time slice [%g-%g s]', r.slice(1), r.slice(2));
        end
        margins_block(fid, lbl, r.timeslice);
    end
    if isfield(r, 'retune')
        rr = r.retune;
        fprintf(fid, '  -- retune (full-series plant) --\n');
        margin_line(fid, 'inner (rate):',     rr.GM_in_dB,  rr.PM_in_deg,  rr.bw_in_Hz);
        margin_line(fid, 'outer (attitude):', rr.GM_out_dB, rr.PM_out_deg, rr.bw_out_Hz);
    end
    fprintf(fid, '\n');
end
end


% ======================================================================
function margins_block(fid, title, o)
% Print one identification group (plant + as-flown open-loop margins).
fprintf(fid, '  -- %s --\n', title);
fprintf(fid, '    identified plant: num=[%s] den=[%s] tau=%.5g s\n', ...
    num2str(o.num), num2str(o.den), o.tau);
if o.has_current
    margin_line(fid, 'inner (rate):',     o.GM_in_dB,  o.PM_in_deg,  o.bw_in_Hz);
    margin_line(fid, 'outer (attitude):', o.GM_out_dB, o.PM_out_deg, o.bw_out_Hz);
else
    fprintf(fid, '    (no as-flown gains)\n');
end
end


% ======================================================================
function margin_line(fid, label, gm_dB, pm_deg, bw_Hz)
fprintf(fid, '    %-18s GM=%-9s PM=%-10s CL crossover=%s\n', ...
    label, dbstr(gm_dB), degstr(pm_deg), hzstr(bw_Hz));
end


% ======================================================================
function plot_slice_overview(d, slices, out_dir, formats)
% Overview: full body-rate series with each axis's time-slice window shaded,
% so the chosen windows can be confirmed against the actual chirps.
if ~isfield(d, 'vehicle_angular_velocity_0'); return; end
av  = d.vehicle_angular_velocity_0;
t   = av.timestamp * 1e-6;        % absolute avionics seconds
rpy = av.rpy * 180 / pi;          % deg/s
fig_dir = fullfile(out_dir, 'figures');
if ~exist(fig_dir, 'dir'); mkdir(fig_dir); end

f = figure('Name', 'Time Slices Overview');
plot(t, rpy(:, 1), 'DisplayName', 'Roll rate'); hold on; grid on
plot(t, rpy(:, 2), 'DisplayName', 'Pitch rate');
plot(t, rpy(:, 3), 'DisplayName', 'Yaw rate');
yl = ylim;
keys = fieldnames(slices);
cmap = lines(max(numel(keys), 1));
for i = 1:numel(keys)
    w = slices.(keys{i});
    patch([w(1) w(2) w(2) w(1)], [yl(1) yl(1) yl(2) yl(2)], cmap(i, :), ...
        'FaceAlpha', 0.15, 'EdgeColor', 'none', 'DisplayName', [keys{i} ' slice']);
end
ylim(yl);
xlabel('Time (s, avionics)'); ylabel('Body rate (deg/s)');
title('Time slices over full body-rate series'); legend('Location', 'best')

base = fullfile(fig_dir, 'Time_Slices_Overview');
for j = 1:numel(formats)
    switch lower(formats{j})
        case 'png'
            try exportgraphics(f, [base '.png'], 'Resolution', 150);
            catch; print(f, [base '.png'], '-dpng', '-r150'); end
        case {'fig', 'matlab'}
            savefig(f, [base '.fig']);
    end
end
close(f);
end


% ======================================================================
function nichols_annotated(L, figname)
% Nichols plot of an open-loop transfer function L, with frequency points
% annotated in Hz directly on the chart.
figure('Name', figname)
nichols(L); hold on
ngrid

% Sample the response at a set of frequencies to label (0.1 Hz to ~30 Hz)
w_label      = 2 * pi * logspace(-1, 1.5, 10);      % rad/s
[mag, phase] = nichols(L, w_label);
mag          = squeeze(mag);
phase        = squeeze(phase);
gain_dB      = 20 * log10(mag);

plot(phase, gain_dB, 'ro', 'MarkerFaceColor', 'r', 'MarkerSize', 4);
for k = 1:numel(w_label)
    text(phase(k), gain_dB(k), sprintf('  %.2g Hz', w_label(k) / (2 * pi)), ...
        'FontSize', 8, 'Color', 'r');
end
end
