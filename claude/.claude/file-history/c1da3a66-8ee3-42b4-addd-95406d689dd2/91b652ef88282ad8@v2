#!/usr/bin/env bash
# sysID_wrapper.sh -- system-ID + gain design for roll/pitch/yaw.
set -euo pipefail

usage() {
    cat <<'EOF'
sysID_wrapper.sh -- system-ID + gain design for roll/pitch/yaw.

Usage:
  ./sysID_wrapper.sh <config.yaml>           (preferred: YAML drives everything)
  ./sysID_wrapper.sh <file.mat | file.ulg>   (direct; uses built-in defaults)
  [optional 2nd arg] out_base_dir

YAML config keys: ulg_path (required), freq_init_Hz, freq_end_Hz, coh_cutoff,
wc_inner_Hz, wc_outer_Hz, PM_target_deg, time_slice (default true), and per-axis
chirp windows slice_roll/slice_pitch/slice_yaw = [t0, t1] in avionics seconds.

Produces a timestamped run folder <out_base>/<name>_<YYYYmmdd_HHMMSS>/ with:
  figures/{roll,pitch,yaw}/*.png|*.fig, figures/Time_Slices_Overview.* (if slicing),
  margins.txt, results.mat, run.log; a ULog input also yields csv/, params.prm, <name>.mat.
  YAML runs also keep config.json + a copy of the yaml for provenance.

out_base defaults to <input_dir>/output.

Env:
  MATLAB=/path/to/matlab   override the matlab binary (default: matlab)
EOF
}

case "${1:-}" in
    -h|--help) usage; exit 0 ;;
esac
if [[ $# -lt 1 ]]; then usage; exit 1; fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MATLAB="${MATLAB:-matlab}"

arg="$1"
if [[ ! -f "$arg" ]]; then
    echo "error: file not found: $arg" >&2
    exit 1
fi
arg="$(realpath "$arg")"
ext="${arg##*.}"; ext="${ext,,}"

# Resolve the data file (target) and, in YAML mode, the config (cfg).
cfg=""
case "$ext" in
    yaml|yml)
        cfg="$arg"
        if ! command -v python3 >/dev/null 2>&1; then
            echo "error: python3 (with PyYAML) is required to read a YAML config." >&2
            exit 1
        fi
        ulg="$(python3 -c 'import yaml,sys; print(yaml.safe_load(open(sys.argv[1])).get("ulg_path") or "")' "$cfg")"
        if [[ -z "$ulg" ]]; then
            echo "error: '$cfg' has no ulg_path." >&2
            exit 1
        fi
        # resolve ulg_path relative to the yaml's directory if not absolute
        if [[ "$ulg" != /* ]]; then ulg="$(dirname "$cfg")/$ulg"; fi
        if [[ ! -f "$ulg" ]]; then
            echo "error: ulg_path not found: $ulg" >&2
            exit 1
        fi
        target="$(realpath "$ulg")"
        ;;
    mat|ulg|ulog)
        target="$arg"
        ;;
    *)
        echo "error: unsupported extension .$ext (expected .yaml/.yml/.mat/.ulg/.ulog)" >&2
        exit 1
        ;;
esac

name="$(basename "$target")"; name="${name%.*}"
indir="$(dirname "$target")"
out_base="${2:-$indir/output}"
ts="$(date +%Y%m%d_%H%M%S)"
rundir="$out_base/${name}_${ts}"
mkdir -p "$rundir"

# Ensure the pyulog CLI tools (ulog2csv, ulog_params) are resolvable by MATLAB's system().
export PATH="$HOME/.local/bin:$PATH"

if ! command -v "$MATLAB" >/dev/null 2>&1; then
    echo "error: MATLAB ('$MATLAB') not found on PATH. Set MATLAB=/path/to/matlab." >&2
    exit 1
fi

echo "Input : $target"
if [[ -n "$cfg" ]]; then echo "Config: $cfg"; fi
echo "Output: $rundir"

# Build the MATLAB command. YAML mode converts to JSON (provenance + jsondecode).
if [[ -n "$cfg" ]]; then
    python3 -c 'import yaml,json,sys; json.dump(yaml.safe_load(open(sys.argv[1])), open(sys.argv[2],"w"))' "$cfg" "$rundir/config.json"
    cp "$cfg" "$rundir/"
    mlcmd="addpath('$SCRIPT_DIR'); run_sysid('$target','$rundir', sysid_opts_from_json('$rundir/config.json'))"
else
    mlcmd="addpath('$SCRIPT_DIR'); run_sysid('$target','$rundir')"
fi

set +e
"$MATLAB" -batch "$mlcmd" 2>&1 | tee "$rundir/run.log"
status=${PIPESTATUS[0]}
set -e

if [[ $status -ne 0 ]]; then
    echo "MATLAB exited with status $status (see $rundir/run.log)" >&2
    exit "$status"
fi
echo "Done. Results in $rundir"
