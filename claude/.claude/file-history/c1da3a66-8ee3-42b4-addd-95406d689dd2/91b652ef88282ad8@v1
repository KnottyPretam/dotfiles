#!/usr/bin/env bash
# run_sysid.sh -- system-ID + gain design for roll/pitch/yaw from a .mat or ULog.
set -euo pipefail

usage() {
    cat <<'EOF'
run_sysid.sh -- system-ID + gain design for roll/pitch/yaw from a .mat or ULog.

Usage:
  ./run_sysid.sh <file.mat | file.ulg> [out_base_dir]

Produces a timestamped run folder <out_base>/<name>_<YYYYmmdd_HHMMSS>/ with:
  figures/{roll,pitch,yaw}/*.png|*.fig, margins.txt, results.mat, run.log
  (a ULog input also yields csv/, params.prm, <name>.mat)

out_base defaults to <input_dir>/output. A first ULog run writes <name>.mat
into the run folder; pass that .mat on later runs to skip re-extraction.

Env:
  MATLAB=/path/to/matlab   override the matlab binary (default: matlab)
EOF
}

case "${1:-}" in
    -h|--help) usage; exit 0 ;;
esac
if [[ $# -lt 1 ]]; then usage; exit 1; fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MATLAB="${MATLAB:-matlab}"

input="$1"
if [[ ! -f "$input" ]]; then
    echo "error: input file not found: $input" >&2
    exit 1
fi
input="$(realpath "$input")"

ext="${input##*.}"; ext="${ext,,}"
case "$ext" in
    mat|ulg|ulog) ;;
    *) echo "error: unsupported extension .$ext (expected .mat/.ulg/.ulog)" >&2; exit 1 ;;
esac

name="$(basename "$input")"; name="${name%.*}"
indir="$(dirname "$input")"
out_base="${2:-$indir/output}"
ts="$(date +%Y%m%d_%H%M%S)"
rundir="$out_base/${name}_${ts}"
mkdir -p "$rundir"

# Ensure the pyulog CLI tools (ulog2csv, ulog_params) are resolvable by
# MATLAB's system() calls.
export PATH="$HOME/.local/bin:$PATH"

if ! command -v "$MATLAB" >/dev/null 2>&1; then
    echo "error: MATLAB ('$MATLAB') not found on PATH. Set MATLAB=/path/to/matlab." >&2
    exit 1
fi

echo "Input : $input"
echo "Output: $rundir"

set +e
"$MATLAB" -batch "addpath('$SCRIPT_DIR'); run_sysid('$input','$rundir')" 2>&1 | tee "$rundir/run.log"
status=${PIPESTATUS[0]}
set -e

if [[ $status -ne 0 ]]; then
    echo "MATLAB exited with status $status (see $rundir/run.log)" >&2
    exit "$status"
fi
echo "Done. Results in $rundir"
