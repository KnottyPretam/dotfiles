function results = run_system_id_and_gain_design(mat_path, out_dir, opts)
% RUN_SYSTEM_ID_AND_GAIN_DESIGN  Chirp system-ID + cascaded gain design for
% the roll, pitch and yaw axes, saving every figure.
%
%   results = run_system_id_and_gain_design(mat_path, out_dir)
%   results = run_system_id_and_gain_design(mat_path, out_dir, opts)
%
% Loads the struct 'd' from MAT_PATH (Thunderball-style: topics are tables
% carrying .timestamp [us] and an Nx3 .rpy), and for each requested axis
% estimates the rate-loop frequency response from a frequency sweep, fits a
% transfer function, designs cascaded rate(PI)+attitude(P) gains, and draws
% Bode / coherence / PSD / loop-gain / step / Nichols figures. All open
% figures are saved to OUT_DIR/figures/<axis>/ as PNG (+ .fig); a margins
% summary and a results struct are written to OUT_DIR.
%
% opts fields (all optional):
%   axes           cellstr subset of {'roll','pitch','yaw'} (default all)
%   wc_inner_Hz    rate-loop target crossover (default 3)
%   wc_outer_Hz    attitude-loop target crossover (default 1)
%   PM_target_deg  phase-margin target for pidtune (default 60)
%   coh_cutoff     coherence threshold for FRF points (default 0.8)
%   freq_init_Hz   chirp start frequency (default 0.01)
%   freq_end_Hz    chirp end frequency (default 5.5)
%   visible        show figures while running (default false)
%   formats        cellstr of saved formats (default {'png','fig'})

if nargin < 3 || isempty(opts); opts = struct(); end
if ~isfield(opts, 'axes');          opts.axes = {'roll', 'pitch', 'yaw'}; end
if ischar(opts.axes) || isstring(opts.axes); opts.axes = cellstr(opts.axes); end
if ~isfield(opts, 'wc_inner_Hz');   opts.wc_inner_Hz = 3;     end
if ~isfield(opts, 'wc_outer_Hz');   opts.wc_outer_Hz = 1;     end
if ~isfield(opts, 'PM_target_deg'); opts.PM_target_deg = 60;  end
if ~isfield(opts, 'coh_cutoff');    opts.coh_cutoff = 0.8;    end
if ~isfield(opts, 'freq_init_Hz');  opts.freq_init_Hz = 0.01; end
if ~isfield(opts, 'freq_end_Hz');   opts.freq_end_Hz = 5.5;   end
if ~isfield(opts, 'visible');       opts.visible = false;     end
if ~isfield(opts, 'formats');       opts.formats = {'png', 'fig'}; end

% sysID_tool dependencies (frequency-response estimation, TF fit, gain design)
addpath('/home/choudhury/repos/sysID_tool');
addpath('/home/choudhury/repos/sysID_tool/Utilities');

% Figure styling. Unlike the original script we do NOT dock or attach the
% toolbar-exploration create-fcn, so this runs under `matlab -batch`.
set(0, 'DefaultLineLineWidth', 2)
set(0, 'DefaultAxesFontSize', 12);
set(0, 'DefaultFigureColor', [1, 1, 1])
prev_vis = get(0, 'DefaultFigureVisible');
if ~opts.visible
    set(0, 'DefaultFigureVisible', 'off');
end
restore_vis = onCleanup(@() set(0, 'DefaultFigureVisible', prev_vis)); %#ok<NASGU>

% Axis -> rpy column index + display labels
axis_defs.roll  = struct('col', 1, 'name', 'Roll',  'rate_sym', 'P', 'cmd', 'Roll Torque Cmd');
axis_defs.pitch = struct('col', 2, 'name', 'Pitch', 'rate_sym', 'Q', 'cmd', 'Pitch Torque Cmd');
axis_defs.yaw   = struct('col', 3, 'name', 'Yaw',   'rate_sym', 'R', 'cmd', 'Yaw Torque Cmd');

% Load flight data
fprintf('[run_system_id] loading %s\n', mat_path);
S = load(mat_path);
if ~isfield(S, 'd')
    error('run_system_id:noD', '%s has no variable ''d''.', mat_path);
end
d = S.d;

if ~exist(out_dir, 'dir'); mkdir(out_dir); end

results = struct();
close all
for ia = 1:numel(opts.axes)
    ax_key = lower(opts.axes{ia});
    if ~isfield(axis_defs, ax_key)
        warning('run_system_id:badAxis', 'Skipping unknown axis ''%s''.', ax_key);
        continue
    end
    A = axis_defs.(ax_key);
    fprintf('\n========== %s axis (rpy column %d) ==========\n', A.name, A.col);

    fig_dir = fullfile(out_dir, 'figures', ax_key);
    if ~exist(fig_dir, 'dir'); mkdir(fig_dir); end

    try
        results.(ax_key) = analyze_axis(d, A, opts);
    catch ME
        fprintf(2, '[%s] analysis failed: %s\n', A.name, ME.message);
        results.(ax_key) = struct('axis', A.name, 'col', A.col, 'error', ME.message);
    end

    save_all_figures(fig_dir, opts.formats);   % saves partial output on failure too
    close all
end

write_margins(fullfile(out_dir, 'margins.txt'), results, opts);
save(fullfile(out_dir, 'results.mat'), 'results');
fprintf('\n[run_system_id] done. Outputs in %s\n', out_dir);
end


% ======================================================================
function res = analyze_axis(d, A, opts)
% Per-axis sys-ID + gain design. Body of the original script, parameterized
% by the rpy column A.col and axis labels.
k = A.col;

%% Input frequency-sweep test data
command_time  = d.vehicle_torque_setpoint_0.timestamp * 1e-6;
command_defl  = d.vehicle_torque_setpoint_0.rpy(:, k);
measured_time = d.vehicle_angular_velocity_0.timestamp * 1e-6;
measured_rate = d.vehicle_angular_velocity_0.rpy(:, k);

chirp_time_s = command_time;
dele_total   = command_defl;
q_rps        = interp1(measured_time, measured_rate, chirp_time_s);

% Drop command samples outside the measurement time range (interp1 -> NaN;
% a single NaN poisons the cubic detrend and FFT).
valid        = ~isnan(q_rps);
chirp_time_s = chirp_time_s(valid);
dele_total   = dele_total(valid);
q_rps        = q_rps(valid);

%% Plot chirp time history
chirp_time_s = chirp_time_s - chirp_time_s(1);
freq_init_Hz = opts.freq_init_Hz;
freq_end_Hz  = opts.freq_end_Hz;

fig_td = figure('Name', sprintf('%s - Time Domain Data', A.name));
subplot(2, 1, 1)
plot(chirp_time_s, dele_total, 'b'); grid on; hold on
ylabel(A.cmd); title(A.name)
subplot(2, 1, 2)
plot(chirp_time_s, q_rps * 180 / pi, 'b'); grid on; hold on
ylabel(sprintf('%s (deg/s)', A.rate_sym))
xlabel('Time (sec)')

%% Preprocessing
dt = mean(diff(chirp_time_s));

% resample data at consistent DT
t            = [chirp_time_s(1):dt:chirp_time_s(end)]';
dele_total   = interp1(chirp_time_s, dele_total, t);
q_rps        = interp1(chirp_time_s, q_rps, t);
chirp_time_s = t;

% detrend
dele_total = nonlinear_detrend(dele_total, chirp_time_s);
q_rps      = nonlinear_detrend(q_rps, chirp_time_s);

freq_sample  = 1 / dt;
freq_nyquist = freq_sample / 2;
freq_Hz      = linspace(0, 1, fix(length(chirp_time_s) / 2) + 1) * freq_nyquist;

%% Estimate frequency response from the time history
[mag_dB, phase_deg, freq_meas_Hz, coherence, Gyu, Syu, Syy, Suu] = ...
    estimate_freq_response(q_rps, dele_total, chirp_time_s, freq_init_Hz, freq_end_Hz); %#ok<ASGLU>

idx_keep     = coherence > opts.coh_cutoff;   % coherence cutoff limit
freq_meas_Hz = freq_meas_Hz(idx_keep);
mag_dB       = mag_dB(idx_keep);
phase_deg    = phase_deg(idx_keep);
coherence    = coherence(idx_keep);

fig_Bode = figure('Name', sprintf('%s - Plant Bode Plot', A.name));
subplot(3, 1, 1)
semilogx(freq_meas_Hz, mag_dB, 'o', 'LineWidth', 1.5, 'MarkerSize', 6);
grid on; hold on
ylabel('Gain (dB)'); xlabel('Frequency (Hz)')
title(sprintf('%s Plant', A.name))

subplot(3, 1, 2)
semilogx(freq_meas_Hz, wrapTo180_custom(phase_deg), 'o', 'LineWidth', 1.5, 'MarkerSize', 6)
grid on; hold on
ylabel('Phase (deg)'); xlabel('Frequency (Hz)')

subplot(3, 1, 3)
semilogx(freq_meas_Hz, coherence, 'LineWidth', 1.5, 'MarkerSize', 6)
grid on; hold on
ylabel('Coherence '); xlabel('Frequency (Hz)')

linkaxes(findall(gcf, 'type', 'axes'), 'x')

%% Estimate a transfer function
[num, den, tau] = estimate_tf_from_freq_response(freq_meas_Hz, mag_dB, phase_deg, 1, 0);

% Display the estimated transfer function
tf_est = tf(num, den, 'InputDelay', tau) %#ok<NOPRT>

sys_id_freqresp = freqresp(tf_est, freq_Hz, 'Hz');
sys_id_freqresp = reshape(sys_id_freqresp, size(freq_Hz));

figure(fig_Bode);
subplot(3, 1, 1)
semilogx(freq_Hz, 20 * log10(abs(sys_id_freqresp))); grid on; hold on
ylabel('Gain (dB)'); xlabel('Frequency (Hz)')
legend('Sys-ID Bode Est', 'Transfer Function Estimate', 'Location', 'Best')

subplot(3, 1, 2)
semilogx(freq_Hz, angle(sys_id_freqresp) * 180 / pi); grid on; hold on
ylabel('Phase (deg)'); xlabel('Frequency (Hz)')
xlim([0.01, 1000])

%% Compute attitude control gains
PM_target_deg = opts.PM_target_deg;   % keep 45..90; lower = faster but less stable
wc_inner_Hz   = opts.wc_inner_Hz;     % inner-loop bandwidth
wc_outer_Hz   = opts.wc_outer_Hz;     % outer loop 3-5x slower than inner

[Kp_rate, Ki_rate, Kp_attitude, GM_dB, PM_deg] = ...
    compute_attitude_control_gains(num, den, tau, PM_target_deg, wc_inner_Hz, wc_outer_Hz) %#ok<NOPRT>

%% Nichols plots of the open-loop transfer functions
% Reconstruct the open loops exactly as built inside
% compute_attitude_control_gains.m, using the identified plant + gains.
[num_pade, den_pade] = pade(tau, 2);
sys_delay = tf(num_pade, den_pade);
sys_q     = tf(num, den) * sys_delay;        % plant with time delay

sys_Ki    = tf([Kp_rate Ki_rate], [1 0]);    % rate PI controller
Li        = sys_Ki * sys_q;                  % rate (inner) open loop
Ti        = Li / (1 + Li);

sys_theta = tf(1, [1 0]) * Ti;
sys_Ko    = tf(Kp_attitude, 1);              % attitude P controller
Lo        = sys_Ko * sys_theta;              % attitude (outer) open loop

nichols_annotated(Li, sprintf('%s - Nichols Rate (Inner) Open Loop', A.name));
nichols_annotated(Lo, sprintf('%s - Nichols Attitude (Outer) Open Loop', A.name));

%% Plot linear time history
q_est_rps = lsim(tf_est, dele_total, chirp_time_s);

figure(fig_td)
subplot(2, 1, 1)
plot(chirp_time_s, dele_total); grid on; hold on
ylabel(A.cmd)
legend('Raw Input', 'Detrended Input')

subplot(2, 1, 2)
plot(chirp_time_s, q_est_rps * 180 / pi); grid on; hold on
ylabel(sprintf('%s (deg/s)', A.rate_sym))
legend('Non-Linear Measurements', 'Linear Sys-ID Model')
xlabel('Time (sec)')

%% Collect results
res = struct('axis', A.name, 'col', k, 'num', num, 'den', den, 'tau', tau, ...
    'Kp_rate', Kp_rate, 'Ki_rate', Ki_rate, 'Kp_attitude', Kp_attitude, ...
    'GM_dB', GM_dB, 'PM_deg', PM_deg, 'tf_est', tf_est);
end


% ======================================================================
function save_all_figures(dest_dir, formats)
% Save every open figure into dest_dir, named from each figure's 'Name'.
figs = findall(0, 'Type', 'figure');
if isempty(figs); return; end
[~, order] = sort([figs.Number]);
figs = figs(order);
for i = 1:numel(figs)
    f  = figs(i);
    nm = f.Name;
    if isempty(nm); nm = sprintf('figure_%d', f.Number); end
    base = fullfile(dest_dir, sanitize_name(nm));
    for j = 1:numel(formats)
        switch lower(formats{j})
            case 'png'
                try
                    exportgraphics(f, [base '.png'], 'Resolution', 150);
                catch
                    print(f, [base '.png'], '-dpng', '-r150');
                end
            case {'fig', 'matlab'}
                savefig(f, [base '.fig']);
            otherwise
                try exportgraphics(f, [base '.' lower(formats{j})]); end
        end
    end
end
fprintf('[run_system_id] saved %d figures to %s\n', numel(figs), dest_dir);
end


% ======================================================================
function s = sanitize_name(s)
s = regexprep(s, '[^\w]+', '_');   % non-word chars -> underscore
s = regexprep(s, '_+', '_');       % collapse repeats
s = regexprep(s, '^_|_$', '');     % trim leading/trailing
if isempty(s); s = 'figure'; end
end


% ======================================================================
function write_margins(path, results, opts)
fid = fopen(path, 'w');
if fid < 0; warning('run_system_id:margins', 'cannot write %s', path); return; end
closer = onCleanup(@() fclose(fid)); %#ok<NASGU>
fprintf(fid, 'System ID + gain design results\n');
fprintf(fid, 'Tuning: wc_inner=%.3g Hz, wc_outer=%.3g Hz, PM_target=%.3g deg, coh_cutoff=%.3g\n\n', ...
    opts.wc_inner_Hz, opts.wc_outer_Hz, opts.PM_target_deg, opts.coh_cutoff);
axs = fieldnames(results);
for i = 1:numel(axs)
    r = results.(axs{i});
    fprintf(fid, '== %s ==\n', axs{i});
    if isfield(r, 'error')
        fprintf(fid, '  FAILED: %s\n\n', r.error);
        continue
    end
    fprintf(fid, '  plant num:        [%s]\n', num2str(r.num));
    fprintf(fid, '  plant den:        [%s]\n', num2str(r.den));
    fprintf(fid, '  input delay tau:  %.5g s\n', r.tau);
    fprintf(fid, '  Kp_rate=%.5g   Ki_rate=%.5g   Kp_attitude=%.5g\n', ...
        r.Kp_rate, r.Ki_rate, r.Kp_attitude);
    fprintf(fid, '  GM=%.3g dB   PM=%.3g deg\n\n', r.GM_dB, r.PM_deg);
end
end


% ======================================================================
function nichols_annotated(L, figname)
% Nichols plot of an open-loop transfer function L, with frequency points
% annotated in Hz directly on the chart.
figure('Name', figname)
nichols(L); hold on
ngrid

% Sample the response at a set of frequencies to label (0.1 Hz to ~30 Hz)
w_label      = 2 * pi * logspace(-1, 1.5, 10);      % rad/s
[mag, phase] = nichols(L, w_label);
mag          = squeeze(mag);
phase        = squeeze(phase);
gain_dB      = 20 * log10(mag);

plot(phase, gain_dB, 'ro', 'MarkerFaceColor', 'r', 'MarkerSize', 4);
for k = 1:numel(w_label)
    text(phase(k), gain_dB(k), sprintf('  %.2g Hz', w_label(k) / (2 * pi)), ...
        'FontSize', 8, 'Color', 'r');
end
end
