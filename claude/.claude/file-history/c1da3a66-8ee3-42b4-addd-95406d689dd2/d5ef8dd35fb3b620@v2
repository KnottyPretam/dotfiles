function opts = sysid_opts_from_json(jsonpath)
% SYSID_OPTS_FROM_JSON  Build a run_system_id_and_gain_design opts struct from
% a JSON config (produced by sysID_wrapper.sh from the YAML config).
%
%   opts = sysid_opts_from_json(jsonpath)
%
% Recognised keys (all optional except as noted):
%   freq_init_Hz, freq_end_Hz, coh_cutoff, wc_inner_Hz, wc_outer_Hz,
%   PM_target_deg, deriv_filter_N  -> passed straight through to opts
%   time_slice (default true)      -> per-axis chirp windowing on/off
%   slice_roll/slice_pitch/slice_yaw = [t0 t1]  -> opts.slices.<axis>
% Uses only built-in jsondecode (no toolbox, no python).

c = jsondecode(fileread(jsonpath));
opts = struct();

passthrough = {'freq_init_Hz', 'freq_end_Hz', 'coh_cutoff', ...
               'wc_inner_Hz', 'wc_outer_Hz', 'PM_target_deg', 'deriv_filter_N'};
for f = passthrough
    if isfield(c, f{1}) && ~isempty(c.(f{1}))
        opts.(f{1}) = c.(f{1});
    end
end

% Time slicing (default on)
if isfield(c, 'time_slice')
    opts.time_slice = logical(c.time_slice);
else
    opts.time_slice = true;
end

% Per-axis [t0 t1] chirp windows
opts.slices = struct();
map = {'slice_roll', 'roll'; 'slice_pitch', 'pitch'; 'slice_yaw', 'yaw'};
for i = 1:size(map, 1)
    if isfield(c, map{i, 1})
        v = c.(map{i, 1})(:).';
        if numel(v) == 2
            opts.slices.(map{i, 2}) = v;
        end
    end
end
end
