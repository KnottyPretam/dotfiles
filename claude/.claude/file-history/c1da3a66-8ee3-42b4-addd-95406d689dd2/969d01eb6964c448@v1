%% Local functions
function nichols_annotated(L, figname)
% Nichols plot of an open-loop transfer function L, with frequency points
% annotated in Hz directly on the chart.
figure('Name', figname)
nichols(L); hold on
ngrid

% Sample the response at a set of frequencies to label (0.1 Hz to ~30 Hz)
w_label      = 2*pi*logspace(-1, 1.5, 10);          % rad/s
[mag, phase] = nichols(L, w_label);
mag          = squeeze(mag);
phase        = squeeze(phase);
gain_dB      = 20*log10(mag);

plot(phase, gain_dB, 'ro', 'MarkerFaceColor', 'r', 'MarkerSize', 4);
for k = 1:numel(w_label)
    text(phase(k), gain_dB(k), sprintf('  %.2g Hz', w_label(k)/(2*pi)), ...
         'FontSize', 8, 'Color', 'r');
end
end








