def _parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Offline reduced PX4-style IMU/MAG EKF replay tool for ULog files."
    )
    parser.add_argument("logfile", type=Path, help="input PX4 ULog file")
    parser.add_argument(
        "-o",
        "--output",
        type=Path,
        default=None,
        help="output CSV path; default is <logfile>_offline_imu_mag_ekf.csv",
    )
    parser.add_argument(
        "--use-baro",
        action="store_true",
        help="also fuse vehicle_air_data.baro_alt_meter to stabilize vertical position",
    )
    parser.add_argument(
        "--gyro-preprocess-mode",
        choices=("auto", "logged", "reconstruct"),
        default="auto",
        help=(
            "gyro path to feed the EKF replay: "
            "'auto' reconstructs delta_angle from sufficiently dense raw sensor_gyro with PX4-style coning and calibration when possible, "
            "'logged' uses the delta_angle already logged in vehicle_imu/sensor_combined, "
            "'reconstruct' requires raw sensor_gyro reconstruction"
        ),
    )
    parser.add_argument(
        "--imu-source",
        choices=("auto", "vehicle_imu", "fifo", "sensor_combined"),
        default="auto",
        help=(
            "IMU stream that drives the replay: "
            "'auto' rebuilds the full vehicle_imu from raw FIFO when sensor_gyro_fifo/"
            "sensor_accel_fifo are present, else logged vehicle_imu, else sensor_combined; "
            "'fifo' forces full-rate reconstruction from FIFO (both gyro and accel); "
            "'vehicle_imu'/'sensor_combined' use the logged deltas"
        ),
    )
    parser.add_argument(
        "--filter-mode",
        choices=("px4", "inertial"),
        default="inertial",
        help=(
            "states which have measurement aid "
            "'px4' , uses gps, mag, bar, gravity "
            "'inertial' uses the delta_angle already logged in vehicle_imu/sensor_combined, "
        ),
    )
    parser.add_argument(
        "--baro-aid-mode",
        choices=("always",),
        default="always",
        help="baro fusion mode when --use-baro is enabled",
    )
    parser.add_argument(
        "--instance",
        type=int,
        default=0,
        help="ULog topic instance to read when applicable",
    )
    return parser.parse_args()


def main() -> None:
    args = _parse_args()
    log_path = args.logfile.expanduser().resolve()

    if not log_path.exists():
        raise SystemExit(f"log file not found: {log_path}")

    output_path = args.output.expanduser().resolve() if args.output else _default_output_path(log_path)

    run_filter(
        log_path=log_path,
        output_path=output_path,
        use_baro=args.use_baro,
        baro_aid_mode=args.baro_aid_mode,
        gyro_preprocess_mode=args.gyro_preprocess_mode,
        filter_mode=args.filter_mode,
        imu_source=args.imu_source,
        instance=args.instance,
    )

    print(f"wrote offline state estimates to {output_path}")


if __name__ == "__main__":
    main()
