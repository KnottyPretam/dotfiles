#!/usr/bin/env python3
"""Reconstruct NED position/velocity from the IMU the way PX4 EKF2 does it in its
predict step (Ekf::predictState, src/modules/ekf2/EKF/ekf.cpp:253) but WITHOUT the
Kalman/error-state correction -- i.e. pure strapdown dead-reckoning of the IMU.

The reconstruction is overlaid against:
  * the EKF's own NED estimate with +/-3 sigma bounds (estimator_states covariance diagonal),
  * GPS converted into the same local NED frame.

This shows how much the EKF is actually doing: GPS (RTK) is truth, the EKF estimate
should sit inside its +/-3 sigma band, and the IMU-only trace should drift away.

Mode implemented: full strapdown (attitude + velocity + position integrated from the
IMU) with the EKF gyro/accel bias sampled once at init and held constant. Initialized
from the EKF state at the first time the EKF solution/origin is valid, then run free.

IMU source defaults to vehicle_imu -- the topic the (multi-)EKF actually consumes, so the
EKF's frozen bias applies to it. sensor_combined is a different sensor-hub signal whose
bias does NOT match the EKF; selecting it prints a warning.

Two figures are written into <cwd>/<out-dir>/ (default 'ekfPosVel_figures'), each as a
PNG and a pickled matplotlib Figure named <log>_<name>.{png,fig.pkl}:
  * <log>_ned_reconstruction : IMU recon vs EKF (+/-3 sigma) vs GPS, NED position & velocity.
                               The Down position panel also carries a baro-derived trace.
  * <log>_gps_drift          : GPS position (+/-eph/epv) vs GPS-Doppler-integrated vs EKF vs
                               IMU recon (+ baro on Down), plus HDOP/VDOP -- to tell real
                               motion from GPS drift.
Reopen a pickle with: python3 show_figure.py <file.fig.pkl>
"""

import argparse
import os
import pickle
import sys

import numpy as np

# PX4 constants (src/lib/geo/geo.h)
CONST_G = 9.80665           # CONSTANTS_ONE_G  [m/s^2]
R_EARTH = 6371000.0         # CONSTANTS_RADIUS_OF_EARTH  [m]


# --------------------------------------------------------------------------- #
# ULog access helpers
# --------------------------------------------------------------------------- #
def get_dataset(ulog, name, multi_id=0):
    for d in ulog.data_list:
        if d.name == name and d.multi_id == multi_id:
            return d
    return None


def require(ds, name):
    if ds is None:
        sys.exit(f"ERROR: required topic '{name}' not found in log")
    return ds


def vec3(ds, base):
    """Stack 'base[0..2]' fields into an (N, 3) array."""
    return np.column_stack([ds.data[f"{base}[{i}]"] for i in range(3)])


def tsec(ds):
    return np.asarray(ds.data["timestamp"], dtype=np.float64) * 1e-6


# --------------------------------------------------------------------------- #
# NED projection -- replicates PX4 MapProjection (azimuthal equidistant, src/lib/geo/geo.cpp)
# --------------------------------------------------------------------------- #
class MapProjection:
    def __init__(self, ref_lat_deg, ref_lon_deg):
        self.ref_lat = np.radians(ref_lat_deg)
        self.ref_lon = np.radians(ref_lon_deg)
        self.sin_lat = np.sin(self.ref_lat)
        self.cos_lat = np.cos(self.ref_lat)

    def project(self, lat_deg, lon_deg):
        """(lat, lon) in degrees -> (north, east) in metres."""
        lat = np.radians(np.asarray(lat_deg, dtype=np.float64))
        lon = np.radians(np.asarray(lon_deg, dtype=np.float64))
        sl, cl = np.sin(lat), np.cos(lat)
        cd = np.cos(lon - self.ref_lon)
        arg = np.clip(self.sin_lat * sl + self.cos_lat * cl * cd, -1.0, 1.0)
        c = np.arccos(arg)
        sinc = np.sin(c)
        k = np.where(np.abs(c) > 1e-12, c / np.where(sinc == 0.0, 1.0, sinc), 1.0)
        x = k * (self.cos_lat * sl - self.sin_lat * cl * cd) * R_EARTH
        y = k * cl * np.sin(lon - self.ref_lon) * R_EARTH
        return x, y


# --------------------------------------------------------------------------- #
# Quaternion helpers -- scalar-first [w, x, y, z], Hamilton product (PX4 matrix::Quatf)
# --------------------------------------------------------------------------- #
def quat_mult(q, r):
    w0, x0, y0, z0 = q
    w1, x1, y1, z1 = r
    return np.array([
        w0 * w1 - x0 * x1 - y0 * y1 - z0 * z1,
        w0 * x1 + x0 * w1 + y0 * z1 - z0 * y1,
        w0 * y1 - x0 * z1 + y0 * w1 + z0 * x1,
        w0 * z1 + x0 * y1 - y0 * x1 + z0 * w1,
    ])


def quat_to_dcm(q):
    """Body -> earth rotation matrix (matches PX4 Dcmf(Quatf))."""
    w, x, y, z = q
    return np.array([
        [1 - 2 * (y * y + z * z), 2 * (x * y - w * z),     2 * (x * z + w * y)],
        [2 * (x * y + w * z),     1 - 2 * (x * x + z * z), 2 * (y * z - w * x)],
        [2 * (x * z - w * y),     2 * (y * z + w * x),     1 - 2 * (x * x + y * y)],
    ])


def axis_angle_to_quat(v):
    """Rotation vector -> quaternion (matches AxisAnglef -> Quatf)."""
    theta = float(np.linalg.norm(v))
    if theta < 1e-9:
        q = np.array([1.0, 0.5 * v[0], 0.5 * v[1], 0.5 * v[2]])
        return q / np.linalg.norm(q)
    s = np.sin(0.5 * theta) / theta
    return np.array([np.cos(0.5 * theta), s * v[0], s * v[1], s * v[2]])


def qnorm(q):
    return q / np.linalg.norm(q)


# --------------------------------------------------------------------------- #
# PX4 rotations & calibration (replicate src/lib/conversion/rotation.* and
# src/lib/sensor_calibration/{Gyroscope,Accelerometer}) -- needed to rebuild
# vehicle_imu from raw FIFO in the EKF's body frame.
# --------------------------------------------------------------------------- #
# rot_lookup table (roll, pitch, yaw in degrees), rotation.h:107
ROT_LOOKUP = [
    (0, 0, 0), (0, 0, 45), (0, 0, 90), (0, 0, 135), (0, 0, 180), (0, 0, 225), (0, 0, 270),
    (0, 0, 315), (180, 0, 0), (180, 0, 45), (180, 0, 90), (180, 0, 135), (0, 180, 0),
    (180, 0, 225), (180, 0, 270), (180, 0, 315), (90, 0, 0), (90, 0, 45), (90, 0, 90),
    (90, 0, 135), (270, 0, 0), (270, 0, 45), (270, 0, 90), (270, 0, 135), (0, 90, 0),
    (0, 270, 0), (0, 180, 90), (0, 180, 270), (90, 90, 0), (180, 90, 0), (270, 90, 0),
    (90, 180, 0), (270, 180, 0), (90, 270, 0), (180, 270, 0), (270, 270, 0), (90, 180, 90),
    (90, 0, 270), (90, 68, 293), (0, 315, 0), (90, 315, 0), (0, 225, 0), (180, 45, 0),
    (0, 90, 180),
]


def euler_to_quat(roll, pitch, yaw):
    """PX4 Quatf(Eulerf): scalar-first [w,x,y,z], 3-2-1 sequence."""
    cr, sr = np.cos(roll / 2), np.sin(roll / 2)
    cp, sp = np.cos(pitch / 2), np.sin(pitch / 2)
    cy, sy = np.cos(yaw / 2), np.sin(yaw / 2)
    return np.array([cr * cp * cy + sr * sp * sy,
                     sr * cp * cy - cr * sp * sy,
                     cr * sp * cy + sr * cp * sy,
                     cr * cp * sy - sr * sp * cy])


def euler_to_dcm(roll, pitch, yaw):
    """Matches PX4 Dcmf(Eulerf) (via Quatf), consistent with quat_to_dcm."""
    return quat_to_dcm(euler_to_quat(roll, pitch, yaw))


def get_rot_matrix(rot):
    """PX4 get_rot_matrix(enum Rotation): DCM from the rot_lookup Euler angles."""
    r, p, y = ROT_LOOKUP[int(rot)]
    return euler_to_dcm(np.radians(r), np.radians(p), np.radians(y))


def sensor_rotation(params, cal_rot):
    """Sensor->body rotation (calibration set_rotation): board level offsets * board
    rotation for internal sensors (CAL_*_ROT<0), or the per-sensor CAL_*_ROT (external)."""
    off = euler_to_dcm(np.radians(params.get("SENS_BOARD_X_OFF", 0.0)),
                       np.radians(params.get("SENS_BOARD_Y_OFF", 0.0)),
                       np.radians(params.get("SENS_BOARD_Z_OFF", 0.0)))
    rot_used = cal_rot if (cal_rot is not None and cal_rot >= 0) else int(params.get("SENS_BOARD_ROT", 0))
    return off @ get_rot_matrix(rot_used)


def find_cal(params, device_id, kind):
    """(offset[3], scale[3], rot) for the CAL_{GYRO,ACC}n whose ID matches device_id."""
    for n in range(4):
        if int(params.get(f"CAL_{kind}{n}_ID", 0)) == int(device_id):
            off = np.array([params.get(f"CAL_{kind}{n}_{a}OFF", 0.0) for a in "XYZ"])
            scale = (np.array([params.get(f"CAL_{kind}{n}_{a}SCALE", 1.0) for a in "XYZ"])
                     if kind == "ACC" else np.ones(3))
            return off, scale, int(params.get(f"CAL_{kind}{n}_ROT", -1))
    return np.zeros(3), np.ones(3), -1


# --------------------------------------------------------------------------- #
# IMU delta source (vehicle_imu = EKF input; sensor_combined / FIFO fallbacks)
# --------------------------------------------------------------------------- #
def _imu_by_device(ulog, name, gyro_dev, accel_dev):
    for d in ulog.data_list:
        if d.name == name and (gyro_dev is None or int(d.data["gyro_device_id"][0]) == int(gyro_dev)):
            return d
    return None


def _fifo_by_device(ulog, name, device_id):
    if device_id is None:
        return None
    for d in ulog.data_list:
        if d.name == name and int(d.data["device_id"][0]) == int(device_id):
            return d
    return None
def _deltas_from_sensor_combined(ulog):
    d = require(get_dataset(ulog, "sensor_combined", 0), "sensor_combined")
    t = tsec(d)
    gyro = vec3(d, "gyro_rad")                 # rad/s, body FRD
    accel = vec3(d, "accelerometer_m_s2")      # m/s^2, body FRD
    # Integrate each sample over its own integration window (= predictState's
    # delta_*_dt). Logging dropouts are spliced over rather than stretched: this
    # keeps per-step attitude increments tiny, so a multi-second gap does not inject
    # a huge one-step rotation that would leak gravity into the horizontal channels.
    dt_ang = np.asarray(d.data["gyro_integral_dt"], dtype=np.float64) * 1e-6
    dt_vel = np.asarray(d.data["accelerometer_integral_dt"], dtype=np.float64) * 1e-6
    return t, gyro * dt_ang[:, None], accel * dt_vel[:, None], dt_ang, dt_vel


def _deltas_from_vehicle_imu(ulog, gyro_dev=None, accel_dev=None):
    d = require(_imu_by_device(ulog, "vehicle_imu", gyro_dev, accel_dev)
                or get_dataset(ulog, "vehicle_imu", 0), "vehicle_imu")
    t = tsec(d)
    dang = vec3(d, "delta_angle")              # rad (already integrated)
    dvel = vec3(d, "delta_velocity")           # m/s (already integrated)
    dt_ang = np.asarray(d.data["delta_angle_dt"], dtype=np.float64) * 1e-6
    dt_vel = np.asarray(d.data["delta_velocity_dt"], dtype=np.float64) * 1e-6
    return t, dang, dvel, dt_ang, dt_vel


def _fifo_samples(d):
    """Per-message batch trapezoidal-mean rate at timestamp_sample -- replicates the driver
    (PX4Gyroscope/Accelerometer::updateFIFO), i.e. the sensor_gyro/accel the EKF's VehicleIMU
    integrates. This batch-averaging low-passes the high-rate FIFO (board FRD frame)."""
    ts = np.asarray(d.data["timestamp_sample"], np.float64) * 1e-6   # s, time of LAST sample
    scale = np.asarray(d.data["scale"], np.float64)
    ns = np.asarray(d.data["samples"]).astype(int)
    nmax = int(ns.max())
    valid = np.arange(nmax)[None, :] < ns[:, None]
    rate = np.empty((len(ts), 3))
    for ci, ax in enumerate("xyz"):
        Xc = np.column_stack([np.asarray(d.data[f"{ax}[{k}]"], np.float64) for k in range(nmax)])
        last = Xc[np.arange(len(ns)), ns - 1]                 # last raw sample of each batch
        prev_last = np.concatenate([[last[0]], last[:-1]])    # previous batch's last sample
        rowsum = np.where(valid, Xc, 0.0).sum(axis=1)
        # trapezoidal sum over [prev_last, x0..x_{N-1}] = 0.5*prev_last + rowsum - 0.5*last
        rate[:, ci] = (0.5 * prev_last + rowsum - 0.5 * last) / ns * scale
    return ts, rate


def _coning_beta(dag, w, nw):
    """Per-window coning correction (IntegratorConing): beta += 0.5*((last_alpha +
    last_delta_alpha/6) x delta_alpha), accumulated within each (reset-per-window) window."""
    ca = np.cumsum(dag, axis=0)
    nb = int(w.max()) + 1
    last_idx = np.searchsorted(w, np.arange(nb), side="right") - 1     # last seg of each window
    end_ca = np.zeros((nb, 3)); ok = last_idx >= 0
    end_ca[np.arange(nb)[ok]] = ca[last_idx[ok]]
    base = np.where(w[:, None] > 0, end_ca[np.clip(w - 1, 0, nb - 1)], 0.0)
    alpha_incl = ca - base                                    # alpha within window up to & incl i
    last_alpha = alpha_incl - dag                             # alpha within window before i
    last_delta = np.vstack([np.zeros((1, 3)), dag[:-1]])
    coning = 0.5 * np.cross(last_alpha + last_delta / 6.0, dag)
    beta = np.zeros((nw, 3)); np.add.at(beta, w, coning)
    return beta


def _integrate_windows(tg, vg, ta, va, win_dt):
    """Integrate gyro (trapezoidal + coning) & accel (trapezoidal) into common win_dt windows,
    replicating VehicleIMU's Integrator/IntegratorConing. Returns paired
    (t, d_ang, dt_ang, d_vel, dt_vel) in board FRD."""
    t0 = min(tg[0], ta[0])
    dtg = np.diff(tg); dag = 0.5 * (vg[1:] + vg[:-1]) * dtg[:, None]   # gyro trapezoidal deltas
    wg = np.floor((tg[1:] - t0) / win_dt).astype(int)
    dtv = np.diff(ta); dav = 0.5 * (va[1:] + va[:-1]) * dtv[:, None]   # accel trapezoidal deltas
    wa = np.floor((ta[1:] - t0) / win_dt).astype(int)
    nw = max(int(wg.max()), int(wa.max())) + 1

    DANG = np.zeros((nw, 3)); DTG = np.zeros(nw); TG = np.zeros(nw)
    np.add.at(DANG, wg, dag); np.add.at(DTG, wg, dtg); np.maximum.at(TG, wg, tg[1:])
    DANG += _coning_beta(dag, wg, nw)                         # add coning per window
    DVEL = np.zeros((nw, 3)); DTA = np.zeros(nw)
    np.add.at(DVEL, wa, dav); np.add.at(DTA, wa, dtv)
    ok = (DTG > 0.5 * win_dt) & (DTA > 0.5 * win_dt)          # keep ~full windows
    return TG[ok], DANG[ok], DTG[ok], DVEL[ok], DTA[ok]


def _deltas_from_fifo(ulog, params, gyro_dev, accel_dev):
    """Rebuild vehicle_imu (delta_angle/velocity in body FRD) from raw FIFO, the same
    way PX4 firmware does: integrate over IMU_INTEG_RATE windows, then calibrate
    (offset, accel scale, board->body rotation)."""
    gd = require(_fifo_by_device(ulog, "sensor_gyro_fifo", gyro_dev),
                 f"sensor_gyro_fifo (device {gyro_dev})")
    ad = require(_fifo_by_device(ulog, "sensor_accel_fifo", accel_dev),
                 f"sensor_accel_fifo (device {accel_dev})")
    tg, vg = _fifo_samples(gd)
    ta, va = _fifo_samples(ad)
    win = 1.0 / int(params.get("IMU_INTEG_RATE", 200))
    t, dang_raw, dt_ang, dvel_raw, dt_vel = _integrate_windows(tg, vg, ta, va, win)

    g_off, _, g_rot = find_cal(params, gyro_dev, "GYRO")
    a_off, a_scale, a_rot = find_cal(params, accel_dev, "ACC")
    Rg = sensor_rotation(params, g_rot)
    Ra = sensor_rotation(params, a_rot)
    # Calibration is affine and constant over a window, so applying it to the integrated
    # delta is identical to per-sample (VehicleIMU does it post-integration too).
    dang = (dang_raw - g_off * dt_ang[:, None]) @ Rg.T
    dvel = ((dvel_raw - a_off * dt_vel[:, None]) * a_scale) @ Ra.T
    return t, dang, dvel, dt_ang, dt_vel


def get_imu_deltas(ulog, source, params, gyro_dev, accel_dev):
    """Return (label, t[s], dang[N,3], dvel[N,3], dt_ang[N], dt_vel[N])."""
    def vi_rate():
        d = _imu_by_device(ulog, "vehicle_imu", gyro_dev, accel_dev)
        if d is None:
            return None
        tt = tsec(d)
        return (len(tt) - 1) / (tt[-1] - tt[0]) if len(tt) > 1 else 0.0

    def fifo_present():
        return (_fifo_by_device(ulog, "sensor_gyro_fifo", gyro_dev) is not None
                and _fifo_by_device(ulog, "sensor_accel_fifo", accel_dev) is not None)

    if source == "auto":
        r = vi_rate()
        if r is not None and r > 50.0:        # full-rate vehicle_imu: best
            source = "vehicle_imu"
        elif fifo_present():                  # rebuild full-rate from FIFO
            source = "fifo"
        elif r is not None:                   # decimated vehicle_imu (no FIFO)
            source = "vehicle_imu"
        else:
            source = "sensor_combined"

    if source == "fifo":
        return ("fifo",) + _deltas_from_fifo(ulog, params, gyro_dev, accel_dev)
    if source == "vehicle_imu":
        return ("vehicle_imu",) + _deltas_from_vehicle_imu(ulog, gyro_dev, accel_dev)
    return ("sensor_combined",) + _deltas_from_sensor_combined(ulog)


# --------------------------------------------------------------------------- #
# EKF instance / IMU device resolution
# --------------------------------------------------------------------------- #
def find_ekf_instance(ulog, requested):
    """Use the requested estimator instance if present, else the first available one
    (multi-EKF logs may only carry the selected primary, e.g. instance 1)."""
    if get_dataset(ulog, "estimator_states", requested) is not None:
        return requested
    for i in range(6):
        if get_dataset(ulog, "estimator_states", i) is not None:
            return i
    sys.exit("ERROR: no estimator_states found in log")


def ekf_imu_devices(ulog, inst):
    """(gyro_device_id, accel_device_id) the EKF instance uses -- to match FIFO/CAL/vehicle_imu."""
    for src in (get_dataset(ulog, "estimator_sensor_bias", inst),
                get_dataset(ulog, "estimator_status", inst),
                get_dataset(ulog, "estimator_sensor_bias", 0)):
        if src is not None and "gyro_device_id" in src.data:
            return int(src.data["gyro_device_id"][0]), int(src.data["accel_device_id"][0])
    vi = get_dataset(ulog, "vehicle_imu", inst) or get_dataset(ulog, "vehicle_imu", 0)
    if vi is not None:
        return int(vi.data["gyro_device_id"][0]), int(vi.data["accel_device_id"][0])
    return None, None


# --------------------------------------------------------------------------- #
# Initialization: t_init, NED origin, and seed state/bias from the EKF
# --------------------------------------------------------------------------- #
def find_init(ulog, inst):
    elp = require(get_dataset(ulog, "estimator_local_position", inst),
                  "estimator_local_position")
    ref_lat = np.asarray(elp.data["ref_lat"], dtype=np.float64)
    valid = np.isfinite(ref_lat) & (np.abs(ref_lat) > 1e-9)
    if not valid.any():
        sys.exit("ERROR: EKF local origin (ref_lat) is never valid in this log")
    i0 = int(np.argmax(valid))
    t_init = float(tsec(elp)[i0])
    ref = (float(elp.data["ref_lat"][i0]),
           float(elp.data["ref_lon"][i0]),
           float(elp.data["ref_alt"][i0]))

    es = require(get_dataset(ulog, "estimator_states", inst), "estimator_states")
    te = tsec(es)
    k = int(np.argmin(np.abs(te - t_init)))
    q0 = qnorm(np.array([es.data[f"states[{i}]"][k] for i in range(0, 4)], dtype=np.float64))
    v0 = np.array([es.data[f"states[{i}]"][k] for i in range(4, 7)], dtype=np.float64)
    p0 = np.array([es.data[f"states[{i}]"][k] for i in range(7, 10)], dtype=np.float64)

    b_gyro, b_accel, bias_src = _frozen_bias(ulog, inst, t_init, es, te, k)
    return dict(t_init=t_init, ref=ref, q0=q0, v0=v0, p0=p0,
                b_gyro=b_gyro, b_accel=b_accel, bias_src=bias_src)


def _frozen_bias(ulog, inst, t_init, es, te, k):
    """Gyro/accel bias in rate units [rad/s], [m/s^2], frozen at t_init."""
    sb = get_dataset(ulog, "estimator_sensor_bias", inst) or \
        get_dataset(ulog, "estimator_sensor_bias", 0)
    if sb is not None and "gyro_bias[0]" in sb.data:
        j = int(np.argmin(np.abs(tsec(sb) - t_init)))
        b_gyro = np.array([sb.data[f"gyro_bias[{i}]"][j] for i in range(3)], dtype=np.float64)
        b_accel = np.array([sb.data[f"accel_bias[{i}]"][j] for i in range(3)], dtype=np.float64)
        return b_gyro, b_accel, "estimator_sensor_bias"
    # Fallback: state stores integrated bias (delta_ang_bias [rad], delta_vel_bias [m/s]);
    # divide by the average EKF step to get rate units (getGyroBias/getAccelBias, ekf.h).
    dt_ekf = float(np.median(np.diff(te)))
    b_gyro = np.array([es.data[f"states[{i}]"][k] for i in range(10, 13)], dtype=np.float64) / dt_ekf
    b_accel = np.array([es.data[f"states[{i}]"][k] for i in range(13, 16)], dtype=np.float64) / dt_ekf
    return b_gyro, b_accel, f"states/dt_ekf({dt_ekf*1e3:.2f}ms)"


# --------------------------------------------------------------------------- #
# Strapdown integration -- mirrors Ekf::predictState minus the Kalman update
# --------------------------------------------------------------------------- #
def strapdown(t, dang, dvel, dt_ang, dt_vel, init):
    """Integrate from the EKF seed state at t_init to the end of the log."""
    q = qnorm(init["q0"].copy())
    v = init["v0"].astype(np.float64).copy()
    p = init["p0"].astype(np.float64).copy()
    b_gyro, b_accel = init["b_gyro"], init["b_accel"]

    idx = np.where(t > init["t_init"])[0]
    out_t = [init["t_init"]]
    out_v = [v.copy()]
    out_p = [p.copy()]
    out_qn = [1.0]
    for i in idx:
        dta, dtv = float(dt_ang[i]), float(dt_vel[i])
        dang_c = dang[i] - b_gyro * dta          # de-bias delta angle  (rate*dt_ang)
        dvel_c = dvel[i] - b_accel * dtv         # de-bias delta velocity
        q = qnorm(quat_mult(q, axis_angle_to_quat(dang_c)))   # q (x) dq
        dvel_e = quat_to_dcm(q) @ dvel_c         # body -> earth
        v_last = v.copy()
        v = v + dvel_e
        v[2] += CONST_G * dtv                    # +g on the Down axis
        p = p + 0.5 * (v_last + v) * dtv         # trapezoidal position
        out_t.append(t[i])
        out_v.append(v.copy())
        out_p.append(p.copy())
        out_qn.append(float(np.linalg.norm(q)))
    return (np.asarray(out_t), np.asarray(out_v),
            np.asarray(out_p), np.asarray(out_qn))


# --------------------------------------------------------------------------- #
# GPS -> NED
# --------------------------------------------------------------------------- #
def gps_to_ned(ulog, proj, ref_alt):
    g = get_dataset(ulog, "vehicle_gps_position", 0) or get_dataset(ulog, "sensor_gps", 0)
    g = require(g, "vehicle_gps_position/sensor_gps")
    t = tsec(g)
    fix = np.asarray(g.data["fix_type"])
    vvalid = np.asarray(g.data["vel_ned_valid"]).astype(bool)
    lat = np.asarray(g.data["lat"], dtype=np.float64) * 1e-7
    lon = np.asarray(g.data["lon"], dtype=np.float64) * 1e-7
    alt = np.asarray(g.data["alt"], dtype=np.float64) * 1e-3
    x, y = proj.project(lat, lon)
    z = -(alt - ref_alt)                         # NED down (positive down)
    pos = np.column_stack([x, y, z])
    vel = np.column_stack([g.data["vel_n_m_s"], g.data["vel_e_m_s"], g.data["vel_d_m_s"]])
    # Position from integrating GPS Doppler velocity (independent of the position solution;
    # a stationary receiver gives ~0 here even if the position solution wanders).
    dop = np.empty_like(pos)
    dop[0] = pos[0]
    dop[1:] = pos[0] + np.cumsum(0.5 * (vel[1:] + vel[:-1]) * np.diff(t)[:, None], axis=0)

    def field(name):
        return np.asarray(g.data[name], dtype=np.float64) if name in g.data else None

    return dict(t=t, pos=pos, pos_ok=(fix >= 3), vel=vel, vel_ok=(vvalid & (fix >= 3)),
                dop_pos=dop, eph=field("eph"), epv=field("epv"),
                hdop=field("hdop"), vdop=field("vdop"))


# --------------------------------------------------------------------------- #
# Baro -> NED Down position
# --------------------------------------------------------------------------- #
def baro_to_ned(ulog, p0_down, t_init):
    """Barometric Down position in the EKF NED frame, anchored to the seed Down at t_init:
    down = p0_down - (baro_alt - baro_alt(t_init)). The baro datum is offset from the NED
    origin altitude (and the EKF baro bias drifts), so an absolute conversion would not line
    up; anchoring at t_init starts the trace on the seed (like the IMU recon) and shows
    relative vertical motion. Baro measures altitude (a vertical *position*), so only Down
    position is produced -- not velocity. Returns None if vehicle_air_data is absent."""
    d = get_dataset(ulog, "vehicle_air_data", 0)
    if d is None:
        return None
    t = tsec(d)
    alt = np.asarray(d.data["baro_alt_meter"], dtype=np.float64)
    a0 = float(np.interp(t_init, t, alt))
    return dict(t=t, down=p0_down - (alt - a0))


# --------------------------------------------------------------------------- #
# EKF estimate + 3-sigma
# --------------------------------------------------------------------------- #
def ekf_estimate(ulog, inst):
    es = require(get_dataset(ulog, "estimator_states", inst), "estimator_states")
    te = tsec(es)
    pos = np.column_stack([es.data[f"states[{i}]"] for i in range(7, 10)])
    vel = np.column_stack([es.data[f"states[{i}]"] for i in range(4, 7)])
    cov_p = np.column_stack([es.data[f"covariances[{i}]"] for i in range(7, 10)])
    cov_v = np.column_stack([es.data[f"covariances[{i}]"] for i in range(4, 7)])
    s3_p = 3.0 * np.sqrt(np.clip(cov_p, 0.0, None))
    s3_v = 3.0 * np.sqrt(np.clip(cov_v, 0.0, None))
    return dict(t=te, pos=pos, vel=vel, s3_pos=s3_p, s3_vel=s3_v)


def load_setpoint(ulog):
    """Position controller's NED setpoint (vehicle_local_position_setpoint), same frame as the
    EKF estimate. Fields are NaN when position/velocity control is inactive; returns None if all NaN."""
    d = get_dataset(ulog, "vehicle_local_position_setpoint", 0)
    if d is None:
        return None
    n = len(d.data["timestamp"])
    pos = np.column_stack([np.asarray(d.data.get(k, np.full(n, np.nan)), float) for k in ("x", "y", "z")])
    vel = np.column_stack([np.asarray(d.data.get(k, np.full(n, np.nan)), float) for k in ("vx", "vy", "vz")])
    if not np.isfinite(np.concatenate([pos, vel])).any():
        return None
    return dict(t=tsec(d), pos=pos, vel=vel)


# --------------------------------------------------------------------------- #
# Plot
# --------------------------------------------------------------------------- #
def _fit_ylim(ax, arrays):
    lo, hi = np.inf, -np.inf
    for a in arrays:
        a = np.asarray(a)
        a = a[np.isfinite(a)]
        if a.size:
            lo = min(lo, a.min())
            hi = max(hi, a.max())
    if np.isfinite(lo) and np.isfinite(hi):
        m = 0.1 * ((hi - lo) if hi > lo else 1.0)
        ax.set_ylim(lo - m, hi + m)


def make_recon_figure(plt, ekf, gps, rec, sp, baro, t_init, t0, imu_label, full_scale, title):
    fig, axes = plt.subplots(3, 2, figsize=(14, 10), sharex=True)
    names = ["North", "East", "Down"]

    for r in range(3):
        for col, (key, s3key, ylab) in enumerate(
                [("pos", "s3_pos", "pos [m]"), ("vel", "s3_vel", "vel [m/s]")]):
            ax = axes[r, col]
            est = ekf[key][:, r]
            s3 = ekf[s3key][:, r]
            ax.fill_between(ekf["t"] - t0, est - s3, est + s3,
                            color="C0", alpha=0.20, lw=0, label="EKF $\\pm3\\sigma$")
            ax.plot(ekf["t"] - t0, est, "C0", lw=1.0, label="EKF estimate")
            ok = gps[f"{key}_ok"]
            ax.plot(gps["t"][ok] - t0, gps[key][ok, r], ".", color="C1", ms=3,
                    label="GPS")
            if sp is not None:
                ax.plot(sp["t"] - t0, sp[key][:, r], "C2", lw=1.0, ls="--", label="setpoint")
            ax.plot(rec["t"] - t0, rec[key][:, r], "C3", lw=1.0,
                    label="IMU recon (no EKF)")
            if baro is not None and r == 2 and key == "pos":
                ax.plot(baro["t"] - t0, baro["down"], color="C6", lw=1.0,
                        label="baro Down position")
            ax.axvline(t_init - t0, ls="--", color="k", lw=0.8, alpha=0.5)
            ax.set_ylabel(f"{names[r]} {ylab}")
            ax.grid(True, alpha=0.3)
            if not full_scale:
                fit = [est - s3, est + s3, gps[key][ok, r]]
                if sp is not None:
                    fit.append(sp[key][:, r])
                if baro is not None and r == 2 and key == "pos":
                    fit.append(baro["down"])
                _fit_ylim(ax, fit)

    axes[0, 0].set_title("NED Position")
    axes[0, 1].set_title("NED Velocity")
    axes[2, 0].set_xlabel("time [s]")
    axes[2, 1].set_xlabel("time [s]")

    handles, labels = axes[0, 0].get_legend_handles_labels()
    # baro is drawn only on the Down position axis, so pull its entry from there.
    for h, l in zip(*axes[2, 0].get_legend_handles_labels()):
        if l not in labels:
            handles.append(h)
            labels.append(l)
    fig.legend(handles, labels, loc="upper center", ncol=6, frameon=False,
               bbox_to_anchor=(0.5, 0.945))
    fig.suptitle(title, y=0.992, fontsize=9)
    fig.tight_layout(rect=[0, 0, 1, 0.92])
    return fig


def make_gps_drift_figure(plt, ekf, gps, rec, baro, t_init, t0, imu_label, title):
    """N/E/D: GPS position (with eph/epv bands) vs GPS-Doppler-integrated vs EKF vs IMU recon,
    plus HDOP/VDOP over time -- to see whether GPS position motion is real or a position-solution drift."""
    fig, axes = plt.subplots(4, 1, figsize=(13, 12), sharex=True)
    names = ["North", "East", "Down"]
    band = [gps["eph"], gps["eph"], gps["epv"]]          # eph on N/E (horiz), epv on D (vert)
    band_lbl = ["GPS ±eph", "GPS ±eph", "GPS ±epv"]
    ok = gps["pos_ok"]
    for r in range(3):
        ax = axes[r]
        gp = gps["pos"][:, r]
        if band[r] is not None:
            ax.fill_between(gps["t"][ok] - t0, (gp - band[r])[ok], (gp + band[r])[ok],
                            color="C1", alpha=0.25, lw=0, label=band_lbl[r])
        ax.plot(gps["t"][ok] - t0, gp[ok], ".", color="C1", ms=3, label="GPS position (carrier/code)")
        ax.plot(gps["t"] - t0, gps["dop_pos"][:, r], "g-", lw=1.4, label="GPS Doppler velocity integrated")
        ax.plot(ekf["t"] - t0, ekf["pos"][:, r], "C0", lw=1.0, label="EKF estimate")
        ax.plot(rec["t"] - t0, rec["pos"][:, r], "C3", lw=1.0, label=f"IMU recon ({imu_label})")
        if baro is not None and r == 2:
            ax.plot(baro["t"] - t0, baro["down"], color="C6", lw=1.0, label="baro Down position")
        ax.axvline(t_init - t0, ls="--", color="k", lw=0.8, alpha=0.5)
        ax.set_ylabel(f"{names[r]} [m]")
        ax.grid(True, alpha=0.3)
    handles, labels = axes[0].get_legend_handles_labels()
    if baro is not None:                                 # baro is only on the Down panel
        for h, l in zip(*axes[2].get_legend_handles_labels()):
            if l not in labels:
                handles.append(h)
                labels.append(l)
    axes[0].legend(handles, labels, ncol=2, fontsize=8, loc="upper left")

    axd = axes[3]
    for fld, lab, c in [("hdop", "HDOP", "C4"), ("vdop", "VDOP", "C5")]:
        if gps[fld] is not None:
            m = gps[fld] > 0                              # drop invalid/zero DOP samples
            axd.plot(gps["t"][m] - t0, gps[fld][m], color=c, lw=1.0, label=lab)
    axd.set_ylabel("DOP")
    axd.set_xlabel("time [s]")
    axd.grid(True, alpha=0.3)
    axd.legend(fontsize=8, loc="upper left")

    fig.suptitle(title, y=0.995, fontsize=9)
    fig.tight_layout(rect=[0, 0, 1, 0.97])
    return fig


def make_fifo_validation_figure(plt, t_rec, gyro_rec, acc_rec, t_log, gyro_log, acc_log, t0, title):
    """Overlay FIFO-reconstructed vs logged vehicle_imu rates (gyro & specific force, XYZ)."""
    fig, axes = plt.subplots(3, 2, figsize=(14, 9), sharex=True)
    axn = ["X", "Y", "Z"]
    for r in range(3):
        for col, (rec, log, ylab) in enumerate(
                [(gyro_rec, gyro_log, f"gyro {axn[r]} [rad/s]"),
                 (acc_rec, acc_log, f"accel {axn[r]} [m/s²]")]):
            ax = axes[r, col]
            ax.plot(t_rec - t0, rec[:, r], "C0", lw=0.8, label="FIFO-reconstructed")
            ax.plot(t_log - t0, log[:, r], ".", color="C3", ms=4, label="logged vehicle_imu")
            ax.set_ylabel(ylab)
            ax.grid(True, alpha=0.3)
    axes[0, 0].set_title("Gyro rate (delta_angle / dt)")
    axes[0, 1].set_title("Specific force (delta_velocity / dt)")
    axes[2, 0].set_xlabel("time [s]")
    axes[2, 1].set_xlabel("time [s]")
    h, l = axes[0, 0].get_legend_handles_labels()
    fig.legend(h, l, loc="upper center", ncol=2, frameon=False, bbox_to_anchor=(0.5, 0.965))
    fig.suptitle(title, y=0.995, fontsize=9)
    fig.tight_layout(rect=[0, 0, 1, 0.93])
    return fig


def save_fig(fig, out_dir, log_base, name):
    """Write <out_dir>/<log_base>_<name>.png and .fig.pkl; return their paths."""
    os.makedirs(out_dir, exist_ok=True)
    base = os.path.join(out_dir, f"{log_base}_{name}")
    fig.savefig(base + ".png", dpi=150)
    with open(base + ".fig.pkl", "wb") as f:
        pickle.dump(fig, f)
    return base + ".png", base + ".fig.pkl"


# --------------------------------------------------------------------------- #
# Main
# --------------------------------------------------------------------------- #
def main():
    ap = argparse.ArgumentParser(description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("ulog", help="path to the .ulg file")
    ap.add_argument("--out-dir", default="ekfPosVel_figures",
                    help="output directory created under the current working dir (default: ekfPosVel_figures)")
    ap.add_argument("--imu-source", choices=["auto", "vehicle_imu", "fifo", "sensor_combined"],
                    default="auto",
                    help="IMU source. auto: full-rate vehicle_imu if present, else rebuild from raw "
                         "FIFO, else decimated vehicle_imu, else sensor_combined (default: auto)")
    ap.add_argument("--ekf-instance", type=int, default=0,
                    help="estimator instance (auto-falls-back to the first present, e.g. multi-EKF)")
    ap.add_argument("--full-scale", action="store_true",
                    help="autoscale y to include the (diverging) IMU recon")
    ap.add_argument("--validate-fifo", action="store_true",
                    help="force the FIFO-vs-logged-vehicle_imu validation figure")
    ap.add_argument("--show", action="store_true", help="display the figure interactively")
    args = ap.parse_args()

    ulog_path = os.path.abspath(os.path.expanduser(args.ulog))
    if not os.path.isfile(ulog_path):
        sys.exit(f"ERROR: log not found: {ulog_path}")

    import matplotlib
    if not args.show:
        matplotlib.use("Agg")
    import matplotlib.pyplot as plt
    from pyulog import ULog

    print(f"Loading {ulog_path} ...")
    ulog = ULog(ulog_path)
    inst = find_ekf_instance(ulog, args.ekf_instance)
    params = ulog.initial_parameters
    gyro_dev, accel_dev = ekf_imu_devices(ulog, inst)
    print(f"EKF instance {inst}; IMU devices gyro={gyro_dev} accel={accel_dev}")

    # IMU deltas
    imu_label, t, dang, dvel, dt_ang, dt_vel = get_imu_deltas(
        ulog, args.imu_source, params, gyro_dev, accel_dev)
    span = float(t[-1] - t[0])
    wall_gap = np.diff(t)                                  # inter-sample wall time
    nominal = float(np.median(dt_vel))
    dropped = wall_gap[wall_gap > 3 * nominal]             # logging dropouts
    drop_time = float(dropped.sum() - len(dropped) * nominal) if len(dropped) else 0.0
    print(f"IMU source: {imu_label}  ({len(t)} samples, ~{(len(t)-1)/span:.1f} Hz over {span:.1f}s)")
    print(f"  integration window ~{nominal*1e3:.2f} ms; integrated time={float(dt_vel.sum()):.1f}s; "
          f"max gap={wall_gap.max()*1e3:.0f} ms; dropout time={drop_time:.1f}s "
          f"({100*drop_time/span:.0f}% of span, spliced over)")
    if imu_label == "sensor_combined":
        print("  WARNING: sensor_combined is NOT the EKF input (this log runs multi-EKF on "
              "vehicle_imu); its bias will not match the EKF frozen bias, so the recon may be invalid.")
    if imu_label == "fifo":
        print(f"  NOTE: vehicle_imu rebuilt from raw FIFO at full rate (devices "
              f"gyro={gyro_dev}/accel={accel_dev}); validating against logged vehicle_imu if present.")
    elif (len(t) - 1) / span < 50.0:
        print(f"  NOTE: {imu_label} logged at ~{(len(t)-1)/span:.1f} Hz (decimated); only "
              f"{float(dt_vel.sum()):.1f}s of IMU motion integrated -- reconstruction is meaningful "
              f"only while the vehicle is quasi-static (full-rate logging needed otherwise).")

    # Init from EKF
    init = find_init(ulog, inst)
    print(f"Init at t={init['t_init']:.1f}s  (EKF origin "
          f"lat={init['ref'][0]:.7f} lon={init['ref'][1]:.7f} alt={init['ref'][2]:.2f})")
    print(f"  seed pos={np.round(init['p0'],3)} vel={np.round(init['v0'],3)} "
          f"quat={np.round(init['q0'],4)}")
    print(f"  frozen bias [{init['bias_src']}]: gyro={np.round(init['b_gyro'],5)} rad/s, "
          f"accel={np.round(init['b_accel'],4)} m/s^2")

    # Strapdown reconstruction
    rt, rv, rp, rqn = strapdown(t, dang, dvel, dt_ang, dt_vel, init)
    rec = dict(t=rt, pos=rp, vel=rv)

    # EKF estimate + GPS in the shared NED frame
    ekf = ekf_estimate(ulog, inst)
    proj = MapProjection(init["ref"][0], init["ref"][1])
    gps = gps_to_ned(ulog, proj, init["ref"][2])
    sp = load_setpoint(ulog)
    baro = baro_to_ned(ulog, float(init["p0"][2]), init["t_init"])
    if baro is not None:
        bspan = float(baro["t"][-1] - baro["t"][0])
        print(f"Baro Down: vehicle_air_data, {len(baro['t'])} samples "
              f"(~{(len(baro['t'])-1)/bspan:.1f} Hz over {bspan:.1f}s), anchored to seed at t_init")
    else:
        print("Baro Down: vehicle_air_data absent -- baro Down skipped")

    # Diagnostics
    t0 = float(ekf["t"][0])
    ke = int(np.argmin(np.abs(ekf["t"] - rt[-1])))
    drift = rp[-1] - ekf["pos"][ke]
    print(f"||q|| over run: min={rqn.min():.4f} max={rqn.max():.4f}")
    print(f"IMU-only drift vs EKF at t={rt[-1]:.0f}s: NED={np.round(drift,1)} m, "
          f"|horiz|={np.hypot(drift[0],drift[1]):.1f} m, |vert|={abs(drift[2]):.1f} m")

    # GPS-vs-EKF consistency (interp EKF onto GPS times) -- validates origin/projection
    okp = gps["pos_ok"]
    ep = np.column_stack([np.interp(gps["t"][okp], ekf["t"], ekf["pos"][:, r]) for r in range(3)])
    rms_p = np.sqrt(np.mean((gps["pos"][okp] - ep) ** 2, axis=0))
    okv = gps["vel_ok"]
    ev = np.column_stack([np.interp(gps["t"][okv], ekf["t"], ekf["vel"][:, r]) for r in range(3)])
    rms_v = np.sqrt(np.mean((gps["vel"][okv] - ev) ** 2, axis=0))
    print(f"GPS vs EKF RMS: pos NED={np.round(rms_p,2)} m, vel NED={np.round(rms_v,3)} m/s")

    # Figures -- both saved as <log>_<name>.{png,fig.pkl} under <cwd>/<out-dir>/
    out_dir = os.path.join(os.getcwd(), args.out_dir)
    log_base = os.path.splitext(os.path.basename(ulog_path))[0]
    logname = os.path.basename(ulog_path)

    figs = [
        (make_recon_figure(
            plt, ekf, gps, rec, sp, baro, init["t_init"], t0, imu_label, args.full_scale,
            f"{logname}   —   IMU-only recon (src={imu_label}, full strapdown, EKF bias frozen)"
            f"  vs  EKF (±3σ)  vs  GPS  vs  setpoint"), "ned_reconstruction"),
        (make_gps_drift_figure(
            plt, ekf, gps, rec, baro, init["t_init"], t0, imu_label,
            f"{logname}   —   GPS position-drift check: GPS pos (±eph/epv) vs GPS Doppler-integrated"
            f" vs EKF vs IMU recon, with HDOP/VDOP"), "gps_drift"),
    ]

    # FIFO reconstruction validation against logged vehicle_imu (same device)
    vi = _imu_by_device(ulog, "vehicle_imu", gyro_dev, accel_dev)
    if (imu_label == "fifo" or args.validate_fifo) and vi is not None:
        gyro_rec, acc_rec = dang / dt_ang[:, None], dvel / dt_vel[:, None]
        tvi = tsec(vi)
        gyro_log = vec3(vi, "delta_angle") / (np.asarray(vi.data["delta_angle_dt"], float)[:, None] * 1e-6)
        acc_log = vec3(vi, "delta_velocity") / (np.asarray(vi.data["delta_velocity_dt"], float)[:, None] * 1e-6)
        rg = np.column_stack([np.interp(tvi, t, gyro_rec[:, j]) for j in range(3)])
        ra = np.column_stack([np.interp(tvi, t, acc_rec[:, j]) for j in range(3)])
        rms_g = np.sqrt(np.mean((rg - gyro_log) ** 2, axis=0))
        rms_a = np.sqrt(np.mean((ra - acc_log) ** 2, axis=0))
        print(f"FIFO recon vs logged vehicle_imu RMS: gyro={np.round(rms_g,5)} rad/s, "
              f"accel={np.round(rms_a,4)} m/s^2  (over {len(tvi)} logged samples)")
        figs.append((make_fifo_validation_figure(
            plt, t, gyro_rec, acc_rec, tvi, gyro_log, acc_log, t0,
            f"{logname}   —   FIFO-reconstructed vs logged vehicle_imu "
            f"(gyro dev {gyro_dev})"), "fifo_validation"))

    for fig, name in figs:
        png, pkl = save_fig(fig, out_dir, log_base, name)
        print(f"Saved: {png}\n       {pkl}")
    print("  reopen a pickle:  python3 show_figure.py <file.fig.pkl>")

    if args.show:
        plt.show()


if __name__ == "__main__":
    main()
