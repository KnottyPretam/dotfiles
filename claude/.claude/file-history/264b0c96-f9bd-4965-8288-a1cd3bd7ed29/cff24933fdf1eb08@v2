\documentclass[border=8pt]{standalone}
\usepackage{tikz}
\usepackage{amsmath}
\usetikzlibrary{positioning, arrows.meta, calc, fit}
\begin{document}
\begin{tikzpicture}[
  >={Latex[length=2.6mm,width=2.2mm]},
  thick,
  font=\sffamily,
  block/.style={draw, rectangle, rounded corners=2pt, minimum height=11mm, minimum width=22mm, align=center, fill=white, font=\small\sffamily},
  gain/.style={draw, rectangle, minimum height=9mm, minimum width=14mm, align=center, fill=white, font=\small\sffamily},
  sum/.style={draw, circle, inner sep=0pt, minimum size=6mm, font=\footnotesize},
  source/.style={draw, rectangle, minimum height=9mm, minimum width=24mm, align=center, fill=blue!10, font=\footnotesize\sffamily},
  plantb/.style={draw, rectangle, rounded corners=2pt, minimum height=11mm, minimum width=44mm, align=center, fill=gray!15, font=\small\sffamily},
  sig/.style={font=\footnotesize\itshape},
  prim/.style={->, very thick},
  fb/.style={->, very thick, color=red!75!black},
  auxfb/.style={->, very thick, color=blue!65!black}
]
% reference + summing junction
\coordinate (start) at (0,0);
\node[sum, right=18mm of start] (sumE) {};
\node[font=\scriptsize, anchor=west, inner sep=1pt] at (sumE.west) {$+$};
\node[font=\scriptsize, anchor=south, inner sep=1pt] at (sumE.south) {$-$};
% three parallel paths
\node[gain, right=18mm of sumE] (KP) {$K\!\cdot\!P$};
\node[gain, above=10mm of KP] (KI) {$\dfrac{K\!\cdot\!I\!\cdot\!i_f}{s}$};
% output sum
\node[sum, right=18mm of KP] (sumT) {};
\node[font=\scriptsize, anchor=west, inner sep=1pt] at (sumT.west) {$+$};
\node[font=\scriptsize, anchor=north, inner sep=1pt] at (sumT.north) {$+$};
\node[font=\scriptsize, anchor=south, inner sep=1pt] at (sumT.south) {$+$};
% D and FF blocks
\node[gain, above=10mm of sumT] (KD) {$-K\!\cdot\!D$};
\node[gain, below=10mm of sumT] (FF) {$FF$};
% output
\node[plantb, right=18mm of sumT] (plant) {Allocator + Motors\\+ Airframe};
% sensors below
\node[source, below=26mm of sumE] (vav1) {VehAngVelocity\\\texttt{...xyz}};
\node[source, right=14mm of vav1] (vav2) {VehAngVelocity\\\texttt{...xyz\_derivative}};
% wsp into sumE
\draw[prim] (start) -- node[sig,above]{$\omega_{sp}$} (sumE);
% wsp tap into FF (split off before sumE)
\coordinate (tap) at ($(start)+(8mm,0)$);
\draw[prim] (tap) |- (FF.west);
% sumE to KP and to KI
\draw[prim] (sumE) -- node[sig,above,pos=0.55]{$e_\omega$} (KP);
\coordinate (etap) at ($(sumE.east)+(8mm,0)$);
\draw[prim] (etap) |- (KI.west);
% KP, KI, KD, FF into sumT
\draw[prim] (KP) -- (sumT);
\draw[prim] (KI.east) -| (sumT.north);
\draw[prim] (KD.south) -- (sumT.north);
\draw[prim] (FF.east) -| (sumT.south);
% sumT to plant
\draw[prim] (sumT) -- node[sig,above]{$\tau$} (plant);
% omega feedback into sumE (primary)
\draw[fb] (vav1.north) -- node[sig,right]{$\omega$} (sumE.south);
% alpha feedback into KD
\draw[auxfb] (vav2.north) |- ($(KD.west)+(-4mm,0)$) -- node[sig,above,pos=0.92]{$\alpha$} (KD.west);
% plant -> sensors
\draw[fb] (plant.south) |- ($(vav2.east)+(8mm,0)$) -- (vav2.east);
\draw[fb] ($(plant.south)+(-6mm,0)$) |- ($(vav1.east)+(8mm,-3mm)$) -- ($(vav1.east)+(0,-3mm)$) -- (vav1.east);
\end{tikzpicture}
\end{document}
