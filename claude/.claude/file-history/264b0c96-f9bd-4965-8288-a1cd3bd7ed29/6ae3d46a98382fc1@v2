\documentclass[border=8pt]{standalone}
\usepackage{tikz}
\usepackage{amsmath}
\usetikzlibrary{positioning, arrows.meta, calc, fit}
\begin{document}
\begin{tikzpicture}[
  >={Latex[length=2.6mm,width=2.2mm]},
  thick,
  font=\sffamily,
  block/.style={draw, rectangle, rounded corners=2pt, minimum height=11mm, minimum width=26mm, align=center, fill=white, font=\small\sffamily},
  gain/.style={draw, rectangle, minimum height=9mm, minimum width=11mm, align=center, fill=white, font=\small\sffamily},
  sum/.style={draw, circle, inner sep=0pt, minimum size=6mm, font=\footnotesize},
  source/.style={draw, rectangle, minimum height=9mm, minimum width=22mm, align=center, fill=blue!10, font=\footnotesize\sffamily},
  plantb/.style={draw, rectangle, rounded corners=2pt, minimum height=11mm, minimum width=44mm, align=center, fill=gray!15, font=\small\sffamily},
  sig/.style={font=\footnotesize\itshape},
  prim/.style={->, very thick},
  fb/.style={->, very thick, color=red!75!black},
  auxfb/.style={->, very thick, color=blue!65!black}
]
% forward path
\coordinate (start) at (0,0);
\node[block, right=4mm of start] (attErr) {Attitude error\\$e_q=2\,\mathrm{Im}(q^{-1}\!q_{d,bld})$};
\node[gain, right=14mm of attErr] (P) {$P$};
\node[sum, right=14mm of P] (sumT) {};
\node[block, right=14mm of sumT, minimum width=18mm] (clip) {clip\\$\pm\omega_{max}$};
\node[plantb, right=14mm of clip] (plant) {Rate loop + Allocator\\+ Motors + Airframe};
% sumT signs: all three inputs are + (D block already has minus baked in)
\node[font=\scriptsize, anchor=west, inner sep=1pt] at (sumT.west) {$+$};
\node[font=\scriptsize, anchor=north, inner sep=1pt] at (sumT.north) {$+$};
\node[font=\scriptsize, anchor=south, inner sep=1pt] at (sumT.south) {$+$};
% D path above
\node[gain, above=14mm of sumT] (D) {$-D$};
% yaw FF path below
\node[block, below=14mm of sumT, minimum width=36mm, minimum height=10mm] (yawff) {yaw FF\\$q^{-1}\hat{z}_W\!\cdot\!\dot\psi_{FF}$\quad(yaw axis)};
% sensors row at bottom
\node[source, below=22mm of attErr] (ekf) {EKF2\\\texttt{vehicle\_attitude.q}};
\node[source, right=14mm of ekf] (vav) {VehAngVelocity\\\texttt{...xyz}};
% forward arrows
\draw[prim] (start) -- node[sig,above]{$q_d$} (attErr);
\draw[prim] (attErr) -- node[sig,above]{$e_q$} (P);
\draw[prim] (P) -- (sumT);
\draw[prim] (sumT) -- node[sig,above]{$\omega_{sp,raw}$} (clip);
\draw[prim] (clip) -- node[sig,above]{$\omega_{sp}$} (plant);
% D path arrows
\draw[prim] (D.south) -- (sumT.north);
% yaw FF path arrows
\draw[prim] (yawff.north) -- (sumT.south);
% q feedback (primary) -> attErr
\draw[fb] (ekf.north) -- node[sig,right]{$q$} (attErr.south);
% q routing to yaw FF (uses q in q^-1 . z_W)
\draw[fb] (ekf.east) -- ($(ekf.east)+(4mm,0)$) |- (yawff.west);
% omega feedback to D block
\draw[auxfb] (vav.north) |- ($(D.west)+(-4mm,0)$) -- node[sig,above,pos=0.92]{$\omega$} (D.west);
% plant -> sensors (closing the loop)
\draw[fb] (plant.south) |- ($(vav.east)+(8mm,0)$) -- (vav.east);
\draw[fb] ($(plant.south)+(-6mm,0)$) |- ($(ekf.east)+(0,-6mm)$) -- ($(ekf.east)+(0,-6mm)$);
% legend box of feedback colors (small)
\end{tikzpicture}
\end{document}
