<style>
  /* Wider layout so the block diagrams and wide tables render large */
  html { font-size: 17px; }
  body { max-width: 74rem; padding: 1.2em 1.4em; line-height: 1.5; }
  h1, h2 { border-bottom: 1px solid #e0e0e0; padding-bottom: .2em; }
  /* Block diagrams: full content-width, centred, framed */
  img { display: block; width: 100%; height: auto; margin: 1.4em auto;
        border: 1px solid #dadce0; border-radius: 8px; padding: 6px; background: #fff; }
  table { width: 100%; border-collapse: collapse; font-size: 0.9em; display: block; overflow-x: auto; }
  th, td { border: 1px solid #d0d0d0; padding: 4px 8px; vertical-align: top; }
  th { background: #f5f7fa; }
  pre { background: #f6f8fa; border: 1px solid #e0e0e0; border-radius: 6px;
        padding: .7em .9em; font-size: 0.84em; overflow-x: auto; }
  code { background: #f0f2f4; padding: 0 3px; border-radius: 3px; }
  pre code { background: none; padding: 0; }
  blockquote { border-left: 4px solid #4285f4; margin: 1em 0; padding: .3em 1em; background: #f8fafe; color: #333; }
  /* MathJax display blocks may be wide (24-state block matrices) — allow scroll */
  mjx-container[display="true"] { overflow-x: auto; overflow-y: hidden; max-width: 100%; }
  #TOC { background: #fafbfc; border: 1px solid #e0e0e0; border-radius: 8px; padding: .6em 1.4em; }
</style>
