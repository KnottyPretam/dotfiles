# D2 — Mode routing (where each MC mode injects)
# =============================================================================
def modes():
    s = SVG(1500, 880)
    s.label(750, 34,
        "Where each mode injects into the multicopter cascade",
        size=17, fill=TITLE, anchor="middle", weight=700)
    s.label(750, 56,
        "(higher rows take more of the cascade; lower rows bypass earlier stages)",
        size=12, fill=SUB, anchor="middle")

    # ----------------- the cascade row at bottom -------------------------------
    # Layout: 5 modules at x = 60, 340, 620, 900, 1180  (width 200, gap 80 → arrows fit)
    cas_y = 620
    boxes = [
        ( 60, "FlightModeManager",  "src"),
        (340, "mc_pos_control",     "pos"),
        (620, "mc_att_control",     "att"),
        (900, "mc_rate_control",    "rate"),
        (1180,"control_allocator",  "alloc"),
    ]
    for x, name, key in boxes:
        s.box(x, cas_y, 200, 64, name, None, key=key, tsize=13)

    # connecting arrows along cascade
    for i in range(len(boxes)-1):
        x0 = boxes[i][0] + 200
        x1 = boxes[i+1][0]
        s.arrow(x0+2, cas_y+32, x1-2, cas_y+32, wid=2.0)

    # Output-topic labels in a row below the cascade (no overlap)
    topic_labels = [
        ( 60+100, "trajectory_setpoint"),
        (340+100, "vehicle_attitude_setpoint"),
        (620+100, "vehicle_rates_setpoint"),
        (900+100, "vehicle_torque_setpoint  +  vehicle_thrust_setpoint"),
        (1180+100, "actuator_motors  /  actuator_servos"),
    ]
    for cx, lbl in topic_labels:
        s.label(cx, cas_y+90, lbl, size=10.5, fill=SUB, anchor="middle", mono=True)
    # Mark injection-point stars below the boxes
    s.star(boxes[2][0], cas_y+32, r=12)   # INJ #1 at mc_att_control left edge
    s.label(boxes[2][0], cas_y+12, "INJ #1", size=10.5, fill="#e65100",
            anchor="middle", weight=700)
    s.star(boxes[4][0], cas_y+32, r=12)   # INJ #2 at control_allocator left edge
    s.label(boxes[4][0], cas_y+12, "INJ #2", size=10.5, fill="#e65100",
            anchor="middle", weight=700)

    # ----------------- mode rows ----------------------------------------------
    # each row: a "source" pill on the left, an arrow to where it injects.
    rows = [
        # (y, src_label, src_sub, color_key, target_idx, side_note)
        (100, "Automated  (Position / Altitude / Velocity)",
              "FMM publishes trajectory_setpoint  →  full cascade",
              "src", 1, "enters mc_pos_control"),
        (175, "Stabilized / Manual-Attitude",
              "mc_att_control::generate_attitude_setpoint() — sticks → q_sp",
              "att", 2, "self-pubs vehicle_attitude_setpoint @ :184"),
        (250, "MAVLink ATTITUDE_TARGET  (Offboard)",
              "mavlink_receiver publishes external attitude_setpoint @ :1573",
              "att", 2, "shares INJ #1 with stabilized"),
        (325, "Acro  (manual rate)",
              "mc_rate_control synthesises _rates_setpoint from sticks  (:189-205)",
              "rate", 3, "skips mc_att_control entirely"),
        (400, "Pure-Manual passthrough  (no attitude, no rates)",
              "mc_rate_control::handle_manual_mode() — sticks → τ  (:113-122)",
              "rate", 4, "writes τ DIRECTLY — closest to a τ shortcut"),
        (475, "Failsafe / Land logic",
              "mc_pos_control::generateFailsafeSetpoint()  (:584+)",
              "pos", 1, "publishes attitude_setpoint from internal traj"),
    ]
    # target_idx is the index in `boxes` whose LEFT edge the arrow should land on

    for (y, lbl, sub, key, ti, note) in rows:
        # source pill
        f, st = PAL[key]
        s.add(f'<rect x="40" y="{y}" width="660" height="50" rx="10" '
              f'fill="{f}" stroke="{st}" stroke-width="1.6"/>')
        s.label(60, y+20, lbl, size=12.5, fill=TITLE, weight=700)
        s.label(60, y+38, sub,  size=10.5, fill=SUB, mono=True)
        # arrow from pill RIGHT edge → vertical down → into target module top edge
        tx = boxes[ti][0] + 100   # land at horizontal centre of the target module
        s.poly_arrow([(700, y+25), (tx, y+25), (tx, cas_y-2)], wid=1.7)
        # side note next to the arrow's vertical bend
        s.label(710, y+20, note, size=10.5, fill=SUB)

    # ----------------- legend / footer ----------------------------------------
    s.label(40, 740,
        "All modes ultimately reach the control_allocator — only the ENTRY STAGE differs.",
        size=12, fill=TITLE, weight=700)
    s.label(40, 760,
        "★ INJ #1  =  arrow tips at mc_att_control left edge  →  consumes vehicle_attitude_setpoint  "
        "(rows 1·publishes via pos_control, 2·self, 3·MAVLink, 6·failsafe).",
        size=11)
    s.label(40, 778,
        "★ INJ #2  =  arrow tips at control_allocator left edge  →  consumes vehicle_torque_setpoint  "
        "(row 5, pure-manual passthrough).",
        size=11)
    s.label(40, 796,
        "INJ #1 and INJ #2 are never the same point — they sit two columns apart "
        "in the cascade row, separated by mc_rate_control.",
        size=11)

    s.label(750, 858,
        "PX4-Autopilot @ branch dev · HEAD 88d6b39aab · 2026-06-01",
        size=10.5, fill=SUB, anchor="middle")

    s.write(BASE + "_modes.svg")


