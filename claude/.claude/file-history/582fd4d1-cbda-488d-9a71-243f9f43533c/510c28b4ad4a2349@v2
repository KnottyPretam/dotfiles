#!/usr/bin/env python3
"""Generate two SVG diagrams for the MC control-cascade reference note.

  D1: cascade   — full pipeline trajectory_setpoint -> ... -> actuators, with
                  the two uORB injection points (vehicle_attitude_setpoint,
                  vehicle_torque_setpoint) highlighted.
  D2: modes     — fan-in showing where each MC mode injects (Auto / Stabilized /
                  Acro / Pure-Manual / MAVLink Offboard).

Hand-laid, dependency-free; mirrors the EKF2 emitter conventions.
"""
import html, os

OUT  = "/home/choudhury/knightwerx-vault/px4-notes"
BASE = "mc_control_cascade_2026-06-01"

# --------------------------------------------------------------------- palette
PAL = {
    "src":  ("#fff8e1", "#c0a000"),   # source / setpoint origin
    "pos":  ("#e8f0fe", "#4285f4"),   # mc_pos_control
    "att":  ("#e6f4ea", "#34a853"),   # mc_att_control
    "rate": ("#fce8e6", "#ea4335"),   # mc_rate_control
    "alloc":("#f3e8fd", "#a142f4"),   # control_allocator
    "act":  ("#e0f7fa", "#00acc1"),   # actuators
    "topic":("#ffffff", "#5f6368"),   # uORB topic chip
    "lib":  ("#fafbfc", "#9aa0a6"),   # math library
    "inj":  ("#ffe0b2", "#e65100"),   # injection marker
    "fb":   ("#fff0f0", "#b00020"),   # feedback
}
TITLE = "#202124"
SUB   = "#5f6368"

def esc(s): return html.escape(str(s), quote=True)

class SVG:
    def __init__(self, w, h):
        self.w, self.h, self.p = w, h, []
    def add(self, s): self.p.append(s)

    def band(self, x, y, w, h, label, key, dash="5 4"):
        f, st = PAL[key]
        self.add(f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="10" '
                 f'fill="{f}" fill-opacity="0.40" stroke="{st}" stroke-width="1.3" '
                 f'stroke-dasharray="{dash}"/>')
        self.add(f'<text x="{x+14}" y="{y+22}" font-size="14" font-weight="700" '
                 f'fill="{st}">{esc(label)}</text>')

    def box(self, x, y, w, h, title, lines=None, key="topic",
            tsize=13, mono=False, bold_title=True, sub_size=10.5):
        f, st = PAL[key]
        self.add(f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="8" '
                 f'fill="{f}" stroke="{st}" stroke-width="1.7"/>')
        cx = x + w/2
        if lines:
            self.add(f'<text x="{cx}" y="{y+19}" font-size="{tsize}" '
                     f'font-weight="{700 if bold_title else 500}" '
                     f'fill="{TITLE}" text-anchor="middle">{esc(title)}</text>')
            fam = ' font-family="DejaVu Sans Mono, monospace"' if mono else ''
            ly = y + 19 + 15
            for ln in lines:
                self.add(f'<text x="{cx}" y="{ly}" font-size="{sub_size}" '
                         f'fill="{SUB}" text-anchor="middle"{fam}>{esc(ln)}</text>')
                ly += 14
        else:
            yc = y + h/2 + tsize*0.34
            self.add(f'<text x="{cx}" y="{yc:.1f}" font-size="{tsize}" '
                     f'font-weight="{700 if bold_title else 500}" '
                     f'fill="{TITLE}" text-anchor="middle">{esc(title)}</text>')

    def topic(self, x, y, w, h, name, sub=None):
        f, st = PAL["topic"]
        self.add(f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="6" '
                 f'fill="{f}" stroke="{st}" stroke-width="1.4"/>')
        cx, cy = x+w/2, y+h/2
        self.add(f'<text x="{cx}" y="{cy-1}" font-size="11.5" '
                 f'font-family="DejaVu Sans Mono, monospace" font-weight="700" '
                 f'fill="#222" text-anchor="middle">{esc(name)}</text>')
        if sub:
            self.add(f'<text x="{cx}" y="{cy+13}" font-size="9.5" '
                     f'fill="{SUB}" text-anchor="middle">{esc(sub)}</text>')

    def label(self, x, y, s, size=11, fill=None, anchor="start", weight=400, mono=False):
        fam = ' font-family="DejaVu Sans Mono, monospace"' if mono else ''
        self.add(f'<text x="{x}" y="{y}" font-size="{size}" font-weight="{weight}" '
                 f'fill="{fill or SUB}" text-anchor="{anchor}"{fam}>{esc(s)}</text>')

    def arrow(self, x1, y1, x2, y2, dashed=False, color="#5f6368", wid=1.6):
        d = ' stroke-dasharray="5 4"' if dashed else ''
        self.add(f'<line x1="{x1}" y1="{y1}" x2="{x2}" y2="{y2}" stroke="{color}" '
                 f'stroke-width="{wid}"{d} marker-end="url(#arw)"/>')

    def poly_arrow(self, pts, color="#5f6368", wid=1.6, dashed=False):
        d = ' stroke-dasharray="5 4"' if dashed else ''
        path = "M" + " L".join(f"{x},{y}" for x,y in pts)
        self.add(f'<path d="{path}" stroke="{color}" stroke-width="{wid}" '
                 f'fill="none"{d} marker-end="url(#arw)"/>')

    def star(self, cx, cy, r=14, color=None):
        # injection-point marker — a filled star w/ outline
        f, st = PAL["inj"]
        if color: st = color
        pts = []
        import math
        for i in range(10):
            a = -math.pi/2 + i*math.pi/5
            rr = r if i%2==0 else r*0.45
            pts.append((cx+rr*math.cos(a), cy+rr*math.sin(a)))
        path = "M" + " L".join(f"{x:.1f},{y:.1f}" for x,y in pts) + " Z"
        self.add(f'<path d="{path}" fill="{f}" stroke="{st}" stroke-width="1.6"/>')

    def render(self):
        head = (f'<svg xmlns="http://www.w3.org/2000/svg" width="{self.w}" height="{self.h}" '
                f'viewBox="0 0 {self.w} {self.h}" font-family="DejaVu Sans, Arial, sans-serif">\n'
                f'<defs><marker id="arw" markerWidth="10" markerHeight="10" refX="8" refY="3" '
                f'orient="auto" markerUnits="strokeWidth"><path d="M0,0 L8,3 L0,6 z" fill="#5f6368"/></marker>\n'
                f'<marker id="arw_r" markerWidth="10" markerHeight="10" refX="8" refY="3" '
                f'orient="auto" markerUnits="strokeWidth"><path d="M0,0 L8,3 L0,6 z" fill="#b00020"/></marker></defs>\n'
                f'<rect width="{self.w}" height="{self.h}" fill="#ffffff"/>\n')
        return head + "\n".join(self.p) + "\n</svg>\n"

    def write(self, name):
        path = os.path.join(OUT, name)
        with open(path, "w") as fh: fh.write(self.render())
        print("wrote", path, os.path.getsize(path), "bytes")


