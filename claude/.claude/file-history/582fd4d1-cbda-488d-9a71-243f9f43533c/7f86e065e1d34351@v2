           "EKF2_SEL_ERR_RED (0.2)",
           "instant switch on IMU fault / timeout",
           "reset relative scores on switch"], "white", mono=False)
    s.arrow(255, 390, 255, 470)
    s.arrow(615, 390, 615, 470)
    s.arrow(980, 390, 980, 470)

    s.box(300, 470, 640, 76, "primary instance → re-publish as system topics",
          ["sensor_selection (active accel/gyro id)  +  vehicle_attitude /",
           "vehicle_local_position / vehicle_global_position / vehicle_odometry / wind"], "sel", mono=False)
    s.arrow(620, 568, 620, 612)

