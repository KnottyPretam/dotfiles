          None, "white", tsize=12)
    s.arrow(cx+BW/2, 106, cx+BW/2, 122)
    s.box(cx, 122, BW, 78, "EstimatorInterface::setIMUData()",
          ["OutputPredictor::calculateOutputStates()  — every full-rate IMU sample",
