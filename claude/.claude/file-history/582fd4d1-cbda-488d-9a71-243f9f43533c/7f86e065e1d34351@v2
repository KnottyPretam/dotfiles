import html, os

OUT = "/home/choudhury/knightwerx-vault/px4-notes"
BASE = "ekf2_estimator_pipeline_2026-05-25"

# ---- palette -------------------------------------------------------------
PAL = {
    "drv":  ("#e8f0fe", "#4285f4"),
    "pre":  ("#e6f4ea", "#34a853"),
    "ing":  ("#fef7e0", "#f9ab00"),
    "core": ("#fce8e6", "#ea4335"),
    "out":  ("#f3e8fd", "#a142f4"),
    "sel":  ("#e0f7fa", "#00acc1"),
    "note": ("#fff8e1", "#c0a000"),
    "white":("#ffffff", "#5f6368"),
    "dark": ("#37474f", "#263238"),
}
TITLE = "#202124"
SUB   = "#5f6368"

def esc(s): return html.escape(str(s), quote=True)

class SVG:
    def __init__(self, w, h):
        self.w, self.h, self.p = w, h, []
    def add(self, s): self.p.append(s)
    def band(self, x, y, w, h, label, key):
        f, st = PAL[key]
        self.add(f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="10" '
                 f'fill="{f}" fill-opacity="0.45" stroke="{st}" stroke-width="1.2" stroke-dasharray="5 4"/>')
        self.add(f'<text x="{x+14}" y="{y+22}" font-size="14" font-weight="700" fill="{st}">{esc(label)}</text>')
    def box(self, x, y, w, h, title, lines=None, key="white", tsize=13, mono=False, bold_title=True):
        f, st = PAL[key]
        self.add(f'<rect x="{x}" y="{y}" width="{w}" height="{h}" rx="7" fill="{f}" stroke="{st}" stroke-width="1.6"/>')
        cx = x + w/2
        if lines:
            self.add(f'<text x="{cx}" y="{y+19}" font-size="{tsize}" font-weight="{700 if bold_title else 500}" '
                     f'fill="{TITLE}" text-anchor="middle">{esc(title)}</text>')
            fam = ' font-family="DejaVu Sans Mono, monospace"' if mono else ''
            ly = y + 19 + 16
            for ln in lines:
                self.add(f'<text x="{cx}" y="{ly}" font-size="10.5" fill="{SUB}" text-anchor="middle"{fam}>{esc(ln)}</text>')
                ly += 14
        else:
            yc = y + h/2 + tsize*0.34
            self.add(f'<text x="{cx}" y="{yc:.1f}" font-size="{tsize}" font-weight="{700 if bold_title else 500}" '
                     f'fill="{TITLE}" text-anchor="middle">{esc(title)}</text>')
    def label(self, x, y, s, size=11, fill=None, anchor="start", weight=400, mono=False):
        fam = ' font-family="DejaVu Sans Mono, monospace"' if mono else ''
        self.add(f'<text x="{x}" y="{y}" font-size="{size}" font-weight="{weight}" '
                 f'fill="{fill or SUB}" text-anchor="{anchor}"{fam}>{esc(s)}</text>')
    def arrow(self, x1, y1, x2, y2, dashed=False, color="#5f6368", wid=1.6):
        d = ' stroke-dasharray="5 4"' if dashed else ''
        self.add(f'<line x1="{x1}" y1="{y1}" x2="{x2}" y2="{y2}" stroke="{color}" '
                 f'stroke-width="{wid}"{d} marker-end="url(#arw)"/>')
    def render(self):
        head = (f'<svg xmlns="http://www.w3.org/2000/svg" width="{self.w}" height="{self.h}" '
                f'viewBox="0 0 {self.w} {self.h}" font-family="DejaVu Sans, Arial, sans-serif">\n'
                f'<defs><marker id="arw" markerWidth="10" markerHeight="10" refX="8" refY="3" '
                f'orient="auto" markerUnits="strokeWidth"><path d="M0,0 L8,3 L0,6 z" fill="#5f6368"/></marker></defs>\n'
                f'<rect width="{self.w}" height="{self.h}" fill="#ffffff"/>\n')
        return head + "\n".join(self.p) + "\n</svg>\n"
    def write(self, name):
        path = os.path.join(OUT, name)
        with open(path, "w") as fh: fh.write(self.render())
        print("wrote", path, os.path.getsize(path), "bytes")

