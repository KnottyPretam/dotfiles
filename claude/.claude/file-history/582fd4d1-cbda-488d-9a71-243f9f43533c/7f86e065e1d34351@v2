    for i,x in enumerate(xs):
        lab = f"EKF2 instance {i}"
        s.box(x, 64, 300, 92, lab,
              [f"IMU {i}  +  MAG {i}", "→ estimator_attitude / _status",
               "  / _local_position / _odometry", "  / _global_position / _wind"], "core", mono=False)
        s.arrow(x+150, 156, x+150, 196)
    s.label(620, 182, "· · ·  up to N instances", size=12, fill=SUB, anchor="middle")

    # selector container
    s.add('<rect x="60" y="196" width="1120" height="372" rx="10" fill="#e0f7fa" '
          'fill-opacity="0.5" stroke="#00acc1" stroke-width="1.3"/>')
    s.label(74, 220, "EKF2Selector::UpdateErrorScores()  →  SelectInstance()", size=14, fill="#00838f", weight=700)

    s.box(90, 240, 330, 150, "IMU fault accumulators",
          ["gyro: Σ(inconsistency − EKF2_SEL_IMU_RAT)·dt",
           "        fault if > EKF2_SEL_IMU_ANG (15°)",
           "accel: Σ(inconsistency − EKF2_SEL_IMU_ACC)·dt",
           "        fault if > EKF2_SEL_IMU_VEL (2 m/s)",
           "",
           "RAT 7°/s · ANG 15° · ACC 1 m/s² · VEL 2 m/s"], "white", mono=False)

    s.box(450, 240, 330, 150, "per-instance test ratios",
          ["combined =",
           "  max( ½(vel_tr + pos_tr), hgt_tr )",
           "relative += (combined_i − combined_sel)",
           "  clamped to ± 1",
           "healthy = (no fault) & combined>0",
           "warning = combined ≥ 1"], "white", mono=False)

    s.box(810, 240, 340, 150, "selection logic",
          ["health hysteresis (≈ 1 s)",
           "switch when a better instance's",
