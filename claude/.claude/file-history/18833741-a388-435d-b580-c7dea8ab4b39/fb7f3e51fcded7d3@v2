"""EKF2 tuning parameters: schema, YAML load, and dump-from-log.

The YAML carries every noise term and every time-delay term that affects the
position/velocity estimate and covariance. `dump_params_from_log` maps the PX4
EKF2_* parameters stored in a ULG into this schema, so the default config *is*
the flight config -- run with it and the reconstruction should match the log.
"""

from dataclasses import dataclass, field

import numpy as np
import yaml


@dataclass
class EkfParams:
    # prediction
    predict_rate_hz: float = 100.0      # 1e6 / EKF2_PREDICT_US
    imu_integ_rate_hz: float = 200.0    # IMU_INTEG_RATE
    # process noise (IMU input + random walk)
    gyro_noise: float = 0.015           # EKF2_GYR_NOISE   [rad/s]
    accel_noise: float = 0.35           # EKF2_ACC_NOISE   [m/s^2]
    gyro_bias_noise: float = 0.001      # EKF2_GYR_B_NOISE [rad/s^2]
    accel_bias_noise: float = 0.003     # EKF2_ACC_B_NOISE [m/s^3]
    mag_e_noise: float = 0.001          # EKF2_MAG_E_NOISE [gauss/s]
    mag_b_noise: float = 0.0001         # EKF2_MAG_B_NOISE [gauss/s]
    wind_nsd: float = 0.01              # EKF2_WIND_NSD    [m/s^2/sqrt(Hz)]
    # measurement noise
    gps_pos_noise: float = 0.5          # EKF2_GPS_P_NOISE [m]
    gps_vel_noise: float = 0.3          # EKF2_GPS_V_NOISE [m/s]
    baro_noise: float = 3.5             # EKF2_BARO_NOISE  [m]
    mag_heading_noise: float = 0.3      # EKF2_HEAD_NOISE  [rad]
    baro_bias_nsd: float = 0.13         # baro_bias_nsd (common.h default; no EKF2_ param)
    # innovation gates [sigma]
    gps_pos_gate: float = 5.0           # EKF2_GPS_P_GATE
    gps_vel_gate: float = 5.0           # EKF2_GPS_V_GATE
    baro_gate: float = 5.0              # EKF2_BARO_GATE
    heading_gate: float = 2.6           # EKF2_HDG_GATE
    # time delays [ms]
    gps_delay_ms: float = 110.0         # EKF2_GPS_DELAY
    baro_delay_ms: float = 0.0          # EKF2_BARO_DELAY
    mag_delay_ms: float = 0.0           # EKF2_MAG_DELAY
    # initial 1-sigma uncertainties
    angle_err_init: float = 0.1         # EKF2_ANGERR_INIT [rad]
    gyro_bias_init: float = 0.1         # EKF2_GBIAS_INIT  [rad/s]
    accel_bias_init: float = 0.2        # EKF2_ABIAS_INIT  [m/s^2]
    pos_noaid_noise: float = 10.0       # EKF2_NOAID_NOISE [m]
    # geometry (lever arms, body FRD, m)
    imu_pos: np.ndarray = field(default_factory=lambda: np.zeros(3))   # EKF2_IMU_POS_*
    gps_pos: np.ndarray = field(default_factory=lambda: np.zeros(3))   # EKF2_GPS_POS_*
    # config
    height_ref: str = "gps"             # EKF2_HGT_REF (gps|baro)
    mag_declination_deg: float = 0.0    # EKF2_MAG_DECL

    # ------- derived -------
    @property
    def predict_period_s(self):
        return 1.0 / self.predict_rate_hz

    @property
    def gps_lever_body(self):
        """GPS antenna position relative to the IMU, body frame (m)."""
        return np.asarray(self.gps_pos) - np.asarray(self.imu_pos)


# --------------------------------------------------------------------------- #
# YAML <-> EkfParams
# --------------------------------------------------------------------------- #
_GROUPS = {
    "predict": ["predict_rate_hz", "imu_integ_rate_hz"],
    "process_noise": ["gyro_noise", "accel_noise", "gyro_bias_noise",
                      "accel_bias_noise", "mag_e_noise", "mag_b_noise", "wind_nsd"],
    "measurement_noise": ["gps_pos_noise", "gps_vel_noise", "baro_noise",
                          "mag_heading_noise", "baro_bias_nsd"],
    "gates": ["gps_pos_gate", "gps_vel_gate", "baro_gate", "heading_gate"],
    "delays_ms": ["gps_delay_ms", "baro_delay_ms", "mag_delay_ms"],
    "init": ["angle_err_init", "gyro_bias_init", "accel_bias_init", "pos_noaid_noise"],
    "geometry": ["imu_pos", "gps_pos"],
}
# delays_ms keys are written without the _ms suffix in the YAML
_DELAY_YAML = {"gps_delay_ms": "gps_delay", "baro_delay_ms": "baro_delay",
               "mag_delay_ms": "mag_delay"}


def to_yaml_dict(p: EkfParams):
    """Nested dict matching the documented YAML layout."""
    out = {}
    for group, names in _GROUPS.items():
        out[group] = {}
        for n in names:
            key = _DELAY_YAML.get(n, n)
            val = getattr(p, n)
            if isinstance(val, np.ndarray):
                val = [float(x) for x in val]
            out[group][key] = val
    out["height_ref"] = p.height_ref
    out["mag_declination_deg"] = float(p.mag_declination_deg)
    return out


def from_yaml_dict(d: dict) -> EkfParams:
    p = EkfParams()
    for group, names in _GROUPS.items():
        g = d.get(group, {})
        for n in names:
            key = _DELAY_YAML.get(n, n)
            if key in g:
                val = g[key]
                if n in ("imu_pos", "gps_pos"):
                    val = np.asarray(val, dtype=np.float64)
                setattr(p, n, val)
    if "height_ref" in d:
        p.height_ref = d["height_ref"]
    if "mag_declination_deg" in d:
        p.mag_declination_deg = float(d["mag_declination_deg"])
    return p


def load_yaml(path) -> EkfParams:
    with open(path) as f:
        return from_yaml_dict(yaml.safe_load(f))


def dump_params_from_log(ulog) -> EkfParams:
    """Map the EKF2_* parameters stored in the log into an EkfParams."""
    P = ulog.initial_parameters

    def g(name, default):
        return float(P[name]) if name in P else default

    p = EkfParams()
    p.predict_rate_hz = 1.0e6 / g("EKF2_PREDICT_US", 10000.0)
    p.imu_integ_rate_hz = g("IMU_INTEG_RATE", 200.0)
    p.gyro_noise = g("EKF2_GYR_NOISE", p.gyro_noise)
    p.accel_noise = g("EKF2_ACC_NOISE", p.accel_noise)
    p.gyro_bias_noise = g("EKF2_GYR_B_NOISE", p.gyro_bias_noise)
    p.accel_bias_noise = g("EKF2_ACC_B_NOISE", p.accel_bias_noise)
    p.mag_e_noise = g("EKF2_MAG_E_NOISE", p.mag_e_noise)
    p.mag_b_noise = g("EKF2_MAG_B_NOISE", p.mag_b_noise)
    p.wind_nsd = g("EKF2_WIND_NSD", p.wind_nsd)
    p.gps_pos_noise = g("EKF2_GPS_P_NOISE", p.gps_pos_noise)
    p.gps_vel_noise = g("EKF2_GPS_V_NOISE", p.gps_vel_noise)
    p.baro_noise = g("EKF2_BARO_NOISE", p.baro_noise)
    p.mag_heading_noise = g("EKF2_HEAD_NOISE", p.mag_heading_noise)
    # baro_bias_nsd has no EKF2_ param in this firmware -> common.h default 0.13
    p.gps_pos_gate = g("EKF2_GPS_P_GATE", p.gps_pos_gate)
    p.gps_vel_gate = g("EKF2_GPS_V_GATE", p.gps_vel_gate)
    p.baro_gate = g("EKF2_BARO_GATE", p.baro_gate)
    p.heading_gate = g("EKF2_HDG_GATE", p.heading_gate)
    p.gps_delay_ms = g("EKF2_GPS_DELAY", p.gps_delay_ms)
    p.baro_delay_ms = g("EKF2_BARO_DELAY", p.baro_delay_ms)
    p.mag_delay_ms = g("EKF2_MAG_DELAY", p.mag_delay_ms)
    p.angle_err_init = g("EKF2_ANGERR_INIT", p.angle_err_init)
    p.gyro_bias_init = g("EKF2_GBIAS_INIT", p.gyro_bias_init)
    p.accel_bias_init = g("EKF2_ABIAS_INIT", p.accel_bias_init)
    p.pos_noaid_noise = g("EKF2_NOAID_NOISE", p.pos_noaid_noise)
    p.imu_pos = np.array([g("EKF2_IMU_POS_X", 0.0), g("EKF2_IMU_POS_Y", 0.0), g("EKF2_IMU_POS_Z", 0.0)])
    p.gps_pos = np.array([g("EKF2_GPS_POS_X", 0.0), g("EKF2_GPS_POS_Y", 0.0), g("EKF2_GPS_POS_Z", 0.0)])
    p.height_ref = "gps" if int(g("EKF2_HGT_REF", 1)) == 1 else "baro"
    p.mag_declination_deg = g("EKF2_MAG_DECL", p.mag_declination_deg)
    return p


_TEMPLATE = """\
# EKF2 offline tuning parameters (generated from log; edit to retune).
# Each entry notes the PX4 EKF2_* parameter it maps to.
predict:
  predict_rate_hz: {predict_rate_hz:.6g}      # 1e6 / EKF2_PREDICT_US
  imu_integ_rate_hz: {imu_integ_rate_hz:.6g}  # IMU_INTEG_RATE
process_noise:
  gyro_noise: {gyro_noise:.6g}            # EKF2_GYR_NOISE   [rad/s]
  accel_noise: {accel_noise:.6g}          # EKF2_ACC_NOISE   [m/s^2]
  gyro_bias_noise: {gyro_bias_noise:.6g}  # EKF2_GYR_B_NOISE [rad/s^2]
  accel_bias_noise: {accel_bias_noise:.6g}  # EKF2_ACC_B_NOISE [m/s^3]
  mag_e_noise: {mag_e_noise:.6g}          # EKF2_MAG_E_NOISE (inert: mag_3D off)
  mag_b_noise: {mag_b_noise:.6g}          # EKF2_MAG_B_NOISE (inert)
  wind_nsd: {wind_nsd:.6g}                # EKF2_WIND_NSD    (inert: wind off)
measurement_noise:
  gps_pos_noise: {gps_pos_noise:.6g}      # EKF2_GPS_P_NOISE [m]
  gps_vel_noise: {gps_vel_noise:.6g}      # EKF2_GPS_V_NOISE [m/s] (vertical x1.5^2)
  baro_noise: {baro_noise:.6g}            # EKF2_BARO_NOISE  [m]
  mag_heading_noise: {mag_heading_noise:.6g}  # EKF2_HEAD_NOISE [rad]
  baro_bias_nsd: {baro_bias_nsd:.6g}      # baro height-bias estimator PSD (m/s/sqrt Hz)
gates:                                  # sigma; reject if innov^2 > gate^2 * innov_var
  gps_pos_gate: {gps_pos_gate:.6g}        # EKF2_GPS_P_GATE
  gps_vel_gate: {gps_vel_gate:.6g}        # EKF2_GPS_V_GATE
  baro_gate: {baro_gate:.6g}              # EKF2_BARO_GATE
  heading_gate: {heading_gate:.6g}        # EKF2_HDG_GATE
delays_ms:
  gps_delay: {gps_delay_ms:.6g}           # EKF2_GPS_DELAY
  baro_delay: {baro_delay_ms:.6g}         # EKF2_BARO_DELAY
  mag_delay: {mag_delay_ms:.6g}           # EKF2_MAG_DELAY
init:
  angle_err_init: {angle_err_init:.6g}    # EKF2_ANGERR_INIT [rad]
  gyro_bias_init: {gyro_bias_init:.6g}    # EKF2_GBIAS_INIT  [rad/s]
  accel_bias_init: {accel_bias_init:.6g}  # EKF2_ABIAS_INIT  [m/s^2]
  pos_noaid_noise: {pos_noaid_noise:.6g}  # EKF2_NOAID_NOISE [m]
geometry:
  imu_pos: [{imu_x:.6g}, {imu_y:.6g}, {imu_z:.6g}]   # EKF2_IMU_POS_* [m, body FRD]
  gps_pos: [{gps_x:.6g}, {gps_y:.6g}, {gps_z:.6g}]   # EKF2_GPS_POS_* [m, body FRD]
height_ref: {height_ref}                # EKF2_HGT_REF (gps|baro)
mag_declination_deg: {mag_declination_deg:.6g}   # EKF2_MAG_DECL (see Risks: WMM if DECL_TYPE geo)
"""


def to_commented_yaml(p: EkfParams) -> str:
    """Render a documented YAML string (re-loadable by load_yaml). Values use 6
    significant figures -- clean to read yet within 1e-6 of the firmware float32."""
    return _TEMPLATE.format(
        imu_x=p.imu_pos[0], imu_y=p.imu_pos[1], imu_z=p.imu_pos[2],
        gps_x=p.gps_pos[0], gps_y=p.gps_pos[1], gps_z=p.gps_pos[2],
        **{k: v for k, v in p.__dict__.items() if not isinstance(v, np.ndarray)},
    )
