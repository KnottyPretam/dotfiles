"""NED map projection + sensor-input readers (GPS, baro, magnetometer).

MapProjection / gps_to_ned lifted from ekf_ned_reconstruction.py; the GPS reader
is extended with the accuracy fields the EKF uses for measurement noise
(hacc=eph, vacc=epv, sacc=s_variance_m_s) and AMSL altitude for height fusion.
"""

import numpy as np

from . import log_io

# PX4 constants (src/lib/geo/geo.h)
R_EARTH = 6371000.0         # CONSTANTS_RADIUS_OF_EARTH [m]


class MapProjection:
    """PX4 MapProjection -- azimuthal equidistant (src/lib/geo/geo.cpp)."""

    def __init__(self, ref_lat_deg, ref_lon_deg):
        self.ref_lat = np.radians(ref_lat_deg)
        self.ref_lon = np.radians(ref_lon_deg)
        self.sin_lat = np.sin(self.ref_lat)
        self.cos_lat = np.cos(self.ref_lat)

    def project(self, lat_deg, lon_deg):
        """(lat, lon) in degrees -> (north, east) in metres."""
        lat = np.radians(np.asarray(lat_deg, dtype=np.float64))
        lon = np.radians(np.asarray(lon_deg, dtype=np.float64))
        sl, cl = np.sin(lat), np.cos(lat)
        cd = np.cos(lon - self.ref_lon)
        arg = np.clip(self.sin_lat * sl + self.cos_lat * cl * cd, -1.0, 1.0)
        c = np.arccos(arg)
        sinc = np.sin(c)
        k = np.where(np.abs(c) > 1e-12, c / np.where(sinc == 0.0, 1.0, sinc), 1.0)
        x = k * (self.cos_lat * sl - self.sin_lat * cl * cd) * R_EARTH
        y = k * cl * np.sin(lon - self.ref_lon) * R_EARTH
        return x, y


def gps_to_ned(ulog, proj, ref_alt):
    """GPS samples in the EKF local NED frame + the accuracy fields used for
    measurement noise. pos is (N,E,D); alt is AMSL [m]; D is -(alt-ref_alt)."""
    g = (log_io.get_dataset(ulog, "vehicle_gps_position", 0)
         or log_io.get_dataset(ulog, "sensor_gps", 0))
    g = log_io.require(g, "vehicle_gps_position/sensor_gps")
    t = log_io.tsec(g)
    fix = np.asarray(g.data["fix_type"])
    vvalid = np.asarray(g.data["vel_ned_valid"]).astype(bool)
    lat = np.asarray(g.data["lat"], dtype=np.float64) * 1e-7
    lon = np.asarray(g.data["lon"], dtype=np.float64) * 1e-7
    alt = np.asarray(g.data["alt"], dtype=np.float64) * 1e-3   # mm -> m (AMSL)
    x, y = proj.project(lat, lon)
    z = -(alt - ref_alt)                                       # NED down (positive down)
    pos = np.column_stack([x, y, z])
    vel = np.column_stack([g.data["vel_n_m_s"], g.data["vel_e_m_s"], g.data["vel_d_m_s"]])

    # Position from integrating Doppler velocity (independent of the position
    # solution; for the GPS-drift sanity overlay).
    dop = np.empty_like(pos)
    dop[0] = pos[0]
    dop[1:] = pos[0] + np.cumsum(0.5 * (vel[1:] + vel[:-1]) * np.diff(t)[:, None], axis=0)

    return dict(
        t=t, pos=pos, alt=alt, vel=vel,
        pos_ok=(fix >= 3), vel_ok=(vvalid & (fix >= 3)),
        dop_pos=dop,
        hacc=log_io.field(g, "eph"), vacc=log_io.field(g, "epv"),
        sacc=log_io.field(g, "s_variance_m_s"),
        eph=log_io.field(g, "eph"), epv=log_io.field(g, "epv"),
        hdop=log_io.field(g, "hdop"), vdop=log_io.field(g, "vdop"),
        fix_type=fix,
    )


def read_baro(ulog):
    """Barometric altitude (vehicle_air_data.baro_alt_meter [m]) or None."""
    d = log_io.get_dataset(ulog, "vehicle_air_data", 0)
    if d is None:
        return None
    return dict(t=log_io.tsec(d),
                hgt=np.asarray(d.data["baro_alt_meter"], dtype=np.float64),
                device_id=log_io.field(d, "baro_device_id"))


def read_mag(ulog):
    """Magnetometer field in body frame (vehicle_magnetometer.magnetometer_ga
    [Gauss]) or None."""
    d = log_io.get_dataset(ulog, "vehicle_magnetometer", 0)
    if d is None:
        return None
    return dict(t=log_io.tsec(d), mag=vec3_ga(d))


def vec3_ga(d):
    return np.column_stack([d.data[f"magnetometer_ga[{i}]"] for i in range(3)])
