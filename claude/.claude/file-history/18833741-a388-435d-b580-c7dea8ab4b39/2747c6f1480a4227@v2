"""Time-ordered event loop: rebuild the IMU, seed the filter from the logged
estimator at the first GPS-aided sample, then predict at the fusion horizon and
fuse each sensor (mag -> GPS vel/hpos -> baro height -> GNSS height) when its
delayed timestamp reaches the horizon. Records the reconstructed state and the
covariance diagonal, plus the logged truth for comparison/plots.
"""

import numpy as np

from . import geo, imu_recon, log_io
from .filter import Ekf


def accumulate_to_predict_rate(t, dang, dvel, dt_ang, dt_vel, period):
    """Sum the reconstructed IMU deltas (~200 Hz) into predict-rate (~100 Hz)
    samples, mirroring the EKF's IMU down-sampler. Returns end-time + summed
    deltas/dt for each predict step.

    Logging-dropout samples (dt far larger than the integration window) are
    skipped: a single sample spanning a multi-100ms gap would otherwise inject a
    huge one-step delta (e.g. g*dt of vertical velocity). The real EKF had
    continuous IMU; we lose the gap's motion and let GPS re-correct."""
    out_t, out_da, out_dv, out_dta, out_dtv = [], [], [], [], []
    acc_da = np.zeros(3); acc_dv = np.zeros(3); acc_dta = 0.0; acc_dtv = 0.0
    dt_max = 3.0 * period
    for i in range(len(t)):
        if dt_vel[i] > dt_max or dt_ang[i] > dt_max:
            continue
        acc_da = acc_da + dang[i]; acc_dv = acc_dv + dvel[i]
        acc_dta += dt_ang[i]; acc_dtv += dt_vel[i]
        if acc_dtv >= period - 1e-6:
            out_t.append(t[i]); out_da.append(acc_da); out_dv.append(acc_dv)
            out_dta.append(acc_dta); out_dtv.append(acc_dtv)
            acc_da = np.zeros(3); acc_dv = np.zeros(3); acc_dta = 0.0; acc_dtv = 0.0
    return (np.asarray(out_t), np.asarray(out_da), np.asarray(out_dv),
            np.asarray(out_dta), np.asarray(out_dtv))


class _Stream:
    """A delayed sensor stream: samples become due when (t - shift) <= horizon.
    pop_due returns the next due sample index (one per call), or None."""

    def __init__(self, t, shift_s, valid=None):
        self.t = np.asarray(t, dtype=np.float64)
        self.shift = shift_s
        self.valid = np.ones(len(self.t), bool) if valid is None else np.asarray(valid, bool)
        self.idx = 0

    def skip_before(self, t0):
        while self.idx < len(self.t) and (self.t[self.idx] - self.shift) < t0:
            self.idx += 1

    def pop_due(self, t_h):
        while self.idx < len(self.t):
            if not self.valid[self.idx]:
                self.idx += 1
                continue
            if (self.t[self.idx] - self.shift) <= t_h:
                i = self.idx
                self.idx += 1
                return i
            return None
        return None


def find_seed(ulog, inst):
    """First estimator_states sample with a valid EKF origin -- seed time, origin,
    state, covariance diagonal."""
    elp = log_io.require(log_io.get_dataset(ulog, "estimator_local_position", inst),
                         "estimator_local_position")
    ref_lat = np.asarray(elp.data["ref_lat"], dtype=np.float64)
    valid = np.isfinite(ref_lat) & (np.abs(ref_lat) > 1e-9)
    if not valid.any():
        raise SystemExit("ERROR: EKF local origin never valid in this log")
    i0 = int(np.argmax(valid))
    t_origin = float(log_io.tsec(elp)[i0])
    origin = (float(elp.data["ref_lat"][i0]), float(elp.data["ref_lon"][i0]),
              float(elp.data["ref_alt"][i0]))

    es = log_io.require(log_io.get_dataset(ulog, "estimator_states", inst), "estimator_states")
    te = log_io.tsec(es)
    k = int(np.argmax(te >= t_origin)) if np.any(te >= t_origin) else 0
    t_seed = float(te[k])
    x0 = np.array([es.data[f"states[{i}]"][k] for i in range(24)], dtype=np.float64)
    c0 = np.array([es.data[f"covariances[{i}]"][k] for i in range(24)], dtype=np.float64)
    return dict(t_seed=t_seed, origin=origin, x0=x0, cov0=c0)


def logged_truth(ulog, inst):
    """Logged EKF estimate + covariance diagonal (the comparison target)."""
    es = log_io.require(log_io.get_dataset(ulog, "estimator_states", inst), "estimator_states")
    t = log_io.tsec(es)
    states = np.column_stack([es.data[f"states[{i}]"] for i in range(24)])
    cov = np.column_stack([es.data[f"covariances[{i}]"] for i in range(24)])
    return dict(t=t, states=states, cov=cov)


def run(ulog, params, inst, imu_source="auto", seed_mode="log_diag", verbose=True):
    """Run the offline EKF over the log. Returns a result dict for plotting/checks.

    seed_mode: 'cold' seeds P from initialiseCovariance (large -> strong gains that
    rebuild the state<->attitude correlations during burn-in, like power-on); the
    covariance converges to the flight's steady state within a few seconds.
    'log_diag' seeds P from the logged covariance diagonal (off-diagonals unknown);
    only viable for low-vibration logs."""
    gyro_dev, accel_dev = log_io.ekf_imu_devices(ulog, inst)
    imu_label, ti, dang, dvel, dta, dtv = imu_recon.get_imu_deltas(
        ulog, imu_source, ulog.initial_parameters, gyro_dev, accel_dev)
    period = params.predict_period_s
    pt, pda, pdv, pdta, pdtv = accumulate_to_predict_rate(ti, dang, dvel, dta, dtv, period)
    if verbose:
        print(f"IMU source: {imu_label}  ({len(ti)} samples) -> {len(pt)} predict steps "
              f"@ ~{(len(pt) - 1) / (pt[-1] - pt[0]):.0f} Hz")

    seed = find_seed(ulog, inst)
    origin = seed["origin"]
    proj = geo.MapProjection(origin[0], origin[1])
    gps = geo.gps_to_ned(ulog, proj, origin[2])
    baro = geo.read_baro(ulog)
    mag = geo.read_mag(ulog)
    decl_rad = np.radians(params.mag_declination_deg)

    ekf = Ekf(params, np.radians(origin[0]))
    ekf.set_state(seed["x0"])
    if seed_mode == "log_diag":
        ekf.seed_covariance_diag(seed["cov0"])
    else:
        ekf.initialise_covariance()
    bb = log_io.get_dataset(ulog, "estimator_baro_bias", inst)
    if bb is not None:
        j = int(np.argmin(np.abs(log_io.tsec(bb) - seed["t_seed"])))
        ekf.seed_baro_bias(bb.data["bias"][j], bb.data["bias_var"][j])
    else:
        ekf.seed_baro_bias(seed["x0"][9] + (baro["hgt"][0] if baro else 0.0), 0.1)

    # delayed sensor streams (shift = delay + half a predict interval, as inserted in PX4)
    half = 0.5 * params.predict_period_s
    s_gps = _Stream(gps["t"], params.gps_delay_ms * 1e-3 + half, valid=gps["pos_ok"] & gps["vel_ok"])
    s_baro = _Stream(baro["t"], params.baro_delay_ms * 1e-3 + half) if baro else None
    s_mag = _Stream(mag["t"], params.mag_delay_ms * 1e-3 + half) if mag else None

    t_seed = seed["t_seed"]
    k0 = int(np.argmax(pt >= t_seed)) if np.any(pt >= t_seed) else 0
    for s in (s_gps, s_baro, s_mag):
        if s is not None:
            s.skip_before(pt[k0])

    rec_t, rec_x, rec_pdiag = [], [], []
    innov_hist = {k: [] for k in ("gps_hvel", "gps_vvel", "gps_hpos", "baro_vpos", "gps_vpos", "heading")}

    for k in range(k0, len(pt)):
        t_h = pt[k]
        ekf.t_now = t_h
        ekf.predict_covariance(pda[k], pdv[k])
        ekf.predict_state(pda[k], pdv[k], pdta[k], pdtv[k])

        # mag heading
        if s_mag is not None:
            i = s_mag.pop_due(t_h)
            if i is not None:
                ekf.fuse_mag_heading(mag["mag"][i], decl_rad)
                _record(innov_hist, ekf, t_h, ("heading",))

        # GPS velocity + horizontal position
        gps_fused = False
        ig = s_gps.pop_due(t_h)
        if ig is not None:
            ekf.fuse_gps(dict(vel=gps["vel"][ig], pos=gps["pos"][ig, 0:2], alt=gps["alt"][ig],
                              sacc=_v(gps["sacc"], ig), hacc=_v(gps["hacc"], ig), vacc=_v(gps["vacc"], ig)))
            gps_fused = True
            _record(innov_hist, ekf, t_h, ("gps_hvel", "gps_vvel", "gps_hpos"))

        # height: baro (bias estimator) then GNSS height (reference)
        ekf.predict_baro_bias()
        if s_baro is not None:
            ib = s_baro.pop_due(t_h)
            if ib is not None:
                ekf.fuse_baro_height(baro["hgt"][ib])
                _record(innov_hist, ekf, t_h, ("baro_vpos",))
        if gps_fused:
            ekf.fuse_gnss_height(origin[2])
            _record(innov_hist, ekf, t_h, ("gps_vpos",))

        rec_t.append(t_h)
        rec_x.append(ekf.x.copy())
        rec_pdiag.append(np.diag(ekf.P).copy())

    if verbose and (ekf.n_vel_resets or ekf.n_pos_resets):
        print(f"GPS resets (fusion timed out): vel={ekf.n_vel_resets} pos={ekf.n_pos_resets}")

    return dict(
        t=np.asarray(rec_t), x=np.asarray(rec_x), pdiag=np.asarray(rec_pdiag),
        innov_hist={k: np.asarray(v) for k, v in innov_hist.items() if v},
        logged=logged_truth(ulog, inst), gps=gps, origin=origin,
        t_seed=t_seed, imu_label=imu_label, inst=inst,
    )


def _v(arr, i):
    return float(arr[i]) if arr is not None else 0.0


def _record(hist, ekf, t_h, names):
    for n in names:
        if n in ekf.aid:
            innov, ivar = ekf.aid[n]
            innov = np.atleast_1d(np.asarray(innov, dtype=np.float64))
            ivar = np.atleast_1d(np.asarray(ivar, dtype=np.float64))
            hist[n].append(np.concatenate([[t_h], innov, ivar]))
