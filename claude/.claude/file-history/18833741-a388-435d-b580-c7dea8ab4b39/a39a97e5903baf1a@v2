"""Quaternion / DCM / Euler helpers -- scalar-first [w, x, y, z], Hamilton product,
matching PX4 matrix::Quatf / Dcmf conventions (body->earth rotation).

Lifted from ekf_ned_reconstruction.py and extended with the yaw helpers the EKF
mag-heading fusion needs (PX4 src/modules/ekf2/EKF/utils.* getEulerYaw etc.).
"""

import numpy as np


def quat_mult(q, r):
    """Hamilton product q (x) r, scalar-first."""
    w0, x0, y0, z0 = q
    w1, x1, y1, z1 = r
    return np.array([
        w0 * w1 - x0 * x1 - y0 * y1 - z0 * z1,
        w0 * x1 + x0 * w1 + y0 * z1 - z0 * y1,
        w0 * y1 - x0 * z1 + y0 * w1 + z0 * x1,
        w0 * z1 + x0 * y1 - y0 * x1 + z0 * w1,
    ])


def quat_to_dcm(q):
    """Body -> earth rotation matrix (matches PX4 Dcmf(Quatf))."""
    w, x, y, z = q
    return np.array([
        [1 - 2 * (y * y + z * z), 2 * (x * y - w * z),     2 * (x * z + w * y)],
        [2 * (x * y + w * z),     1 - 2 * (x * x + z * z), 2 * (y * z - w * x)],
        [2 * (x * z - w * y),     2 * (y * z + w * x),     1 - 2 * (x * x + y * y)],
    ])


def axis_angle_to_quat(v):
    """Rotation vector (rad) -> quaternion (matches AxisAnglef -> Quatf)."""
    theta = float(np.linalg.norm(v))
    if theta < 1e-9:
        q = np.array([1.0, 0.5 * v[0], 0.5 * v[1], 0.5 * v[2]])
        return q / np.linalg.norm(q)
    s = np.sin(0.5 * theta) / theta
    return np.array([np.cos(0.5 * theta), s * v[0], s * v[1], s * v[2]])


def qnorm(q):
    return np.asarray(q, dtype=np.float64) / np.linalg.norm(q)


def euler_to_quat(roll, pitch, yaw):
    """PX4 Quatf(Eulerf): scalar-first [w,x,y,z], 3-2-1 (yaw-pitch-roll) sequence."""
    cr, sr = np.cos(roll / 2), np.sin(roll / 2)
    cp, sp = np.cos(pitch / 2), np.sin(pitch / 2)
    cy, sy = np.cos(yaw / 2), np.sin(yaw / 2)
    return np.array([cr * cp * cy + sr * sp * sy,
                     sr * cp * cy - cr * sp * sy,
                     cr * sp * cy + sr * cp * sy,
                     cr * cp * sy - sr * sp * cy])


def euler_to_dcm(roll, pitch, yaw):
    """Matches PX4 Dcmf(Eulerf) (via Quatf), consistent with quat_to_dcm."""
    return quat_to_dcm(euler_to_quat(roll, pitch, yaw))


def wrap_pi(x):
    """Wrap angle (rad) to (-pi, pi], matching matrix::wrap_pi."""
    return (x + np.pi) % (2.0 * np.pi) - np.pi


# --------------------------------------------------------------------------- #
# Yaw extraction / insertion -- PX4 utils.cpp (getEulerYaw / updateYawInRotMat).
# The EKF picks a 321 or 312 Euler sequence to avoid the gimbal-lock singularity.
# --------------------------------------------------------------------------- #
def shouldUse321RotationSequence(R):
    return abs(R[2, 0]) < abs(R[2, 1])


def getEuler321Yaw(R):
    return np.arctan2(R[1, 0], R[0, 0])


def getEuler312Yaw(R):
    return np.arctan2(-R[0, 1], R[1, 1])


def getEulerYaw(R):
    if shouldUse321RotationSequence(R):
        return getEuler321Yaw(R)
    return getEuler312Yaw(R)


def _dcm312(roll, pitch, yaw):
    """DCM for the 3-1-2 (yaw-roll-pitch) intrinsic sequence used by PX4's 312 path.
    Built as R = Rz(yaw) * Rx(roll) * Ry(pitch) (matrix::Dcm from Euler 312)."""
    cy, sy = np.cos(yaw), np.sin(yaw)
    cr, sr = np.cos(roll), np.sin(roll)
    cp, sp = np.cos(pitch), np.sin(pitch)
    Rz = np.array([[cy, -sy, 0.0], [sy, cy, 0.0], [0.0, 0.0, 1.0]])
    Rx = np.array([[1.0, 0.0, 0.0], [0.0, cr, -sr], [0.0, sr, cr]])
    Ry = np.array([[cp, 0.0, sp], [0.0, 1.0, 0.0], [-sp, 0.0, cp]])
    return Rz @ Rx @ Ry


def updateYawInRotMat(yaw, R):
    """Return a rotation equal to R but with its yaw replaced by `yaw`,
    preserving roll/pitch -- matches PX4 updateYawInRotMat (utils.cpp).
    Uses a 321 sequence unless near pitch singularity, then 312."""
    if shouldUse321RotationSequence(R):
        roll = np.arctan2(R[2, 1], R[2, 2])
        pitch = np.arcsin(-np.clip(R[2, 0], -1.0, 1.0))
        return euler_to_dcm(roll, pitch, yaw)
    # 312 sequence: roll about x, pitch about y, then apply requested yaw about z.
    roll = np.arcsin(np.clip(R[2, 1], -1.0, 1.0))
    pitch = np.arctan2(-R[2, 0], R[2, 2])
    return _dcm312(roll, pitch, yaw)
