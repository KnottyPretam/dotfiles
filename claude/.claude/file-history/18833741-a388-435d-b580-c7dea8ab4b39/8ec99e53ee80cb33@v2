#!/usr/bin/env python3
"""Offline PX4 EKF2 reconstruction & tuning.

Re-runs the EKF2 estimator from a ULG flight log using tuning parameters from a
YAML file, reproducing the NED position/velocity estimates and their covariance.
If the YAML values equal what flew, the reconstruction should match the logged
estimator; change a value to see how the estimate and +/-3 sigma envelope move.

Usage:
  # write a YAML of the flight's own EKF2 params (edit it to retune):
  python3 ekf2_offline.py LOG.ulg --dump-params params.yaml

  # run with a params YAML (defaults to the log's own params if omitted):
  python3 ekf2_offline.py LOG.ulg --params params.yaml

Outputs two figures (PNG + pickled Figure) under <cwd>/<out-dir>/:
  <log>_pos_vel_recon  : NED pos/vel -- logged EKF, reconstructed EKF (+/-3 sigma), GPS overlay
  <log>_variance_cmp   : reconstructed vs logged covariance diagonal (pos/vel)
"""

import argparse
import os
import sys

from ekf2 import log_io, params as P, plots, runner


def main():
    ap = argparse.ArgumentParser(
        description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("ulog", help="path to the .ulg file")
    ap.add_argument("--params", help="tuning-parameter YAML (default: use the log's EKF2_* params)")
    ap.add_argument("--dump-params", metavar="PATH",
                    help="write a YAML of the log's EKF2_* params to PATH and exit")
    ap.add_argument("--out-dir", default="ekf2_figures",
                    help="output directory under the cwd (default: ekf2_figures)")
    ap.add_argument("--ekf-instance", type=int, default=1,
                    help="estimator instance (auto-falls-back to the first present)")
    ap.add_argument("--imu-source", choices=["auto", "vehicle_imu", "fifo", "sensor_combined"],
                    default="auto", help="IMU source (default: auto -> rebuild from FIFO)")
    ap.add_argument("--seed-mode", choices=["log_diag", "cold"], default="log_diag",
                    help="covariance seeding: log_diag seeds P from the logged covariance "
                         "diagonal (no transient); cold uses initialiseCovariance (power-on)")
    ap.add_argument("--show", action="store_true", help="display the figures interactively")
    args = ap.parse_args()

    ulog_path = os.path.abspath(os.path.expanduser(args.ulog))
    if not os.path.isfile(ulog_path):
        sys.exit(f"ERROR: log not found: {ulog_path}")

    print(f"Loading {ulog_path} ...")
    ulog = log_io.load_ulog(ulog_path)
    inst = log_io.find_ekf_instance(ulog, args.ekf_instance)

    if args.dump_params:
        params = P.dump_params_from_log(ulog)
        with open(args.dump_params, "w") as f:
            f.write(P.to_commented_yaml(params))
        print(f"Wrote {args.dump_params} (EKF2 params from log, instance {inst})")
        return

    if args.params:
        params = P.load_yaml(args.params)
        print(f"Params: {args.params}")
    else:
        params = P.dump_params_from_log(ulog)
        print("Params: from log (EKF2_*)")

    result = runner.run(ulog, params, inst, imu_source=args.imu_source, seed_mode=args.seed_mode)

    import matplotlib
    if not args.show:
        matplotlib.use("Agg")
    import matplotlib.pyplot as plt

    out_dir = os.path.join(os.getcwd(), args.out_dir)
    log_base = os.path.splitext(os.path.basename(ulog_path))[0]
    plots.report_match(result, ulog)
    for fig, name in (
        (plots.make_pos_vel_figure(plt, result, os.path.basename(ulog_path)), "pos_vel_recon"),
        (plots.make_variance_figure(plt, result, os.path.basename(ulog_path)), "variance_cmp"),
    ):
        png, pkl = plots.save_fig(fig, out_dir, log_base, name)
        print(f"Saved: {png}\n       {pkl}")

    if args.show:
        plt.show()


if __name__ == "__main__":
    main()
