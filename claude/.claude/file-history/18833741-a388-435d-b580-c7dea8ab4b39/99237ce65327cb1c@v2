"""Figures + numeric match report for the offline EKF2 reconstruction.

Figure 1 (pos/vel): logged EKF estimate, reconstructed EKF, GPS overlay, and the
                    +/-3 sigma band taken from the reconstructed covariance.
Figure 2 (variance): reconstructed covariance diagonal vs the logged
                    estimator_states covariance, for the pos/vel components.
"""

import os
import pickle

import numpy as np

from . import log_io

NED = ["North", "East", "Down"]
VEL = slice(4, 7)
POS = slice(7, 10)
BURN_IN_S = 5.0     # ignore the first seconds (off-diagonals rebuild after seeding)


def save_fig(fig, out_dir, log_base, name):
    os.makedirs(out_dir, exist_ok=True)
    base = os.path.join(out_dir, f"{log_base}_{name}")
    fig.savefig(base + ".png", dpi=150)
    with open(base + ".fig.pkl", "wb") as f:
        pickle.dump(fig, f)
    return base + ".png", base + ".fig.pkl"


def make_pos_vel_figure(plt, res, logname):
    t0 = float(res["logged"]["t"][0])
    rt = res["t"] - t0
    lt = res["logged"]["t"] - t0
    rec_pos, rec_vel = res["x"][:, POS], res["x"][:, VEL]
    s3_pos = 3.0 * np.sqrt(np.clip(res["pdiag"][:, POS], 0, None))
    s3_vel = 3.0 * np.sqrt(np.clip(res["pdiag"][:, VEL], 0, None))
    log_pos, log_vel = res["logged"]["states"][:, POS], res["logged"]["states"][:, VEL]
    gps = res["gps"]

    fig, axes = plt.subplots(3, 2, figsize=(14, 10), sharex=True)
    for r in range(3):
        for col, (rec, s3, log, gkey, ok, ylab) in enumerate([
            (rec_pos, s3_pos, log_pos, "pos", "pos_ok", "pos [m]"),
            (rec_vel, s3_vel, log_vel, "vel", "vel_ok", "vel [m/s]"),
        ]):
            ax = axes[r, col]
            ax.fill_between(rt, rec[:, r] - s3[:, r], rec[:, r] + s3[:, r],
                            color="C3", alpha=0.20, lw=0, label=r"recon $\pm3\sigma$")
            ax.plot(lt, log[:, r], "C0", lw=1.4, label="EKF (flight log)")
            ax.plot(rt, rec[:, r], "C3", lw=1.0, label="EKF (reconstructed)")
            m = gps[ok]
            ax.plot(gps["t"][m] - t0, gps[gkey][m, r], ".", color="C1", ms=3, label="GPS")
            ax.set_ylabel(f"{NED[r]} {ylab}")
            ax.grid(True, alpha=0.3)
    axes[0, 0].set_title("NED Position"); axes[0, 1].set_title("NED Velocity")
    axes[2, 0].set_xlabel("time [s]"); axes[2, 1].set_xlabel("time [s]")
    h, lb = axes[0, 0].get_legend_handles_labels()
    fig.legend(h, lb, loc="upper center", ncol=4, frameon=False, bbox_to_anchor=(0.5, 0.95))
    fig.suptitle(f"{logname}  -  offline EKF2 reconstruction vs flight (instance {res['inst']})",
                 y=0.995, fontsize=9)
    fig.tight_layout(rect=[0, 0, 1, 0.92])
    return fig


def make_variance_figure(plt, res, logname):
    t0 = float(res["logged"]["t"][0])
    rt = res["t"] - t0
    lt = res["logged"]["t"] - t0
    fig, axes = plt.subplots(3, 2, figsize=(14, 10), sharex=True)
    for r in range(3):
        for col, (sl, ylab) in enumerate([(POS, "pos var [m$^2$]"), (VEL, "vel var [m$^2$/s$^2$]")]):
            ax = axes[r, col]
            idx = sl.start + r
            ax.plot(lt, res["logged"]["cov"][:, idx], "C0", lw=1.4, label="flight log")
            ax.plot(rt, res["pdiag"][:, idx], "C3", lw=1.0, label="reconstructed")
            ax.set_ylabel(f"{NED[r]} {ylab}")
            ax.grid(True, alpha=0.3)
    axes[0, 0].set_title("Position variance"); axes[0, 1].set_title("Velocity variance")
    axes[2, 0].set_xlabel("time [s]"); axes[2, 1].set_xlabel("time [s]")
    h, lb = axes[0, 0].get_legend_handles_labels()
    fig.legend(h, lb, loc="upper center", ncol=2, frameon=False, bbox_to_anchor=(0.5, 0.95))
    fig.suptitle(f"{logname}  -  covariance diagonal: reconstructed vs flight (instance {res['inst']})",
                 y=0.995, fontsize=9)
    fig.tight_layout(rect=[0, 0, 1, 0.92])
    return fig


def report_match(res, ulog=None):
    """Print quantitative agreement between reconstruction and flight log."""
    t0 = res["t_seed"]
    lt = res["logged"]["t"]
    mask = lt >= (t0 + BURN_IN_S)
    if not mask.any():
        mask = lt >= t0
    print(f"\n--- match report (after {BURN_IN_S:.0f}s burn-in; {mask.sum()} samples) ---")

    # estimate RMS (reconstruction interpolated onto log timestamps)
    for label, sl in (("pos", POS), ("vel", VEL)):
        rms = []
        for r in range(3):
            rec_i = np.interp(lt, res["t"], res["x"][:, sl.start + r])
            rms.append(np.sqrt(np.mean((rec_i[mask] - res["logged"]["states"][mask, sl.start + r]) ** 2)))
        print(f"  {label} estimate RMS (recon vs log) NED = {np.round(rms, 4)}")

    # variance ratio (reconstructed / logged), median over the window
    for label, sl in (("pos", POS), ("vel", VEL)):
        ratios = []
        for r in range(3):
            rec_i = np.interp(lt, res["t"], res["pdiag"][:, sl.start + r])
            lg = res["logged"]["cov"][:, sl.start + r]
            good = mask & (lg > 0)
            ratios.append(np.median(rec_i[good] / lg[good]))
        print(f"  {label} variance ratio (recon/log) NED = {np.round(ratios, 3)}")

    # innovation / innovation-variance check against logged topics
    if ulog is not None:
        _report_innovations(res, ulog)


def _report_innovations(res, ulog):
    inst = res["inst"]
    inn = log_io.get_dataset(ulog, "estimator_innovations", inst)
    iv = log_io.get_dataset(ulog, "estimator_innovation_variances", inst)
    if inn is None or iv is None:
        return
    tin = log_io.tsec(inn)
    print("  innovation vs log (RMS over matched times):")
    # name -> (recon-column layout, logged field(s))
    checks = {
        "heading": (["heading"], 1),
        "gps_hpos": (["gps_hpos[0]", "gps_hpos[1]"], 2),
        "gps_hvel": (["gps_hvel[0]", "gps_hvel[1]"], 2),
        "baro_vpos": (["baro_vpos"], 1),
    }
    for name, (fields, ncomp) in checks.items():
        h = res["innov_hist"].get(name)
        if h is None or not all(f in inn.data for f in fields):
            continue
        th = h[:, 0]
        di, dv = [], []
        for c in range(ncomp):
            log_in = np.interp(th, tin, np.asarray(inn.data[fields[c]], float))
            log_iv = np.interp(th, tin, np.asarray(iv.data[fields[c]], float))
            di.append(np.sqrt(np.mean((h[:, 1 + c] - log_in) ** 2)))
            dv.append(np.median(h[:, 1 + ncomp + c] / np.where(log_iv > 0, log_iv, np.nan)))
        print(f"    {name:9s} innov RMS={np.round(di,4)}  innov_var ratio(recon/log)={np.round(dv,3)}")
