function mark_nichols_freqs(L, w_label_Hz)
% Annotate frequency points (Hz) on the current Nichols axes for open-loop L.
% Mirrors the reference nichols_annotated style: red filled circles + Hz labels.
%
% L          : open-loop transfer function (already drawn with nichols(L)).
% w_label_Hz : marker frequencies in Hz (default 10 log-spaced points 0.1..~31.6).
%
% Uses [mag,phase] = nichols(L, w) so the marker phase branch matches the curve
% that nichols(L) drew — no manual unwrap, no off-by-360 mismatch.

if nargin < 2 || isempty(w_label_Hz)
    w_label_Hz = logspace(-1, 1.5, 10);   % 0.1 .. ~31.6 Hz, 10 points
end

w = 2*pi*w_label_Hz(:);
[mag, phase] = nichols(L, w);
mag   = squeeze(mag);
phase = squeeze(phase);
gain_dB = 20*log10(mag);

hold on;
plot(phase, gain_dB, 'ro', 'MarkerFaceColor', 'r', 'MarkerSize', 4, ...
     'HandleVisibility', 'off');
for k = 1:numel(w)
    text(phase(k), gain_dB(k), sprintf('  %.2g Hz', w_label_Hz(k)), ...
         'FontSize', 8, 'Color', 'r', 'HandleVisibility', 'off');
end
end
