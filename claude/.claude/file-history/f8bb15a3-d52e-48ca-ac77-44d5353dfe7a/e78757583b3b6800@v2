#!/usr/bin/env bash
# Replay linear analysis with user-supplied gains against a saved plant.
# Reads gains from a YAML file (which also names the run_dir to read plants.mat from),
# rebuilds the controllers, re-runs analyze_loop, and writes Bode/Nichols/step
# plots plus a margins.txt with GM / PM / VM per channel.
#
# Usage: ./replay_margins.sh /path/to/gains.yaml

set -euo pipefail

yaml="${1:?usage: replay_margins.sh <gains.yaml>}"
if [[ ! -r "$yaml" ]]; then
    echo "not readable: $yaml" >&2
    exit 1
fi

yaml_abs="$(readlink -f "$yaml")"
yaml_base="$(basename "$yaml_abs" .yaml)"
ts="$(date +%Y%m%d_%H%M%S)"
here="$(cd "$(dirname "$0")" && pwd)"

# Extract run_dir from YAML and write a JSON sidecar for MATLAB to jsondecode.
read -r run_dir json_tmp < <(python3 - "$yaml_abs" <<'PY'
import sys, yaml, json, tempfile, os
with open(sys.argv[1]) as f:
    d = yaml.safe_load(f)
if not isinstance(d, dict) or 'run_dir' not in d:
    print("ERROR: YAML must contain top-level 'run_dir'", file=sys.stderr)
    sys.exit(2)
rd = d.pop('run_dir')
fd, path = tempfile.mkstemp(suffix='.json', prefix='replay_gains_')
os.close(fd)
with open(path, 'w') as f:
    json.dump(d, f)
print(rd, path)
PY
)

if [[ ! -d "$run_dir" || ! -r "$run_dir/plants.mat" ]]; then
    echo "missing plants.mat in $run_dir" >&2
    exit 1
fi

outdir="${run_dir}/replay_${yaml_base}_${ts}"
mkdir -p "$outdir"
cp "$yaml_abs" "$outdir/gains.yaml"
log="${outdir}/replay.log"

cd "$here"
nohup matlab -batch "replay_margins('${json_tmp}','${run_dir}','${outdir}')" > "$log" 2>&1 &
pid=$!
echo "PID=$pid"
echo "log=$log"
echo "outdir=$outdir"
