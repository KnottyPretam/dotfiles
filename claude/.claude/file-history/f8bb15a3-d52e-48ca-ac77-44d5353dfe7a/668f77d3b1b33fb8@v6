function compare_inputs(ulg_path, out_dir)
% Sanity check: does using vehicle_rates_setpoint as the sysID input give the
% same identified TF as using vehicle_torque_setpoint? Expected answer is NO:
%   torque_setpoint -> rates  identifies the open-loop plant P_rate
%   rates_setpoint  -> rates  identifies the closed-loop rate transfer T_rate
%     = C_rate*P_rate / (1 + C_rate*P_rate)
% This script identifies both per axis, overlays the FRFs, and writes a verdict.
%
% Usage:
%   compare_inputs('/path/to/log.ulg')
%   compare_inputs('/path/to/log.ulg', '/path/outdir')

% ===== Configuration (matches run_sysid.m defaults) =====
cfg.axes         = {'roll','pitch','yaw'};
cfg.regime       = 'mc';
cfg.fmin_Hz      = 0.05;
cfg.fmax_Hz      = 10;
cfg.coh_cutoff   = 0.6;
cfg.np           = 1;   % first-order rate plant, matches run_sysid.m default
cfg.nz           = 0;
cfg.min_segment_s = 10;
% ========================================================

here = fileparts(mfilename('fullpath'));
addpath(here);
addpath(fullfile(here, 'utils'));
addpath('/home/choudhury/repos/sysID_tool');
addpath('/home/choudhury/repos/sysID_tool/Utilities');

if nargin < 2 || isempty(out_dir)
    [~, base, ~] = fileparts(ulg_path);
    out_dir = fullfile(pwd, 'output', ['compare_inputs_' base '_' datestr(now,'yyyymmdd_HHMMSS')]);
end
if ~isfolder(out_dir); mkdir(out_dir); end

set(0, 'DefaultFigureVisible', 'off');

fprintf('[compare_inputs] ulg=%s\n[compare_inputs] out=%s\n', ulg_path, out_dir);

[D, ~, ~] = ulg_to_csv(ulg_path, out_dir);
D = derive_signals(D);

required = {'vehicle_angular_velocity_0', 'vehicle_rates_setpoint_0', 'vehicle_torque_setpoint_0'};
for k = 1:numel(required)
    if ~isfield(D, required{k}) || ~isfield(D.(required{k}), 'rpy')
        error('missing topic or .rpy field: %s', required{k});
    end
end

base_t  = D.vehicle_angular_velocity_0.t;
vs_base = D.vehicle_angular_velocity_0.vtol_state;

switch lower(cfg.regime)
    case 'mc'; target_state = 3;
    case 'fw'; target_state = 4;
    otherwise; error('unknown regime: %s', cfg.regime);
end

sl = segment_by_vtol_state(base_t, vs_base, target_state, cfg.min_segment_s);
if isempty(sl)
    error('no %s segment >= %.1fs', upper(cfg.regime), cfg.min_segment_s);
end
[~, j] = max(sl(:,2) - sl(:,1));
i_start = sl(j,1); i_end = sl(j,2);
t_seg_t = base_t(i_start:i_end);
dt      = median(diff(t_seg_t));
fs      = 1/dt;
fmax_use = min(cfg.fmax_Hz, 0.4*fs);
if fmax_use < cfg.fmax_Hz
    warning('fmax clamped from %.2f to %.2f Hz (0.4*fs)', cfg.fmax_Hz, fmax_use);
end
fprintf('[%s] segment [%.1f - %.1f]s, dt=%.4f s, fs=%.1f Hz\n', ...
        upper(cfg.regime), t_seg_t(1), t_seg_t(end), dt, fs);

t_grid = (t_seg_t(1):dt:t_seg_t(end))';
t_zero = t_grid - t_grid(1);

fig_dir = fullfile(out_dir, 'figures', cfg.regime);
if ~isfolder(fig_dir); mkdir(fig_dir); end

verdicts = {};
for ax = 1:numel(cfg.axes)
    ax_name = cfg.axes{ax};
    fprintf('  [%s] identifying both inputs...\n', ax_name);

    y = interp_safe(D.vehicle_angular_velocity_0.t, ...
                    D.vehicle_angular_velocity_0.rpy(:, ax), t_grid);
    y = nonlinear_detrend(y, t_zero);

    u_A = interp_safe(D.vehicle_torque_setpoint_0.t, ...
                      D.vehicle_torque_setpoint_0.rpy(:, ax), t_grid);
    u_A = nonlinear_detrend(u_A, t_zero);
    P_A = identify_plant(u_A, y, t_zero, cfg.fmin_Hz, fmax_use, cfg.np, cfg.nz, cfg.coh_cutoff);

    u_B = interp_safe(D.vehicle_rates_setpoint_0.t, ...
                      D.vehicle_rates_setpoint_0.rpy(:, ax), t_grid);
    u_B = nonlinear_detrend(u_B, t_zero);
    P_B = identify_plant(u_B, y, t_zero, cfg.fmin_Hz, fmax_use, cfg.np, cfg.nz, cfg.coh_cutoff);

    % Raw time-domain rates (no detrend) for the rate-loop tracking diagnostic
    rates_sp_t   = interp_safe(D.vehicle_rates_setpoint_0.t, ...
                               D.vehicle_rates_setpoint_0.rpy(:, ax), t_grid);
    rates_meas_t = interp_safe(D.vehicle_angular_velocity_0.t, ...
                               D.vehicle_angular_velocity_0.rpy(:, ax), t_grid);

    plot_overlay(P_A, P_B, fig_dir, ax_name, cfg.fmin_Hz, fmax_use);
    plot_rates_time(t_grid, rates_sp_t, rates_meas_t, fig_dir, ax_name);

    rate_track = compute_rate_track(rates_sp_t, rates_meas_t);
    verdicts{end+1} = compute_verdict(P_A, P_B, ax_name, cfg, rate_track); %#ok<AGROW>

    close(findall(0, 'Type', 'figure'));
end

write_verdict_report(fullfile(out_dir, 'compare_inputs.txt'), verdicts, ulg_path, cfg, fmax_use);
fprintf('[compare_inputs] done. outdir=%s\n', out_dir);
end


% ====================== helpers ======================

function y = interp_safe(t_src, x_src, t_dst)
[t_src, ix] = unique(t_src, 'stable');
x_src = x_src(ix);
y = interp1(t_src, x_src, t_dst, 'linear', 'extrap');
end


function plot_overlay(P_A, P_B, fig_dir, axis_name, fmin_Hz, fmax_Hz)
fig = figure('Name', ['Compare-' axis_name], 'Visible', 'off', 'Color', 'w', ...
             'Position', [100 100 900 800]);

label_A = 'A: torque\_setpoint\rightarrowrates  (plant P\_rate)';
label_B = 'B: rates\_setpoint\rightarrowrates  (closed loop T\_rate)';

% --- Magnitude ---
subplot(3,1,1); grid on; hold on;
if ~isempty(P_A.freq)
    semilogx(P_A.freq, P_A.mag_dB, 'b.', 'MarkerSize', 6, 'DisplayName', [label_A ' (measured)']);
end
if ~isempty(P_B.freq)
    semilogx(P_B.freq, P_B.mag_dB, 'r.', 'MarkerSize', 6, 'DisplayName', [label_B ' (measured)']);
end
if ~isempty(P_A.tf)
    f = P_A.freq;
    h = squeeze(freqresp(P_A.tf, f, 'Hz'));
    semilogx(f, 20*log10(abs(h)), 'b-', 'LineWidth', 1.5, 'DisplayName', 'A TF fit');
end
if ~isempty(P_B.tf)
    f = P_B.freq;
    h = squeeze(freqresp(P_B.tf, f, 'Hz'));
    semilogx(f, 20*log10(abs(h)), 'r-', 'LineWidth', 1.5, 'DisplayName', 'B TF fit');
end
set(gca, 'XScale', 'log');
ylabel('Gain (dB)');
title(['Compare inputs — axis: ' axis_name]);
legend('Location', 'best', 'Interpreter', 'tex');

% --- Phase ---
subplot(3,1,2); grid on; hold on;
if ~isempty(P_A.freq)
    semilogx(P_A.freq, P_A.phase, 'b.', 'MarkerSize', 6);
end
if ~isempty(P_B.freq)
    semilogx(P_B.freq, P_B.phase, 'r.', 'MarkerSize', 6);
end
set(gca, 'XScale', 'log');
ylabel('Phase (deg)');

% --- Coherence ---
subplot(3,1,3); grid on; hold on;
if ~isempty(P_A.freq)
    semilogx(P_A.freq, P_A.coh, 'b-', 'LineWidth', 1.2);
end
if ~isempty(P_B.freq)
    semilogx(P_B.freq, P_B.coh, 'r-', 'LineWidth', 1.2);
end
set(gca, 'XScale', 'log');
ylabel('Coherence'); ylim([0 1.05]);
xlabel('Frequency (Hz)');

save_fig(fig, fig_dir, ['compare_' axis_name '_bode']);

% --- Nichols overlay (interpolated TF fits only) ---
fig = figure('Name', ['Nichols-' axis_name], 'Visible', 'off', 'Color', 'w', ...
             'Position', [100 100 900 700]);
hold on; grid on;
w = logspace(log10(2*pi*fmin_Hz), log10(2*pi*fmax_Hz), 512).';
f_Hz = w/(2*pi);
have_any = false;
phA = []; mgA = []; phB = []; mgB = [];
if ~isempty(P_A.tf)
    h = squeeze(freqresp(P_A.tf, w));
    phA = unwrap(angle(h))*180/pi; mgA = 20*log10(abs(h));
    plot(phA, mgA, 'b-', 'LineWidth', 1.5, 'DisplayName', label_A);
    have_any = true;
end
if ~isempty(P_B.tf)
    h = squeeze(freqresp(P_B.tf, w));
    phB = unwrap(angle(h))*180/pi; mgB = 20*log10(abs(h));
    plot(phB, mgB, 'r-', 'LineWidth', 1.5, 'DisplayName', label_B);
    have_any = true;
end
xlabel('Phase (deg)'); ylabel('Gain (dB)');
title(['Nichols (TF fits) — axis: ' axis_name]);
if have_any
    legend('Location', 'best', 'Interpreter', 'tex');
end
% Frequency markers per curve. This chart draws two FRF-fit curves manually
% (so nichols(L,w) can't be used per curve); markers snap to the nearest sample
% of each plotted curve. Styled like the single-loop charts (filled circle +
% "%.2g Hz" label), colored per curve. Added after the legend so they stay out.
if ~isempty(phA)
    mark_curve_freqs(f_Hz, phA, mgA, fmin_Hz, fmax_Hz, 'b');
end
if ~isempty(phB)
    mark_curve_freqs(f_Hz, phB, mgB, fmin_Hz, fmax_Hz, 'r');
end
save_fig(fig, fig_dir, ['compare_' axis_name '_nichols']);
end


function mark_curve_freqs(f_Hz, phase_deg, mag_dB, fmin_Hz, fmax_Hz, color)
% Annotate a fixed log-spaced frequency set on a manually-plotted Nichols curve.
% Markers snap to the nearest plotted sample (robust to phase wrapping).
w_label = logspace(-1, 1.5, 10);                       % 0.1 .. ~31.6 Hz
w_label = w_label(w_label >= fmin_Hz & w_label <= fmax_Hz);
for i = 1:numel(w_label)
    [~, idx] = min(abs(f_Hz - w_label(i)));
    plot(phase_deg(idx), mag_dB(idx), 'o', 'MarkerSize', 5, ...
         'MarkerFaceColor', color, 'MarkerEdgeColor', color, 'HandleVisibility', 'off');
    text(phase_deg(idx), mag_dB(idx), sprintf('  %.2g Hz', w_label(i)), ...
         'FontSize', 8, 'Color', color, 'VerticalAlignment', 'bottom', ...
         'HandleVisibility', 'off');
end
end


function save_fig(fig, fig_dir, basename)
try
    exportgraphics(fig, fullfile(fig_dir, [basename '.png']), 'Resolution', 200);
catch err
    warning('PNG save failed for %s: %s', basename, err.message);
end
try
    savefig(fig, fullfile(fig_dir, [basename '.fig']));
catch err
    warning('FIG save failed for %s: %s', basename, err.message);
end
close(fig);
end


function plot_rates_time(t, rates_sp, rates_meas, fig_dir, axis_name)
% Time-domain rate-loop tracking diagnostic: overlay commanded vs measured rates,
% plus a tracking-error panel below.
fig = figure('Name', ['Rates-' axis_name], 'Visible', 'off', 'Color', 'w', ...
             'Position', [100 100 1000 700]);
t0 = t(1);
tt = t - t0;

subplot(2,1,1); grid on; hold on;
plot(tt, rates_sp,   'b-', 'LineWidth', 1.2, 'DisplayName', 'rates\_setpoint');
plot(tt, rates_meas, 'r-', 'LineWidth', 1.2, 'DisplayName', 'angular\_velocity (measured)');
ylabel('Rate (rad/s)');
title(sprintf('Rate-loop tracking — axis: %s  (segment starts at t=%.1fs)', axis_name, t0));
legend('Location', 'best', 'Interpreter', 'tex');

subplot(2,1,2); grid on; hold on;
err = rates_sp - rates_meas;
plot(tt, err, 'k-', 'LineWidth', 1.0);
plot([tt(1) tt(end)], [0 0], 'k:');
ylabel('Tracking error (rad/s)');
xlabel('Time since segment start (s)');
title(sprintf('Error RMS = %.3f rad/s, max |err| = %.3f rad/s', ...
              sqrt(mean(err.^2)), max(abs(err))));

save_fig(fig, fig_dir, ['compare_' axis_name '_rates']);
end


function rt = compute_rate_track(rates_sp, rates_meas)
err = rates_sp - rates_meas;
rt.sp_rms   = sqrt(mean(rates_sp.^2));
rt.meas_rms = sqrt(mean(rates_meas.^2));
rt.err_rms  = sqrt(mean(err.^2));
rt.err_max  = max(abs(err));
end


function v = compute_verdict(P_A, P_B, axis_name, cfg, rate_track)
v = struct('axis', axis_name, 'f_lo', NaN, 'f_hi', NaN, ...
           'mag_rms_dB', NaN, 'mag_max_dB', NaN, 'phase_rms_deg', NaN, ...
           'A_DC_dB', NaN, 'B_DC_dB', NaN, 'verdict', 'SKIPPED', 'reason', '', ...
           'rate_sp_rms', rate_track.sp_rms, 'rate_meas_rms', rate_track.meas_rms, ...
           'rate_err_rms', rate_track.err_rms, 'rate_err_max', rate_track.err_max);

if ~P_A.ok && ~P_B.ok
    v.reason = sprintf('both fits failed (A: %s; B: %s)', P_A.reason, P_B.reason);
    return;
elseif ~P_A.ok
    v.reason = sprintf('A fit failed: %s', P_A.reason);
    return;
elseif ~P_B.ok
    v.reason = sprintf('B fit failed: %s', P_B.reason);
    return;
end

% Joint coherent band: interpolate both onto a common log-spaced grid in [fmin, fmax].
f_lo = max([cfg.fmin_Hz, min(P_A.freq), min(P_B.freq)]);
f_hi = min([cfg.fmax_Hz, max(P_A.freq), max(P_B.freq)]);
if f_hi <= f_lo
    v.verdict = 'SKIPPED';
    v.reason  = 'no overlapping frequency band';
    return;
end
fg = logspace(log10(f_lo), log10(f_hi), 200).';

mA = interp1(P_A.freq, P_A.mag_dB, fg, 'linear', NaN);
mB = interp1(P_B.freq, P_B.mag_dB, fg, 'linear', NaN);
pA = interp1(P_A.freq, P_A.phase,  fg, 'linear', NaN);
pB = interp1(P_B.freq, P_B.phase,  fg, 'linear', NaN);
cA = interp1(P_A.freq, P_A.coh,    fg, 'linear', NaN);
cB = interp1(P_B.freq, P_B.coh,    fg, 'linear', NaN);

mask = isfinite(mA) & isfinite(mB) & isfinite(pA) & isfinite(pB) ...
       & (cA > cfg.coh_cutoff) & (cB > cfg.coh_cutoff);
if nnz(mask) < 4
    v.verdict = 'SKIPPED';
    v.reason  = sprintf('only %d joint-coherent points', nnz(mask));
    return;
end

dm = mA(mask) - mB(mask);
dp = pA(mask) - pB(mask);
% Bring phase difference to a comparable wraparound: fold to (-180, 180].
dp = mod(dp + 180, 360) - 180;

v.f_lo          = min(fg(mask));
v.f_hi          = max(fg(mask));
v.mag_rms_dB    = sqrt(mean(dm.^2));
v.mag_max_dB    = max(abs(dm));
v.phase_rms_deg = sqrt(mean(dp.^2));
v.A_DC_dB       = mA(find(mask, 1, 'first'));
v.B_DC_dB       = mB(find(mask, 1, 'first'));

if v.mag_rms_dB < 3 && v.phase_rms_deg < 10
    v.verdict = 'SAME';
    v.reason  = 'within tolerance';
else
    v.verdict = 'DIFFER';
    v.reason  = sprintf(['A (torque->rates) identifies open-loop plant P_rate; ' ...
                         'B (rates_sp->rates) identifies closed-loop T_rate. ' ...
                         'DC gains: A=%.1f dB, B=%.1f dB.'], v.A_DC_dB, v.B_DC_dB);
end
end


function write_verdict_report(path, verdicts, ulg_path, cfg, fmax_use)
fid = fopen(path, 'w');
cleanup = onCleanup(@() fclose(fid)); %#ok<NASGU>

fprintf(fid, 'ULG: %s\n', ulg_path);
fprintf(fid, 'Run: %s\n', datestr(now, 'yyyy-mm-dd HH:MM:SS'));
fprintf(fid, 'Regime: %s\n', cfg.regime);
fprintf(fid, 'u_A = vehicle_torque_setpoint_0.rpy   (rate controller OUTPUT -> plant input)\n');
fprintf(fid, 'u_B = vehicle_rates_setpoint_0.rpy    (rate controller INPUT  = attitude controller output)\n');
fprintf(fid, 'y   = vehicle_angular_velocity_0.rpy  (gyro)\n');
fprintf(fid, 'Frequency band evaluated: %.3f–%.3f Hz   Coherence cutoff: %.2f\n', ...
        cfg.fmin_Hz, fmax_use, cfg.coh_cutoff);
fprintf(fid, '\n');

header_fmt = '%-7s %-15s %-12s %-12s %-14s %-9s %-9s %-9s\n';
row_fmt    = '%-7s %5.2f-%-7.2f %9.2f dB  %9.2f dB  %9.1f deg     %6.1f    %6.1f    %s\n';
skip_fmt   = '%-7s %s\n';

fprintf(fid, header_fmt, 'Axis', 'Band [Hz]', '|dmag| RMS', '|dmag| max', '|dphase| RMS', 'A(DC) dB', 'B(DC) dB', 'Verdict');
fprintf(fid, '%s\n', repmat('-', 1, 105));
for k = 1:numel(verdicts)
    v = verdicts{k};
    if strcmp(v.verdict, 'SKIPPED')
        fprintf(fid, skip_fmt, v.axis, ['SKIPPED: ' v.reason]);
    else
        fprintf(fid, row_fmt, v.axis, v.f_lo, v.f_hi, ...
                v.mag_rms_dB, v.mag_max_dB, v.phase_rms_deg, ...
                v.A_DC_dB, v.B_DC_dB, v.verdict);
    end
end
fprintf(fid, '\n');

fprintf(fid, 'Interpretation\n');
fprintf(fid, '--------------\n');
fprintf(fid, 'Input A (torque_setpoint -> rates) identifies the open-loop plant P_rate(s).\n');
fprintf(fid, 'Input B (rates_setpoint  -> rates) identifies the closed-loop rate transfer\n');
fprintf(fid, '  T_rate(s) = C_rate*P_rate / (1 + C_rate*P_rate).\n');
fprintf(fid, 'These are different objects in the rate-control loop topology, so they should\n');
fprintf(fid, 'NOT match in general. The verdict above quantifies the gap for this dataset.\n');
fprintf(fid, '\n');
fprintf(fid, 'Per-axis details:\n');
for k = 1:numel(verdicts)
    v = verdicts{k};
    fprintf(fid, '  %s: %s — %s\n', v.axis, v.verdict, v.reason);
end
fprintf(fid, '\n');

fprintf(fid, 'Rate-loop tracking (time-domain, raw signals on the analysis segment)\n');
fprintf(fid, '%s\n', repmat('-', 1, 70));
fprintf(fid, '%-7s %12s %12s %12s %12s\n', 'Axis', 'sp_RMS', 'meas_RMS', 'err_RMS', 'err_max');
for k = 1:numel(verdicts)
    v = verdicts{k};
    fprintf(fid, '%-7s %9.4f rad/s %9.4f rad/s %9.4f rad/s %9.4f rad/s\n', ...
            v.axis, v.rate_sp_rms, v.rate_meas_rms, v.rate_err_rms, v.rate_err_max);
end
end
