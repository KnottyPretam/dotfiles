function make_plots(P, loop, fig_dir, mode, axis_name, loop_name, fmin_Hz, fmax_Hz) %#ok<INUSD>
% Save Bode (with coherence), Nichols, Nyquist, and step plots for one (mode, axis, loop).
% P    : plant identification struct from identify_plant
% loop : margin/loop struct from analyze_loop
% fig_dir : directory in which to save plots
% mode, axis, loop_name : strings used in titles and filenames

if ~isfolder(fig_dir); mkdir(fig_dir); end

tag      = sprintf('%s_%s_%s', lower(mode), lower(axis_name), lower(loop_name));
title_t  = sprintf('%s / %s / %s', upper(mode), axis_name, loop_name);

% --- Bode of identified plant (rate loop only) or constructed attitude plant ---
fig = new_fig(['Bode-' tag]);
if strcmpi(loop_name, 'rate') && ~isempty(P) && ~isempty(P.freq)
    subplot(3,1,1);
    semilogx(P.freq, P.mag_dB, 'o', 'MarkerSize', 4, 'DisplayName', 'measured'); grid on; hold on;
    if ~isempty(P.tf)
        h = squeeze(freqresp(P.tf, P.freq, 'Hz'));
        semilogx(P.freq, 20*log10(abs(h)), 'LineWidth', 1.5, 'DisplayName', 'TF fit');
    end
    ylabel('Gain (dB)'); title({['Plant Bode — ' title_t], ['n_p=' num2str(numel(P.den)-1) ', n_z=' num2str(numel(P.num)-1)]});
    legend('Location','best');

    subplot(3,1,2);
    semilogx(P.freq, P.phase, 'o', 'MarkerSize', 4); grid on; hold on;
    if ~isempty(P.tf)
        ph = angle(h)*180/pi;
        semilogx(P.freq, ph, 'LineWidth', 1.5);
    end
    ylabel('Phase (deg)');

    subplot(3,1,3);
    semilogx(P.freq, P.coh, 'LineWidth', 1.5); grid on;
    ylabel('Coherence'); ylim([0 1.05]); xlabel('Frequency (Hz)');
else
    % Attitude or no plant identification: just plot the open-loop |L|, ∠L
    if ~isempty(loop.L_response)
        w = loop.w_grid; f = w/(2*pi);
        subplot(2,1,1);
        semilogx(f, 20*log10(abs(loop.L_response)), 'LineWidth', 1.5); grid on;
        ylabel('|L| (dB)'); title(['Open-loop L — ' title_t]);

        subplot(2,1,2);
        semilogx(f, unwrap(angle(loop.L_response))*180/pi, 'LineWidth', 1.5); grid on;
        ylabel('∠L (deg)'); xlabel('Frequency (Hz)');
    end
end
save_fig(fig, fig_dir, [tag '_bode']);

% --- Nichols ---
fig = new_fig(['Nichols-' tag]);
if ~isempty(loop.L)
    nichols(loop.L); hold on; ngrid;
    mark_nichols_freqs(loop.L);
    title(['Nichols — ' title_t]);
end
save_fig(fig, fig_dir, [tag '_nichols']);

% --- Nyquist ---
fig = new_fig(['Nyquist-' tag]);
if ~isempty(loop.L_response)
    h = loop.L_response;
    plot(real(h), imag(h), 'b-', 'LineWidth', 1.5); grid on; hold on;
    plot(real(h), -imag(h), 'b--', 'LineWidth', 0.8);
    theta = linspace(0, 2*pi, 200);
    plot(cos(theta), sin(theta), 'k:', 'LineWidth', 0.7);
    plot(-1, 0, 'rx', 'MarkerSize', 12, 'LineWidth', 2);
    [~, k] = min(abs(1 + h));
    plot([-1, real(h(k))], [0, imag(h(k))], 'r-', 'LineWidth', 1.2);
    text(real(h(k)), imag(h(k)), sprintf('  VM=%.3f', loop.VM), 'Color','r');
    xlabel('Re'); ylabel('Im'); axis equal;
    xlim([-2 2]); ylim([-2 2]);
    title(['Nyquist — ' title_t]);
end
save_fig(fig, fig_dir, [tag '_nyquist']);

% --- Closed-loop step response ---
fig = new_fig(['Step-' tag]);
if ~isempty(loop.T)
    try
        t_end = 5;
        if ~isnan(loop.wc_Hz) && loop.wc_Hz > 0
            t_end = max(t_end, 10/loop.wc_Hz);
        end
        [y, t] = step(loop.T, t_end);
        plot(t, y, 'b', 'LineWidth', 1.5); grid on; hold on;
        plot([t(1) t(end)], [1 1], 'k--');
        ylabel('y(t)'); xlabel('Time (s)');
        title(['Closed-loop step — ' title_t]);
    catch err
        text(0.1, 0.5, sprintf('step() failed: %s', err.message), 'Units', 'normalized');
    end
end
save_fig(fig, fig_dir, [tag '_step']);
end

function fig = new_fig(name)
fig = figure('Name', name, 'Visible', 'off', 'Color', 'w', ...
             'Position', [100 100 900 700]);
end

function save_fig(fig, fig_dir, basename)
try
    exportgraphics(fig, fullfile(fig_dir, [basename '.png']), 'Resolution', 200);
catch err
    warning('PNG save failed for %s: %s', basename, err.message);
end
try
    savefig(fig, fullfile(fig_dir, [basename '.fig']));
catch err
    warning('FIG save failed for %s: %s', basename, err.message);
end
close(fig);
end
