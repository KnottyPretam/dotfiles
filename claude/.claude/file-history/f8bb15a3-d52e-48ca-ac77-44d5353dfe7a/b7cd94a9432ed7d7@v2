## Change 3: `replay_margins.sh`

```bash
#!/usr/bin/env bash
# Replay linear analysis with user-supplied gains against a saved plant.
# Usage: ./replay_margins.sh /path/to/gains.yaml
set -euo pipefail

yaml="${1:?usage: replay_margins.sh <gains.yaml>}"
[[ -r "$yaml" ]] || { echo "not readable: $yaml" >&2; exit 1; }

yaml_abs="$(readlink -f "$yaml")"
yaml_base="$(basename "$yaml_abs" .yaml)"
ts="$(date +%Y%m%d_%H%M%S)"
here="$(cd "$(dirname "$0")" && pwd)"

# Extract run_dir from YAML and convert YAML -> JSON sidecar
read run_dir json_tmp < <(python3 - "$yaml_abs" <<'PY'
import sys, yaml, json, tempfile, os
d = yaml.safe_load(open(sys.argv[1]))
rd = d.pop('run_dir')
fd, path = tempfile.mkstemp(suffix='.json'); os.close(fd)
json.dump(d, open(path,'w'))
print(rd, path)
PY
)

[[ -d "$run_dir" && -r "$run_dir/plants.mat" ]] || \
    { echo "missing plants.mat in $run_dir" >&2; exit 1; }

outdir="${run_dir}/replay_${yaml_base}_${ts}"
mkdir -p "$outdir"
cp "$yaml_abs" "$outdir/gains.yaml"
log="${outdir}/replay.log"

cd "$here"
nohup matlab -batch "replay_margins('${json_tmp}','${run_dir}','${outdir}')" > "$log" 2>&1 &
echo "PID=$!"
echo "log=$log"
echo "outdir=$outdir"
```

Mirrors `run_sysid.sh` (set -euo pipefail, nohup matlab -batch, log file). Python3 + PyYAML are confirmed available (`/usr/bin/python3`, PyYAML 6.0.1).

