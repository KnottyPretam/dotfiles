def select_gyro_device(ulog, cfg):
    """device_id of the gyro feeding vehicle_angular_velocity, with fallbacks for logs that
    don't record sensor_selection (only ~2 of the oddjob logs do). All of these report the
    *selected* gyro, since the controller, EKF and IMU status share sensor_selection.
    Returns (device_id, source) or (None, None)."""
    if cfg.get("gyro_device_id") is not None:
        return int(cfg["gyro_device_id"]), "yaml gyro_device_id"
    sel = aiv.get_topic(ulog, "sensor_selection")
    if sel is not None and "gyro_device_id" in sel.data:
        return int(sel.data["gyro_device_id"][-1]), "sensor_selection"
    for topic in ("estimator_sensor_bias", "vehicle_imu_status"):
        d = aiv.get_topic(ulog, topic)
        if d is not None and "gyro_device_id" in d.data:
            vals = np.unique(d.data["gyro_device_id"])
            if len(vals) == 1:
                return int(vals[0]), topic
    return None, None


def inflight_window(ulog):
    """(t0, t1) FMU-boot seconds for the in-air segment via vehicle_land_detected.landed==0."""
    d = aiv.get_topic(ulog, "vehicle_land_detected")
    if d is not None and "landed" in d.data:
        t = d.data["timestamp"] / 1e6
        air = t[d.data["landed"] == 0]
        if air.size:
            return float(air[0]), float(air[-1])
    return None, None


def match_index(t_us, out_ts):
    """For each output timestamp, index of the nearest per-sample FIFO timestamp."""
    order = np.argsort(t_us, kind="stable")
    ts = t_us[order]
    pos = np.clip(np.searchsorted(ts, out_ts), 1, len(ts) - 1)
    left, right = ts[pos - 1], ts[pos]
    take = np.where(np.abs(out_ts - left) <= np.abs(out_ts - right), pos - 1, pos)
    return order[take]


def fifo_gap_intervals(d):
    """(starts_s, ends_s) of FIFO logging dropouts (inter-batch gap > 1.5*dt).
    The FC had continuous data here; only the SD log dropped samples, so filtering
    across these gaps rings — exclude a settle window around them when scoring."""
    ts_last = d.data["timestamp_sample"].astype(np.int64)
    dt = d.data["dt"].astype(np.int64)
    ns = d.data["samples"].astype(np.int32)
    if len(ts_last) < 2:
        return np.array([]), np.array([])
    t_first = ts_last - (ns - 1) * dt
    gap = t_first[1:] - ts_last[:-1]
    dtn = dt[1:]
    over = (dtn > 0) & (gap > 1.5 * dtn)
    return ts_last[:-1][over] / 1e6, t_first[1:][over] / 1e6


def gap_valid_mask(out_t, starts, ends, settle):
    """True where out_t is NOT inside a FIFO gap (+- settle seconds)."""
    bad = np.zeros(len(out_t), bool)
    for s, e in zip(starts, ends):
        bad |= (out_t >= s - settle) & (out_t <= e + settle)
    return ~bad


def gap_free_zoom(t0, t1, starts, ends, dur=2.0):
    """Find a dur-second window within [t0, t1] containing no FIFO gap."""
    for c in np.arange(t0 + 0.2 * (t1 - t0), t1 - dur, 0.5):
        if not np.any((ends >= c) & (starts <= c + dur)):
            return float(c), float(c + dur)
    return float(t0), float(t0 + dur)


def bias_at(ulog, device_id, out_ts):
    """ZOH-interpolate estimator_sensor_bias.gyro_bias (this device) onto output times. (3,Nout)."""
    d = aiv.get_topic(ulog, "estimator_sensor_bias")
    if d is None or "gyro_bias[0]" not in d.data:
        return np.zeros((3, len(out_ts)))
    gid = d.data.get("gyro_device_id")
    mask = (gid == int(device_id)) if gid is not None else np.ones(len(d.data["timestamp"]), bool)
    bt = d.data["timestamp"][mask].astype(np.int64)
    if bt.size == 0:
        return np.zeros((3, len(out_ts)))
    bxyz = np.vstack([d.data[f"gyro_bias[{i}]"][mask] for i in range(3)])
    order = np.argsort(bt)
    bt, bxyz = bt[order], bxyz[:, order]
    pos = np.clip(np.searchsorted(bt, out_ts, side="right") - 1, 0, len(bt) - 1)
    return bxyz[:, pos]


# ---------- metrics ----------
def axis_metrics(rec, log):
    resid = rec - log
    rms_log = np.sqrt(np.mean(log ** 2))
    rms_ac = np.std(log)
    nrmse = np.sqrt(np.mean(resid ** 2)) / rms_log if rms_log > 0 else np.nan
    nrmse_ac = np.std(resid) / rms_ac if rms_ac > 0 else np.nan
    corr = np.corrcoef(rec, log)[0, 1] if np.std(rec) > 0 and rms_ac > 0 else np.nan
    return dict(rms_resid=float(np.sqrt(np.mean(resid ** 2))), nrmse=float(nrmse),
                nrmse_ac=float(nrmse_ac), corr=float(corr), maxabs=float(np.max(np.abs(resid))))


