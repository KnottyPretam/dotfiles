# filter_tune.yaml — retune the PX4 gyro/dgyro filters offline and compare against the
# logged vehicle_angular_velocity.  Used by recreate_angular_velocity.py.
#
# The values below are SEEDED with OD1A079's actual on-aircraft params, so a first run
# reproduces what the flight controller actually published (the validation baseline).
# Edit them to explore alternative tunings, then re-run.
#
# Filter types are fixed to match PX4 exactly (you only set the cutoff/notch values):
#   IMU_GYRO_CUTOFF   -> gyro 2nd-order Butterworth low-pass   (math::LowPassFilter2p)
#   IMU_DGYRO_CUTOFF  -> dgyro 1st-order alpha low-pass on d/dt of the filtered gyro (math::AlphaFilter)
#   IMU_GYRO_NF0/NF1  -> general biquad notch filters          (math::NotchFilter)
# Set any cutoff/notch frequency to 0 to disable that stage (same as PX4).

log: OD1A079_nexus_endurance.ulg   # .ulg path (a positional CLI arg overrides this)

# gyro_device_id: 3670026          # optional override; default = sensor_selection.gyro_device_id
#                                  # (the gyro the controller actually used → feeds vehicle_angular_velocity)
# start_s: null                    # in-air comparison window (FMU-boot seconds);
# end_s: null                      # default = vehicle_land_detected in-air span

# ---- Baseline filter params (this run) ----
IMU_GYRO_CUTOFF:  15.0   # gyro Butterworth cutoff (Hz); 0 disables
IMU_DGYRO_CUTOFF: 30.0   # dgyro alpha-LPF cutoff (Hz); 0 disables
IMU_GYRO_NF0_FRQ: 0.0    # notch 0 centre frequency (Hz); 0 disables
IMU_GYRO_NF0_BW:  20.0   # notch 0 bandwidth (Hz)
IMU_GYRO_NF1_FRQ: 0.0    # notch 1 centre frequency (Hz); 0 disables
IMU_GYRO_NF1_BW:  20.0   # notch 1 bandwidth (Hz)

# ---- Optional "what-if" overlay ----
# If present, this second tuning is filtered from the same FIFO and drawn on the PSD plots
# alongside the baseline, so you can see how a candidate change (e.g. a notch on the ~99.4 Hz
# vibration line) would reshape the spectrum. Uncomment and edit to use.
# candidate:
#   IMU_GYRO_CUTOFF:  25.0
#   IMU_DGYRO_CUTOFF: 30.0
#   IMU_GYRO_NF0_FRQ: 99.4
#   IMU_GYRO_NF0_BW:  10.0
#   IMU_GYRO_NF1_FRQ: 0.0
#   IMU_GYRO_NF1_BW:  20.0
